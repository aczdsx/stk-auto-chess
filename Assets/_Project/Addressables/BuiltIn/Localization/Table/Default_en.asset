    m_Localized: Guardian
    m_Metadata:
      m_Items: []
  - m_Id: 775280237994427
    m_Localized: <color=#F75D32>High Magic DEF</color>, reducing damage from <color=#F75D32>Mages</color>,
      but powerless against <color=#0047AB>Rangers</color> with physical attacks.
