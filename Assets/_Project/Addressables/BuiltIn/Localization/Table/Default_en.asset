      m_Items: []
  - m_Id: 2291923464216691
    m_Localized: "\uB2E4\uC6B4\uB85C\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 2291923464216692
    m_Localized: "\uB370\uC774\uD130 \uB2E4\uC6B4\uB85C\uB4DC\uB97C \uC9C4\uD589\uD569\uB2C8\uB2E4.\n\n\uACFC\uB3C4\uD55C
      \uB370\uC774\uD130 \uC0AC\uC6A9\uC744 \uB9C9\uADC0 \uC704\uD574 \nWIFI \uD658\uACBD\uC5D0\uC11C
      \uB2E4\uC6B4\uB85C\uB4DC\uB97C \uAD8C\uC7A5\uD569\uB2C8\uB2E4."
