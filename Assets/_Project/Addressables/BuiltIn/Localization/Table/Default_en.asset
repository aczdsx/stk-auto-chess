      DEF'
    m_Metadata:
      m_Items: []
  - m_Id: 717267972121042
    m_Localized: Water
    m_Metadata:
      m_Items: []
  - m_Id: 717267972121043
    m_Localized: Generates a <color=#F75D32>shield</color> for the entire team equal
