    m_Localized: "\uC2B5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327290996
    m_Localized: "\uCE58\uBA85\uC801 \uC77C\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327290997
    m_Localized: "{0}\uCD08 \uB9C8\uB2E4 CC \uD6A8\uACFC\uB97C \uB9C9\uC544\uB0B4\uB294
      \uBC29\uC5B4\uB9C9\uC774 \uC0DD\uC131\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327290998
    m_Localized: "{0}\uCD08 \uB9C8\uB2E4 \uC801\uC758 \uC77C\uBC18 \uACF5\uACA9\uC744
      3\uD68C \uBB34\uC2DC\uD558\uB294 \uBCA0\uB9AC\uC5B4\uB97C \uD68D\uB4DD\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327290999
    m_Localized: "{0}% \uD655\uB960\uB85C \uC801\uC758 \uBB3C\uB9AC, \uB9C8\uBC95
      \uBC29\uC5B4\uB825\uC744 \uBB34\uC2DC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291000
    m_Localized: "{0}% \uD655\uB960\uB85C \uC77C\uBC18 \uACF5\uACA9\uC774 \uD3ED\uBC1C\uD558\uC5EC
      \uAC00\uB85C \uC138\uB85C 3x3 {0}\uC758 \uBC94\uC704 \uD53C\uD574\uB97C \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291001
    m_Localized: "\uC77C\uBC18\uACF5\uACA9\uC2DC \uACF5\uACA9 \uBC94\uC704 \uB0B4\uC5D0
      \uC544\uAD70 \uC911 \uCCB4\uB825\uC774 \uB0AE\uC740 \uCE90\uB9AD\uD130(\uBCF8\uC778\uD3EC\uD568)
      \uC624\uB77C\uD074\uC758 \uACF5\uACA9\uB825\uC758 {0}% \uBE44\uB840\uD55C \uD68C\uBCF5\uB825\uC774
      \uBD80\uC5EC\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291002
    m_Localized: "\uC804\uD22C \uAC1C\uC2DC\uC640 \uD568\uAED8 \uC801 \uC9C4\uC601
      \uB4A4\uCABD \uC88C\uD45C\uB85C \uC21C\uAC04\uC774\uB3D9\uD55C\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291003
    m_Localized: "\uC77C\uBC18 \uACF5\uACA9 1\uD68C\uB9C8\uB2E4 \uC2A4\uD0DD\uC774
      1\uC529\uC624\uB974\uACE0 {0}\uD68C \uC2A4\uD0DD\uB9C8\uB2E4 \uB2E4\uC74C \uACF5\uACA9\uC774
      \uD06C\uB9AC\uD2F0\uCEEC\uB85C \uBA85\uC911\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291004
    m_Localized: "\uC2A4\uD0C0\uCFFC\uCE20"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291005
    m_Localized: "\uBAA8\uB77C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291006
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uD3EC\uC778\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291007
    m_Localized: "\uC2A4\uD0DC\uBBF8\uB108\uD329"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291008
    m_Localized: "\uCE90\uB9AD\uD130 \uD2F0\uCF13"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291009
    m_Localized: "\uC6E8\uD3F0 \uD2F0\uCF13"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291010
    m_Localized: "\uC9C0\uD718\uAD00 \uACBD\uD5D8\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291011
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130 \uCE72"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291012
    m_Localized: "\uC544\uB808\uB098 \uD2F0\uCF13"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291013
    m_Localized: "\uD558\uAE09 \uAC74\uC124 \uC7AC\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291014
    m_Localized: "\uAE30\uC0AC\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291015
    m_Localized: "\uBD88\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291016
    m_Localized: "\uBC14\uB78C\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291017
    m_Localized: "\uB300\uC9C0\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291018
    m_Localized: "\uD3ED\uD48D\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291019
    m_Localized: "\uB300\uC591\uC758 \uB514\uBA58\uC158 \uD050\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 2870408327291020
