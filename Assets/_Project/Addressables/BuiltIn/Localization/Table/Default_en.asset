  - m_Id: 534344006361495
    m_Localized: Supporter
    m_Metadata:
      m_Items: []
  - m_Id: 534344006361496
    m_Localized: Specialized in <color=#F75D32>healing, buffing, and debuffing</color>,
      this position focuses on strengthening allies or weakening enemies. Supporters
      have <color=#0047AB>low</color> base ATK and HP.
    m_Metadata:
