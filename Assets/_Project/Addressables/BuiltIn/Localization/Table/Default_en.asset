    m_Localized: "\uBAAC\uC2A4\uD130\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 \uB4DC\uB860
      Lv.3\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2945424275264166
    m_Localized: "\uBAAC\uC2A4\uD130\uC0CC\uB4DC \uC2A4\uD1A0\uCEE4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2945424275264167
    m_Localized: "\uBAAC\uC2A4\uD130\uC0CC\uB4DC \uD06C\uB864\uB7EC\uC785\uB2C8\uB2E4."
