    m_Metadata:
      m_Items: []
  - m_Id: 424862962147648
    m_Localized: Water
    m_Metadata:
      m_Items: []
  - m_Id: 424862962147649
    m_Localized: Generates a <color=#F75D32>shield</color> for the entire team equal
