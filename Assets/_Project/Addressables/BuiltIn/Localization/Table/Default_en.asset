      m_Items: []
  - m_Id: 415962951049257
    m_Localized: 'Fire Synergy Mage


      Skill : Launches a <color=#F75D32>Fire
      Energy Spell</color> in a 3x3 area.

      The spell scorches the ground, dealing
      <color=#F75D32>additional damage.</color>'
