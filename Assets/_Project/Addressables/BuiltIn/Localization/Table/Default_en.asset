  - m_Id: 2607753417970318
    m_Localized: "Deals damage equal to <b><color=#F75D32>500%</color></b> of allies\u2019
      average ATK to enemies within the area."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970319
    m_Localized: Freezes enemies within a cross-shaped area for 3 seconds.
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970320
    m_Localized: Airbornes 1 selected enemy for 3 seconds.
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970321
    m_Localized: "Restores the HP of allies within the area by 700% of the highest
      ally\u2019s ATK."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970322
    m_Localized: Randomly swaps the positions of allies, enemies, and terrain features
      on the battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970323
    m_Localized: Reduces ATK of enemies within a 3*3 area by 50% for 5 seconds.
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970324
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBD84\uCD9C\uD558\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4.
      \uC774 \uBD88\uC758 \uBCBD\uC740 {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uBA70
      \uB2FF\uC740 \uC801\uC740 {1}\uC758 \uD53C\uD574\uC640 {2}%\uC758 \uC9C0\uC18D
      \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970325
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBD84\uCD9C\uD558\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4.
      \uC774 \uC5BC\uC74C\uC758 \uBCBD\uC740 {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uBA70
      \uB2FF\uC740 \uC801\uC740 {1}\uC758 \uD53C\uD574\uC640 {2}\uCD08 \uB3D9\uC548
      \uB300\uC0C1\uC744 \uC5BC\uB824\uBC84\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970326
    m_Localized: "\uACFC\uAC70 \uACE0\uB300 \uC778\uB958\uC758 \uC794\uC601\uC744
      \uAD00\uCE21\uD558\uC5EC \uD604\uC138\uC5D0 \uD5CC\uD5CC \uC2DC\uD0B5\uB2C8\uB2E4.
      \uC18C\uD658\uB41C \uC544\uC774\uAE30\uC2A4 \uBCD1\uB2E8\uC740 \uC77C\uC9C1\uC120\uC758
      \uC801\uB4E4\uC744 {0}\uCE78 \uBC00\uC5B4\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970327
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBC14\uB78C\uC744 \uC77C\uC73C\uD0B5\uB2C8\uB2E4.
      \uB2FF\uC740 \uB300\uC0C1\uC740 \uBB34\uC791\uC704 \uC704\uCE58\uC5D0 \uB5A8\uC5B4\uC9C0\uAC8C
      \uB418\uBA70 \uC801\uAD70\uC778 \uACBD\uC6B0 {0}\uC758 \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2607753417970328
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBC14\uB78C\uC744 \uC77C\uC73C\uD0B5\uB2C8\uB2E4.
      \uB2FF\uC740 \uB300\uC0C1\uC740 \uBB34\uC791\uC704 \uC704\uCE58\uC5D0 \uB5A8\uC5B4\uC9C0\uAC8C
      \uB418\uBA70 \uC801\uAD70\uC778 \uACBD\uC6B0 {0}\uC758 \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4."
