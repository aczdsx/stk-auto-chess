      m_Items: []
  - m_Id: 550502285697576
    m_Localized: "<color=#ec9f19>\uCC55\uD130 \uD074\uB9AC\uC5B4 \uBCF4\uC0C1</color>,\uD018\uC2A4\uD2B8,
