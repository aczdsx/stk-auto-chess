      m_Items: []
  - m_Id: 415962951049613
    m_Localized: "\uC554\uC0B4\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049614
    m_Localized: "<color=#F75D32>\uB192\uC740 \uACF5\uACA9 \uC18D\uB3C4</color>\uC640
      <color=#F75D32>\uC774\uB3D9\uC18D\uB3C4</color>\uB97C \uC9C0\uB154\uC73C\uBA70
      <color=#F75D32>\uC2A4\uD0AC \uCFE8\uD0C0\uC784</color>\uC774 \uC9E7\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049615
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC2DC \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049616
    m_Localized: "\uC11C\uD3EC\uD130"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049617
    m_Localized: "<color=#F75D32>\uD790, \uBC84\uD504, \uB514\uBC84\uD504</color>
      \uB4F1 \uC544\uAD70 \uAC15\uD654 \uB610\uB294 \uC801\uAD70 \uC57D\uD654\uC5D0
      \uD2B9\uD654\uB41C \uD3EC\uC9C0\uC158\uC774\uB2E4. \uAE30\uBCF8 \uACF5\uACA9\uB825\uACFC
      \uCCB4\uB825\uC740 <color=#0047AB>\uB0AE\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049618
    m_Localized: "{0}\uBA85 : \uCCAB \uC2A4\uD0AC \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b>
