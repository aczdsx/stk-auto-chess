  - m_Id: 551054100914392
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC870\uAC01"
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914393
    m_Localized: "\uC131\uC7A5\uC758 \uACB0\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914394
    m_Localized: "PVP \uC785\uC7A5 \uC544\uC774\uD15C"
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914395
    m_Localized: "\uBC29\uD574\uBB3C"
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914396
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC18C\uD658\uC5D0 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914397
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914398
    m_Localized: "\uBC29\uCE58 \uBCF4\uC0C1\uC744 \uC5BB\uB294\uB370 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914399
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uC9C4\uD589\uC5D0 \uD544\uC694\uD55C
      \uD589\uB3D9\uB825\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914400
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC18C\uD658\uC5D0 \uD544\uC694\uD55C
      \uC18C\uD658\uAD8C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914401
    m_Localized: "\uBB34\uAE30 \uC18C\uD658\uC5D0 \uD544\uC694\uD55C \uC18C\uD658\uAD8C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914402
    m_Localized: "\uAD00\uCE21\uC790 \uB808\uBCA8 \uC5C5\uC5D0 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914403
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914404
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20"
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914405
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uC758 \uD798\uC774 \uB2F4\uAE34
      \uC870\uAC01\uC785\uB2C8\uB2E4. \n20\uAC1C \uC870\uAC01\uC744 \uBAA8\uC744
      \uC2DC, \uD574\uB2F9 \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uD68D\uB4DD\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914406
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB418\uB294 \uC544\uC774\uD15C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914407
    m_Localized: "PVP \uC785\uC7A5 \uC2DC \uD544\uC694\uD55C \uC544\uC774\uD15C \uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914408
    m_Localized: "PVP \uBC30\uCE58\uC5D0 \uC0AC\uC6A9\uB418\uB294 \uAE30\uBBF9 \uC544\uC774\uD15C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 551054100914409
    m_Localized: "<color=#ec9f19>\uCC55\uD130 \uB9C8\uC77C\uC2A4\uD1A4</color>"
