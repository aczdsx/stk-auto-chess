  - m_Id: 534344006361494
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC2DC \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
