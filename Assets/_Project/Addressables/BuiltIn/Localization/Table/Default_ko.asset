  - m_Id: 1869565540688191
    m_Localized: "\uB8E8\uBBF8\uB124 \uC2DC\uD2F0 6-30 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688192
    m_Localized: "\uB8E8\uBBF8\uB124 \uC2DC\uD2F0 6-32 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688193
    m_Localized: "\uB8E8\uBBF8\uB124 \uC2DC\uD2F0 6-34 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688194
    m_Localized: "\uB8E8\uBBF8\uB124 \uC2DC\uD2F0 6-36 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688195
    m_Localized: "\uACBD\uD5D8\uCE58 \uC544\uC774\uD15C\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688196
    m_Localized: "\uACE8\uB4DC\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688197
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20 \uC870\uAC01\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688198
    m_Localized: "\uD589\uB3D9\uB825\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688199
    m_Localized: "\uBCF4\uC11D\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688200
    m_Localized: "\uC18C\uD658 \uD2F0\uCF13\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688201
    m_Localized: "\uC131\uC7A5\uC758 \uACB0\uC815\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4.
      (<color=#F75D32>\uC99D\uBA85\uC758 \uC804\uC7A5, \uBC29\uCE58 \uBCF4\uC0C1</color>\uC73C\uB85C
      \uD68D\uB4DD \uAC00\uB2A5)"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688202
    m_Localized: "\uBCF4\uC0C1 \uC218\uB839 \uAC00\uB2A5 \uCD5C\uC18C \uC2DC\uAC04\uC5D0
      \uB3C4\uB2EC\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688203
    m_Localized: "\uCC55\uD130\uAC00 \uC544\uC9C1 \uD574\uAE08\uB418\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688204
    m_Localized: "\uC9C0\uD718\uC790 \uC2A4\uD0AC\uC774 \uC544\uC9C1 \uD574\uAE08\uB418\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688205
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0\uAC00 \uC544\uC9C1 \uD574\uAE08\uB418\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688206
    m_Localized: "\uB9C8\uC77C\uC2A4\uD1A4 \uBCF4\uC0C1\uC774 \uC544\uC9C1 \uD574\uAE08\uB418\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688207
    m_Localized: "\uC7A0\uC2DC \uD6C4\uC5D0 \uB2E4\uC2DC \uC9C4\uD589\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688208
    m_Localized: "\uBC30\uCE58 \uAC00\uB2A5 \uC778\uC6D0 \uC218\uAC00 \uCD08\uACFC\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688209
    m_Localized: "\uD544\uD130\uB9C1\uB41C \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uAC00
      \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688210
    m_Localized: "\uC5C5\uB370\uC774\uD2B8 \uC608\uC815\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688211
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uAC00 \uCD5C\uB300 \uB808\uBCA8\uC5D0
      \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688212
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uAC00 \uBC30\uCE58\uB418\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688213
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB97C <color=#F75D32>\uCD94\uAC00
      \uBC30\uCE58</color>\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC804\uD22C\uC5D0
      \uC9C4\uC785\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688214
    m_Localized: "\uC801\uC808\uD55C \uD0C0\uC77C \uC704\uCE58\uB97C \uC124\uC815\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688215
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0\uC5D0 \uC785\uC7A5\uD560 <color=#F75D32>\uD589\uB3D9\uB825</color>
      \uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688216
    m_Localized: "\uBC30\uD2C0 \uBC84\uD2BC \uC0C1\uB2E8\uC758 (+)\uB97C \uD074\uB9AD\uD574
      \n\uC9C0\uD718\uC790 \uC2A4\uD0AC\uC744 \uC7A5\uCC29\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688217
    m_Localized: "\uD074\uB9AC\uC5B4 \uC81C\uD55C \uC2DC\uAC04\uC744 \uCD08\uACFC\uD558\uC600\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688218
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0\uB97C \uD074\uB9AC\uC5B4\uD558\uC5EC,
      \uBC29\uCE58 \uBCF4\uC0C1 \uD6A8\uC728\uC774 \uC99D\uAC00\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688219
    m_Localized: "PVP \uD2F0\uCF13\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4. \uD2F0\uCF13\uC774
      \uCDA9\uC804\uB41C \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688220
    m_Localized: "\uACE8\uB4DC\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4. \uC2A4\uD14C\uC774\uC9C0\uB97C
      \uD50C\uB808\uC774\uD574 \uACE8\uB4DC\uB97C \uD68D\uB4DD\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688221
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uC758 \uB808\uBCA8\uC744 \uCD08\uAE30\uD654\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688222
    m_Localized: "\uB9AC\uC14B \uAC00\uB2A5 \uB808\uBCA8\uC774 \uC544\uB2D9\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688223
    m_Localized: "\uC77C\uC77C \uB9AC\uC14B \uAC00\uB2A5 \uD69F\uC218\uB97C \uBAA8\uB450
      \uC18C\uC9C4\uD588\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C \uB0A0 \uD69F\uC218\uAC00
      \uC790\uB3D9 \uCDA9\uC804\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688224
    m_Localized: "\uB354 \uC774\uC0C1 \uAD6C\uB9E4\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688225
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uBCC4 \uAC2F\uC218\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688226
    m_Localized: "\uC774\uBBF8 \uD074\uB9AC\uC5B4\uD55C \uB358\uC804\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688227
    m_Localized: "\uC774\uC804 \uB2E8\uACC4\uB97C \uD074\uB9AC\uC5B4 \uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688228
    m_Localized: "\uB9AC\uC14B \uC544\uC774\uD15C \uB370\uC774\uD130 \uC5D0\uB7EC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688229
    m_Localized: "\uC544\uB808\uB098 \uBC29\uC5B4 \uB371 \uC124\uC815\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688230
    m_Localized: "\uC544\uC9C1 PVP \uC0C1\uB300\uB97C \uAC31\uC2E0\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688231
    m_Localized: "\uC544\uB808\uB098 \uC804\uD22C \uC2DC\uAC04\uC774 \uC885\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688232
    m_Localized: "<color=#F75D32>{0}</color> \uC644\uB8CC \uD6C4 \uC0AC\uC6A9 \uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688233
    m_Localized: "\uC9C0\uD718\uC790 \uC2A4\uD0AC <color=#F75D32>[{0}]</color>\uC774
      \uC7A5\uCC29\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688234
    m_Localized: "<color=#F75D32>{0}</color> \uCD08\uC6D4\uC744 \uC9C4\uD589\uD558\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688235
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8\uC774 \uD655\uC7A5\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688236
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uBC30\uCE58\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688237
    m_Localized: "\uBC29\uC5B4 \uB371\uC744 \uC800\uC7A5\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688238
    m_Localized: "<color=#F75D32>\uC2A4\uD154\uB77C \uB098\uC774\uCE20</color>\uC640
      <color=#F75D32>\uC9C0\uD615\uC9C0\uBB3C</color>\uC744 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688239
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8\uC5D0 \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4,
      \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C <color=#F75D32>\uCD08\uC6D4</color>\uC2DC\uCF1C\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688240
    m_Localized: "\uC120\uD0DD\uD55C \uC5B8\uC5B4\uB85C \uBCC0\uACBD\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?
      \n\uD655\uC778 \uBC84\uD2BC\uC744 \uD074\uB9AD\uD560 \uC2DC \uB85C\uBE44\uB85C
      \uC774\uB3D9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688241
    m_Localized: "\uD30C\uC6CC \uC5B4\uD0DD \uACE0\uAE09"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688242
    m_Localized: "\uBAAC\uC2A4\uD130 \uBC94\uC704 \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688243
    m_Localized: "\uB109\uBC31"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688244
    m_Localized: "\uC2A4\uD134"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688245
    m_Localized: "\uD06C\uB85C\uC2A4 \uD30C\uC774\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688246
    m_Localized: "\uC800\uACA9\uC218 \uD30C\uC6CC \uC5B4\uD0DD"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688247
    m_Localized: "\uC800\uACA9\uC218 \uAD00\uD1B5\uC0F7"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688248
    m_Localized: "\uC11C\uD3EC\uD130 \uD790"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688249
    m_Localized: "\uD06C\uB85C\uC2A4 \uC544\uC774\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688250
    m_Localized: "\uBCF4\uC2A4 \uD0F1\uCEE4 \uBC94\uC704 \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688251
    m_Localized: "\uD30C\uC6CC \uC5B4\uD0DD \uC554\uC0B4\uC790 \uBC84\uC804"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688252
    m_Localized: "\uC544\uC2A4\uD2B8\uB784 \uC6E8\uC774\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688253
    m_Localized: "\uD504\uB85C\uC98C \uC2AC\uB798\uC2DC"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688254
    m_Localized: "\uAC00\uB4DC \uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688255
    m_Localized: "\uC544\uC774\uC2A4 \uC2A4\uD53C\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688256
    m_Localized: "\uC778\uD398\uB974\uB178"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688257
    m_Localized: "\uAC74 \uC2A4\uD2B8\uB77C\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688258
    m_Localized: "\uB85D \uC628"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688259
    m_Localized: "\uC0AC\uC77C\uB7F0\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688260
    m_Localized: "\uD50C\uB808\uC784 \uBE0C\uB808\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688261
    m_Localized: "\uD30C\uC6CC \uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688262
    m_Localized: "\uC5D1\uC140 \uBD80\uC2A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688263
    m_Localized: "\uC2A4\uD2B8\uB808\uC774 \uBD88\uB9BF!"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688264
    m_Localized: "\uC5B4\uC2A4\uD018\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688265
    m_Localized: "\uD574\uBA38 \uC0F7!"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688266
    m_Localized: "\uD640\uB9AC \uC530"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688267
    m_Localized: "\uADF8\uB77C\uC6B4\uB4DC \uC2AC\uB7A8"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688268
    m_Localized: "\uC368\uBAAC \uB808\uBE57"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688269
    m_Localized: "\uBD88\uB9BF \uD0C0\uC784"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688270
    m_Localized: "\uC708\uB4DC \uBE14\uB808\uC774\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688271
    m_Localized: "\uD3EC\uC774\uC98C \uBC24"
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688272
