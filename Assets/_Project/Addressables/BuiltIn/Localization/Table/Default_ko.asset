    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798771
    m_Localized: "\uD604\uC7AC \uC811\uC18D\uC774 \uBD88\uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798772
    m_Localized: "\uC644\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798773
    m_Localized: "\uB2E4\uC74C \uAC31\uC2E0 \uAE4C\uC9C0 : {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798774
    m_Localized: "\uC7A5\uC560\uBB3C\uC774 \uC124\uCE58\uB418\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4.\n(\uC7A5\uC560\uBB3C\uC744
      \uC124\uCE58\uD574\uBCF4\uC138\uC694)"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798775
    m_Localized: "\uB2E4\uC6B4\uB85C\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798776
    m_Localized: "\uB370\uC774\uD130 \uB2E4\uC6B4\uB85C\uB4DC\uB97C \uC9C4\uD589\uD569\uB2C8\uB2E4.\n\n\uACFC\uB3C4\uD55C
      \uB370\uC774\uD130 \uC0AC\uC6A9\uC744 \uB9C9\uADC0 \uC704\uD574 \nWIFI \uD658\uACBD\uC5D0\uC11C
      \uB2E4\uC6B4\uB85C\uB4DC\uB97C \uAD8C\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
