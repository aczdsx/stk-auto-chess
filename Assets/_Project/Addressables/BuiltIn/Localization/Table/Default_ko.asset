  - m_Id: 415962951049718
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC870\uAC01"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049719
    m_Localized: "\uC131\uC7A5\uC758 \uACB0\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049720
    m_Localized: "PVP \uC785\uC7A5 \uC544\uC774\uD15C"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049721
    m_Localized: "\uBC29\uD574\uBB3C"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049722
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC18C\uD658\uC5D0 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049723
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049724
    m_Localized: "\uBC29\uCE58 \uBCF4\uC0C1\uC744 \uC5BB\uB294\uB370 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049725
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uC9C4\uD589\uC5D0 \uD544\uC694\uD55C
      \uD589\uB3D9\uB825\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049726
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uC18C\uD658\uC5D0 \uD544\uC694\uD55C
      \uC18C\uD658\uAD8C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049727
    m_Localized: "\uBB34\uAE30 \uC18C\uD658\uC5D0 \uD544\uC694\uD55C \uC18C\uD658\uAD8C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049728
    m_Localized: "\uAD00\uCE21\uC790 \uB808\uBCA8 \uC5C5\uC5D0 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049729
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049730
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049731
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uC758 \uD798\uC774 \uB2F4\uAE34
      \uC870\uAC01\uC785\uB2C8\uB2E4. \n20\uAC1C \uC870\uAC01\uC744 \uBAA8\uC744
      \uC2DC, \uD574\uB2F9 \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uD68D\uB4DD\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049732
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20 \uB808\uBCA8 \uC5C5\uC5D0
      \uC0AC\uC6A9\uB418\uB294 \uC544\uC774\uD15C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049733
    m_Localized: "PVP \uC785\uC7A5 \uC2DC \uD544\uC694\uD55C \uC544\uC774\uD15C \uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049734
    m_Localized: "PVP \uBC30\uCE58\uC5D0 \uC0AC\uC6A9\uB418\uB294 \uAE30\uBBF9 \uC544\uC774\uD15C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049735
    m_Localized: "<color=#ec9f19>\uCC55\uD130 \uB9C8\uC77C\uC2A4\uD1A4</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049736
    m_Localized: "<color=#ec9f19>\uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4, \uBC29\uCE58
      \uBCF4\uC0C1</color>, \uD018\uC2A4\uD2B8, \uCD9C\uC11D, \uC774\uBCA4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049737
    m_Localized: "<color=#ec9f19>\uC131\uBCBD</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049738
    m_Localized: "<color=#ec9f19>\uBC29\uCE58 \uBCF4\uC0C1</color>, \uC544\uB808\uB098
      \uC77C\uC77C \uBCF4\uC0C1, \uCD9C\uC11D, \uC774\uBCA4\uD2B8, \uACC4\uC815 \uB808\uBCA8
      \uC5C5 \uBCF4\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049739
    m_Localized: "<color=#ec9f19>\uC2A4\uD14C\uC774\uC9C0 \uB204\uC801 \uD68D\uB4DD
      \uBCC4 \uBCF4\uC0C1</color>, \uCC55\uD130 \uD074\uB9AC\uC5B4, \uCD9C\uC11D,
      \uC774\uBCA4\uD2B8, \uC544\uB808\uB098 \uC2DC\uC98C \uBCF4\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049740
    m_Localized: "<color=#ec9f19>\uCC55\uD130 \uD074\uB9AC\uC5B4 \uBCF4\uC0C1</color>,\uD018\uC2A4\uD2B8,
      \uC774\uBCA4\uD2B8, PVP \uC0C1\uC810, \uC131\uBCBD"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049741
    m_Localized: "<color=#ec9f19>\uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4</color>,
      \uBC29\uCE58 \uBCF4\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049742
    m_Localized: "<color=#ec9f19>\uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4, \uBC29\uCE58
      \uBCF4\uC0C1</color>, \uD018\uC2A4\uD2B8, \uCD9C\uC11D, \uC774\uBCA4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049743
    m_Localized: "<color=#ec9f19>\uC18C\uD658</color>, \uAC00\uC774\uB4DC \uBBF8\uC158"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049744
    m_Localized: "<color=#ec9f19>\uC18C\uD658 </color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049745
    m_Localized: "<color=#ec9f19>\uC99D\uBA85\uC758 \uC804\uC7A5 </color>, \uBC29\uCE58
      \uBCF4\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049746
    m_Localized: "<color=#ec9f19>\uC77C\uC77C \uC790\uB3D9 \uC9C0\uAE09 </color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049747
    m_Localized: "<color=#ec9f19>\uC544\uB808\uB098 </color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049748
    m_Localized: "\uC77C\uC77C \uC544\uB808\uB098 \uBCF4\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049749
    m_Localized: "\uC7AC\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049750
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049751
    m_Localized: "\uAE30\uD0C0"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049752
    m_Localized: "\uC811\uC18D\uC774 \uC81C\uD55C\uB41C \uACC4\uC815\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049753
    m_Localized: "\uD29C\uD1A0\uB9AC\uC5BC \uC911\uC5D0\uB294 \uBD88\uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049754
    m_Localized: "\uBB34\uB8CC \uAC31\uC2E0 \uAC00\uB2A5"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049755
    m_Localized: "\uB2E4\uC2DC \uC811\uC18D\uC744 \uC2DC\uB3C4\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049756
    m_Localized: "\uC774\uBBF8 \uC0AC\uC6A9\uC911\uC778 \uB2C9\uB124\uC784\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049757
    m_Localized: "\uC544\uC774\uB514\uB294 \uC601\uBB38 4~16 \uAE00\uC790, \uD55C\uAE00
      2~8\uAE00\uC790\uB85C \uC0DD\uC131 \uAC00\uB2A5 \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049758
    m_Localized: "\uC77C\uC77C \uAC31\uC2E0 \uAC00\uB2A5 \uD69F\uC218\uB97C \uBAA8\uB450
      \uC18C\uC9C4\uD588\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C \uB0A0 \uC624\uC804 9\uC2DC\uC5D0
      \uD69F\uC218\uAC00 \uCDA9\uC804\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049759
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uD68D\uB4DD\uD558\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049760
    m_Localized: "\uB2C9\uB124\uC784\uC744 \uC785\uB825\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049761
    m_Localized: "\uBCF4\uC0C1 \uD68D\uB4DD"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049762
    m_Localized: "\uC7AC\uCDA9\uC804\uAE4C\uC9C0 \uB0A8\uC740\uC2DC\uAC04 : {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049763
    m_Localized: "\uC804\uD22C\uB97C \uC9C4\uD589\uD560 \uC218 \uC5C6\uB294 \uC0C1\uB300\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049764
    m_Localized: "\uD130\uCE58\uD574\uC11C \uC774\uB984\uC744 \uC124\uC815\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049765
    m_Localized: "\uB124\uD2B8\uC6CC\uD06C\uAC00 \uC6D0\uD65C\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC2DC\uB3C4\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049766
    m_Localized: "\uB7AD\uD0B9 \uAE30\uB85D \uB85C\uB4DC\uC911\uC785\uB2C8\uB2E4.
      \uC7A0\uC2DC \uB4A4 \uAC31\uC2E0\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049767
    m_Localized: "\uB4DC\uB798\uADF8 \uD574\uC11C \uC9C0\uD718\uC790 \uC2A4\uD0AC\uC744
      \uC0AC\uC6A9\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049768
    m_Localized: "\uC131\uC7A5\uC2DC\uD0A4\uACE0 \uC2F6\uC740 \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB97C
      \uC120\uD0DD\uD574 \uB808\uBCA8\uC5C5\uC744 \uD574\uBCF4\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049769
    m_Localized: "\uB0A0\uB9C8\uB2E4 \uC811\uC18D \uC2DC\uAC04\uC5D0 \uB530\uB77C
      \uBCF4\uC0C1\uC744 \uBC1B\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
