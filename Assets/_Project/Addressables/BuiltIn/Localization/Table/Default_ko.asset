  - m_Id: 530996293624432
    m_Localized: "\uC544\uB808\uB098\n<color=#EDF8FF><size=\"25\">BETA</size></color>"
    m_Metadata:
      m_Items: []
  - m_Id: 530996293624433
    m_Localized: "\uB9E4\uCE6D \uAC00\uB2A5\uD55C \uC720\uC800\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 530996293624434
    m_Localized: "\uBC29\uC5B4 \uB371 \uC124\uC815"
    m_Metadata:
      m_Items: []
