  - m_Id: 2327957212226156
    m_Localized: "\uC544\uC774\uC2A4\uD06C\uB85C\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226157
    m_Localized: "\uC544\uC774\uAE30\uC2A4\uC758 \uBC29\uD328"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226158
    m_Localized: "\uC2E4\uD504\uC758\uC7A5\uB09C"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226159
    m_Localized: "\uCC9C\uC0C1\uC758\uBB38"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226160
    m_Localized: "\uC0DD\uCE04\uC5B4\uB9AC"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226161
    m_Localized: "\uBC94\uC704 \uB0B4 \uC801\uC5D0\uAC8C \uC544\uAD70 \uD3C9\uADE0
      \uACF5\uACA9\uB825\uC758 <b><color=#F75D32>500%</color></b>\uB9CC\uD07C\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226162
    m_Localized: "\uBC94\uC704 \uB0B4 \uC801\uC5D0\uAC8C \uC544\uAD70 \uD3C9\uADE0
      \uACF5\uACA9\uB825\uC758 <b><color=#F75D32>500%</color></b>\uB9CC\uD07C\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226163
    m_Localized: "\uC120\uD0DD\uD55C \uC801 1\uBA85\uC744 <b><color=#F75D32>3\uCD08
      \uB3D9\uC548 \uC5D0\uC5B4\uBCF8</color></b>\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226164
    m_Localized: "\uBC94\uC704 \uB0B4 \uC704\uCE58\uD55C \uC544\uAD70\uC758 \uCCB4\uB825\uC744
      \uC544\uAD70 \uCD5C\uACE0 \uACF5\uACA9\uB825\uC758 <b><color=#F75D32>700%\uB9CC\uD07C
      \uD68C\uBCF5</color></b>\uC2DC\uD0A8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226165
    m_Localized: "\uBC30\uCE58\uD310 \uC704\uC758 \uC544\uAD70\uACFC \uC801, \uC9C0\uD615
      \uC9C0\uBB3C \uC694\uC18C\uC758 \uC704\uCE58\uB97C \uBAA8\uB450 \uB79C\uB364\uD558\uAC8C
      \uBC14\uAFBC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226166
    m_Localized: "3*3\uBC94\uC704 \uB0B4\uC758 \uC801\uC758 \uACF5\uACA9\uB825\uC744
      <b><color=#F75D32>5\uCD08</color></b> \uB3D9\uC548 <b><color=#F75D32>50% \uAC10\uC18C</color></b>\uC2DC\uD0A8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226167
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBD84\uCD9C\uD558\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4.
      \uC774 \uBD88\uC758 \uBCBD\uC740 {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uBA70
      \uB2FF\uC740 \uC801\uC740 {1}\uC758 \uD53C\uD574\uC640 {2}%\uC758 \uC9C0\uC18D
      \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226168
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBD84\uCD9C\uD558\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4.
      \uC774 \uC5BC\uC74C\uC758 \uBCBD\uC740 {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uBA70
      \uB2FF\uC740 \uC801\uC740 {1}\uC758 \uD53C\uD574\uC640 {2}\uCD08 \uB3D9\uC548
      \uB300\uC0C1\uC744 \uC5BC\uB824\uBC84\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226169
    m_Localized: "\uACFC\uAC70 \uACE0\uB300 \uC778\uB958\uC758 \uC794\uC601\uC744
      \uAD00\uCE21\uD558\uC5EC \uD604\uC138\uC5D0 \uD5CC\uD5CC \uC2DC\uD0B5\uB2C8\uB2E4.
      \uC18C\uD658\uB41C \uC544\uC774\uAE30\uC2A4 \uBCD1\uB2E8\uC740 \uC77C\uC9C1\uC120\uC758
      \uC801\uB4E4\uC744 {0}\uCE78 \uBC00\uC5B4\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2327957212226170
    m_Localized: "\uD589\uC131\uC758 \uC790\uC5F0 \uC5D0\uB108\uC9C0\uB97C \uAD00\uCE21\uD558\uC5EC
      \uD2B9\uC815 \uC9C0\uC810\uC5D0 \uBC14\uB78C\uC744 \uC77C\uC73C\uD0B5\uB2C8\uB2E4.
      \uB2FF\uC740 \uB300\uC0C1\uC740 \uBB34\uC791\uC704 \uC704\uCE58\uC5D0 \uB5A8\uC5B4\uC9C0\uAC8C
      \uB418\uBA70 \uC801\uAD70\uC778 \uACBD\uC6B0 {0}\uC758 \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
