      m_Items: []
  - m_Id: 3067737926783003
    m_Localized: "\uC77C\uC77C \uB9AC\uC14B \uAC00\uB2A5 \uD69F\uC218\uB97C \uBAA8\uB450
      \uC18C\uC9C4\uD588\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C \uB0A0 \uD69F\uC218\uAC00
      \uC790\uB3D9 \uCDA9\uC804\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783004
    m_Localized: "\uB354 \uC774\uC0C1 \uAD6C\uB9E4\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783005
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uBCC4 \uAC2F\uC218\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783006
    m_Localized: "\uC774\uBBF8 \uD074\uB9AC\uC5B4\uD55C \uB358\uC804\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783007
    m_Localized: "\uC774\uC804 \uB2E8\uACC4\uB97C \uD074\uB9AC\uC5B4 \uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783008
    m_Localized: "\uB9AC\uC14B \uC544\uC774\uD15C \uB370\uC774\uD130 \uC5D0\uB7EC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783009
    m_Localized: "\uC544\uB808\uB098 \uBC29\uC5B4 \uB371 \uC124\uC815\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783010
    m_Localized: "\uC544\uC9C1 PVP \uC0C1\uB300\uB97C \uAC31\uC2E0\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783011
    m_Localized: "\uC544\uB808\uB098 \uC804\uD22C \uC2DC\uAC04\uC774 \uC885\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783012
    m_Localized: "<color=#F75D32>{0}</color> \uC644\uB8CC \uD6C4 \uC0AC\uC6A9 \uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783013
    m_Localized: "\uC9C0\uD718\uC790 \uC2A4\uD0AC <color=#F75D32>[{0}]</color>\uC774
      \uC7A5\uCC29\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783014
    m_Localized: "<color=#F75D32>{0}</color> \uCD08\uC6D4\uC744 \uC9C4\uD589\uD558\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783015
    m_Localized: "\uCD08\uC6D4\uC758 \uD6A8\uACFC\uB85C \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, \uD398\uC2DC\uBE0C \uC2A4\uD0AC \uB808\uBCA8\uC774
      \uC131\uC7A5\uD558\uC600\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783016
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uBC30\uCE58\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783017
    m_Localized: "\uBC29\uC5B4 \uB371\uC744 \uC800\uC7A5\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783018
    m_Localized: "<color=#F75D32>\uC2A4\uD154\uB77C \uB098\uC774\uCE20</color>\uC640
      <color=#F75D32>\uC9C0\uD615\uC9C0\uBB3C</color>\uC744 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783019
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8\uC5D0 \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4,
      \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C <color=#F75D32>\uCD08\uC6D4</color>\uC2DC\uCF1C\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783020
    m_Localized: "\uC120\uD0DD\uD55C \uC5B8\uC5B4\uB85C \uBCC0\uACBD\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?
      \n\uD655\uC778 \uBC84\uD2BC\uC744 \uD074\uB9AD\uD560 \uC2DC \uB85C\uBE44\uB85C
      \uC774\uB3D9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783021
    m_Localized: "\uAC00\uC774\uB4DC \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD55C \uD6C4
      \uC9C4\uC785\uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783022
    m_Localized: "\uAC00\uC774\uB4DC \uBBF8\uC158\uC744 \uD074\uB9AC\uC5B4 \uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783023
    m_Localized: "\uAC00\uC774\uB4DC \uBBF8\uC158 \uBAA9\uD45C \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783024
    m_Localized: "\uD14C\uC2A4\uD2B8 \uC885\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783025
    m_Localized: "\uD14C\uC2A4\uD2B8 \uD50C\uB808\uC774\uC5D0 \uCC38\uC5EC\uD574\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4!\n\uAC04\uB2E8\uD55C \uC124\uBB38\uC73C\uB85C
      \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB97C \uC751\uC6D0\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783026
    m_Localized: "\uC124\uBB38\uD558\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783027
    m_Localized: "\uC804\uD22C \uC778\uC6D0\uC774 \uCD5C\uB300 \uC778\uC6D0\uBCF4\uB2E4
      \uC801\uC2B5\uB2C8\uB2E4.\n\uC804\uD22C\uB97C \uC2DC\uC791\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783028
    m_Localized: "\uB2E4\uC74C \uC2A4\uD14C\uC774\uC9C0\uB85C \uC774\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783029
    m_Localized: "\uB2E4\uC74C \uCC55\uD130\uB85C \uC774\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783030
    m_Localized: "<color=#F75D32>\uD074\uB9AD</color>\uD574\uC11C \uC720\uB2DB\uC744
      \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783031
    m_Localized: "\uD558\uB2E8\uBD80 \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C
      <color=#F75D32>\uAE38\uAC8C</color> \uB204\uB974\uBA74 <color=#F75D32>\uC2A4\uD0AC</color>
      \uC815\uBCF4 \uCD9C\uB825"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783032
    m_Localized: "\uAD6C\uB9E4 \uAC00\uB2A5 \uD69F\uC218 : {0}/{1}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783033
    m_Localized: "\uC99D\uBA85\uC758 \uC804\uC7A5 \n{0} \uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783034
    m_Localized: "\uCD94\uCC9C \uBC30\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737926783035
    m_Localized: "{0} \uB2E8\uACC4"
