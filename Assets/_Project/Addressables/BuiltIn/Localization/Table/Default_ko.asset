  - m_Id: 3250580409798858
    m_Localized: "\uC544\uB974\uCE74\uB098"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798859
    m_Localized: "<color=#F75D32>\uB192\uC740 \uB9C8\uBC95 \uBC29\uC5B4\uB825</color>\uC73C\uB85C,
      <color=#F75D32>\uB9C8\uBC95\uC0AC</color>\uC758 \uB300\uBBF8\uC9C0\uB97C \uB0AE\uAC8C
      \uBC1B\uB294\uB2E4. \uBB3C\uB9AC \uACF5\uACA9\uC744 \uD558\uB294 <color=#0047AB>\uC800\uACA9\uC218</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798860
    m_Localized: "{0}\uBA85 : \uB9C8\uBC95 \uACF5\uACA9 \uD53C\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798861
    m_Localized: "<color=#F75D32>\uBB3C\uB9AC \uBC29\uC5B4\uB825</color>\uC774 \uB192\uC544,
      \uAC00\uB514\uC5B8\uACFC <color=#F75D32>\uC800\uACA9\uC218</color> \uACF5\uACA9\uC744
      \uD6A8\uACFC\uC801\uC73C\uB85C \uBC29\uC5B4\uD55C\uB2E4.\uB9C8\uBC95 \uACF5\uACA9\uC744
      \uD558\uB294  <color=#0047AB>\uB9C8\uBC95\uC0AC</color>\uC5D0\uAC8C \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798862
    m_Localized: "{0}\uBA85 : \uBB3C\uB9AC \uACF5\uACA9 \uD53C\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798863
    m_Localized: "<color=#F75D32>\uB9C8\uBC95 \uACF5\uACA9</color>\uC744 \uC0AC\uC6A9\uD558\uC5EC,
      <color=#F75D32>\uD0F1\uCEE4</color>\uB97C \uD6A8\uACFC\uC801\uC73C\uB85C \uD0C0\uACA9\uD55C\uB2E4.
      \uB9C8\uBC95 \uBC29\uC5B4\uAC00 \uB192\uC740 <color=#0047AB>\uAC00\uB514\uC5B8</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798864
    m_Localized: "{0}\uBA85 : \uC2A4\uD0AC \uC0AC\uC6A9 \uC2DC \uB2E4\uC74C \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798865
    m_Localized: "<color=#F75D32>\uAC00\uC7A5 \uAE34 \uC0AC\uAC70\uB9AC</color>\uB97C
      \uC9C0\uB154\uC73C\uBA70, <color=#F75D32>\uB192\uC740 \uACF5\uACA9\uB825</color>\uC73C\uB85C
      <color=#F75D32>\uAC00\uB514\uC5B8</color>\uC744 \uD6A8\uACFC\uC801\uC73C\uB85C
      \uD0C0\uACA9\uD55C\uB2E4. \uBB3C\uB9AC \uBC29\uC5B4\uAC00 \uB192\uC740 <color=#0047AB>\uD0F1\uCEE4</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798866
    m_Localized: "{0}\uBA85 : \uCE58\uBA85\uD0C0 \uACF5\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798867
    m_Localized: "<color=#F75D32>\uB192\uC740 \uACF5\uACA9 \uC18D\uB3C4</color>\uC640
      <color=#F75D32>\uC774\uB3D9\uC18D\uB3C4</color>\uB97C \uC9C0\uB154\uC73C\uBA70
      <color=#F75D32>\uC2A4\uD0AC \uCFE8\uD0C0\uC784</color>\uC774 \uC9E7\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798868
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC2DC \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798869
    m_Localized: "<color=#F75D32>\uD790, \uBC84\uD504, \uB514\uBC84\uD504</color>
      \uB4F1 \uC544\uAD70 \uAC15\uD654 \uB610\uB294 \uC801\uAD70 \uC57D\uD654\uC5D0
      \uD2B9\uD654\uB41C \uD3EC\uC9C0\uC158\uC774\uB2E4. \uAE30\uBCF8 \uACF5\uACA9\uB825\uACFC
      \uCCB4\uB825\uC740 <color=#0047AB>\uB0AE\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798870
    m_Localized: "{0}\uBA85 : \uCCAB \uC2A4\uD0AC \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b>
      \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798871
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC774
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798872
    m_Localized: "{0}\uBA85 : \uACF5\uACA9\uB825 {1}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798873
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uAD00\uD1B5\uB825\uACFC
      \uBE14\uB7ED\uC728\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798874
    m_Localized: "{0}\uBA85 : \uAD00\uD1B5\uB825 {1}%, \uBE14\uB7ED\uC728 {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798875
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uC0DD\uBA85\uB825 \uBC0F
      \uBC29\uC5B4\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798876
    m_Localized: "{0}\uBA85 : \uC0DD\uBA85\uB825 {1}%, \uBC29\uC5B4\uB825 {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798877
    m_Localized: "\uBE5B \uC2DC\uB108\uC9C0 \uC2A4\uD154\uB77C \uB098\uC774\uCE20
      \uD2B9\uC815 \uC2DC\uAC04 \uB3D9\uC548 <color=#F75D32>\uBAA8\uB4E0 \uC0C1\uD0DC
      \uC774\uC0C1 \uBA74\uC5ED</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798878
    m_Localized: "{0}\uBA85 : <b><color=#F75D32>{1}\uCD08</color></b>\uB3D9\uC548
      \uBAA8\uB4E0 \uC0C1\uD0DC \uC774\uC0C1 \uBA74\uC5ED"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798879
    m_Localized: "\uC801\uAD70 <color=#F75D32>\uC2A4\uD0AC \uCFE8\uD0C0\uC784 \uAC10\uC18C
      \uC18D\uB3C4 \uAC10\uC18C </color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798880
    m_Localized: "{0}\uBA85 : \uC2A4\uD0AC \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b>
      \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798881
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uC18D\uB3C4
      \uBC0F \uD68C\uD53C\uC728\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798882
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC18D\uB3C4 {1}%, \uD68C\uD53C\uC728
      {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798883
    m_Localized: "{0} \uC2DC\uB108\uC9C0 \uBC30\uCE58 \uD6A8\uACFC"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798884
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uD06C\uB9AC\uD2F0\uCEEC
      \uD655\uB960 \uBC0F \uC704\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798885
    m_Localized: "{0}\uBA85 : \uD06C\uB9AC\uD2F0\uCEEC \uD655\uB960{1}%, \uC704\uB825
      {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798886
    m_Localized: "\uC655\uAC00\uC758 \uB099\uC778\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uD06C\uAE30\uAC00 {0}% \uC0C1\uC2B9\uD558\uACE0 \uACF5\uACA9\uB825\uC774 {1}%
      \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798887
    m_Localized: "\uADC0\uC871\uC758 \uC758\uBB34\uAC00 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uCD1D\uCCB4\uB825\uC758 {0}%\uC5D0 \uD574\uB2F9\uD558\uB294 \uC274\uB4DC\uAC00
      \uC0DD\uC131\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798888
    m_Localized: "\uC5D8\uB9AC\uD2B8\uC758 \uC790\uC874\uC2EC\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uC804\uD22C \uC2DC\uC791 \uD6C4 {0}\uCD08\uAC04 CC \uD6A8\uACFC\uC5D0 \uBA74\uC5ED\uC774\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798889
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798890
    m_Localized: "\uC804\uC120\uC744 \uC720\uC9C0\uD558\uAE30 \uC704\uD55C \uB300\uC804\uCC28
      \uC9C0\uB8B0\uB97C \uC804\uC7A5\uC5D0 \uC124\uCE58\uD569\uB2C8\uB2E4. \uC9C0\uB8B0\uC758
      \uACF5\uACA9\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825\uC5D0
      \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798891
    m_Localized: "\uB2E4\uC591\uD55C \uD6A8\uACFC\uB97C \uC9C0\uB2CC \uBCF4\uAE09\uD488\uC744
      {0}\uCD08 \uB9C8\uB2E4 \uD68D\uB4DD\uD569\uB2C8\uB2E4. \uBCF4\uAE09\uD488 \uC548\uC5D0
      \uB0B4\uC6A9\uBB3C\uC740 \uBB34\uC791\uC704\uB85C \uACB0\uC815\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798892
    m_Localized: "\uC804\uD22C \uD568\uC120\uC744 {0}\uCD08 \uB9C8\uB2E4 \uBD88\uB7EC\uB0B4
      \uD3EC\uACA9\uC73C\uB85C \uC804\uC7A5\uC744 \uCD08\uD1A0\uD654 \uC2DC\uD0B5\uB2C8\uB2E4.
      \uD3EC\uACA9\uC758 \uC704\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825\uC5D0
      \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798893
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798894
    m_Localized: "\uC131\uAD70\uC6D0\uB4E4\uC758 \uCCB4\uB825 \uC911 {0}%\uC744 \uD761\uC218\uD558\uC5EC
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4. \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC
      \uCD08\uC2E0\uC131 \uBAA8\uB4DC1\uB2E8\uACC4\uC5D0 \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798895
    m_Localized: "\uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825 \uC911 {0}%\uC744
      \uD761\uC218\uD558\uC5EC \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4.
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC \uCD08\uC2E0\uC131 \uBAA8\uB4DC 2\uB2E8\uACC4\uC5D0
      \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798896
    m_Localized: "\uCD08\uC2E0\uC131\uC744 \uB354\uC6B1 \uAC00\uC18D\uC2DC\uCF1C
      \uBC29\uC5B4\uAD00\uD1B5\uB825\uC774 {0}% \uC0C1\uC2B9\uD558\uACE0, \uD06C\uB9AC\uD2F0\uCEEC
      \uC704\uB825\uC774 {1}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3250580409798897
    m_Localized: NONE
    m_Metadata:
      m_Items: []
