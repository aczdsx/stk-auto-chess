    m_Localized: "\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 <b><color=#F75D32>300%</color></b>\uC758
      \uB9C8\uBC95 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC
      : \uBD88 \uC2DC\uB108\uC9C0 \uC801\uC5D0\uAC8C\uB294 \uC2A4\uD0AC \uACF5\uACA9\uB825\uC774
      <b><color=#F75D32>150% \uC99D\uAC00</color></b>\uD55C\uB2E4. \n\uB300\uC0C1
      : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298282
    m_Localized: "\uB300\uBBF8\uC9C0 : \uD654\uC5FC \uBE54\uC744 \uC18C\uD658\uD574,
      \uACF5\uACA9\uB825 <b><color=#F75D32>350%</color></b>\uC758 \n\uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : \uACF5\uACA9 \uBC94\uC704\uC5D0
      \uC794\uC5F4\uC774 \uB0A8\uC544, <b><color=#F75D32>2\uCD08</color></b> \uB3D9\uC548
      \n\uCD08\uB2F9 <b><color=#F75D32>75%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801 \uC911\uC2EC
      3x3"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298283
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC0F7\uAC74\uC744 \uBC1C\uC0AC\uD574 \uD544\uB9AC\uC544
      \uACF5\uACA9\uB825 <b><color=#F75D32>400%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uAC00\uD55C\uB2E4.\n\uD2B9\uC218 \uD6A8\uACFC : \uC2A4\uD0AC\uB85C \uC801\uC744
      \uC0AC\uB9DD \uC2DC\uCF30\uC744 \uC2DC, \n\uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774
      \uC989\uC2DC \uCD08\uAE30\uD654\uB41C\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298284
    m_Localized: "\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 <b><color=#F75D32>850%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC :
      \uD53C\uACA9\uB41C \uC801\uC740 \uB450 \uCE78 \uAC70\uB9AC\uB9CC\uD07C \n<b><color=#F75D32>\uB109\uBC31</color></b>\uB41C\uB2E4.
      \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740 \uC801
      1\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298285
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD558\uAC8C \uBCA0\uC5B4 \uACF5\uACA9\uB825
      <b><color=#F75D32>250%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4.
      \n\uD2B9\uC218 \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC740 <b><color=#F75D32>3\uCD08
      \uB3D9\uC548 \uCE68\uBB35 \uB514\uBC84\uD504</color></b>\uC5D0 \uAC78\uB9AC\uAC8C
      \uD55C\uB2E4. \n<color=#77889A><b><color=#F75D32>*</color></b>\uCE68\uBB35
      : \uC2A4\uD0AC \uC0AC\uC6A9 \uBD88\uAC00\uB2A5, \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      \uAC10\uC18C \uC815\uC9C0</color>\n\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4
      \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298286
    m_Localized: "\uB300\uBBF8\uC9C0 : \uBD88\uAE38\uC744 \uC18C\uD658\uD574 \uACF5\uACA9\uB825
      <b><color=#F75D32>450%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\n\uD2B9\uC218
      \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC5D0\uAC8C \uBCF4\uD638\uB9C9\uC774
      \uC788\uC744 \uACBD\uC6B0, \n\uBCF4\uD638\uB9C9\uC774 \uC989\uC2DC \uD30C\uAD34\uB41C\uB2E4.
      \n\uBC94\uC704 : \uB8E8\uD0A4\uB2E4 \uC911\uC2EC 3x3"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298287
    m_Localized: "\uD6A8\uACFC : \uACF5\uACA9\uB825\uC744 <b><color=#F75D32>3\uCD08</color></b>
      \uB3D9\uC548 <b><color=#F75D32>30%</color></b> \uC99D\uAC00\uC2DC\uD0A8\uB2E4.
      \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740 \uC544\uAD70
      2\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298288
    m_Localized: "\uD6A8\uACFC : \uC544\uAD70 \uC804\uCCB4\uC758 \uCCB4\uB825\uC744
      \uC5D4\uD0A4 \uACF5\uACA9\uB825 <b><color=#F75D32>500%</color></b>\uB9CC\uD07C
      \uD68C\uBCF5\uC2DC\uD0A4\uACE0 \n<b><color=#F75D32>2\uCD08</color></b> \uB3D9\uC548
      \uACF5\uACA9 \uC18D\uB3C4\uB97C <b><color=#F75D32>40%</color></b> \uB9CC\uD07C
      \uC99D\uAC00\uC2DC\uD0A8\uB2E4. \n\uB300\uC0C1 : \uC544\uAD70 \uC804\uCCB4"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298289
    m_Localized: "\uB300\uBBF8\uC9C0 : \uD14C\uD1A0\uB77C \uACF5\uACA9\uB825 <color=#F75D32>500%</color>
      + \uB9C8\uBC95 \uBC29\uC5B4\uB825 \uBE44\uB840 \uB300\uBBF8\uC9C0 \uC99D\uAC00\n\uD6A8\uACFC
      : \uB300\uAC80\uC744 \uD718\uB458\uB7EC \uC801 1\uBA85\uC5D0\uAC8C \uB300\uBBF8\uC9C0\uB97C
      \uC8FC\uACE0 <color=#F75D32>4\uCE78</color> \uB109\uBC31\uC2DC\uD0A8\uB2E4.\n\n\uD2B9\uC218
      \uD6A8\uACFC : \uB109\uBC31\uB41C \uC801\uC774 \uAD6C\uC870\uBB3C \uB610\uB294
      \uB2E4\uB978 \uB300\uC0C1\uC5D0 \uBD80\uB52A\uD790 \uC2DC, 3*3\uBC94\uC704\uB85C
      <color=#F75D32>1.5\uCD08</color> \uB3D9\uC548 \uC2A4\uD134\uC744 \uC77C\uC73C\uD0A4\uBA70\n\uACF5\uACA9\uB825
      <color=#F75D32>200%</color>+\uB9C8\uBC95 \uBC29\uC5B4\uB825 \uBE44\uB840 \uCD94\uAC00
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\n\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0
      \uC704\uCE58\uD55C \uC801 1\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298290
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC801\uC5D0\uAC8C \uC720\uD0C4\uC744 \uBC1C\uC0AC\uD574
      \uACF5\uACA9\uB825 <color=#F75D32>250%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \uC720\uD0C4\uC744 \uC801\uC744 \uD0C0\uAC9F\uD55C \uD6C4 \uD3ED\uBC1C\uD574
      \uC8FC\uBCC0\uC5D0 <color=#F75D32>150%</color>\uC758 \uCD94\uAC00 \uD53C\uD574\uB97C
      \uC900\uB2E4. \n\uD0C0\uAC9F : \uD604\uC7AC \uCCB4\uB825\uC774 \uBE44\uC728\uC774
      \uAC00\uC7A5 \uB0AE\uC740 \uC21C\uC704\uB85C \uC801 3\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298291
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC8FC\uBCC0 \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825
      <color=#F75D32>250%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC8FC\uBA70 \uC2ED\uC790
      \uBC94\uC704 \uBC14\uAE65 \uBC29\uD5A5\uC73C\uB85C \uB109\uBC31 \uC2DC\uD0A8\uB2E4.
      \n\uD6A8\uACFC : <color=#F75D32>4\uCD08</color> \uB3D9\uC548 \uC790\uAE30\uC5D0\uAC8C
      <color=#F75D32>50%</color>\uC758 \uBC29\uC5B4\uB825 \uC99D\uAC00 \uBC84\uD504\uB97C
      \uAC74\uB2E4. \n\uCD94\uAC00 \uD6A8\uACFC : \uBC14\uB78C \uC2DC\uB108\uC9C0
      \uBC30\uCE58 \uC778\uC6D0 1\uBA85\uB2F9 \uBB3C\uB9AC \uBC29\uC5B4\uB825 <color=#F75D32>25%</color>
      \uCD94\uAC00 \uC99D\uAC00\n(\uCD5C\uB300 3\uBA85\uAE4C\uC9C0\uB9CC \uC801\uC6A9)
      \n\n\uBC94\uC704 : \uC790\uAE30 \uC911\uC2EC \uC2ED\uC790 \uBC94\uC704"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298292
    m_Localized: "\uD6A8\uACFC : \uC801\uC744 <color=#F75D32>3\uCD08</color> \uB3D9\uC548
      \uAD00\uC5D0 \uAC00\uB46C \uBD09\uC778\uD55C\uB2E4. \uBD09\uC778\uB41C \uC801\uB3C4
      \uACF5\uACA9 \uB300\uC0C1\uC73C\uB85C \uCDE8\uAE09\uB418\uBA70, \uBD09\uC778\uB41C
      \uC801\uC740 \uBD09\uC778\uB3D9\uC548 \uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774
      \uD750\uB974\uC9C0 \uC54A\uB294\uB2E4. \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774
      \uAC00\uC7A5 \uB192\uC740 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298293
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC544\uB4DC\uB9AC\uC544 \uACF5\uACA9\uB825<color=#F75D32>500%</color>
      \uB300\uBBF8\uC9C0\uB97C \uC785\uD788\uACE0, <color=#F75D32>\uBB3C\uB9AC \uBC29\uC5B4\uB825</color>\uC5D0
      \uBE44\uB840\uD574 \uD53C\uD574\uAC00 \uC99D\uAC00\uD55C\uB2E4. \n\uCD94\uAC00
      \uD6A8\uACFC : \uBC94\uC704 \uB0B4\uC5D0 \uC704\uCE58\uD55C \uC801\uC740 <color=#F75D32>1\uCD08</color>
      \uB3D9\uC548 \uC2A4\uD134\uC5D0 \uAC78\uB9B0\uB2E4.\n\uBC94\uC704 : \uC790\uAE30
      \uC911\uC2EC"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298294
    m_Localized: "\uD6A8\uACFC : \uACF0\uC744 {0}\uCD08 \uB3D9\uC548 \uC18C\uD658\uD55C\uB2E4,
      \uC18C\uD658 \uC2DC \uACF0 \uC911\uC2EC 3*3\uBC94\uC704\uC5D0 \uD53C\uD540
      \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C\uC900\uB2E4. \uC18C\uD658\uB41C
      \uACF0\uC740 3*3\uBC94\uC704\uB85C {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uB294
      \uB3C4\uBC1C\uC744 \uC2DC\uC804\uD55C\uB2E4. \n\uACF0 \uC2A4\uD0EF : \uD53C\uD540
      \uCCB4\uB825\uC758 200%, \uD53C\uD540 \uACF5\uACA9\uB825\uC758 70%, \uADF8
      \uC678 \uC2A4\uD0EF\uC740 \uD53C\uD540\uACFC \uB3D9\uC77C \n\uB300\uC0C1 :
      \uD53C\uD540\uC774 \uACF5\uACA9 \uC911\uC778 \uB300\uC0C1 \uC8FC\uBCC0"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298295
    m_Localized: "\uBC94\uC704 : \uC804\uBC29 1\uCE78, 3\uCE78, 5\uCE78, 7\uCE78
      \n\uD6A8\uACFC : \uB113\uC740 \uBC94\uC704\uC5D0 \uB2E4\uC218\uC758 \uCD1D\uAE30\uB97C
      \uAEBC\uB0B4 <color=#F75D32>3\uCD08</color> \uB3D9\uC548 <color=#F75D32>10\uD68C</color>
      \uD0C0\uACA9\uD558\uBA70, \uBC94\uC704\uBCC4\uB85C \uB2E4\uB978 \uB300\uBBF8\uC9C0\uB97C
      \uBD80\uC5EC\uD55C\uB2E4. \n\uB300\uBBF8\uC9C0 : \n-\uC804\uBC29 1\uCE78, 3\uCE78\uC740
      \uD68C\uB2F9 \uACF5\uACA9\uB825 <color=#F75D32>900%</color>\uC758 \uB300\uBBF8\uC9C0\n-\uC804\uBC29
      5\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA9\uB825 <color=#F75D32>700%</color>\uC758
      \uB300\uBBF8\uC9C0 \n-\uC804\uBC29 7\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA8\uB825
      <color=#F75D32>500%</color>\uC758 \uB300\uBBF8\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298296
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC801\uC5D0\uAC8C \uBD80\uBA54\uB791\uC744
      \uB358\uC838 \uACF5\uACA9\uB825 <color=#F75D32>300%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uBD80\uBA54\uB791\uC744 \uB9DE\uC740 \uC801 \uADFC\uCC98\uC5D0
      \uB2E4\uB978 \uC801\uC774 \uC788\uC73C\uBA74, \uBD80\uBA54\uB791\uC774 \uADF8
      \uC801\uC5D0\uAC8C \uD295\uAE34\uB2E4. \n\uBD80\uBA54\uB791\uC774 \uD295\uAE38
      \uB54C\uB9C8\uB2E4 \uB300\uBBF8\uC9C0\uAC00 <color=#F75D32>50%</color>\uC529
      \uC904\uC5B4\uB4E0\uB2E4. \n\uBD80\uBA54\uB791\uC740 \uCD5C\uB300 <color=#F75D32>5\uBA85</color>\uAE4C\uC9C0
      \uACF5\uACA9\uAC00\uB2A5\uD558\uB2E4. \n\uCD94\uAC00 \uD6A8\uACFC : \uD53C\uACA9\uB41C
      \uC801 1\uBA85\uB2F9 2\uCD08 \uB3D9\uC548 \uACF5\uACA9\uC18D\uB3C4\uAC00 <color=#F75D32>10%</color>
      \uC99D\uAC00\uD55C\uB2E4. \n\uD0C0\uAC9F : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0
      \uC704\uCE58\uD55C \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298297
    m_Localized: "\uD6A8\uACFC : \uC57D\uBCD1\uC744 \uD22C\uD558\uD574 <color=#F75D32>3\uCD08</color>
      \uB3D9\uC548 \uBC94\uC704 \uB0B4\uC5D0 \uC704\uCE58\uD55C \uC801\uAD70\uC758
      \uCE58\uC720 \uD6A8\uACFC\uB97C <color=#F75D32>60%</color>, \n\uBB3C\uB9AC
      \uBC29\uC5B4\uB825\uC744 <color=#F75D32>80%</color> \uAC10\uC18C\uC2DC\uD0A8\uB2E4.\n\uB300\uC0C1
      : \uBB3C\uB9AC \uB610\uB294 \uB9C8\uBC95 \uBC29\uC5B4\uB825\uC774 \uAC00\uC7A5
      \uB192\uC740 \uC801\uC758 3*3 \uBC94\uC704"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298298
    m_Localized: "\uBC94\uC704 : \uBA58\uC0E4\uC640 \uB3D9\uC77C\uD55C \uC5F4 \uC790\uC2E0\uC744
      \uAE30\uC900\uC73C\uB85C 3*3 \uBC94\uC704\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04:
      {0} \uCD08\n\uD6A8\uACFC : \uC544\uAD70\uC5D0\uAC8C {1}\uCD08 \uB3D9\uC548
      \uBA58\uC0E4 \uACF5\uACA9\uB825 \uCCB4\uB825 {2}%\uC758 \uC2E4\uB4DC\uB97C
      \uBD80\uC5EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298299
    m_Localized: "\uBC94\uC704 : \uC790\uAE30 \uC911\uC2EC \uC2ED\uC790 \uBC94\uC704\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04 {0}\r\n\uB300\uBBF8\uC9C0 : \uC8FC\uBCC0 \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825
      {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C \uC8FC\uBA70 \uC2ED\uC790 \uBC94\uC704
      \uBC14\uAE65 \uBC29\uD5A5\uC73C\uB85C \uB109\uBC31 \uC2DC\uD0A8\uB2E4.\r\n\uD6A8\uACFC
      : {2}\uCD08 \uB3D9\uC548 \uC790\uAE30\uC5D0\uAC8C {3}%\uC758 \uBC29\uC5B4\uB825
      \uC99D\uAC00 \uBC84\uD504\uB97C \uAC74\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298300
    m_Localized: "\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801  \uC2ED\uC790\uAC00
      \uBAA8\uC591 3by3\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\r\n\uB300\uBBF8\uC9C0
      : \uACF5\uACA9\uB825 {1}%\uC758 \uB9C8\uBC95 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\r\n\uD2B9\uC218
      \uD6A8\uACFC : \uC801\uC744 \uBB3C \uAC10\uC625\uC5D0 \uAC00\uB46C {2}\uCD08\uAC04
      \uC801\uC758 \uC774\uB3D9\uACFC \uACF5\uACA9\uC744 \uBD09\uC1C4\uD55C\uB2E4.\r\n\uB300\uC0C1\uC774
      \uD53C\uD574\uB97C \uBC1B\uC744 \uC2DC \uC774 \uD6A8\uACFC\uB294 \uC989\uC2DC
      \uC81C\uAC70\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298301
    m_Localized: "\uB300\uC0C1 : \uAC00\uC7A5 \uBA3C \uC801\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\r\n\uB300\uBBF8\uC9C0 : \uC815\uC870\uC900\uD55C \uD6C4 \uBC1C\uC0AC\uD574
      \uD544\uB9AC\uC544 \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4.\r\n\uD2B9\uC218
      \uD6A8\uACFC : \uC2A4\uD0AC\uB85C \uC801\uC744 \uC0AC\uB9DD \uC2DC\uCF30\uC744
      \uC2DC, \uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774 \uC989\uC2DC \uCD08\uAE30\uD654\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298302
    m_Localized: "\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uB300\uBBF8\uC9C0 : \uAC15\uD558\uAC8C \uBCA0\uC5B4
      \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4.\r\n\uD2B9\uC218
      \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC740 {2}\uCD08 \uB3D9\uC548 \uCE68\uBB35
      \uB514\uBC84\uD504\uC5D0 \uAC78\uB9AC\uAC8C \uD55C\uB2E4.\r\n*\uCE68\uBB35
      : \uC2A4\uD0AC \uC0AC\uC6A9 \uBD88\uAC00\uB2A5, \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      \uAC10\uC18C \uC815\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298303
    m_Localized: "\uB300\uC0C1 : \uCCB4\uB825\uC774 \uAC00\uC7A5 \uB0AE\uC740 \uC544\uAD70
      3\uC778\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0} \uCD08\n\uD6A8\uACFC : \uB300\uC0C1\uC5D0\uAC8C
      \uC720\uB2C8 \uCE58\uC720\uB825\uC758 {1}% \uB9CC\uD07C \uD68C\uBCF5 \uC2DC\uD0A4\uACE0,
      CC\uC0C1\uD0DC\uB97C {2}\uAC1C \uC81C\uAC70\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298304
    m_Localized: "\uBC94\uC704 : \uC804\uBC29 X\uCD95 3\uCE78\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uB300\uBBF8\uC9C0 : \uAC80\uAE30\uB97C \uB0A0\uB824,
      \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\r\n\uD2B9\uC218
      \uD6A8\uACFC : \uAC80\uAE30\uB294 \uB9F5 \uB05D\uAE4C\uC9C0 \uC9C0\uC18D\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298305
    m_Localized: "\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0 \uC704\uCE58\uD55C
      \uC801 1\uBA85\r\n\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\r\n\uD6A8\uACFC
      : \uB300\uAC80\uC744 \uD718\uB458\uB7EC \uC801 1\uBA85\uC5D0\uAC8C \uB300\uBBF8\uC9C0\uB97C
      \uC8FC\uACE0 4\uCE78 \uB109\uBC31\uC2DC\uD0A8\uB2E4.\r\n\r\n\uB300\uBBF8\uC9C0
      : \uD14C\uD1A0\uB77C \uACF5\uACA9\uB825 {1}% + \uB9C8\uBC95 \uBC29\uC5B4\uB825
      \uBE44\uB840 \uB300\uBBF8\uC9C0 \uC99D\uAC00\r\n\r\n\uAC1C\uBC1C\uC6A9 \uB300\uBBF8\uC9C0
      \uACC4\uC0B0\uC2DD : \uD14C\uD1A0\uB77C \uACF5\uACA9\uB825*{1}(1+\uB9C8\uBC95
      \uBC29\uC5B4\uB825/{2})\r\n\r\n\uB9CC\uC57D \uBD84\uB178\uAC00 30 \uC774\uC0C1\uC778
      \uACBD\uC6B0 \uC704\uB825\uC774 2\uBC30\uB85C \uC99D\uAC00\uD569\uB2C8\uB2E4.\r\n\r\n\uAC1C\uBC1C
      \uCC38\uACE0 \uC0AC\uD56D\r\n\uD53C\uACA9\uB41C \uC801\uC774 \uC544\uAD70\uC5D0\uAC8C
      \uBD80\uB52A\uD790 \uACBD\uC6B0, \uC801\uAD70\uC740 \uCDA9\uB3CC \uC911\uC9C0
      + \uC2A4\uD134 \uC801\uC6A9\r\n\uC544\uAD70\uC5D0\uAC8C\uB294 \uB300\uBBF8\uC9C0\uC640
      \uC2A4\uD134\uC774 \uC801\uC6A9\uB418\uC9C0 \uC54A\uC74C."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298306
    m_Localized: "\uBC94\uC704 : \uBCF8\uC778\uC744 \uAE30\uC900\uC73C\uB85C  2*3
      \uBC94\uC704/3*3 \uBC94\uC704\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\uCD08\r\n\uB0AB\uC744
      \uD06C\uAC8C \uD718\uB458\uB7EC, \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825 {1}%\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC8FC\uACE0, \uC0C1\uB300\uC758 \uB4A4\uD3B8\uC73C\uB85C
      \uC774\uB3D9\uD558\uC5EC \uB113\uC740 \uBC94\uC704\uC758 \uACF5\uACA9\uC744
      \uC9C4\uD589\uD569\uB2C8\uB2E4.\r\n\uD2B9\uC218 \uD6A8\uACFC : \uD53C\uACA9\uB41C
      \uC801\uC740 {2}\uB3D9\uC548 \uACF5\uACA9 \uC18D\uB3C4\uAC00 {3}% \uAC10\uC18C\uD558\uACE0
      \uD55C\uAE30\uB97C \uC911\uCCA9 \uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298307
    m_Localized: "\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740
      \uC801\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC : \uC801\uC744
      {1}\uCD08 \uB3D9\uC548 \uAD00\uC5D0 \uAC00\uB46C \uBD09\uC778\uD55C\uB2E4.
      \uBD09\uC778\uB41C \uC801\uB3C4 \uACF5\uACA9 \uB300\uC0C1\uC73C\uB85C \uCDE8\uAE09\uB418\uBA70,
      \uBD09\uC778\uB41C \uC801\uC740 \uBD09\uC778\uB3D9\uC548 \uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774
      \uD750\uB974\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298308
    m_Localized: "\uBC94\uC704 : \uC790\uAE30 \uC911\uC2EC\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uB300\uBBF8\uC9C0 : \uC544\uB4DC\uB9AC\uC544 \uACF5\uACA9\uB825{1}%
      \uB300\uBBF8\uC9C0\uB97C \uC785\uD788\uACE0, \uBB3C\uB9AC \uBC29\uC5B4\uB825\uC5D0
      \uBE44\uB840\uD574 \uD53C\uD574\uAC00 \uC99D\uAC00\uD55C\uB2E4.\r\n\uCD94\uAC00
      \uD6A8\uACFC : \uBC94\uC704 \uB0B4\uC5D0 \uC704\uCE58\uD55C \uC801\uC740 {2}\uCD08
      \uB3D9\uC548 \uC2A4\uD134\uC5D0 \uAC78\uB9B0\uB2E4.\r\n\uAC1C\uBC1C\uC6A9 \uB300\uBBF8\uC9C0
      \uACC4\uC0B0\uC2DD : \uC544\uB4DC\uB9AC\uC544 \uACF5\uACA9\uB825*{1}*(1+\uBB3C\uB9AC
      \uBC29\uC5B4\uB825/{2})"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298309
    m_Localized: "\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801 \uAE30\uC900
      5*5 \uB2E4\uC774\uC544\uBAAC\uB4DC \uBC94\uC704\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04:
      {0}\uCD08\r\n\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 {1}%\uC758 \uB9C8\uBC95
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298310
    m_Localized: "\uBC94\uC704 : \uC804\uBC29 1\uCE78, 3\uCE78, 5\uCE78, 7\uCE78\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC : \uB113\uC740 \uBC94\uC704\uC5D0 \uB2E4\uC218\uC758
      \uCD1D\uAE30\uB97C \uAEBC\uB0B4 3\uCD08 \uB3D9\uC548 {1}\uD68C \uB09C\uC0AC\uD558\uBA70,
      \uBC94\uC704\uBCC4\uB85C \uB2E4\uB978 \uB300\uBBF8\uC9C0\uB97C \uBD80\uC5EC\uD55C\uB2E4.\r\n\uB300\uBBF8\uC9C0
      :\r\n-\uC804\uBC29 1\uCE78, 3\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA9\uB825 {2}%\uC758
      \uB300\uBBF8\uC9C0\r\n-\uC804\uBC29 5\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA9\uB825
      {3}%\uC758 \uB300\uBBF8\uC9C0\r\n-\uC804\uBC29 7\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA8\uB825
      {4}%\uC758 \uB300\uBBF8\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298311
    m_Localized: "\uB300\uC0C1 : \uAC70\uB9AC\uAC00 \uAC00\uC7A5 \uBA3C \uC801 1\uBA85
      \uAC70\uB9AC\uAC00 \uAC00\uC7A5 \uBA3C \uC801\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04:
      {0}\uCD08\n\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uAC00\uD55C\uB2E4.\n\uD2B9\uC218 \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC740
      {2} \uCE78 \uAC70\uB9AC\uB9CC\uD07C \uB109\uBC31\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298312
    m_Localized: "\uD0C0\uAC9F : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0 \uC704\uCE58\uD55C
      \uC801 \r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\uCD08\r\n\uB300\uBBF8\uC9C0
      : \uC801\uC5D0\uAC8C \uBD80\uBA54\uB791\uC744 \uB358\uC838 \uACF5\uACA9\uB825
      {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\r\n\r\n\uBD80\uBA54\uB791\uC744
      \uB9DE\uC740 \uC801 \uADFC\uCC98\uC5D0 \uB2E4\uB978 \uC801\uC774 \uC788\uC73C\uBA74,
      \uBD80\uBA54\uB791\uC774 \uADF8 \uC801\uC5D0\uAC8C \uD295\uAE34\uB2E4.\r\n\uBD80\uBA54\uB791\uC774
      \uD295\uAE38 \uB54C\uB9C8\uB2E4 \uB300\uBBF8\uC9C0\uAC00 {2}%\uC529 \uC904\uC5B4\uB4E0\uB2E4.\r\n\uBD80\uBA54\uB791\uC740
      \uCD5C\uB300 {3}\uBA85\uAE4C\uC9C0 \uACF5\uACA9\uAC00\uB2A5\uD558\uB2E4. \r\n\r\n\uCD94\uAC00
      \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801 1\uBA85\uB2F9 {4}\uCD08 \uB3D9\uC548
      \uACF5\uACA9\uC18D\uB3C4\uAC00 {5}% \uC99D\uAC00\uD55C\uB2E4. \r\n\r\n\uAC1C\uBC1C
      \uC0AC\uC774\uB4DC \uD544\uC694 \uB0B4\uC6A9 : \uD295\uAE34 \uC801\uC5D0\uAC8C
      \uB2E4\uC2DC \uD295\uAE30\uC9C0\uB294 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298313
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04:
      {0}\uCD08\r\n\uD6A8\uACFC: \uC989\uC2DC \uC5EC\uC6B0\uBD88\uC744 {1}\uAC1C
      \uB9CC\uD07C \uD68D\uB4DD\uD569\uB2C8\uB2E4. {2}\uCD08\uAC04 \uBCF4\uC720\uD55C
      \uC5EC\uC6B0\uBD88\uC758 \uAC2F\uC218\uB2F9 \uACF5\uACA9\uC18D\uB3C4\uAC00
      {3}% \uB9CC\uD07C \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298314
    m_Localized: "\uB300\uC0C1: \uCCB4\uB825\uC774 \uAC00\uC7A5 \uB0AE\uC740 \uC801\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC: {1}\uCD08 \uB3D9\uC548 \uC9C0\uC815
      \uBD88\uAC00 \uC0C1\uD0DC\uAC00 \uB418\uBA70, 3\uBA85\uC758 \uB300\uC0C1\uC5D0\uAC8C
      \uC21C\uCC28\uC801\uC73C\uB85C \uC774\uB3D9\uD558\uC5EC \uCC38\uACA9\uC744
      \uB0A0\uB9BD\uB2C8\uB2E4.  \uAC01 \uD0C0\uACA9 \uB9C8\uB2E4 \uACF5\uACA9\uB825\uC758
      {2}% \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \uCC38\uACA9\uC774 \uBAA8\uB450
      \uC644\uB8CC\uB420 \uACBD\uC6B0 \uC9C0\uC815 \uBD88\uAC00 \uC0C1\uD0DC\uAC00
      \uD574\uC9C0\uB418\uBA70 {3}\uCD08\uAC04 \uD68C\uD53C\uC728\uC774 {4}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298315
    m_Localized: "\uB300\uC0C1 : \uC544\uAD70 \uC804\uCCB4\r\n\uC7AC\uC0AC\uC6A9
      \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC : \r\n\uD070 \uBB3C\uACB0\uC744 \uC77C\uC73C\uCF1C
      \uC544\uAD70\uC744 \uC5D4\uD0A4\uC758 \uCE58\uC720\uB825 {1}% \uB9CC\uD07C
      \uCE58\uC720\uD558\uACE0, {2}\uCD08\uAC04 \uC9C0\uC18D\uB418\uB294 {3}%\uC704\uB825\uC758
      \uC9C0\uC18D \uD68C\uBCF5\uC744 \uBD80\uC5EC\uD569\uB2C8\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298316
    m_Localized: "\uBC94\uC704: \uC790\uC2E0 \uAE30\uC900 \uB2E4\uC774\uC544 \uBAA8\uC591
      5*5\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC: \uC601\uC5ED\uC5D0
      \uC788\uB294 \uC544\uAD70\uC740 \uD074\uB808\uC774\uC758 {1}% \uCE58\uC720\uB825
      \uB9CC\uD07C \uD68C\uBCF5 \uBC0F CC\uC81C\uAC70 \uD6A8\uACFC\uB97C \uC81C\uACF5\uBC1B\uB294\uB2E4.
      \r\n\uC601\uC5ED\uC5D0 \uC788\uB294 \uC801\uAD70\uC740 {2}% \uB9CC\uD07C \uD53C\uD574\uC640
      \uD68C\uBCF5\uB7C9 {3}%\uAC10\uC18C \uB514\uBC84\uD504\uB97C {4}\uCD08\uAC04
      \uBC1B\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298317
    m_Localized: "\uB300\uC0C1: \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740
      \uC801\r\n\uC7AC\uC0AC\uC6A9 \uC2DC\uAC04: {0}\uCD08\r\n\uD6A8\uACFC: \uB300\uC0C1\uC758
      \uB4A4\uB85C \uC774\uB3D9\uD558\uC5EC {1}\uD68C \uB9CC\uD07C \uACF5\uACA9\uD569\uB2C8\uB2E4.
      \uD0C0\uACA9 \uC2DC \uB9C8\uB2E4 \uB9C8\uB9AC\uC5D0\uC758 \uACF5\uACA9\uB825\uC758
      {2}% \uB9CC\uD07C \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \r\n\uB9CC\uC57D
      \uC801\uC5D0\uAC8C \uD45C\uC2DD-\uC544\uB77C\uD06C\uB124\uAC00 \uB0A8\uC544\uC788\uB2E4\uBA74
      {3}\uCD08\uAC04 \uC801\uC758 \uACF5\uACA9\uB825\uACFC \uBC29\uC5B4\uB825\uC744
      {4}%\uB9CC\uD07C \uB0AE\uCDA5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298318
    m_Localized: "\uB300\uC0C1: 3x3 \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uAC15\uD55C
      \uC801\uAD70\r\n\uD6A8\uACFC: \uBC94\uC704\uB0B4\uC5D0 {1}% \uD53C\uD574\uB97C
      \uC785\uD788\uACE0, {2}\uCD08\uAC04, \uBC29\uC5B4\uB825\uACFC \uACF5\uACA9\uC18D\uB3C4\uAC00
      {3}% \uAC10\uC18C\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298319
    m_Localized: "\uB300\uC0C1: 3x3 \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801\uAD70\r\n\uD6A8\uACFC:
      \uBC94\uC704 \uB0B4\uC5D0 {0}% \uB9CC\uD07C \uD53C\uD574\uB97C \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298320
    m_Localized: "\uB300\uC0C1: 5x5 \uC2ED\uC790 \uBC94\uC704\r\n\uD6A8\uACFC: \uBC94\uC704
      \uB0B4\uC5D0 {0}%\uB9CC\uD07C \uD53C\uD574\uB97C \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298321
    m_Localized: "\uB300\uC0C1: \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801\r\n\uD6A8\uACFC:
      {1}% \uB9CC\uD07C \uD53C\uD574\uB97C \uC989\uC2DC \uC785\uD788\uACE0, {2}\uCD08\uAC04
      {3}%\uC758 \uD53C\uD574\uB97C \uB9E4\uCD08 \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298322
    m_Localized: "\uB300\uC0C1: \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC9C1\uC120\uC758
      \uC801 -> \uC774\uB3D9\uD558\uC5EC \uACF5\uACA9\r\n\uD6A8\uACFC: \uC9C1\uC120
      3\uCE78\uC5D0 {1}% \uB9CC\uD07C \uD53C\uD574\uB97C \uC785\uD788\uACE0 {2}\uCD08\uAC04
      \uAE30\uC808 \uC0C1\uD0DC\uB85C \uB9CC\uB4E0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298323
    m_Localized: "\uC804\uC220"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298324
    m_Localized: "\uAC15\uD0C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298325
    m_Localized: "\uD3C9\uD654\uC758 \uC0C1\uC9D5"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298326
    m_Localized: "\uAC15\uD654\uD0C4"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298327
    m_Localized: "\uC57D\uC810\uAC04\uD30C"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298328
    m_Localized: "\uB530\uB4EF\uD55C \uD654\uC5FC"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298329
    m_Localized: "\uC5EC\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298330
    m_Localized: "\uBC84\uC11C\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298331
    m_Localized: "\uB0C9\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298332
    m_Localized: "\uCE58\uC720\uC758 \uBC14\uB78C"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298333
    m_Localized: "\uCCA0\uC758 \uC544\uAC00\uC528"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298334
    m_Localized: "\uB9C8\uC548 \uD3ED\uC5FC\uB8E1"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298335
    m_Localized: "\uC911\uD654\uAE30 \uBA54\uC774\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298336
    m_Localized: "\uD45C\uC801 \uC9C0\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298337
    m_Localized: "\uB9C8\uD53C\uC544 \uC544\uAC00\uC528"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298338
    m_Localized: "\uC5EC\uC6B0\uBD88"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298339
    m_Localized: "\uBC31\uC124\uC758 \uC794\uC601"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298340
    m_Localized: "\uB05D\uC5C6\uB294 \uC870\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298341
    m_Localized: "\uC6D4\uC2DD"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298342
    m_Localized: "\uD45C\uC2DD-\uC544\uB77C\uD06C\uB124"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298343
    m_Localized: "\uB300\uC0C1: 3*3\uBC94\uC704 \uB0B4 \uC544\uAD70\n\uD6A8\uACFC:
      \uBC94\uC704 \uB0B4 \uC544\uAD70 1\uBA85\uB2F9 {0}% \uB9CC\uD07C \uBB3C\uB9AC
      \uC800\uD56D\uB825 \uBC0F \uB9C8\uBC95 \uC800\uD56D\uB825\uC774 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298344
    m_Localized: "\uB300\uC0C1: \uC801 1\uC778\n\uC77C\uBC18 \uACF5\uACA9 \uC2DC
      {0}% \uD655\uB960\uB85C \uC801\uC744 2\uCE78 \uB109\uBC31 \uC2DC\uD0A4\uACE0
      {1}\uCD08 \uB3D9\uC548 {2}%\uB9CC\uD07C \uC790\uC2E0\uC758 \uBC29\uC5B4\uB825\uC744
      \uC0C1\uC2B9\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298345
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\n\uC5D0\uC2A4\uD37C \uC9C1\uC5C5
      \uC2A4\uD0AC(3x3 \uAD11\uC5ED \uACF5\uACA9) \uBC1C\uB3D9 \uC2DC, \uD53C\uACA9\uB41C
      \uC801\uB4E4\uC758 \uACF5\uACA9 \uC18D\uB3C4\uC640 \uC774\uB3D9 \uC18D\uB3C4\uB97C
      {0}\uCD08\uAC04 {1}% \uAC10\uC18C\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298346
    m_Localized: "\uBC94\uC704: \uC790\uAE30 \uC790\uC2E0\n{0}\uD68C \uD0C0\uACA9
      \uC2DC \uB9C8\uB2E4 \uB2E4\uC74C \uACF5\uACA9\uC740 \uAC15\uD654\uD0C4\uC73C\uB85C
      \uBCC0\uACBD\uB429\uB2C8\uB2E4. \n#\uAC15\uD654\uD0C4: \uBC18\uB4DC\uC2DC \uBA85\uC911,
      \uD06C\uB9AC\uD2F0\uCEEC \uD788\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298347
    m_Localized: "\uB300\uC0C1: \uACF5\uACA9 \uB300\uC0C1\n\uACF5\uACA9 \uB300\uC0C1\uC758
      \uC778\uC811\uD55C \uC140(\uADF8\uB9AC\uB4DC)\uC5D0 \uC544\uAD70(\uC801\uAD70)\uC774
      \uC5C6\uB2E4\uBA74 \uC77C\uBC18 \uACF5\uACA9\uC774 {0}% \uCD94\uAC00 \uD53C\uD574\uB97C\uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298348
    m_Localized: "\uB300\uC0C1: \uCE58\uC720 \uB300\uC0C1\n\uC720\uB2C8\uC758 \uCE58\uC720
      \uB300\uC0C1\uC758 \uACBD\uC6B0 {0}\uCD08\uAC04 \uACF5\uACA9\uB825\uC774 {1}%
      \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298349
    m_Localized: "\uBC94\uC704: \uC790\uAE30 \uC790\uC2E0\n\uC2A4\uD0AC \uC0AC\uC6A9
      \uC2DC {0}\uD68C \uC801\uC758 \uACF5\uACA9\uC744 \uBB34\uC2DC\uD558\uB294 \uBCF4\uD638\uB9C9\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298350
    m_Localized: "\uBC94\uC704: \uC790\uAE30 \uC790\uC2E0\n\uD14C\uD1A0\uB77C\uC758
      \uCCB4\uB825\uC744 {0}% \uC783\uC744 \uB54C \uB9C8\uB2E4, \uBD84\uB178\uB97C
      1 \uD68D\uB4DD\uD569\uB2C8\uB2E4. \uC774 \uACF5\uACA9\uB825 \uC99D\uAC00\uBD84\uC740
      \uCCB4\uB825\uC744 \uD68C\uBCF5\uD560 \uACBD\uC6B0 \uCDE8\uC18C \uB429\uB2C8\uB2E4.\n#\uBD84\uB178:
      \uACF5\uACA9\uB825\uC774 {1}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298351
    m_Localized: "\uBC94\uC704: \uACF5\uACA9 \uB300\uC0C1\n\uC77C\uBC18 \uACF5\uACA9
      \uC2DC \uC801\uC5D0\uAC8C [\uD55C\uAE30]\uB97C \uC911\uCCA9\uC2DC\uD0B5\uB2C8\uB2E4.\n\uD55C\uAE30\uAC00
      {0}\uD68C \uC911\uCCA9 \uC2DC \uD55C\uAE30\uB97C \uC18C\uBAA8\uD574 {1}\uCD08\uAC04
      \uBE59\uACB0 \uC0C1\uD0DC\uAC00 \uB429\uB2C8\uB2E4.\n#\uBE59\uACB0: {1}\uCD08\uAC04
      \uD589\uB3D9 \uBD88\uAC00, \uC2A4\uD0AC \uC0AC\uC6A9 \uBD88\uAC00\n#\uD55C\uAE30
      \uC9C0\uC18D\uC2DC\uAC04: \uC601\uAD6C"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298352
    m_Localized: "\uBC94\uC704: \uC544\uAD70 \uC804\uCCB4\n\uBBF8\uC0AC\uAC00 \uC77C\uBC18
      \uACF5\uACA9 \uC2DC \uBBF8\uC0AC\uC758 \uCD5C\uB300 \uCCB4\uB825\uC758 {0}%
      \uB9CC\uD07C \uC544\uAD70\uC758 \uCCB4\uB825\uC744 \uD68C\uBCF5\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298353
    m_Localized: "\uBC94\uC704: \uC790\uAE30 \uC790\uC2E0\n3*3 \uBC94\uC704\uC5D0
      \uC788\uB294 \uC801\uB4E4\uC758 \uC218\uC5D0 \uB530\uB77C \uC790\uC2E0\uC758
      \uBB3C\uB9AC/\uB9C8\uBC95 \uC800\uD56D\uB825\uC774 {0}% \uC0C1\uC2B9\uD558\uACE0,
      {1}% \uB9CC\uD07C \uCE58\uC720\uB825\uC774 \uC62C\uB77C\uAC11\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298354
    m_Localized: "\uBC94\uC704: \uC790\uAE30 \uC790\uC2E0\n\uC5D0\uC2A4\uD37C\uC758
      \uD6A8\uACFC\uB85C \uD3ED\uACA9(3*3)\uD53C\uD574\uB97C \uC785\uD78C \uB300\uC0C1\uC5D0
      \uB530\uB77C \u2018\uC5F4\uAE30\u2019\uC911\uCCA9\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4.
      \uC5F4\uAE30 \uC911\uCCA9\uC774 {0}\uD68C\uAC00 \uB418\uBA74 \uB2E4\uC74C \uACF5\uACA9\uC774
      \uAC15\uD654 \uB429\uB2C8\uB2E4.\n#\uD3ED\uC5FC: 3*3 \uBC94\uC704\uC5D0 \uBE14\uB9B0\uC5D0
      \uACF5\uACA9\uB825\uC758 {1}%\uC5D0 \uD574\uB2F9\uD558\uB294 \uD53C\uD574\uB97C
      \uC785\uD788\uACE0 {2}\uCD08\uAC04 {3}%\uC758 \uC704\uB825\uC758 \uC9C0\uC18D\uD53C\uD574\uB97C
      \uC785\uD788\uB294 \uBD88\uC9C0\uB300\uB97C \uB9CC\uB4ED\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298355
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\n\uC5D0\uC774\uD504\uB9B4\uC774
      \uACF5\uACA9\uC704\uCE58\uB97C \uC720\uC9C0\uD560\uC218\uB85D {0}\uCD08\uB2F9
      \uACF5\uACA9\uC18D\uB3C4\uAC00 {1}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4. \uC774
      \uD6A8\uACFC\uB294 \uCD5C\uB300 60%\uB97C \uB118\uAE38 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.\n\uC774\uB3D9\uD560
      \uACBD\uC6B0 \uC774 \uC99D\uAC00\uBD84\uC740 \uCC9C\uCC9C\uD788 \uD558\uB77D\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298356
    m_Localized: "\uB300\uC0C1: \uAC70\uB9AC\uAC00 \uAC00\uC7A5 \uBA3C\uC801 \uC6B0\uC120
      \uD0C0\uACA9\n\uD6A8\uACFC: \uB300\uC0C1 \uACFC\uC758 \uAC70\uB9AC\uAC00 1\uCE78\uB2F9
      \uC704\uB825\uC774 {0}% \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298357
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\n\uC790\uAE30 \uC790\uC2E0
      3*3 \uBC94\uC704\uC5D0 \uC788\uB294 \uC801\uB4E4\uC758 \uC218\uC5D0 \uB530\uB77C
      \uBCA0\uC778\uC758 \uACF5\uACA9\uB825\uC774 {0}% \uC0C1\uC2B9\uD558\uACE0,
      \uBC29\uC5B4 \uAD00\uD1B5\uB825\uC774 {1}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298358
    m_Localized: "\uB300\uC0C1: \uC790\uAE30\uC790\uC2E0\n\uC77C\uBC18\uACF5\uACA9
      \uC2DC {0}% \uD655\uB960\uB85C \uC5EC\uC6B0\uBD88\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4.
      \n\uC5EC\uC6B0\uBD88\uC758 \uAC2F\uC218 \uB2F9 {1}%\uC758 \uCD94\uAC00 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4. \n#\uC5EC\uC6B0\uBD88\uC740 \uAC1C\uBCC4 \uC9C0\uC18D\uC2DC\uAC04\uC744
      \uAC00\uC9C0\uBA70 {2}\uCD08\uAC04 \uC720\uC9C0\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298359
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\n\uD68C\uD53C\uC5D0 \uC131\uACF5\uD560
      \uACBD\uC6B0 \uD68C\uD53C\uC728\uC774{0}% \uC99D\uAC00\uD569\uB2C8\uB2E4.(\uCD5C\uB300
      {1}\uD68C \uC911\uCCA9) \uC0C1\uB300\uC758 \uACF5\uACA9\uC744 \uD68C\uD53C\uD560
      \uACBD\uC6B0 \uACF5\uACA9 \uB300\uC0C1\uC5D0\uAC8C {2}%\uC758 \uC704\uB825\uC744
      \uAC00\uC9C4 \uCC38\uACA9\uC744 \uB0A0\uB824 \uBC18\uACA9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298360
    m_Localized: "\uB300\uC0C1: \uC790\uAE30 \uC790\uC2E0\n\uC5D4\uD0A4\uAC00 \uC544\uAD70\uC744
      \uCE58\uC720\uD560 \uB54C \uB9C8\uB2E4 \u2018\uC870\uB958\u2019\uC911\uCCA9
      1 \uD68D\uB4DD(\uCD5C\uB300 {0})\n\uC911\uCCA9 1\uB2F9 \uC5D4\uD0A4\uC758 \uCE58\uC720\uB7C9\uC774
      {1}% \uC99D\uAC00\uD558\uBA70 \uC804\uD22C \uC885\uB8CC \uC2DC \uAE4C\uC9C0
      \uC720\uC9C0\uB429\uB2C8\uB2E4. \uD53C\uACA9 \uC2DC \uC870\uB958 \uC911\uCCA9\uC774
      1 \uCC28\uAC10\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298361
    m_Localized: "\uBC94\uC704: \uCE58\uC720 \uB300\uC0C1\n\uD074\uB808\uC774\uC758
      \uC77C\uBC18 \uACF5\uACA9\uC73C\uB85C \uCE58\uC720\uB41C \uC544\uAD70\uC758
      \uACF5\uACA9\uB825\uACFC \uBC29\uC5B4\uB825\uC774 {0}% \uC99D\uAC00\uD558\uBA70,
      {1}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298362
    m_Localized: "\uBC94\uC704: \uACF5\uACA9 \uB300\uC0C1\n\uB300\uC0C1\uC5D0\uAC8C
      \uD06C\uB9AC\uD2F0\uCEEC \uD788\uD2B8 \uC801\uC911 \uC2DC \uD45C\uC2DD-\uC544\uB77C\uD06C\uB124\uB97C
      \uB0A8\uAE41\uB2C8\uB2E4. \uD45C\uC2DD \uC544\uB77C\uD06C\uB124\uC758 \uC911\uCCA9\uC774
      {0}\uAC00 \uB418\uBA74 \uB300\uC0C1\uC774 {1}\uCD08\uAC04 \uAE30\uC808 \uC0C1\uD0DC\uAC00
      \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298363
    m_Localized: "\uC775\uC2A4\uD50C\uB85C\uC804"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298364
    m_Localized: "\uD504\uB9AC\uC9D5"
    m_Metadata:
      m_Items: []
  - m_Id: 3083661912298365
    m_Localized: "\uC5D0\uC5B4\uBCF8"
