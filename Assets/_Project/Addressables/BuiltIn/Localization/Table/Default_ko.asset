    m_Localized: "{0}\uBA85 : \uCD08\uC2E0\uC131\uC744 \uB354\uC6B1 \uAC00\uC18D\uC2DC\uCF1C
      \uBC29\uC5B4\uAD00\uD1B5\uB825\uC774 {1}% \uC0C1\uC2B9\uD558\uACE0, \uD06C\uB9AC\uD2F0\uCEEC
      \uC704\uB825\uC774 {2}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542946
    m_Localized: "{0}\uBA85 : \uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825 \uC911
      {1}%\uC744 \uD761\uC218\uD558\uC5EC \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4.
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC \uCD08\uC2E0\uC131 \uBAA8\uB4DC 2\uB2E8\uACC4\uC5D0
      \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542945
    m_Localized: "{0}\uBA85 : \uC131\uAD70\uC6D0\uB4E4\uC758 \uCCB4\uB825 \uC911
      {1}%\uC744 \uD761\uC218\uD558\uC5EC \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4.
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC \uCD08\uC2E0\uC131 \uBAA8\uB4DC1\uB2E8\uACC4\uC5D0
      \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542944
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542943
    m_Localized: "{0}\uBA85 : \uC804\uD22C \uD568\uC120\uC744 {1}\uCD08 \uB9C8\uB2E4
      \uBD88\uB7EC\uB0B4 \uD3EC\uACA9\uC73C\uB85C \uC804\uC7A5\uC744 \uCD08\uD1A0\uD654
      \uC2DC\uD0B5\uB2C8\uB2E4. \uD3EC\uACA9\uC758 \uC704\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758
      \uACF5\uACA9\uB825\uC5D0 {2}% \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542942
    m_Localized: "{0}\uBA85 : \uB2E4\uC591\uD55C \uD6A8\uACFC\uB97C \uC9C0\uB2CC
      \uBCF4\uAE09\uD488\uC744 {1}\uCD08 \uB9C8\uB2E4 \uD68D\uB4DD\uD569\uB2C8\uB2E4.
      \uBCF4\uAE09\uD488 \uC548\uC5D0 \uB0B4\uC6A9\uBB3C\uC740 \uBB34\uC791\uC704\uB85C
      \uACB0\uC815\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542941
    m_Localized: "{0}\uBA85 : \uC804\uC120\uC744 \uC720\uC9C0\uD558\uAE30 \uC704\uD55C
      \uB300\uC804\uCC28 \uC9C0\uB8B0\uB97C \uC804\uC7A5\uC5D0 \uC124\uCE58\uD569\uB2C8\uB2E4.
      \uC9C0\uB8B0\uC758 \uACF5\uACA9\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758
      \uACF5\uACA9\uB825\uC5D0 \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542940
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542939
    m_Localized: "{0}\uBA85 : \uC5D8\uB9AC\uD2B8\uC758 \uC790\uC874\uC2EC\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uC804\uD22C \uC2DC\uC791 \uD6C4 {1}\uCD08\uAC04 CC \uD6A8\uACFC\uC5D0 \uBA74\uC5ED\uC774\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542938
    m_Localized: "{0}\uBA85: \uADC0\uC871\uC758 \uC758\uBB34\uAC00 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uCD1D\uCCB4\uB825\uC758 {1}%\uC5D0 \uD574\uB2F9\uD558\uB294 \uC274\uB4DC\uAC00
      \uC0DD\uC131\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542937
    m_Localized: "{0}\uBA85 : \uC655\uAC00\uC758 \uB099\uC778\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uD06C\uAE30\uAC00 {1}% \uC0C1\uC2B9\uD558\uACE0 \uACF5\uACA9\uB825\uC774 {2}%
      \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542936
    m_Localized: "{0}\uBA85 : \uD06C\uB9AC\uD2F0\uCEEC \uD655\uB960{1}%, \uC704\uB825
      {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753988542935
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uD06C\uB9AC\uD2F0\uCEEC
      \uD655\uB960 \uBC0F \uC704\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
