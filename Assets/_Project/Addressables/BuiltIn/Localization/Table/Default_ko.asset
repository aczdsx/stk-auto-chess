    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688324
    m_Localized: "<color=#F75D32>\uAC00\uC7A5 \uAE34 \uC0AC\uAC70\uB9AC</color>\uB97C
      \uC9C0\uB154\uC73C\uBA70, <color=#F75D32>\uB192\uC740 \uACF5\uACA9\uB825</color>\uC73C\uB85C
      <color=#F75D32>\uAC00\uB514\uC5B8</color>\uC744 \uD6A8\uACFC\uC801\uC73C\uB85C
      \uD0C0\uACA9\uD55C\uB2E4. \uBB3C\uB9AC \uBC29\uC5B4\uAC00 \uB192\uC740 <color=#0047AB>\uD0F1\uCEE4</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
