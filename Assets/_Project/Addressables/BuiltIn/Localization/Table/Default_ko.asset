    m_Metadata:
      m_Items: []
  - m_Id: 544917196628336
    m_Localized: "\uB300\uBBF8\uC9C0 : <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC :
