      m_Items: []
  - m_Id: 415962951049637
    m_Localized: "{0} \uC2DC\uB108\uC9C0 \uBC30\uCE58 \uD6A8\uACFC"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049638
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049639
    m_Localized: "30\uCD08 \uB0B4 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049640
    m_Localized: "\uD55C \uBA85\uC758 \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB3C4
      \uC8FD\uC9C0 \uC54A\uACE0 \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049641
    m_Localized: "<b>\uACF5\uB7B51.</b> \uC2A4\uD154\uB77C \uB098\uC774\uCE20 <color=#F75D32>\uB808\uBCA8
      \uC5C5</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049642
    m_Localized: "<b>\uACF5\uB7B52.</b> \uC2A4\uD154\uB77C \uB098\uC774\uCE20 <color=#F75D32>\uC2DC\uB108\uC9C0
      \uC870\uD569</color> \uD65C\uC6A9"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049643
    m_Localized: "<b>\uACF5\uB7B53.</b> \uC2A4\uD154\uB77C \uB098\uC774\uCE20 <color=#F75D32>\uBC30\uCE58
      \uC774\uB3D9</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049644
    m_Localized: "\uAC00\uC774\uB4DC \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD55C \uD6C4
      \uC9C4\uC785\uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049645
    m_Localized: "\uAC00\uC774\uB4DC \uBBF8\uC158\uC744 \uD074\uB9AC\uC5B4 \uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049646
    m_Localized: "\uAC00\uC774\uB4DC \uBBF8\uC158 \uBAA9\uD45C \uD074\uB9AC\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049647
    m_Localized: "\uD14C\uC2A4\uD2B8 \uC885\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049648
    m_Localized: "\uD14C\uC2A4\uD2B8 \uD50C\uB808\uC774\uC5D0 \uCC38\uC5EC\uD574\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4!\n\uAC04\uB2E8\uD55C \uC124\uBB38\uC73C\uB85C
      \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB97C \uC751\uC6D0\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049649
    m_Localized: "\uC124\uBB38\uD558\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049650
    m_Localized: "\uC804\uD22C \uC778\uC6D0\uC774 \uCD5C\uB300 \uC778\uC6D0\uBCF4\uB2E4
      \uC801\uC2B5\uB2C8\uB2E4.\n\uC804\uD22C\uB97C \uC2DC\uC791\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049651
    m_Localized: "\uB2E4\uC74C \uC2A4\uD14C\uC774\uC9C0\uB85C \uC774\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049652
    m_Localized: "\uB2E4\uC74C \uCC55\uD130\uB85C \uC774\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049653
    m_Localized: "<color=#F75D32>\uD074\uB9AD</color>\uD574\uC11C \uC720\uB2DB\uC744
      \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 415962951049654
    m_Localized: "\uD558\uB2E8\uBD80 \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C
