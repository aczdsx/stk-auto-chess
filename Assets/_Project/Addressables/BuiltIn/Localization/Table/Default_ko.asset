  - m_Id: 424862957953044
    m_Localized: "\uC5D0\uC774\uD504\uB9B4"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953045
    m_Localized: "\uD558\uD2F0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953046
    m_Localized: "\uBBF8\uB178"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953047
    m_Localized: "\uBCA0\uC778"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953048
    m_Localized: "\uB8E8\uD0A4\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953049
    m_Localized: "\uC2DC\uB77C\uC720\uD0A4"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953050
    m_Localized: "\uC5D4\uD0A4"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953051
    m_Localized: "\uB77C\uD0A4\uC720"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953052
    m_Localized: "\uD074\uB808\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953053
    m_Localized: "\uB9C8\uB9AC\uC5D0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953054
    m_Localized: "\uB300\uC9C0 \uC2DC\uB108\uC9C0 \uD0F1\uCEE4 \n\uC2A4\uD0AC : \uAC19\uC740
      \uC5F4\uC758 \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uC5D0\uAC8C <color=#F75D32>\uBCF4\uD638\uB9C9</color>\uC744
      \uBD80\uC5EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953055
    m_Localized: "\uACE0\uBBFC\uD558\uB294 \uC815\uC758"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953056
    m_Localized: "\uBB3C \uC2DC\uB108\uC9C0 \uB9C8\uBC95\uC0AC \n\uC2A4\uD0AC : \uC77C\uC815
      \uBC94\uC704\uC5D0 <color=#F75D32>\uC5BC\uC74C\uC744 \uC18C\uD658\uD574</color>
      \uC801\uC744 \uACF5\uACA9. \n<color=#F75D32>\uBD88 \uC2DC\uB108\uC9C0</color>
      \uC801\uC5D0\uAC8C\uB294 \uCD94\uAC00 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953057
    m_Localized: "\uBB3C \uC2DC\uB108\uC9C0 \uC800\uACA9\uC218 \n\uC2A4\uD0AC : \uC801
      1\uBA85\uC5D0\uAC8C <color=#F75D32>\uAC15\uB825\uD55C \uC77C\uACA9</color>\uC744
      \uB0A0\uB9B0\uB2E4. \uC2A4\uD0AC\uB85C \uC801\uC744 \uCC98\uCE58\uD558\uBA74
      \n\uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774 <color=#F75D32>\uC989\uC2DC \uCD08\uAE30\uD654</color>\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953058
    m_Localized: "\uC5B4\uB460 \uC2DC\uB108\uC9C0 \uC554\uC0B4\uC790\n\uC2A4\uD0AC
      : \uC801 1\uBA85\uC5D0\uAC8C \uB300\uBBF8\uC9C0\uB97C \uC8FC\uACE0, \uC7A0\uC2DC\uB3D9\uC548
      \uCE68\uBB35 \uC0C1\uD0DC\uB97C \uBD80\uC5EC\uD55C\uB2E4. \n*\uCE68\uBB35 :
      \uC77C\uC815 \uC2DC\uAC04 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uC9C0 \uBABB\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953059
    m_Localized: "\uBD88 \uC2DC\uB108\uC9C0 \uC11C\uD3EC\uD130 \n\uC2A4\uD0AC : \uBAA8\uB4E0
      \uC544\uAD70\uC758 <color=#F75D32>\uACF5\uACA9\uB825</color>\uC744 \uC77C\uC815\uC2DC\uAC04
      \uC0C1\uC2B9\uC2DC\uD0A8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953060
    m_Localized: "\uC774\uB984\uC5C6\uB294 \uBCC4"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953061
    m_Localized: "\uB300\uC9C0\uC758 \uD30C\uAD34\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953062
    m_Localized: "\uC21C\uBC31\uC758 \uCC98\uD615\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953063
    m_Localized: "\uC548\uC2DD\uC758 \uC218\uD638\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953064
    m_Localized: "\uAC15\uCCA0\uC758 \uC758\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953065
    m_Localized: "\uBD88 \uC2DC\uB108\uC9C0 \uB9C8\uBC95\uC0AC\n\n\uC2A4\uD0AC :
      3x3 \uBC94\uC704\uC5D0 <color=#F75D32>\uBA54\uD14C\uC624 \uB808\uC774\uC800</color>\uB97C
      \uBC1C\uC0AC\uD55C\uB2E4.  \n\uB9C8\uBC95\uC740 \uBC14\uB2E5\uC744 \uBD88\uD0DC\uC6CC
      <color=#F75D32>\uCD94\uAC00 \uBD88 \uB370\uBBF8\uC9C0</color>\uB97C \uC900\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953066
    m_Localized: "\uC5B4\uB460\uC758 \uC18C\uD658\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953067
    m_Localized: "\uC640\uC77C\uB4DC \uBA54\uC774\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953068
    m_Localized: "\uCE68\uBB35\uC758 \uC800\uACA9\uC218"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953069
    m_Localized: "\uB300\uC9C0 \uC2DC\uB108\uC9C0 \uC800\uACA9\uC218 \n\uC2A4\uD0AC
      : \uC720\uD0C4 3\uBC1C\uC744 \uBC1C\uC0AC\uD574 \uC77C\uC815 \uBC94\uC704\uC758
      \uC801\uC5D0\uAC8C \uAC15\uB825\uD55C \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953070
    m_Localized: "\uD769\uB0A0\uB9AC\uB294 \uCE7C\uB0A0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953071
    m_Localized: "\uAD50\uD65C\uD55C \uC5EC\uC6B0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953072
    m_Localized: "\uCC28\uAC00\uC6B4 \uCE7C\uB0A0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953073
    m_Localized: "\uCC9C\uC7AC \uD504\uB85C\uADF8\uB798\uBA38"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953074
    m_Localized: "\uB9E4\uB4DC \uC0AC\uC774\uC5B8\uD2F0\uC2A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953075
    m_Localized: "\uACE0\uC694\uD55C \uAC10\uC2DC\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953076
    m_Localized: "\uC81C\uD074\uB9B0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953077
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uB8F8"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953078
    m_Localized: "\uBD88\uD0C0\uB294 \uC804\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953079
    m_Localized: "\uC5BC\uC5B4\uBD99\uC740 \uB3C4\uC2DC"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953080
    m_Localized: "\uC78A\uD600\uC9C4 \uC0AC\uB9C9"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953081
    m_Localized: "\uC57C\uC218\uC758 \uC232"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953082
    m_Localized: "\uB8E8\uBBF8\uB124 \uC2DC\uD2F0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953083
    m_Localized: "\uAC71\uC815\uB9C8\uC138\uC694, \uB2F9\uC2E0\uC740 \uCCB4\uD3EC\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953084
    m_Localized: "\uC694\uB9AC\uB294 \uC880 \uBABB\uD574\uB3C4, \uC5B4\uC5FF\uD55C
      \uBA54\uC774\uB4DC\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953085
    m_Localized: "\uC6D0\uCE59\uB300\uB85C \uCC98\uB9AC\uD558\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953086
    m_Localized: "\uBB50! \uB0B4 \uB9D0\uC5D0 \uBD88\uB9CC \uC788\uC5B4?!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953087
    m_Localized: "\uB098\uB294 \uC0AC\uC2E4 \uBE68\uAC04\uC0C9\uC774 \uC81C\uC77C
      \uC88B\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953088
    m_Localized: "\uB208\uC740 \uC783\uC5C8\uC9C0\uB9CC, \uAC10\uAC01\uC740 \uB354
      \uC120\uBA85\uD574\uC84C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953089
    m_Localized: "\uC9C0\uD718\uAD00\uB2D8\uC744 \uB9CC\uB098\uC11C \uB2E4\uD589\uC774\uB77C\uB294
      \uC0DD\uAC01\uC774 \uB4E4\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953090
    m_Localized: "\uAC15\uD568\uC744 \uC99D\uBA85\uD558\uB294 \uAC83\uB9CC\uD07C
      \uC758\uBBF8\uC788\uB294 \uAC74 \uC5C6\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953091
    m_Localized: "\uB450\uB835\uB2C8? \uAFC8\uC5D0\uC11C \uAE68\uC5B4\uBC84\uB9AC\uB294
      \uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953092
    m_Localized: "\uC544\uC8FC \uC870\uC6A9\uD788... \uC7A0\uAE50 \uC7A0\uB4DC\uB294
      \uAC83 \uBFD0\uC774\uB2C8\uAE50"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953093
    m_Localized: "\uD314\uC774 \uBA87 \uAC1C\uB0D0\uACE0 \uBB3C\uC73C\uC2E0\uB2E4\uBA74,
      \uC5EC\uBD84\uAE4C\uC9C0 \uD3EC\uD568\uD574 428\uAC1C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953094
    m_Localized: "\uD638\uAE30\uC2EC\uACFC \uB3C8\uB9CC \uC788\uC73C\uBA74, \uBB50\uB4E0\uC9C0
      \uAC00\uB2A5\uD558\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953095
    m_Localized: "\uB10C \uC18C\uAFC9\uB180\uC774 \uC548 \uB07C\uC6CC\uC904\uAC70\uC57C,
      \uD788\uD788!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953096
    m_Localized: "\uD6C4\uD6D7, \uAD1C\uCC2E\uC544\uC694. \uC624\uB298\uC740 \uADF8\uC800
      \uC548\uBD80\uB97C \uBB3C\uC73C\uB7EC \uC628 \uAC83 \uBFD0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953097
    m_Localized: "\uBE5B\uC774 \uAC00\uC7A5 \uD544\uC694\uD55C \uAC74 \uC5B4\uB460\uC5D0
      \uAC07\uD78C \uC774\uB4E4\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953098
    m_Localized: "\uAE30\uBD84\uC774\uB2E4, \uD2B9\uBCC4\uD788 \uB0B4\uAC00 \uB9CC\uB4E0
      \uBB34\uAE30\uB97C \uC0AC\uC6A9\uD558\uAC8C \uD574\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953099
    m_Localized: "\uBC14\uB78C\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC624\uB294\uAD70\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953100
    m_Localized: "\uB0A0 \uAE38\uB4E4\uC774\uACA0\uB2E4\uACE0? \uC7AC\uBBF8\uC788\uB294
      \uC18C\uB9AC\uB97C \uD558\uB294\uAD6C\uB098, \uAD00\uCE21\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953101
    m_Localized: "\uAE4C, \uAE5C\uC791\uC774\uC57C! \uBCC4 \uC77C\uB3C4 \uC544\uB2CC\uB370
      '\uC5B4? '\uD558\uC9C0 \uB9D0\uB780\uB9D0\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953102
    m_Localized: "\uC65C \uBB34\uC11C\uC6CC\uD558\uB294 \uAC70\uC9C0\uC774... \uC544\uC8FC
      \uC7A0\uAE50 \uB530\uB054\uD560 \uBFD0\uC778\uB370.."
    m_Metadata:
      m_Items: []
  - m_Id: 424862957953103
    m_Localized: "\uC2E0\uB150\uC774\uB780 '\uAD73\uAC8C \uBBFF\uB294 \uB9C8\uC74C'\uC774\uC9C0."
    m_Metadata:
      m_Items: []
