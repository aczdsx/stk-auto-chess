    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977589
    m_Localized: "\uC601\uC9C0 \uD655\uC7A5 \uD61C\uD0DD"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977590
    m_Localized: "\uC601\uC9C0 \uD655\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977591
    m_Localized: "\uD544\uC694\uD55C \uC5D8\uD53C\uC2A4 \uCF54\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977592
    m_Localized: "{0}\uB97C \uC0C8\uB85C \uAC74\uC124\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977593
    m_Localized: "{0}\uC758 \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD569\uB2C8\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977594
    m_Localized: "1\uCC28 \uAD6C\uC5ED\uC774 \uD65C\uC131\uD654 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977595
    m_Localized: "2\uCC28 \uAD6C\uC5ED\uC774 \uD65C\uC131\uD654 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977596
    m_Localized: "\uAC74\uC124 \uD574\uAE08"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977597
    m_Localized: "\uAC74\uC124 \uC218 \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977598
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8 \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977599
    m_Localized: "\uC601\uC9C0 \uD655\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977600
    m_Localized: "\uD130\uCE58\uD558\uC5EC \uB2EB\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977601
    m_Localized: "\uD655\uC7A5 \uB808\uBCA8 \uB2EC\uC131!"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977602
    m_Localized: "\uAE30\uC0AC \uACF5\uACA9\uB825 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977603
    m_Localized: "\uAE30\uC0AC \uBC29\uC5B4\uB825 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977604
    m_Localized: "\uAE30\uC0AC \uCCB4\uB825 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977605
    m_Localized: "\uBD88 \uC18D\uC131 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977606
    m_Localized: "\uBC14\uB78C \uC18D\uC131 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977607
    m_Localized: "\uB300\uC9C0 \uC18D\uC131 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977608
    m_Localized: "\uBC88\uAC1C \uC18D\uC131 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977609
    m_Localized: "\uBB3C \uC18D\uC131 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977610
    m_Localized: "\uB178\uBE14\uB808\uC2A4 \uC131\uAD70 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977611
    m_Localized: "\uC288\uD37C\uB178\uBC14 \uC131\uAD70 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977612
    m_Localized: "\uD2B8\uB7EC\uBE14\uC288\uD130 \uC131\uAD70 \uC5F0\uAD6C {0}\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977613
    m_Localized: "\uAE30\uC0AC \uACF5\uACA9\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977614
    m_Localized: "\uAE30\uC0AC \uBC29\uC5B4\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977615
    m_Localized: "\uAE30\uC0AC \uCCB4\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977616
    m_Localized: "\uACF5\uACA9\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977617
    m_Localized: "\uCCB4\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977618
    m_Localized: "\uBC29\uC5B4\uB825 \uC99D\uAC00 {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977619
    m_Localized: "\uAE30\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977620
    m_Localized: "\uC18D\uC131"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977621
    m_Localized: "\uC2A4\uD154\uB77C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977622
    m_Localized: "\uAC15\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977623
    m_Localized: "\uC5F0\uAD6C\uC18C \uB808\uBCA8\uC5C5 \uD544\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977624
    m_Localized: "\uAC74\uBB3C \uAC15\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977625
    m_Localized: "\uAC74\uBB3C \uAC74\uC124"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977626
    m_Localized: "\uC124\uCE58 \uC644\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977627
    m_Localized: "\uC124\uCE58 \uC911"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977628
    m_Localized: "\uC774\uC804 \uB808\uBCA8 \uC124\uCE58 \uD544\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977629
    m_Localized: "\uB2E4\uB978 \uAC74\uBB3C \uC124\uCE58 \uC911"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977630
    m_Localized: "\uD574\uAE08 \uD544\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977631
    m_Localized: "\"\uC5B4\uC11C \uC624\uC138\uC694, \uAD00\uCE21\uC790\uB2D8. \uC601\uC9C0
      \uB0B4 \uC0DD\uBA85 \uC720\uC9C0 \uC7A5\uCE58 \uBC0F \uC5D0\uD14C\uB974 \uC5D0\uB108\uC9C0
      \uD750\uB984, \uBAA8\uB450 \uC815\uC0C1\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC744
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977632
    m_Localized: "\"\uC5D8\uD53C\uC2A4\uB85C\uBD80\uD130 \uBBF8\uD655\uC778 \uB370\uC774\uD130\uAC00
      \uC218\uC2E0\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBD84\uC11D\uC744 \uC2DC\uC791\uD560\uAE4C\uC694?
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD310\uB2E8\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977633
    m_Localized: "\"\uC774 \uAD11\uD65C\uD55C \uC6B0\uC8FC\uC5D0\uC11C \uC88C\uD45C\uB97C
      \uC783\uC9C0 \uC54A\uB294 \uC720\uC77C\uD55C \uBC29\uBC95\uC740... \uBC14\uB85C
      \uB2F9\uC2E0\uC774 \uC81C \uACC1\uC5D0 \uC788\uB294 \uAC83\uC774\uACA0\uC8E0.
      \uD6C4\uD6C4, \uB18D\uB2F4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977634
    m_Localized: "\"\uCEE4\uD53C\uB77C\uB3C4 \uD55C \uC794 \uB0B4\uB824\uB4DC\uB9B4\uAE4C\uC694? 
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD734\uC2DD\uB3C4 \uC911\uC694\uD55C \uC784\uBB34\uC758
      \uC77C\uBD80\uB2C8\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977635
    m_Localized: "\"\uC800\uC758 \uCD5C\uC6B0\uC120 \uC120\uD0DD\uC0AC\uD56D\uC740
      \uC5B8\uC81C\uB098 \uAD00\uCE21\uC790\uB2D8\uC758 \uC548\uC804\uACFC \uC2B9\uB9AC\uC785\uB2C8\uB2E4.
      \uADF8\uB7EC\uB2C8 \uC548\uC2EC\uD558\uACE0 \uC9C0\uD718\uD574 \uC8FC\uC138\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977636
    m_Localized: "\"\uC624\uC168\uB098\uC694, \uAD00\uCE21\uC790\uB2D8? \uC624\uB298
      \uD6C8\uB828 \uC2A4\uCF00\uC904\uC740 \uD3C9\uC18C\uBCF4\uB2E4 1.5\uBC30 \uB354
      \uBE61\uBE61\uD558\uAC8C \uC7A1\uC544 \uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977637
    m_Localized: "\"\uB370\uC774\uD130\uB9CC \uBBFF\uB294\uB2E4\uBA74 \uC2E4\uC804\uC5D0\uC11C
      \uBB34\uB108\uC9C8 \uBFD0\uC774\uC5D0\uC694. \uB2F9\uC2E0\uC744 \uC704\uD574\uC11C
      \uB354\uB354\uC6B1 \uD558\uB4DC\uD55C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uC900\uBE44\uD574\uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977638
    m_Localized: "\"\uC6C0\uC9C1\uC784\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uB454\uD558\uB124\uC694.
      \uC544\uAE4C\uBD80\uD130 \uC800\uB97C \uD790\uB057 \uAC70\uB9AC\uC2DC\uB358\uB370
      \uD639\uC2DC......?\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977639
    m_Localized: "\"\uC2DC\uBBAC\uB808\uC774\uC158 \uC885\uB8CC. ...\uD765, \uC774\uBC88\uC5D4
      \uC81C\uBC95\uC774\uAD70\uC694. \uC544\uC8FC \uC870\uAE08\uC740, \uAD00\uCE21\uC790\uB2D8\uC744
      \uB2E4\uC2DC \uBD24\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977640
    m_Localized: "\"\uC804\uC7A5\uC740 \uC790\uBE44\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC5EC\uAE30\uC11C \uD758\uB9B0 \uB540\uBC29\uC6B8\uB9CC\uD07C\uC740
      \uB2F9\uC2E0\uC744 \uBC30\uC2E0\uD558\uC9C0 \uC54A\uC744\uAC70\uC5D0\uC694.
      \uC790, \uB2E4\uC74C \uC2DC\uBBAC\uB808\uC774\uC158\uC744 \uBC14\uB85C \uC9C4\uD589\uD574\uBCF4\uC8E0\""
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977641
    m_Localized: "\uC2A4\uD2B8\uB77C\uC774\uCEE4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977642
    m_Localized: "\uAC00\uB514\uC5B8"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977643
    m_Localized: "\uC5D0\uC2A4\uD37C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977644
    m_Localized: "\uACE0\uC2A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977645
    m_Localized: "\uC624\uB77C\uD074"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977646
    m_Localized: "\uC0E4\uD504\uC288\uD130"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977647
    m_Localized: "\uBD88"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977648
    m_Localized: "\uB300\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977649
    m_Localized: "\uBE5B"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977650
    m_Localized: "\uC5B4\uB460"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977651
    m_Localized: "\uBB3C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977652
    m_Localized: "\uBC14\uB78C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977653
    m_Localized: "\uBC88\uAC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977654
    m_Localized: "\uB178\uBE14\uB808\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977655
    m_Localized: "\uD2B8\uB7EC\uBE14\uC288\uD130"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977656
    m_Localized: "\uC288\uD37C\uB178\uBC14"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977657
    m_Localized: "\uC774\uD074\uB9BD\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977658
    m_Localized: "\uBE44\uC9C8\uB780\uD14C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977659
    m_Localized: "\uC544\uB974\uCE74\uB098"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977660
    m_Localized: "<color=#F75D32>\uB192\uC740 \uB9C8\uBC95 \uBC29\uC5B4\uB825</color>\uC73C\uB85C,
      <color=#F75D32>\uB9C8\uBC95\uC0AC</color>\uC758 \uB300\uBBF8\uC9C0\uB97C \uB0AE\uAC8C
      \uBC1B\uB294\uB2E4. \uBB3C\uB9AC \uACF5\uACA9\uC744 \uD558\uB294 <color=#0047AB>\uC800\uACA9\uC218</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977661
    m_Localized: "{0}\uBA85 : \uB9C8\uBC95 \uACF5\uACA9 \uD53C\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977662
    m_Localized: "<color=#F75D32>\uBB3C\uB9AC \uBC29\uC5B4\uB825</color>\uC774 \uB192\uC544,
      \uAC00\uB514\uC5B8\uACFC <color=#F75D32>\uC800\uACA9\uC218</color> \uACF5\uACA9\uC744
      \uD6A8\uACFC\uC801\uC73C\uB85C \uBC29\uC5B4\uD55C\uB2E4.\uB9C8\uBC95 \uACF5\uACA9\uC744
      \uD558\uB294  <color=#0047AB>\uB9C8\uBC95\uC0AC</color>\uC5D0\uAC8C \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977663
    m_Localized: "{0}\uBA85 : \uBB3C\uB9AC \uACF5\uACA9 \uD53C\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977664
    m_Localized: "<color=#F75D32>\uB9C8\uBC95 \uACF5\uACA9</color>\uC744 \uC0AC\uC6A9\uD558\uC5EC,
      <color=#F75D32>\uD0F1\uCEE4</color>\uB97C \uD6A8\uACFC\uC801\uC73C\uB85C \uD0C0\uACA9\uD55C\uB2E4.
      \uB9C8\uBC95 \uBC29\uC5B4\uAC00 \uB192\uC740 <color=#0047AB>\uAC00\uB514\uC5B8</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977665
    m_Localized: "{0}\uBA85 : \uC2A4\uD0AC \uC0AC\uC6A9 \uC2DC \uB2E4\uC74C \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977666
    m_Localized: "<color=#F75D32>\uAC00\uC7A5 \uAE34 \uC0AC\uAC70\uB9AC</color>\uB97C
      \uC9C0\uB154\uC73C\uBA70, <color=#F75D32>\uB192\uC740 \uACF5\uACA9\uB825</color>\uC73C\uB85C
      <color=#F75D32>\uAC00\uB514\uC5B8</color>\uC744 \uD6A8\uACFC\uC801\uC73C\uB85C
      \uD0C0\uACA9\uD55C\uB2E4. \uBB3C\uB9AC \uBC29\uC5B4\uAC00 \uB192\uC740 <color=#0047AB>\uD0F1\uCEE4</color>\uC5D0\uAC8C
      \uBB34\uB825\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977667
    m_Localized: "{0}\uBA85 : \uCE58\uBA85\uD0C0 \uACF5\uACA9 \uC2DC \uC2A4\uD0AC
      \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977668
    m_Localized: "<color=#F75D32>\uB192\uC740 \uACF5\uACA9 \uC18D\uB3C4</color>\uC640
      <color=#F75D32>\uC774\uB3D9\uC18D\uB3C4</color>\uB97C \uC9C0\uB154\uC73C\uBA70
      <color=#F75D32>\uC2A4\uD0AC \uCFE8\uD0C0\uC784</color>\uC774 \uC9E7\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977669
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC2DC \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      <b><color=#F75D32>{1}%</color></b> \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977670
    m_Localized: "<color=#F75D32>\uD790, \uBC84\uD504, \uB514\uBC84\uD504</color>
      \uB4F1 \uC544\uAD70 \uAC15\uD654 \uB610\uB294 \uC801\uAD70 \uC57D\uD654\uC5D0
      \uD2B9\uD654\uB41C \uD3EC\uC9C0\uC158\uC774\uB2E4. \uAE30\uBCF8 \uACF5\uACA9\uB825\uACFC
      \uCCB4\uB825\uC740 <color=#0047AB>\uB0AE\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977671
    m_Localized: "{0}\uBA85 : \uCCAB \uC2A4\uD0AC \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b>
      \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977672
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC774
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977673
    m_Localized: "{0}\uBA85 : \uACF5\uACA9\uB825 {1}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977674
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uAD00\uD1B5\uB825\uACFC
      \uBE14\uB7ED\uC728\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977675
    m_Localized: "{0}\uBA85 : \uAD00\uD1B5\uB825 {1}%, \uBE14\uB7ED\uC728 {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977676
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uC0DD\uBA85\uB825 \uBC0F
      \uBC29\uC5B4\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977677
    m_Localized: "{0}\uBA85 : \uC0DD\uBA85\uB825 {1}%, \uBC29\uC5B4\uB825 {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977678
    m_Localized: "\uBE5B \uC2DC\uB108\uC9C0 \uC2A4\uD154\uB77C \uB098\uC774\uCE20
      \uD2B9\uC815 \uC2DC\uAC04 \uB3D9\uC548 <color=#F75D32>\uBAA8\uB4E0 \uC0C1\uD0DC
      \uC774\uC0C1 \uBA74\uC5ED</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977679
    m_Localized: "{0}\uBA85 : <b><color=#F75D32>{1}\uCD08</color></b>\uB3D9\uC548
      \uBAA8\uB4E0 \uC0C1\uD0DC \uC774\uC0C1 \uBA74\uC5ED"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977680
    m_Localized: "\uC801\uAD70 <color=#F75D32>\uC2A4\uD0AC \uCFE8\uD0C0\uC784 \uAC10\uC18C
      \uC18D\uB3C4 \uAC10\uC18C </color>"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977681
    m_Localized: "{0}\uBA85 : \uC2A4\uD0AC \uCFE8\uD0C0\uC784 <b><color=#F75D32>{1}%</color></b>
      \uAC10\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977682
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uC18D\uB3C4
      \uBC0F \uD68C\uD53C\uC728\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977683
    m_Localized: "{0}\uBA85 : \uACF5\uACA9 \uC18D\uB3C4 {1}%, \uD68C\uD53C\uC728
      {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977684
    m_Localized: "{0} \uC2DC\uB108\uC9C0 \uBC30\uCE58 \uD6A8\uACFC"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977685
    m_Localized: "\uC804\uCCB4 \uAE30\uC0AC\uB4E4\uC758 \uD06C\uB9AC\uD2F0\uCEEC
      \uD655\uB960 \uBC0F \uC704\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977686
    m_Localized: "{0}\uBA85 : \uD06C\uB9AC\uD2F0\uCEEC \uD655\uB960{1}%, \uC704\uB825
      {2}% \uC99D\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977687
    m_Localized: "\uC655\uAC00\uC758 \uB099\uC778\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uD06C\uAE30\uAC00 {0}% \uC0C1\uC2B9\uD558\uACE0 \uACF5\uACA9\uB825\uC774 {1}%
      \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977688
    m_Localized: "\uADC0\uC871\uC758 \uC758\uBB34\uAC00 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uB178\uBE14\uB808\uC2A4 \uC131\uAD70\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB4E4\uC758
      \uCD1D\uCCB4\uB825\uC758 {0}%\uC5D0 \uD574\uB2F9\uD558\uB294 \uC274\uB4DC\uAC00
      \uC0DD\uC131\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977689
    m_Localized: "\uC5D8\uB9AC\uD2B8\uC758 \uC790\uC874\uC2EC\uC774 \uBC1C\uB3D9\uD569\uB2C8\uB2E4.
      \uC804\uD22C \uC2DC\uC791 \uD6C4 {0}\uCD08\uAC04 CC \uD6A8\uACFC\uC5D0 \uBA74\uC5ED\uC774\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977690
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977691
    m_Localized: "\uC804\uC120\uC744 \uC720\uC9C0\uD558\uAE30 \uC704\uD55C \uB300\uC804\uCC28
      \uC9C0\uB8B0\uB97C \uC804\uC7A5\uC5D0 \uC124\uCE58\uD569\uB2C8\uB2E4. \uC9C0\uB8B0\uC758
      \uACF5\uACA9\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825\uC5D0
      \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977692
    m_Localized: "\uB2E4\uC591\uD55C \uD6A8\uACFC\uB97C \uC9C0\uB2CC \uBCF4\uAE09\uD488\uC744
      {0}\uCD08 \uB9C8\uB2E4 \uD68D\uB4DD\uD569\uB2C8\uB2E4. \uBCF4\uAE09\uD488 \uC548\uC5D0
      \uB0B4\uC6A9\uBB3C\uC740 \uBB34\uC791\uC704\uB85C \uACB0\uC815\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977693
    m_Localized: "\uC804\uD22C \uD568\uC120\uC744 {0}\uCD08 \uB9C8\uB2E4 \uBD88\uB7EC\uB0B4
      \uD3EC\uACA9\uC73C\uB85C \uC804\uC7A5\uC744 \uCD08\uD1A0\uD654 \uC2DC\uD0B5\uB2C8\uB2E4.
      \uD3EC\uACA9\uC758 \uC704\uB825\uC740 \uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825\uC5D0
      \uBE44\uB840\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977694
    m_Localized: NONE
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977695
    m_Localized: "\uC131\uAD70\uC6D0\uB4E4\uC758 \uCCB4\uB825 \uC911 {0}%\uC744 \uD761\uC218\uD558\uC5EC
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4. \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC
      \uCD08\uC2E0\uC131 \uBAA8\uB4DC1\uB2E8\uACC4\uC5D0 \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977696
    m_Localized: "\uC131\uAD70\uC6D0\uB4E4\uC758 \uACF5\uACA9\uB825 \uC911 {0}%\uC744
      \uD761\uC218\uD558\uC5EC \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6C1\uB2C8\uB2E4.
      \uC2A4\uC2A4\uB85C \uBD88\uD0DC\uC6CC \uCD08\uC2E0\uC131 \uBAA8\uB4DC 2\uB2E8\uACC4\uC5D0
      \uB3CC\uC785\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977697
    m_Localized: "\uCD08\uC2E0\uC131\uC744 \uB354\uC6B1 \uAC00\uC18D\uC2DC\uCF1C
      \uBC29\uC5B4\uAD00\uD1B5\uB825\uC774 {0}% \uC0C1\uC2B9\uD558\uACE0, \uD06C\uB9AC\uD2F0\uCEEC
      \uC704\uB825\uC774 {1}% \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
