  - m_Id: 707502290231584
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0\uC5D0 \uC785\uC7A5\uD560 <color=#F75D32>\uD589\uB3D9\uB825</color>
      \uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231585
    m_Localized: "\uBC30\uD2C0 \uBC84\uD2BC \uC0C1\uB2E8\uC758 (+)\uB97C \uD074\uB9AD\uD574
      \n\uC9C0\uD718\uC790 \uC2A4\uD0AC\uC744 \uC7A5\uCC29\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231586
    m_Localized: "\uD074\uB9AC\uC5B4 \uC81C\uD55C \uC2DC\uAC04\uC744 \uCD08\uACFC\uD558\uC600\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231587
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0\uB97C \uD074\uB9AC\uC5B4\uD558\uC5EC,
      \uBC29\uCE58 \uBCF4\uC0C1 \uD6A8\uC728\uC774 \uC99D\uAC00\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231588
    m_Localized: "PVP \uD2F0\uCF13\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4. \uD2F0\uCF13\uC774
      \uCDA9\uC804\uB41C \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231589
    m_Localized: "\uACE8\uB4DC\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4. \uC2A4\uD14C\uC774\uC9C0\uB97C
      \uD50C\uB808\uC774\uD574 \uACE8\uB4DC\uB97C \uD68D\uB4DD\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231590
    m_Localized: "\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uC758 \uB808\uBCA8\uC744 \uCD08\uAE30\uD654\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231591
    m_Localized: "\uB9AC\uC14B \uAC00\uB2A5 \uB808\uBCA8\uC774 \uC544\uB2D9\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231592
    m_Localized: "\uC77C\uC77C \uB9AC\uC14B \uAC00\uB2A5 \uD69F\uC218\uB97C \uBAA8\uB450
      \uC18C\uC9C4\uD588\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C \uB0A0 \uD69F\uC218\uAC00
      \uC790\uB3D9 \uCDA9\uC804\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231593
    m_Localized: "\uB354 \uC774\uC0C1 \uAD6C\uB9E4\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231594
    m_Localized: "\uC2A4\uD14C\uC774\uC9C0 \uBCC4 \uAC2F\uC218\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231595
    m_Localized: "\uC774\uBBF8 \uD074\uB9AC\uC5B4\uD55C \uB358\uC804\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231596
    m_Localized: "\uC774\uC804 \uB2E8\uACC4\uB97C \uD074\uB9AC\uC5B4 \uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231597
    m_Localized: "\uB9AC\uC14B \uC544\uC774\uD15C \uB370\uC774\uD130 \uC5D0\uB7EC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231598
    m_Localized: "\uC544\uB808\uB098 \uBC29\uC5B4 \uB371 \uC124\uC815\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231599
    m_Localized: "\uC544\uC9C1 PVP \uC0C1\uB300\uB97C \uAC31\uC2E0\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231600
    m_Localized: "\uC544\uB808\uB098 \uC804\uD22C \uC2DC\uAC04\uC774 \uC885\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231601
    m_Localized: "<color=#F75D32>{0}</color> \uC644\uB8CC \uD6C4 \uC0AC\uC6A9 \uAC00\uB2A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231602
    m_Localized: "\uC9C0\uD718\uC790 \uC2A4\uD0AC <color=#F75D32>[{0}]</color>\uC774
      \uC7A5\uCC29\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231603
    m_Localized: "<color=#F75D32>{0}</color> \uCD08\uC6D4\uC744 \uC9C4\uD589\uD558\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231604
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8\uC774 \uD655\uC7A5\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231605
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C \uBC30\uCE58\uD574\uC8FC\uC138\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231606
    m_Localized: "\uBC29\uC5B4 \uB371\uC744 \uC800\uC7A5\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231607
    m_Localized: "<color=#F75D32>\uC2A4\uD154\uB77C \uB098\uC774\uCE20</color>\uC640
      <color=#F75D32>\uC9C0\uD615\uC9C0\uBB3C</color>\uC744 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231608
    m_Localized: "\uCD5C\uB300 \uB808\uBCA8\uC5D0 \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4,
      \uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB97C <color=#F75D32>\uCD08\uC6D4</color>\uC2DC\uCF1C\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231609
    m_Localized: "\uC120\uD0DD\uD55C \uC5B8\uC5B4\uB85C \uBCC0\uACBD\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?
      \n\uD655\uC778 \uBC84\uD2BC\uC744 \uD074\uB9AD\uD560 \uC2DC \uB85C\uBE44\uB85C
      \uC774\uB3D9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231610
    m_Localized: "\uD30C\uC6CC \uC5B4\uD0DD \uACE0\uAE09"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231611
    m_Localized: "\uBAAC\uC2A4\uD130 \uBC94\uC704 \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231612
    m_Localized: "\uB109\uBC31"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231613
    m_Localized: "\uC2A4\uD134"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231614
    m_Localized: "\uD06C\uB85C\uC2A4 \uD30C\uC774\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231615
    m_Localized: "\uC800\uACA9\uC218 \uD30C\uC6CC \uC5B4\uD0DD"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231616
    m_Localized: "\uC800\uACA9\uC218 \uAD00\uD1B5\uC0F7"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231617
    m_Localized: "\uC11C\uD3EC\uD130 \uD790"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231618
    m_Localized: "\uD06C\uB85C\uC2A4 \uC544\uC774\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231619
    m_Localized: "\uBCF4\uC2A4 \uD0F1\uCEE4 \uBC94\uC704 \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231620
    m_Localized: "\uD30C\uC6CC \uC5B4\uD0DD \uC554\uC0B4\uC790 \uBC84\uC804"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231621
    m_Localized: "\uC544\uC2A4\uD2B8\uB784 \uC6E8\uC774\uBE0C"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231622
    m_Localized: "\uD504\uB85C\uC98C \uC2AC\uB798\uC2DC"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231623
    m_Localized: "\uAC00\uB4DC \uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231624
    m_Localized: "\uC544\uC774\uC2A4 \uC2A4\uD53C\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231625
    m_Localized: "\uC778\uD398\uB974\uB178"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231626
    m_Localized: "\uAC74 \uC2A4\uD2B8\uB77C\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231627
    m_Localized: "\uB85D \uC628"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231628
    m_Localized: "\uC0AC\uC77C\uB7F0\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231629
    m_Localized: "\uD50C\uB808\uC784 \uBE0C\uB808\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231630
    m_Localized: "\uD30C\uC6CC \uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231631
    m_Localized: "\uC5D1\uC140 \uBD80\uC2A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231632
    m_Localized: "\uC2A4\uD2B8\uB808\uC774 \uBD88\uB9BF!"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231633
    m_Localized: "\uC5B4\uC2A4\uD018\uC774\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231634
    m_Localized: "\uD574\uBA38 \uC0F7!"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231635
    m_Localized: "\uD640\uB9AC \uC530"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231636
    m_Localized: "\uADF8\uB77C\uC6B4\uB4DC \uC2AC\uB7A8"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231637
    m_Localized: "\uC368\uBAAC \uB808\uBE57"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231638
    m_Localized: "\uBD88\uB9BF \uD0C0\uC784"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231639
    m_Localized: "\uC708\uB4DC \uBE14\uB808\uC774\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231640
    m_Localized: "\uD3EC\uC774\uC98C \uBC24"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231641
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD55C \uC77C\uACA9\uC744 \uAC00\uD574
      <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801  \uC911\uC2EC
      \uC804\uBC29 3x1"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231642
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD55C \uC77C\uACA9\uC744 \uAC00\uD574
      <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : \uB4A4\uB85C <b><color=#F75D32>1\uCE78
      \uB109\uBC31</color></b> \uC2DC\uD0A8\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231643
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD55C \uC77C\uACA9\uC744 \uAC00\uD574
      <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : <b><color=#F75D32>{1}\uCD08 \uB3D9\uC548
      \uC2A4\uD134</color></b>\uC2DC\uD0A8\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4
      \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231644
    m_Localized: "\uB300\uBBF8\uC9C0 : \uBD88\uC744 \uC18C\uD658\uD574 <b><color=#F75D32>\uACF5\uACA9\uB825
      {0}%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\n\uBC94\uC704
      : \uC801\uC774 \uC704\uCE58\uD55C \uCE78 \uC911\uC2EC \uC2ED\uC790\uAC00 \uBC94\uC704
      \n\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231645
    m_Localized: "\uB300\uBBF8\uC9C0 : <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC785\uD78C\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231646
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAD00\uD1B5\uD558\uB294 \uB808\uC774\uC800
      \uBC1C\uC0AC\uD574 <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\n\uBC94\uC704 : \uC804\uBC29 \uC77C\uC9C1\uC120
      (\uD604\uC7AC \uC704\uCE58\uC5D0\uC11C \uC989\uBC1C)"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231647
    m_Localized: "\uD6A8\uACFC : \uCCB4\uB825\uC744 <b><color=#F75D32>\uACF5\uACA9\uB825
      {0}%\uB9CC\uD07C \uD68C\uBCF5</color></b>\uC2DC\uD0A8\uB2E4. \n\uB300\uC0C1
      : \uC544\uAD70 \uC804\uCCB4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231648
    m_Localized: "\uB300\uBBF8\uC9C0 : <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758
      \uB9C8\uBC95 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231649
    m_Localized: "\uB300\uBBF8\uC9C0 : <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC :
      \uD53C\uACA9\uB41C \uC801\uC740 <b><color=#F75D32>{1}\uCD08 \uB3D9\uC548 \uC9E7\uC740
      \uC2A4\uD134</color></b>\uC5D0 \uAC78\uB9B0\uB2E4. \n\uBC94\uC704 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801 \uC911\uC2EC 3x3 \uBC94\uC704"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231650
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD55C \uC77C\uACA9\uC744 \uAC00\uD574
      <b><color=#F75D32>\uACF5\uACA9\uB825 {0}%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231651
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC80\uAE30\uB97C \uB0A0\uB824, \uC801\uC5D0\uAC8C
      \uACF5\uACA9\uB825 <b><color=#F75D32>500%</color></b>\uC758 \n\uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : \uAC80\uAE30\uB294 \uB9F5 \uB05D\uAE4C\uC9C0
      \uC774\uB3D9\uD55C\uB2E4. \n\uBC94\uC704 : \uC804\uBC29 X\uCD95 3\uCE78"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231652
    m_Localized: "\uB300\uBBF8\uC9C0 : \uB0AB\uC744 \uD06C\uAC8C \uD718\uB458\uB7EC,
      \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825 <b><color=#F75D32>500%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : \uD53C\uACA9\uB41C
      \uC801\uC740 <b><color=#F75D32>3\uCD08</color></b> \uB3D9\uC548 \n\uACF5\uACA9
      \uC18D\uB3C4\uAC00 <b><color=#F75D32>50% \uAC10\uC18C</color></b>\uD55C\uB2E4.
      \n\uBC94\uC704 : \uC804\uBC29 X\uCD95 3\uCE78"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231653
    m_Localized: "\uD6A8\uACFC : \uC544\uAD70\uC5D0\uAC8C <b><color=#F75D32>4\uCD08</color></b>
      \uB3D9\uC548 \uBA58\uC0E4 \uACF5\uACA9\uB825 <b><color=#F75D32>1000%</color></b>\uC758
      \uC2E4\uB4DC\uB97C \uBD80\uC5EC\uD55C\uB2E4. \n\uBC94\uC704 : \uBA58\uC0E4\uC640
      \uB3D9\uC77C\uD55C \uC5F4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231654
    m_Localized: "\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 <b><color=#F75D32>300%</color></b>\uC758
      \uB9C8\uBC95 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC
      : \uBD88 \uC2DC\uB108\uC9C0 \uC801\uC5D0\uAC8C\uB294 \uC2A4\uD0AC \uACF5\uACA9\uB825\uC774
      <b><color=#F75D32>150% \uC99D\uAC00</color></b>\uD55C\uB2E4. \n\uB300\uC0C1
      : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231655
    m_Localized: "\uB300\uBBF8\uC9C0 : \uD654\uC5FC \uBE54\uC744 \uC18C\uD658\uD574,
      \uACF5\uACA9\uB825 <b><color=#F75D32>350%</color></b>\uC758 \n\uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC : \uACF5\uACA9 \uBC94\uC704\uC5D0
      \uC794\uC5F4\uC774 \uB0A8\uC544, <b><color=#F75D32>2\uCD08</color></b> \uB3D9\uC548
      \n\uCD08\uB2F9 <b><color=#F75D32>75%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC801 \uC911\uC2EC
      3x3"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231656
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC0F7\uAC74\uC744 \uBC1C\uC0AC\uD574 \uD544\uB9AC\uC544
      \uACF5\uACA9\uB825 <b><color=#F75D32>400%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uAC00\uD55C\uB2E4.\n\uD2B9\uC218 \uD6A8\uACFC : \uC2A4\uD0AC\uB85C \uC801\uC744
      \uC0AC\uB9DD \uC2DC\uCF30\uC744 \uC2DC, \n\uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774
      \uC989\uC2DC \uCD08\uAE30\uD654\uB41C\uB2E4. \n\uB300\uC0C1 : \uAC00\uC7A5
      \uAC00\uAE4C\uC6B4 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231657
    m_Localized: "\uB300\uBBF8\uC9C0 : \uACF5\uACA9\uB825 <b><color=#F75D32>850%</color></b>\uC758
      \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4. \n\uD2B9\uC218 \uD6A8\uACFC :
      \uD53C\uACA9\uB41C \uC801\uC740 \uB450 \uCE78 \uAC70\uB9AC\uB9CC\uD07C \n<b><color=#F75D32>\uB109\uBC31</color></b>\uB41C\uB2E4.
      \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740 \uC801
      1\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231658
    m_Localized: "\uB300\uBBF8\uC9C0 : \uAC15\uD558\uAC8C \uBCA0\uC5B4 \uACF5\uACA9\uB825
      <b><color=#F75D32>250%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uAC00\uD55C\uB2E4.
      \n\uD2B9\uC218 \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC740 <b><color=#F75D32>3\uCD08
      \uB3D9\uC548 \uCE68\uBB35 \uB514\uBC84\uD504</color></b>\uC5D0 \uAC78\uB9AC\uAC8C
      \uD55C\uB2E4. \n<color=#77889A><b><color=#F75D32>*</color></b>\uCE68\uBB35
      : \uC2A4\uD0AC \uC0AC\uC6A9 \uBD88\uAC00\uB2A5, \uC2A4\uD0AC \uCFE8\uD0C0\uC784
      \uAC10\uC18C \uC815\uC9C0</color>\n\uB300\uC0C1 : \uAC00\uC7A5 \uAC00\uAE4C\uC6B4
      \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231659
    m_Localized: "\uB300\uBBF8\uC9C0 : \uBD88\uAE38\uC744 \uC18C\uD658\uD574 \uACF5\uACA9\uB825
      <b><color=#F75D32>450%</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4.\n\uD2B9\uC218
      \uD6A8\uACFC : \uD53C\uACA9\uB41C \uC801\uC5D0\uAC8C \uBCF4\uD638\uB9C9\uC774
      \uC788\uC744 \uACBD\uC6B0, \n\uBCF4\uD638\uB9C9\uC774 \uC989\uC2DC \uD30C\uAD34\uB41C\uB2E4.
      \n\uBC94\uC704 : \uB8E8\uD0A4\uB2E4 \uC911\uC2EC 3x3"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231660
    m_Localized: "\uD6A8\uACFC : \uACF5\uACA9\uB825\uC744 <b><color=#F75D32>3\uCD08</color></b>
      \uB3D9\uC548 <b><color=#F75D32>30%</color></b> \uC99D\uAC00\uC2DC\uD0A8\uB2E4.
      \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774 \uAC00\uC7A5 \uB192\uC740 \uC544\uAD70
      2\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231661
    m_Localized: "\uD6A8\uACFC : \uC544\uAD70 \uC804\uCCB4\uC758 \uCCB4\uB825\uC744
      \uC5D4\uD0A4 \uACF5\uACA9\uB825 <b><color=#F75D32>500%</color></b>\uB9CC\uD07C
      \uD68C\uBCF5\uC2DC\uD0A4\uACE0 \n<b><color=#F75D32>2\uCD08</color></b> \uB3D9\uC548
      \uACF5\uACA9 \uC18D\uB3C4\uB97C <b><color=#F75D32>40%</color></b> \uB9CC\uD07C
      \uC99D\uAC00\uC2DC\uD0A8\uB2E4. \n\uB300\uC0C1 : \uC544\uAD70 \uC804\uCCB4"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231662
    m_Localized: "\uB300\uBBF8\uC9C0 : \uD14C\uD1A0\uB77C \uACF5\uACA9\uB825 <color=#F75D32>500%</color>
      + \uB9C8\uBC95 \uBC29\uC5B4\uB825 \uBE44\uB840 \uB300\uBBF8\uC9C0 \uC99D\uAC00\n\uD6A8\uACFC
      : \uB300\uAC80\uC744 \uD718\uB458\uB7EC \uC801 1\uBA85\uC5D0\uAC8C \uB300\uBBF8\uC9C0\uB97C
      \uC8FC\uACE0 <color=#F75D32>4\uCE78</color> \uB109\uBC31\uC2DC\uD0A8\uB2E4.\n\n\uD2B9\uC218
      \uD6A8\uACFC : \uB109\uBC31\uB41C \uC801\uC774 \uAD6C\uC870\uBB3C \uB610\uB294
      \uB2E4\uB978 \uB300\uC0C1\uC5D0 \uBD80\uB52A\uD790 \uC2DC, 3*3\uBC94\uC704\uB85C
      <color=#F75D32>1.5\uCD08</color> \uB3D9\uC548 \uC2A4\uD134\uC744 \uC77C\uC73C\uD0A4\uBA70\n\uACF5\uACA9\uB825
      <color=#F75D32>200%</color>+\uB9C8\uBC95 \uBC29\uC5B4\uB825 \uBE44\uB840 \uCD94\uAC00
      \uB300\uBBF8\uC9C0\uB97C \uC900\uB2E4. \n\n\uBC94\uC704 : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0
      \uC704\uCE58\uD55C \uC801 1\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231663
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC801\uC5D0\uAC8C \uC720\uD0C4\uC744 \uBC1C\uC0AC\uD574
      \uACF5\uACA9\uB825 <color=#F75D32>250%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \uC720\uD0C4\uC744 \uC801\uC744 \uD0C0\uAC9F\uD55C \uD6C4 \uD3ED\uBC1C\uD574
      \uC8FC\uBCC0\uC5D0 <color=#F75D32>150%</color>\uC758 \uCD94\uAC00 \uD53C\uD574\uB97C
      \uC900\uB2E4. \n\uD0C0\uAC9F : \uD604\uC7AC \uCCB4\uB825\uC774 \uBE44\uC728\uC774
      \uAC00\uC7A5 \uB0AE\uC740 \uC21C\uC704\uB85C \uC801 3\uBA85"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231664
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC8FC\uBCC0 \uC801\uC5D0\uAC8C \uACF5\uACA9\uB825
      <color=#F75D32>250%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC8FC\uBA70 \uC2ED\uC790
      \uBC94\uC704 \uBC14\uAE65 \uBC29\uD5A5\uC73C\uB85C \uB109\uBC31 \uC2DC\uD0A8\uB2E4.
      \n\uD6A8\uACFC : <color=#F75D32>4\uCD08</color> \uB3D9\uC548 \uC790\uAE30\uC5D0\uAC8C
      <color=#F75D32>50%</color>\uC758 \uBC29\uC5B4\uB825 \uC99D\uAC00 \uBC84\uD504\uB97C
      \uAC74\uB2E4. \n\uCD94\uAC00 \uD6A8\uACFC : \uBC14\uB78C \uC2DC\uB108\uC9C0
      \uBC30\uCE58 \uC778\uC6D0 1\uBA85\uB2F9 \uBB3C\uB9AC \uBC29\uC5B4\uB825 <color=#F75D32>25%</color>
      \uCD94\uAC00 \uC99D\uAC00\n(\uCD5C\uB300 3\uBA85\uAE4C\uC9C0\uB9CC \uC801\uC6A9)
      \n\n\uBC94\uC704 : \uC790\uAE30 \uC911\uC2EC \uC2ED\uC790 \uBC94\uC704"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231665
    m_Localized: "\uD6A8\uACFC : \uC801\uC744 <color=#F75D32>3\uCD08</color> \uB3D9\uC548
      \uAD00\uC5D0 \uAC00\uB46C \uBD09\uC778\uD55C\uB2E4. \uBD09\uC778\uB41C \uC801\uB3C4
      \uACF5\uACA9 \uB300\uC0C1\uC73C\uB85C \uCDE8\uAE09\uB418\uBA70, \uBD09\uC778\uB41C
      \uC801\uC740 \uBD09\uC778\uB3D9\uC548 \uC2A4\uD0AC \uCFE8\uD0C0\uC784\uC774
      \uD750\uB974\uC9C0 \uC54A\uB294\uB2E4. \n\uB300\uC0C1 : \uACF5\uACA9\uB825\uC774
      \uAC00\uC7A5 \uB192\uC740 \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231666
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC544\uB4DC\uB9AC\uC544 \uACF5\uACA9\uB825<color=#F75D32>500%</color>
      \uB300\uBBF8\uC9C0\uB97C \uC785\uD788\uACE0, <color=#F75D32>\uBB3C\uB9AC \uBC29\uC5B4\uB825</color>\uC5D0
      \uBE44\uB840\uD574 \uD53C\uD574\uAC00 \uC99D\uAC00\uD55C\uB2E4. \n\uCD94\uAC00
      \uD6A8\uACFC : \uBC94\uC704 \uB0B4\uC5D0 \uC704\uCE58\uD55C \uC801\uC740 <color=#F75D32>1\uCD08</color>
      \uB3D9\uC548 \uC2A4\uD134\uC5D0 \uAC78\uB9B0\uB2E4.\n\uBC94\uC704 : \uC790\uAE30
      \uC911\uC2EC"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231667
    m_Localized: "\uD6A8\uACFC : \uACF0\uC744 {0}\uCD08 \uB3D9\uC548 \uC18C\uD658\uD55C\uB2E4,
      \uC18C\uD658 \uC2DC \uACF0 \uC911\uC2EC 3*3\uBC94\uC704\uC5D0 \uD53C\uD540
      \uACF5\uACA9\uB825 {1}%\uC758 \uB300\uBBF8\uC9C0\uB97C\uC900\uB2E4. \uC18C\uD658\uB41C
      \uACF0\uC740 3*3\uBC94\uC704\uB85C {0}\uCD08 \uB3D9\uC548 \uC720\uC9C0\uB418\uB294
      \uB3C4\uBC1C\uC744 \uC2DC\uC804\uD55C\uB2E4. \n\uACF0 \uC2A4\uD0EF : \uD53C\uD540
      \uCCB4\uB825\uC758 200%, \uD53C\uD540 \uACF5\uACA9\uB825\uC758 70%, \uADF8
      \uC678 \uC2A4\uD0EF\uC740 \uD53C\uD540\uACFC \uB3D9\uC77C \n\uB300\uC0C1 :
      \uD53C\uD540\uC774 \uACF5\uACA9 \uC911\uC778 \uB300\uC0C1 \uC8FC\uBCC0"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231668
    m_Localized: "\uBC94\uC704 : \uC804\uBC29 1\uCE78, 3\uCE78, 5\uCE78, 7\uCE78
      \n\uD6A8\uACFC : \uB113\uC740 \uBC94\uC704\uC5D0 \uB2E4\uC218\uC758 \uCD1D\uAE30\uB97C
      \uAEBC\uB0B4 <color=#F75D32>3\uCD08</color> \uB3D9\uC548 <color=#F75D32>10\uD68C</color>
      \uD0C0\uACA9\uD558\uBA70, \uBC94\uC704\uBCC4\uB85C \uB2E4\uB978 \uB300\uBBF8\uC9C0\uB97C
      \uBD80\uC5EC\uD55C\uB2E4. \n\uB300\uBBF8\uC9C0 : \n-\uC804\uBC29 1\uCE78, 3\uCE78\uC740
      \uD68C\uB2F9 \uACF5\uACA9\uB825 <color=#F75D32>900%</color>\uC758 \uB300\uBBF8\uC9C0\n-\uC804\uBC29
      5\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA9\uB825 <color=#F75D32>700%</color>\uC758
      \uB300\uBBF8\uC9C0 \n-\uC804\uBC29 7\uCE78\uC740 \uD68C\uB2F9 \uACF5\uACA8\uB825
      <color=#F75D32>500%</color>\uC758 \uB300\uBBF8\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231669
    m_Localized: "\uB300\uBBF8\uC9C0 : \uC801\uC5D0\uAC8C \uBD80\uBA54\uB791\uC744
      \uB358\uC838 \uACF5\uACA9\uB825 <color=#F75D32>300%</color>\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC900\uB2E4. \n\uBD80\uBA54\uB791\uC744 \uB9DE\uC740 \uC801 \uADFC\uCC98\uC5D0
      \uB2E4\uB978 \uC801\uC774 \uC788\uC73C\uBA74, \uBD80\uBA54\uB791\uC774 \uADF8
      \uC801\uC5D0\uAC8C \uD295\uAE34\uB2E4. \n\uBD80\uBA54\uB791\uC774 \uD295\uAE38
      \uB54C\uB9C8\uB2E4 \uB300\uBBF8\uC9C0\uAC00 <color=#F75D32>50%</color>\uC529
      \uC904\uC5B4\uB4E0\uB2E4. \n\uBD80\uBA54\uB791\uC740 \uCD5C\uB300 <color=#F75D32>5\uBA85</color>\uAE4C\uC9C0
      \uACF5\uACA9\uAC00\uB2A5\uD558\uB2E4. \n\uCD94\uAC00 \uD6A8\uACFC : \uD53C\uACA9\uB41C
      \uC801 1\uBA85\uB2F9 2\uCD08 \uB3D9\uC548 \uACF5\uACA9\uC18D\uB3C4\uAC00 <color=#F75D32>10%</color>
      \uC99D\uAC00\uD55C\uB2E4. \n\uD0C0\uAC9F : \uAC00\uC7A5 \uAC00\uAE4C\uC774\uC5D0
      \uC704\uCE58\uD55C \uC801"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231670
    m_Localized: "\uD6A8\uACFC : \uC57D\uBCD1\uC744 \uD22C\uD558\uD574 <color=#F75D32>3\uCD08</color>
      \uB3D9\uC548 \uBC94\uC704 \uB0B4\uC5D0 \uC704\uCE58\uD55C \uC801\uAD70\uC758
      \uCE58\uC720 \uD6A8\uACFC\uB97C <color=#F75D32>60%</color>, \n\uBB3C\uB9AC
      \uBC29\uC5B4\uB825\uC744 <color=#F75D32>80%</color> \uAC10\uC18C\uC2DC\uD0A8\uB2E4.\n\uB300\uC0C1
      : \uBB3C\uB9AC \uB610\uB294 \uB9C8\uBC95 \uBC29\uC5B4\uB825\uC774 \uAC00\uC7A5
      \uB192\uC740 \uC801\uC758 3*3 \uBC94\uC704"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231671
    m_Localized: "\uC775\uC2A4\uD50C\uB85C\uC804"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231672
    m_Localized: "\uD504\uB9AC\uC9D5"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231673
    m_Localized: "\uC5D0\uC5B4\uBCF8"
    m_Metadata:
      m_Items: []
  - m_Id: 707502290231674
    m_Localized: "\uB77C\uC774\uD504 \uD790"
