  - m_Id: 3324053790580740
    m_Localized: "\uBAAC\uC2A4\uD130\uC704\uC2A4\uD504\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319482586587137
    m_Localized: "\uACFC\uB3C4\uD55C \uB370\uC774\uD130 \uC0AC\uC6A9\uC744 \uB9C9\uAE30
      \uC704\uD574\nWIFI \uD658\uACBD\uC5D0\uC11C \uB2E4\uC6B4\uB85C\uB4DC\uB97C
      \uAD8C\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319482586587136
    m_Localized: "\uB370\uC774\uD130 \uB2E4\uC6B4\uB85C\uB4DC\uB97C \uC9C4\uD589\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124098
    m_Localized: "\uC774\uB9AC\uC640, \uD53C\uCF54. \uC5EC\uD589\uC744 \uC2DC\uC791\uD558\uC790!
      \uC800 \uB4DC\uB113\uC740 \uD558\uB298 \uB05D\uAE4C\uC9C0 \uD568\uAED8 \uB0A0\uC544\uAC00\uB294
      \uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124099
    m_Localized: "\uBB50\uC57C, \uADF8 \uB208\uBE5B\uC740? \uD0A4 \uC791\uB2E4\uACE0
      \uB180\uB9AC\uBA74 \uC7AC\uBBF8\uC5C6\uC744 \uC904 \uC54C\uC544! \uB0B4\uAC00
      \uC5BC\uB9C8\uB098 \uB300\uB2E8\uD55C\uC9C0 \uB611\uB611\uD788 \uBCF4\uC5EC\uC904
      \uD14C\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124100
    m_Localized: "\uB098\uC544\uAC00\uB294 \uB370 \uD544\uC694\uD55C \uAC74 \uC6A9\uAE30
      \uD55C \uC2A4\uD47C! \uC790, \uC800\uB791 \uAC19\uC774 \uC6B4\uB3D9\uD558\uB7EC
      \uAC00\uC2E4\uB798\uC694? \uBAB8\uC774 \uADFC\uC9C8\uAC70\uB9B0\uB2E4\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124101
    m_Localized: "M.A.I.D \uC131\uB2E8\uC758 \uBA54\uC774\uC785\uB2C8\uB2E4. \uC2DD\uC0AC\uB294
      \uC81C\uAC8C... \uC5B4\uBA38, \uC65C \uB2E4\uB4E4 \uB3C4\uB9DD\uAC00\uC2DC\uC8E0?
      \uADF8\uB7FC \uC77C\uB2E8 \uC548\uC544\uB4DC\uB9B4\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124102
    m_Localized: "\uB208\uC740 \uC783\uC5C8\uC9C0\uB9CC, \uAC10\uAC01\uC740 \uB9C8\uC74C\uC758
      \uB208\uC73C\uB85C \uBCF4\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124103
    m_Localized: "\uBAA8\uB450\uB97C \uC9C0\uD0A4\uB294 \uBC29\uD328\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4.
      \uC81C \uB4A4\uC5D0 \uC228\uC73C\uC2ED\uC2DC\uC624, \uB2F9\uC2E0\uC5D0\uAC8C\uB294
      \uC190\uAC00\uB77D \uD558\uB098 \uB300\uC9C0 \uBABB\uD558\uAC8C \uD560 \uD14C\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124104
    m_Localized: "\uAD00\uCE21\uC790\uB2D8\uACFC \uD568\uAED8\uB77C\uBA74 \uC5B4\uB514\uB77C\uB3C4
      \uAC08 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124105
    m_Localized: "\uC9C0\uD0A4\uC9C0 \uBABB\uD560 \uC57D\uC18D\uC740 \uD558\uC9C0
      \uC54A\uB294 \uD3B8\uC774 \uB0AB\uC2B5\uB2C8\uB2E4. ...\uD558\uC9C0\uB9CC \uB2F9\uC2E0\uC774\uB77C\uBA74,
      \uD55C\uBC88 \uBBFF\uC5B4\uBD10\uB3C4 \uAD1C\uCC2E\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uAD70\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124106
    m_Localized: "\uC88B\uC740 \uC544\uCE68\uC774\uC5D0\uC694, \uAD00\uCE21\uC790\uB2D8!
      \uC624\uB298\uB3C4 \uBAA8\uB450\uAC00 \uC0AC\uB791\uD558\uB294 \uC568\uB9AC\uC2A4\uAC00
      \uB418\uC5B4 \uB2F9\uC2E0 \uACC1\uC744 \uC9C0\uCF1C \uB4DC\uB9B4\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124107
    m_Localized: "\uB10C \uC18C\uAFC9\uB180\uC774 \uC548 \uB07C\uC6CC\uC904\uAC70\uC57C,
      \uD788\uD788!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124108
    m_Localized: "\uB0B4\uAC8C \uB2E4\uAC00\uC624\uC9C0\uB9C8... \uC0C1\uCC98\uC785\uC744
      \uBFD0\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124109
    m_Localized: "\uC774\uBD10~ \uC9C4\uC815\uD55C \uD0D0\uD5D8\uAC00\uAC00 \uC5EC\uAE30\uC5D0
      \uB3C4\uB798\uD588\uB2E4! \uD06D... \uB0B4 \uC624\uB978\uCABD \uB208\uC774
      \uB610 \uC6B1\uC2E0\uAC70\uB9AC\uB294\uAD70. \uBAA8\uD5D8\uC774 \uB0A0 \uBD80\uB974\uACE0
      \uC788\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124110
    m_Localized: "\uB0A0 \uCC3E\uC558\uB2E4\uACE0? \uC218\uB2F9\uC740 \uD655\uC2E4\uD788
      \uC900\uBE44\uD588\uACA0\uC9C0! \uC785\uAE08\uB9CC \uD655\uC778\uB418\uBA74,
      \uB124 \uBAA9\uC228\uB3C4 \uD655\uC2E4\uD558\uAC8C \uC9C0\uCF1C\uC904\uAC8C~"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124111
    m_Localized: "\uC800\uAE30... \uAD00\uCE21\uC790\uB2D8\uC744 \uBB3B\uC73C\uB824\uB294
      \uAC8C \uC544\uB2C8\uC5D0\uC694... \uADF8\uC800, \uB2F9\uC2E0\uC774 \uD3B8\uC548\uD560
      \uC218 \uC788\uB3C4\uB85D \uB05D\uAE4C\uC9C0 \uACC1\uC744 \uC9C0\uD0A4\uACE0
      \uC2F6\uC744 \uBFD0\uC774\uB78D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124112
    m_Localized: "\uD6C4\uD6D7. \uAD00\uCE21\uC790\uB2D8. \uD64D\uCC28 \uD55C \uC794
      \uD558\uC2DC\uACA0\uC5B4\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124113
    m_Localized: "\uD604\uC0C1, \uACFC\uC815, \uACB0\uACFC... \uB0B4\uAC90 \uADF8\uAC83\uBFD0\uC774\uC57C.
      \uD750\uC74C, \uB108 \uAF64 \uC88B\uC740 \uC2E4\uD5D8\uCCB4\uAC00 \uB420 \uAC83
      \uAC19\uC740 \uB0C4\uC0C8\uAC00 \uB098\uB294\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124114
    m_Localized: "\uAD00\uCE21\uC790, \uB9E5\uC8FC \uD55C\uC794 \uD558\uC9C0 \uC54A\uACA0\uC5B4?
      \uC77C \uB05D\uB098\uACE0 \uB9C8\uC2DC\uB294 \uC220\uB9DB\uC740 \uAC01\uBCC4\uD558\uAC70\uB4E0.
      \uC544, \uC548\uC8FC\uB294 \uB0B4\uAC00 \uC3DC\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124115
    m_Localized: "\uAC15\uD568\uC744 \uC99D\uBA85\uD558\uB294 \uAC83\uB9CC\uD07C
      \uC758\uBBF8\uC788\uB294 \uAC74 \uC5C6\uC9C0!  \uAD00\uCE21\uC790. \uB098\uB791
      \uD55C \uD310 \uBD99\uC9C0 \uC54A\uACA0\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124116
    m_Localized: "\uC99D\uBA85\uC744 \uD558\uC9C0 \uBABB\uD55C\uB2E4\uBA74 \uC5C6\uB294
      \uAC83\uACFC \uB9C8\uCC2C\uAC00\uC9C0\uC57C"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124117
    m_Localized: "\uD604\uC0C1, \uACFC\uC815, \uACB0\uACFC... \uB0B4\uAC90 \uADF8\uAC83\uBFD0\uC774\uC57C.
      \uD750\uC74C, \uB108 \uAF64 \uC88B\uC740 \uC2E4\uD5D8\uCCB4\uAC00 \uB420 \uAC83
      \uAC19\uC740 \uB0C4\uC0C8\uAC00 \uB098\uB294\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124118
    m_Localized: "\uCD5C\uCD08\uC758 \uAE30\uC0AC... \uADF8\uAC8C \uBC14\uB85C \uC800\uB78D\uB2C8\uB2E4.
      \uBE44\uB85D \uC81C \uBCC4\uC740 \uBCF4\uC774\uC9C0 \uC54A\uC9C0\uB9CC, \uB2F9\uC2E0\uC758
      \uAE38\uC744 \uBE44\uCD94\uB294 \uBE5B\uC774 \uB418\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124119
    m_Localized: "\uADF8 \uC0AC\uB78C\uC5D0\uAC8C \uBCF4\uB2F5\uD558\uAE30 \uC704\uD574
      \uCD5C\uC120\uC744 \uB2E4\uD558\uACA0\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124120
    m_Localized: "\uC774\uC820 \uB354 \uC774\uC0C1 \uC0AC\uB78C\uB4E4\uC744 \uC783\uC9C0
      \uC54A\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124121
    m_Localized: "\uB2F9\uC2E0\uC758 \uAD6C\uC870 \uC694\uCCAD\uC744 \uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC774\uC81C \uC548\uC2EC\uD558\uC138\uC694, \uD130\uC804\uC744 \uC783\uC740
      \uB2F9\uC2E0\uC5D0\uAC8C \uC81C\uAC00 \uC704\uB85C\uAC00 \uB418\uC5B4 \uB4DC\uB9B4\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124122
    m_Localized: "\uB2E4\uAC00\uC624\uC9C0\uB9C8. \uB0B4\uAC8C \uB2E4\uAC00\uC62C
      \uC218 \uC788\uB294 \uC0AC\uB78C\uC740 \uD55C \uC0AC\uB78C \uBFD0\uC784."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124123
    m_Localized: "\uC774 \uBB34\uB300\uC5D0 \uC624\uB97C \uC218 \uC788\uB294 \uD504\uB9AC\uB9C8
      \uB3C8\uB098\uB294 \uB2E8 \uD55C \uBA85\uBFD0\uC774\uC57C. \uB0B4 \uCDA4\uC5D0
      \uBC29\uD574\uB418\uC9C0 \uC54A\uB3C4\uB85D \uC870\uC2EC\uD574 \uC904\uB798?"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124124
    m_Localized: "\uC5B8\uC81C\uB098\uCC98\uB7FC \uC120\uBD09\uC5D0 \uC11C\uACA0\uC2B5\uB2C8\uB2E4.
      \uC81C \uC0AC\uC804, \uADF8\uB9AC\uACE0 \uC81C \uACC4\uD68D\uD45C\uC5D0 '\uD328\uBC30'\uB780
      \uB2E8\uC5B4\uB294 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124125
    m_Localized: "...\uC2E4\uC218\uAC00 \uC544\uB2C8\uC57C? \uC815\uB9D0 \uB098 \uAC19\uC740
      \uAC78\uB85C \uAD1C\uCC2E\uC544? ...\uADF8\uB798, \uD3D0\uAC00 \uB418\uC9C0
      \uC54A\uB3C4\uB85D \uC870\uC6A9\uD788 \uC788\uC744\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124126
    m_Localized: "\uC640\uC544! \uB9C8\uCE68 \uBE44\uAC00 \uC62C \uAC83 \uAC19\uC544!
      \uB098\uB791 \uAC19\uC774 \uC6B0\uC0B0 \uC4F0\uACE0 \uBE57\uC18C\uB9AC \uB4E4\uC73C\uB7EC
      \uAC08\uB798? \uC7A5\uD654 \uC2E0\uB294 \uAC70 \uC78A\uC9C0 \uB9C8!"
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124127
    m_Localized: "\uC774 \uCC9C\uC7AC \uC5D4\uD0A4 \uB2D8\uC774 \uAD6C\uD604\uD558\uC9C0
      \uBABB\uD558\uB294 \uAC74 \uC5C6\uC5B4! \uC601\uAD11\uC778 \uC904 \uC54C\uB77C\uACE0.
      \uC544, \uC0AC\uB840\uAE08\uC740 \uC5D0\uB108\uC9C0 \uC74C\uB8CC\uB85C \uBC1B\uC744\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 4319068357124128
    m_Localized: "\uC774 \uAC80\uC5D0 \uB9F9\uC138\uD558\uC8E0. \uC124\uAD6D\uC758
      \uB9C8\uC9C0\uB9C9 \uB208\uC774 \uB179\uAE30 \uC804\uAE4C\uC9C0, \uB2F9\uC2E0\uACFC
      \uD568\uAED8 \uC774 \uB545\uC758 \uD3C9\uD654\uB97C \uB418\uCC3E\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 4445818290429952
    m_Localized: "\uB098\uB808\uC774\uD130"
    m_Metadata:
      m_Items: []
  - m_Id: 5067501291687936
    m_Localized: "\uCE90\uB9AD\uD130 \uBC30\uCE58\uC218\uAC00 \uCD08\uACFC\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7701474569084928
    m_Localized: "\uC7AC\uD654\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7702678502105088
    m_Localized: "\uAE30\uC0AC\uC758 \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uC600\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7704414641971200
    m_Localized: "\uC7AC\uD654\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7704414692302848
    m_Localized: "\uAE30\uC0AC\uC758 \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uC600\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 10933054054162432
    m_Localized: "\uCE90\uB9AD\uD130 \uBAA9\uB85D"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds:
