    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688395
    m_Localized: "\uD574\uB2F9 \uBC1C\uD310 \uC704\uC5D0 \uC704\uCE58\uD560 \uC2DC
      <b><color=#F75D32>{0}\uCD08 \uB3D9\uC548 \uBE59\uACB0</color></b> \uC0C1\uD0DC\uAC00
      \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688396
    m_Localized: "\uD574\uB2F9 \uBC1C\uD310 \uC704\uC5D0 \uC62C\uB77C\uAC08 \uC2DC
      <b><color=#F75D32>{0}\uCD08 \uB3D9\uC548 \uC5D0\uC5B4\uBCF8</color></b> \uC0C1\uD0DC\uAC00
      \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688397
    m_Localized: "\uD574\uB2F9 \uBC1C\uD310 \uC704\uC5D0 \uC704\uCE58\uD560 \uC2DC
      <b><color=#F75D32>{0}</color></b>\uC758 \uB300\uBBF8\uC9C0\uB97C \uC8FC\uACE0
      <b><color=#F75D32>{1}\uCD08 \uB3D9\uC548 \uC774\uB3D9 \uBD88\uAC00</color></b>
      \uC0C1\uD0DC\uAC00 \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688398
    m_Localized: "\uD574\uB2F9 \uBC1C\uD310 \uC704\uC5D0 \uC704\uCE58\uD560 \uC2DC
      \uB79C\uB364\uD55C \uC704\uCE58\uB85C \uC804\uC1A1\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1869565540688399
    m_Localized: "\uC544\uB808\uB098 \uC785\uC7A5 \uD2F0\uCF13\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
