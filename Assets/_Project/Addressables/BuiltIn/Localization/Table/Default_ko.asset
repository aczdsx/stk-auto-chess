  - m_Id: 3260753992736881
    m_Localized: "\uC704\uC2A4\uD504_\uD640\uB85C\uADF8\uB7A8"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736880
    m_Localized: "\uC784\uD504"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736879
    m_Localized: "\uACE0\uB974\uACE4_\uD640\uB85C\uADF8\uB7A8"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736878
    m_Localized: "\uD5CC\uD130_1"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736877
    m_Localized: "\uD5CC\uD130_\uD640\uB85C\uADF8\uB7A8"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736876
    m_Localized: "\uC2E0\uB150\uC774\uB780 '\uAD73\uAC8C \uBBFF\uB294 \uB9C8\uC74C'\uC774\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736875
    m_Localized: "\uC65C \uBB34\uC11C\uC6CC\uD558\uB294 \uAC70\uC9C0\uC774... \uC544\uC8FC
      \uC7A0\uAE50 \uB530\uB054\uD560 \uBFD0\uC778\uB370.."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736874
    m_Localized: "\uAE4C, \uAE5C\uC791\uC774\uC57C! \uBCC4 \uC77C\uB3C4 \uC544\uB2CC\uB370
      '\uC5B4? '\uD558\uC9C0 \uB9D0\uB780\uB9D0\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736873
    m_Localized: "\uB0A0 \uAE38\uB4E4\uC774\uACA0\uB2E4\uACE0? \uC7AC\uBBF8\uC788\uB294
      \uC18C\uB9AC\uB97C \uD558\uB294\uAD6C\uB098, \uAD00\uCE21\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736872
    m_Localized: "\uBC14\uB78C\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC624\uB294\uAD70\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736871
    m_Localized: "\uAE30\uBD84\uC774\uB2E4, \uD2B9\uBCC4\uD788 \uB0B4\uAC00 \uB9CC\uB4E0
      \uBB34\uAE30\uB97C \uC0AC\uC6A9\uD558\uAC8C \uD574\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736870
    m_Localized: "\uBE5B\uC774 \uAC00\uC7A5 \uD544\uC694\uD55C \uAC74 \uC5B4\uB460\uC5D0
      \uAC07\uD78C \uC774\uB4E4\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736869
    m_Localized: "\uD6C4\uD6D7, \uAD1C\uCC2E\uC544\uC694. \uC624\uB298\uC740 \uADF8\uC800
      \uC548\uBD80\uB97C \uBB3C\uC73C\uB7EC \uC628 \uAC83 \uBFD0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736868
    m_Localized: "\uB10C \uC18C\uAFC9\uB180\uC774 \uC548 \uB07C\uC6CC\uC904\uAC70\uC57C,
      \uD788\uD788!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736867
    m_Localized: "\uD638\uAE30\uC2EC\uACFC \uB3C8\uB9CC \uC788\uC73C\uBA74, \uBB50\uB4E0\uC9C0
      \uAC00\uB2A5\uD558\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736866
    m_Localized: "\uD314\uC774 \uBA87 \uAC1C\uB0D0\uACE0 \uBB3C\uC73C\uC2E0\uB2E4\uBA74,
      \uC5EC\uBD84\uAE4C\uC9C0 \uD3EC\uD568\uD574 428\uAC1C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736865
    m_Localized: "\uC544\uC8FC \uC870\uC6A9\uD788... \uC7A0\uAE50 \uC7A0\uB4DC\uB294
      \uAC83 \uBFD0\uC774\uB2C8\uAE50"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736864
    m_Localized: "\uB450\uB835\uB2C8? \uAFC8\uC5D0\uC11C \uAE68\uC5B4\uBC84\uB9AC\uB294
      \uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736863
    m_Localized: "\uAC15\uD568\uC744 \uC99D\uBA85\uD558\uB294 \uAC83\uB9CC\uD07C
      \uC758\uBBF8\uC788\uB294 \uAC74 \uC5C6\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736862
    m_Localized: "\uC9C0\uD718\uAD00\uB2D8\uC744 \uB9CC\uB098\uC11C \uB2E4\uD589\uC774\uB77C\uB294
      \uC0DD\uAC01\uC774 \uB4E4\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736861
    m_Localized: "\uB208\uC740 \uC783\uC5C8\uC9C0\uB9CC, \uAC10\uAC01\uC740 \uB354
      \uC120\uBA85\uD574\uC84C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736860
    m_Localized: "\uB098\uB294 \uC0AC\uC2E4 \uBE68\uAC04\uC0C9\uC774 \uC81C\uC77C
      \uC88B\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736859
    m_Localized: "\uBB50! \uB0B4 \uB9D0\uC5D0 \uBD88\uB9CC \uC788\uC5B4?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736858
    m_Localized: "\uC6D0\uCE59\uB300\uB85C \uCC98\uB9AC\uD558\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736857
    m_Localized: "\uC694\uB9AC\uB294 \uC880 \uBABB\uD574\uB3C4, \uC5B4\uC5FF\uD55C
      \uBA54\uC774\uB4DC\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736856
    m_Localized: "\uAC71\uC815\uB9C8\uC138\uC694, \uB2F9\uC2E0\uC740 \uCCB4\uD3EC\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736855
    m_Localized: "\uAC00\uBCF4\uB85C \uB0B4\uB824\uC624\uB294 \uB9C8\uAC80\uC744
      \uC18C\uC9C0\uD55C \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736854
    m_Localized: "\uD5C8\uBE14\uC758 AI \uC2DC\uC2A4\uD15C\uC744 \uAD6C\uCD95\uD55C
      \uC790\uC874\uAC10 2000%\uC758 \uC790\uCE6D \uCC9C\uC7AC \uD504\uB85C\uADF8\uB798\uBA38\uC785\uB2C8\uB2E4.
      \n\uBC84\uB987\uC5C6\uC5B4 \uBCF4\uC774\uC9C0\uB9CC \uC2E4\uB825\uB9CC\uD07C\uC740
      \uD655\uC2E4\uD558\uBA70, \n\uC18C\uAFC9\uCE5C\uAD6C \uB9B4\uB9AC\uC2A4\uC5D0\uAC8C
      \uBCF8\uC778 \uCDE8\uD5A5\uC758 \uC637\uC744 \uC785\uD788\uB294 \uAC83\uC744
      \uB099\uC73C\uB85C \uC0BC\uB294 \uADC0\uC5EC\uC6B4 \uC545\uB3D9\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736853
    m_Localized: "\uBE44\uAD50\uC801 \uC5B4\uB9B0 \uB098\uC774, \uCD5C\uADFC \uC131\uD754\uC774
      \uC0C8\uACA8\uC9C4 \uC218\uC2B5 \uAE30\uC0AC. \uBCF8\uC778\uC774 \uBC1B\uC740
      \uBCC4\uC758 \uD798\uC774 \uB2E4\uB978 \uBCC4\uB4E4\uACFC\uB294 \uB2EC\uB9AC
      \uC5C4\uCCAD\uB09C \uD798\uC744 \uAC00\uC9C0\uACE0 \uC788\uB2E4\uACE0 \uBBFF\uB294\uB2E4.\n
      \uD2B9\uD788 \uC778\uAC04\uB4E4\uC774 \uAC70\uC8FC\uD558\uB294 \uCC28\uC6D0\uACFC
      \uBB3C\uC9C8\uACC4 \uBC16\uC758 \uC5B4\uB518\uAC00\uC5D0\uC11C \uAC70\uC8FC\uD558\uB294
      \uCD08\uCC28\uC6D0\uC801\uC778 \uC874\uC7AC\uB77C\uACE0 \uC0DD\uAC01\uD558\uBA70,
      \uC54C \uC218 \uC5C6\uB294 \uC5B8\uC5B4\uC758 \uB178\uB798\uB97C \uC678\uC6B0\uACE0
      \uB2E4\uB2C8\uB294 \uB4F1 4\uCC28\uC6D0\uC801\uC778 \uBA74\uBAA8\uB97C \uBCF4\uC778\uB2E4.
      \n\uB7EC\uBE0C\uC758 \uBA38\uB9AC\uCE74\uB77D\uC744 \uD0DC\uC6B0\uBA74 \uD2B9\uC774\uD55C
      \uB0C4\uC0C8\uAC00 \uB098\uB294\uB370, \uBC14\uB85C \uC624\uC9D5\uC5B4 \uAD6C\uC6B4
      \uB0C4\uC0C8\uC774\uB2E4. \uB355\uBD84\uC5D0 \uC544\uCE74\uB370\uBBF8 \uC131\uB2E8\uC758
      \uB3D9\uB8CC \uAE30\uC0AC\uB4E4\uC774 \uBC30\uACE0\uD50C\uB54C \uC885\uC885
      \uBA38\uB9AC\uCE74\uB77D\uC744 \uBAB0\uB798 \uAD6C\uC6CC \uBA39\uB294\uB2E4\uACE0
      \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736852
    m_Localized: "\uADDC\uACA9 \uC678\uC758 \uC874\uC7AC\"\uB85C \uBD88\uB9AC\uBA70
      \uC0C1\uCC98\uBC1B\uACE0 \uBC29\uCE58\uB418\uC5C8\uB358, \uB9C8\uC74C \uC5EC\uB9B0
      \uD638\uBB38\uCFE8\uB8E8\uC2A4\uC785\uB2C8\uB2E4. \n\uC790\uC2E0\uC758 \uC548\uC704\uBCF4\uB2E4
      \uB3D9\uC0DD\uC758 \uD3C9\uD654\uB97C \uC704\uD574 \uACE0\uD1B5\uC744 \uAC10\uB0B4\uD574\uC654\uC73C\uBA70,
      \n\uD0C0\uC778\uC5D0\uAC8C \uD3D0\uB97C \uB07C\uCE58\uB294 \uAC83\uC744 \uADF9\uB3C4\uB85C
      \uB450\uB824\uC6CC\uD558\uB294 \uC548\uC4F0\uB7EC\uC6B4 \uC18C\uB140\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736851
    m_Localized: "\uBD88\uD328\uC758 \uAE30\uC0AC'\uB77C \uBD88\uB9AC\uB294 \uBA54\uC2DC\uC5D041\uC758
      \uC644\uBCBD\uC8FC\uC758\uC790\uC774\uC790 \uC815\uC758\uB85C\uC6B4 \uBAA8\uBC94\uC0DD\uC785\uB2C8\uB2E4.
      \n\uD750\uD2B8\uB7EC\uC9D0 \uC5C6\uB294 \uBAA8\uC2B5 \uB4A4\uC5D0 \uADC0\uC5EC\uC6B4
      \uC18C\uB3D9\uBB3C\uACFC \uB538\uAE30 \uCF00\uC774\uD06C\uB97C \uC0AC\uB791\uD558\uB294
      \n\uC18C\uB140 \uAC10\uC131\uC744 \uC228\uAE30\uACE0 \uC788\uB294, \uBC18\uC804
      \uB9E4\uB825\uC758 \uAE30\uC0AC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736850
    m_Localized: "\uB300\uC911\uC5D0\uAC8C\uB294 \uC644\uBCBD\uD55C '\uCC9C\uC0AC'\uB85C
      \uCE6D\uC1A1\uBC1B\uC9C0\uB9CC, \uAE30\uC0AC\uB4E4 \uC0AC\uC774\uC5D0\uC11C\uB294
      \uC5C4\uACA9\uD558\uACE0 \uAE4C\uCE60\uD55C '\uD558\uC580 \uC545\uB9C8'\uB85C
      \uD1B5\uD558\uB294 \uC774\uC911\uC801\uC778 \uB9E4\uB825\uC758 \uC18C\uC720\uC790\uC785\uB2C8\uB2E4.
      \n\uC6B0\uC544\uD55C \uBC31\uC870\uCC98\uB7FC \uC644\uBCBD\uD568\uC744 \uCD94\uAD6C\uD558\uBA70
      \uD0C0\uC778\uACFC \uC790\uC2E0\uC744 \uBAB0\uC544\uBD99\uC774\uC9C0\uB9CC,
      \n\uC2E4\uC740 \uB2EC\uCF64\uD55C \uB514\uC800\uD2B8\uC758 \uC720\uD639 \uC55E\uC5D0\uC11C
      \uB9E4\uBC88 \uBB34\uB108\uC9C0\uB294 \uC778\uAC04\uC801\uC778 \uBA74\uBAA8\uB97C
      \uC228\uAE30\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736849
    m_Localized: "\"\uADC0\uCC28\uB2C8\uC998 \uC554\uC0B4\uC790\"\n\uADC0\uCC28\uB2C8\uC998
      \uB54C\uBB38\uC778\uC9C0 \uBAA8\uB4E0 \uB9D0\uC744 \uC9E7\uAC8C \uB04A\uC5B4\uBC84\uB9AC\uB294
      \uC2B5\uAD00\uC744 \uAC00\uC9C4 \uC2A4\uD154\uB77C \uB098\uC774\uCE20.\n\uB300\uBD80\uBD84\uC758
      \uBB3C\uC74C\uC5D0 \uD589\uB3D9\uC73C\uB85C\uB9CC \uB300\uB2F5\uD558\uC9C0\uB9CC
      \uD50C\uB808\uC774\uC544 \uB370\uC2A4 \uC131\uB2E8\uC6D0\uB4E4\uACFC\uB294
      \uB098\uB984 \uC9E7\uAC8C\uB098\uB9C8 \uC18C\uD1B5\uC744 \uC9C0\uC18D\uD569\uB2C8\uB2E4.\n\uC5B4\uB5A4
      \uC0AC\uAC74\uC774\uB4E0 \uD070 \uB3D9\uC694\uB97C \uC77C\uC73C\uD0A4\uC9C0
      \uC54A\uB294 \uCE68\uCC29\uD55C \uC131\uACA9\uC744 \uC9C0\uB154\uC9C0\uB9CC,
      \uC18C\uC911\uD55C \uC874\uC7AC\uC5D0 \uB300\uD574\uC11C\uB294 \uC5C4\uCCAD\uB09C
      \uC560\uCC29\uC744 \uAC00\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736848
    m_Localized: "\uC0C1\uCC98 \uC785\uC740 \uC774\uB4E4\uC744 \uBCF4\uB4EC\uB294
      \uD50C\uB808\uC774\uC544\uB370\uC2A4\uC758 \uB2E4\uC815\uD55C \uB9CF\uC5B8\uB2C8\uC774\uC790
      \uCE58\uC720\uC0AC\uC785\uB2C8\uB2E4. \n\uACFC\uAC70 \uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC5D0\uC11C
      \uD1F4\uCD9C\uB2F9\uD55C \uC544\uD508 \uAE30\uC5B5\uC744 \uAC00\uC2B4 \uAE4A\uC774
      \uBB3B\uC5B4\uB454 \uCC44, \n\uC774\uC81C\uB294 \uC0C8\uB85C\uC6B4 \uAC00\uC871\uC774
      \uB41C \uB3D9\uB8CC\uB4E4\uC744 \uB2E4\uC2DC\uB294 \uC783\uC9C0 \uC54A\uACA0\uB2E4\uB294
      \uAC01\uC624\uB85C \uB2F9\uC2E0 \uACC1\uC744 \uC9C0\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736847
    m_Localized: "\uC5B4\uB5A0\uD55C \uC0AC\uACE0\uB85C \uC778\uD574 \uC2E0\uCCB4\uC758
      50%\uC774\uC0C1\uC744 \uC758\uCCB4\uB85C \uB300\uCCB4\uD55C \uC18C\uB140. \n\uADF8\uB140\uC758
      \uC678\uACE8\uACA9\uC740 \uB2E8\uC21C\uD55C \uAC15\uD654 \uC7A5\uBE44\uAC00
      \uC544\uB2C8\uB77C \uC18D\uC8C4\uC758 \uD615\uD0DC\uC785\uB2C8\uB2E4.\n\uADF8\uB798\uC11C
      \uC544\uB4DC\uB9AC\uC544\uB294 \uAC15\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uADF8 \uAC15\uD568\uC740 \u201C\uB354 \uB9CE\uC774 \uBD80\uC218\uAE30 \uC704\uD574\uC11C\u201D\uAC00
      \uC544\uB2C8\uB77C, \uB354 \uC774\uC0C1 \uBD80\uC11C\uC9C0\uC9C0 \uC54A\uAC8C
      \uD558\uAE30 \uC704\uD574 \uC874\uC7AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736846
    m_Localized: "\uC30D\uCC3D\uC758 \uB2EC\uC778"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736845
    m_Localized: "\uC131\uD754\uC774 \uC5C6\uB294 \uC720\uC77C\uD55C \uAE30\uC0AC\uC774\uC790
      'Unknown'\uC774\uB77C\uB294 \uC774\uBA85\uC744 \uAC00\uC9C4, \uC18C\uC2EC\uD558\uC9C0\uB9CC
      \uB0B4\uBA74\uC774 \uB2E8\uB2E8\uD55C \uC131\uC7A5\uD615 \uAE30\uC0AC\uC785\uB2C8\uB2E4.
      \n\uC790\uC2E0\uC758 \uBCC4\uC744 \uCC3E\uC9C0 \uBABB\uD588\uB2E4\uB294 \uAF2C\uB9AC\uD45C\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0, \uB3D9\uB8CC\uB4E4\uACFC\uC758 \uC720\uB300\uB97C
      \uD1B5\uD574 \uC810\uCC28 \uC6A9\uAE30\uB97C \uC5BB\uC73C\uBA70 \uD50C\uB808\uC774\uC544\uB370\uC2A4\uC758
      \uC9C4\uC815\uD55C \uD798\uC744 \uAC1C\uD654\uD574 \uB098\uAC11\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736844
    m_Localized: "\uC2A4\uCF5C\uC758 \uC30D\uB465\uC774 \uC5B8\uB2C8\uC774\uC790
      \uC5D8\uD53C\uC2A4 \uD2B9\uC218 \uBD80\uB300\uC758 \uB9AC\uB354 \uAE30\uC0AC.\n\uC5B4\uB9B0\uC2DC\uC808
      \uC2A4\uCF5C\uACFC \uD568\uAED8 \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uAC00
      \uB41C \uC774\uD6C4, \uC9C0\uAE08\uAE4C\uC9C0 \uCB49 \uC0AC\uB78C\uB4E4\uC744
      \uC9C0\uCF1C\uC654\uB2E4. \uACE0\uC9C0\uC2DD\uD574\uBCF4\uC774\uB294 \uB9D0\uD22C\uC640
      \uB2E8\uC815\uD558\uAC8C \uCC28\uB824 \uC785\uC740 \uBCF5\uC7A5 \uB54C\uBB38\uC5D0
      \uB2E4\uAC00\uAC00\uAE30 \uC5B4\uB824\uC6B4 \uC0AC\uB78C\uC73C\uB85C \uC885\uC885
      \uC624\uD574\uBC1B\uACE4 \uD558\uC9C0\uB9CC, \uC0AC\uC2E4\uC740 \uB2E4\uC815\uD558\uACE0
      \uC774\uD0C0\uC801\uC778 \uC131\uACA9\uC758 \uC18C\uC720\uC790\uB85C, ESO\uC5D0\uC11C\uB3C4
      \uC2E0\uB8B0\uBC1B\uB294 \uB9AC\uB354 \uC5ED\uD560\uC744 \uD574\uB0B4\uACE0
      \uC788\uB2E4.\n\n\uACFC\uAC70 \uD5C8\uBE14\uC5D0 \uAD6C\uC870\uB420 \uB2F9\uC2DC
      \uD558\uD2F0\uC758 \uACB0\uC815\uD55C \uC120\uD0DD\uC73C\uB85C \uC778\uD574
      \uD558\uD2F0\uC640\uB294 \uBA40\uC5B4\uC9C0\uAC8C \uB418\uC5C8\uC73C\uBA70,
      \uD558\uD2F0\uB294 \uC9C0\uAE08\uB3C4 \uADF8 \uC77C\uC5D0 \uB300\uD55C \uCC45\uC784\uAC10\uC744
      \uB290\uB07C\uACE0 \uC788\uB2E4.\n\uC2A4\uCF5C\uC744 \uC9C0\uD0A4\uACE0\uC790
      \uD588\uB358 \uD589\uB3D9\uC774\uB77C\uACE0 \uC0DD\uAC01\uD558\uC9C0\uB9CC,
      \uC9C0\uAE08 \uB3CC\uC544\uBCF4\uBA74 \uD558\uD2F0 \uC790\uC2E0\uC744 \uC704\uD55C
      \uC120\uD0DD\uC774\uC5C8\uC744\uC9C0\uB3C4 \uBAA8\uB978\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736843
    m_Localized: "\uCC9C\uC7AC \uACFC\uD559\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736842
    m_Localized: "\uAD49\uC7A5\uD55C \uC644\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uB294
      \uC2A4\uD154\uB77C \uB098\uC774\uCE20. \uD638\uBC29\uD55C \uC131\uACA9\uC73C\uB85C
      \uC778\uD574 \uB9CE\uC740 \uCD94\uC885\uC790\uAC00 \uC788\uC2B5\uB2C8\uB2E4.\n\uAC15\uD568\uC744
      \uC22D\uC0C1\uD558\uB098 \uADF8\uB807\uB2E4\uACE0 \uC57D\uC790\uB97C \uBA78\uC2DC\uD558\uC9C0
      \uC54A\uC73C\uBA70 \uC9C0\uCF1C\uC918\uC57C\uD558\uB294 \uB300\uC0C1\uC73C\uB85C
      \uC5EC\uAE41\uB2C8\uB2E4.\n\uB2E4\uB9CC, \uC804\uD22C\uAD11\uC73C\uB85C\uC11C
      \uD55C \uBC88 \uBAA9\uD45C\uB85C \uC0BC\uC73C\uBA74 \uC0C1\uB300\uAC00 \uC2F8\uC6CC\uC904
      \uB54C \uAE4C\uC9C0 \uB2EC\uB824\uB4DC\uB294 \uB9C9\uBB34\uAC00\uB0B4 \uC801\uC778
      \uC131\uACA9\uB3C4 \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736841
    m_Localized: "\uC77C \uB05D\uB09C \uD6C4 \uB9C8\uC2DC\uB294 \uBC00\uB9E5\uC8FC
      \uD55C \uC794\uC744 \uC0AC\uB791\uD558\uB294 \uD138\uD138\uD55C \uC131\uACA9\uC758
      \uAE30\uC0AC\uC785\uB2C8\uB2E4. \n\uC6B4\uBCF4\uB2E4\uB294 \uB178\uB825\uC758
      \uAC00\uCE58\uB97C \uBBFF\uC73C\uBA70 \uB04A\uC784\uC5C6\uC774 \uC790\uC2E0\uC744
      \uB2E8\uB828\uD558\uC9C0\uB9CC, \uC220\uC5D0 \uCDE8\uD558\uBA74 \uBA48\uCD94\uC9C0
      \uC54A\uB294 \uC794\uC18C\uB9AC \uD3ED\uACA9\uAE30\uAC00 \uB418\uC5B4\uBC84\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736840
    m_Localized: "\uC2E4\uD5D8\uACFC \uC5F0\uAD6C \uC678\uC758 \uBAA8\uB4E0 \uAC83\uC744
      \uADC0\uCC2E\uC544\uD558\uB294 \uAC8C\uC73C\uB978 \uCC9C\uC7AC\uC774\uC790,
      \uB3C5\uADF9\uBB3C\uACFC \uBBF8\uC9C0\uC758 \uD604\uC0C1\uC5D0 \uC5F4\uAD11\uD558\uB294
      \uB9E4\uB4DC \uC0AC\uC774\uC5B8\uD2F0\uC2A4\uD2B8\uC785\uB2C8\uB2E4. \n\uC804\uC7A5\uC744
      \uAC70\uB300\uD55C \uC2E4\uD5D8\uC2E4\uB85C \uC5EC\uAE30\uBA70, \uAD00\uCE21\uC790\uC5D0\uAC8C\uC11C
      \uD48D\uAE30\uB294 \uBBF8\uC9C0\uC218\uC758 \uB0C4\uC0C8\uB97C \uB9E1\uACE0
      \uB2F9\uC2E0\uC744 \uCD5C\uACE0\uC758 '\uC2E4\uD5D8\uCCB4'\uB85C \uD0D0\uB0B4\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736839
    m_Localized: "\uB530\uC0AC\uB85C\uC6B4 \uD587\uC0B4\uACFC \uAC19\uC740 \uC628\uD654\uD55C
      \uBBF8\uC18C, \uC6B0\uC544\uD55C \uBAB8\uC9D3, \uBD80\uB4DC\uB7EC\uC6B4 \uC5B8\uD589.
      \uC5B4\uB514\uB85C \uBCF4\uB098 \uC131\uC219\uD55C \uC219\uB140\uC758 \uBD84\uC704\uAE30\uB97C
      \uD48D\uAE30\uB294 \uAE30\uC0AC. MAID\uC5D0\uC11C\uB294 \uBA85\uC2E4\uC0C1\uBD80\uD558\uAC8C
      \uB9AC\uB354\uC758 \uC5ED\uD560\uC744 \uB9E1\uACE0 \uC788\uB2E4.\nMAID \uC131\uB2E8\uC5D0
      \uC18D\uD55C \uAE30\uC0AC\uB4E4\uC740 \uC73C\uB808 \uADF8\uB807\uC9C0\uB9CC,
      \uC5D0\uC774\uD504\uB9B4\uC740 \uD2B9\uD788 \uD0C0\uC778\uC5D0 \uB300\uD55C
      \uBC30\uB824\uC2EC\uC774 \uAE4A\uACE0, \uB610 \uC774\uD0C0\uC2EC\uC774 \uB9CE\uC544
      \uBD09\uC0AC\uD558\uB294 \uC77C\uC5D0 \uC775\uC219\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736838
    m_Localized: "\uAC70\uB300\uD55C \uAD00\uC744 \uC9CA\uC5B4\uC9C0\uACE0 \uB2E4\uB140
      \uACF5\uD3EC\uAC10\uC744 \uC870\uC131\uD558\uC9C0\uB9CC, \uC0AC\uC2E4\uC740
      \uC791\uC740 \uC18C\uB9AC\uC5D0\uB3C4 \uB180\uB77C\uB294 \uAC81\uC7C1\uC774\uC5D0
      \uB9C8\uC74C \uC5EC\uB9B0 \uCE58\uC720\uC0AC\uC785\uB2C8\uB2E4. \n\uC0AC\uB78C\uACFC\uC758
      \uB300\uD654\uBCF4\uB2E4 \uAD00 \uC18D\uC758 \uACE0\uC694\uD568\uC744 \uC88B\uC544\uD558\uC9C0\uB9CC,
      \uB204\uAD70\uAC00 \uB2E4\uCE58\uB294 \uAC83\uC744 \uBCFC \uC218 \uC5C6\uC5B4
      \uC6A9\uAE30\uB97C \uB0B4\uC5B4 \uC804\uC7A5\uC5D0 \uB098\uC11C\uB294 \uC0C1\uB0E5\uD55C
      \uC601\uD63C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736837
    m_Localized: "\uB3C8\uC73C\uB85C \uC548 \uB418\uB294 \uAC74 \uB3C8\uC774 \uBD80\uC871\uD55C
      \uD0D3\"\uC774\uB77C\uACE0 \uBBFF\uB294 \uC18D\uBB3C \uADC0\uC5EC\uC6B4 \uC5EC\uC6B0
      \uC18C\uB140\uC785\uB2C8\uB2E4.\n\uCCA0\uC800\uD55C \uC790\uBCF8\uC8FC\uC758\uC801
      \uB9C8\uC778\uB4DC\uB85C \uC6C0\uC9C1\uC774\uC9C0\uB9CC, \n\uC785\uAE08\uB41C
      \uB9CC\uD07C\uC740 \uD655\uC2E4\uD558\uAC8C \uC77C \uCC98\uB9AC\uB97C \uD574\uB0B4\uB294
      \uBBF8\uC6CC\uD560 \uC218 \uC5C6\uB294 \uC9E0\uC21C\uC774\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736836
    m_Localized: "\uBBF8\uC9C0\uC758 \uC138\uACC4\uB97C \uD0D0\uD5D8\uD558\uB294
      \uC790\uCE6D '\uC704\uB300\uD55C \uBAA8\uD5D8\uAC00'\uC774\uC790 \uD638\uAE30\uC2EC
      \uB300\uC7A5\uC785\uB2C8\uB2E4.\n \uAD81\uAE08\uD55C \uAC83\uC744 \uCC38\uC9C0
      \uBABB\uD574 \uB9E4\uBC88 \uC0AC\uACE0\uB97C \uCE58\uACE0 \uB2E4\uB2C8\uBA70,
      \uC9112\uBCD1 \uB118\uCE58\uB294 \uB300\uC0AC\uB85C \uC8FC\uBCC0\uC744 \uB2F9\uD669\uD558\uAC8C
      \uB9CC\uB4DC\uB294 \n\uC544\uCE74\uB370\uBBF8\uC758 4\uCC28\uC6D0 \uD2B8\uB7EC\uBE14
      \uBA54\uC774\uCEE4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736835
    m_Localized: "\uB0B4\uBD80\uC5D0\uC11C \uB05D\uC5C6\uC774 \uCE58\uC19F\uB294
      \uC5F4 \uC5D0\uB108\uC9C0\uB85C \uC778\uD574 \uD654\uC0C1\uC744 \uC785\uC5B4\uBC84\uB9AC\uB294
      \uD2B9\uC774\uCCB4\uC9C8\uC744 \uAC00\uC9C4 \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736834
    m_Localized: "\uC21C\uC9C4\uD574\uBCF4\uB294 \uAC89\uBAA8\uC2B5\uACFC \uB2E4\uB974\uAC8C
      \uB9E4\uC6B0 \uD749\uD3EC\uD55C \uC2EC\uC131\uC744 \uAC00\uC9C4 \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736833
    m_Localized: "\uC5B8\uC81C\uB098 \uBC1D\uC740 \uBBF8\uC18C\uC640 \uC120\uD55C
      \uC5B8\uD589\uC73C\uB85C \uBA54\uC2DC\uC5D041\uC758 \uC774\uBBF8\uC9C0\uB97C
      \uCC45\uC784\uC9C0\uB294 \uB9C8\uC2A4\uCF54\uD2B8\uC774\uC790 \uC0AC\uB791\uC2A4\uB7EC\uC6B4
      \uC18C\uB140\uC785\uB2C8\uB2E4. \n\uD558\uC9C0\uB9CC \uADF8 \uC644\uBCBD\uD55C
      '\uCC29\uD55C \uC544\uC774'\uC758 \uAC00\uBA74 \uB4A4\uC5D0\uB294, \uC5B5\uB20C\uB7EC\uC654\uB358
      \uC194\uC9C1\uD55C \uC695\uB9DD\uACFC \uB450\uB824\uC6C0\uC744 \uC228\uAE30\uACE0
      \n\uC5B4\uB978\uB4E4\uC758 \uAE30\uB300\uC5D0 \uB9DE\uCDB0 \uC5F0\uAE30\uD558\uB294
      \uC131\uC219\uD55C \uB0B4\uBA74\uC774 \uC790\uB9AC\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736832
    m_Localized: "\uBC18\uB824 \uC0C8 '\uD53C\uCF54'\uC640 \uAD50\uAC10\uD558\uBA70
      \uC790\uC720\uB86D\uAC8C \uD558\uB298\uC744 \uB098\uB294 \uAFC8\uC744 \uAFB8\uB294
      \uAE30\uC0AC\uC785\uB2C8\uB2E4. \n\uB298 \uC6C3\uB294 \uC5BC\uAD74\uB85C \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uD76C\uB9DD\uC744 \uC804\uD558\uC9C0\uB9CC, \n\uADF8 \uBC1D\uC740 \uBBF8\uC18C
      \uB4A4\uC5D0\uB294 \uB124\uD53C\uB9BC\uC5D0\uAC8C \uAC00\uC871\uC744 \uC783\uC740
      \uC2AC\uD508 \uACFC\uAC70\uB97C \uC228\uAE30\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736831
    m_Localized: "\uC8FC\uBCC0\uC744 \uB530\uB4EF\uD558\uAC8C \uBC1D\uD600\uC8FC\uB294
      \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736830
    m_Localized: "\uC77C\uBD80\uB7EC \uAC70\uCE5C \uB9D0\uC744 \uB0B4\uBC49\uAC70\uB098,
      \uC637\uC744 \uC5B4\uC815\uCA61\uD558\uAC8C \uC785\uB294 \uB4F1 \uC5D8\uD53C\uC2A4\uC758
      \uCE58\uC548 \uB2F4\uB2F9 \uAE30\uC0AC\uB77C\uACE0\uB294 \uC0DD\uAC01\uD560
      \uC218 \uC5C6\uC744 \uC815\uB3C4\uB85C \uBD88\uB7C9\uC2A4\uB7FD\uAC8C \uBCF4\uC774\uB294
      \uAE30\uC0AC.\n\uAC70\uB300\uD55C \uBC29\uD328\uC640 \uACBD\uCC30\uBD09\uC744
      \uB4E4\uACE0 \uC2DC\uBBFC\uC744 \uC9C0\uD0A4\uACA0\uB2E4\uB294 \uC0AC\uBA85\uAC10
      \uD558\uB098\uB85C \uBB49\uCE5C \uC6B0\uC9C1\uD55C \uAE30\uC0AC\uC785\uB2C8\uB2E4.
      \n\uD5D8\uC545\uD574 \uBCF4\uC774\uB294 \uC778\uC0C1 \uB54C\uBB38\uC5D0 \uC624\uD574\uB97C
      \uC0AC\uACE4 \uD558\uC9C0\uB9CC, \uC2E4\uC740 \uC8FC\uBA38\uB2C8 \uC18D\uC5D0
      \uC6B0\uB294 \uC544\uC774\uB97C \uB2EC\uB798 \uC904 \uC0AC\uD0D5\uC744 \uCC59\uACA8
      \uB2E4\uB2D0 \uB9CC\uD07C \uB204\uAD6C\uBCF4\uB2E4 \uB530\uB73B\uD558\uACE0
      \uC5EC\uB9B0 \uB9C8\uC74C\uC744 \uC9C0\uB154\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736829
    m_Localized: "\uC815\uB9D0\uB85C \uC55E\uC744 \uBCFC \uC218 \uC5C6\uB2E4. \uB54C\uBB38\uC5D0
      \uB298 \uB208\uC744 \uAC10\uACE0 \uB2E4\uB2CC\uB2E4.  \n\uC6D0\uB798 \uD574\uB2F9
      \uCE7C\uB0A0\uC5D0 \uC81C \uC9DD\uC73C\uB85C \uB9CC\uB4E4\uC5B4\uC9C4 \uCE7C\uC9D1\uACFC
      \uCE7C\uC790\uB8E8, \uCF54\uB4F1\uC774\uAC00 \uC788\uC73C\uB098 \uB204\uAD70\uAC00\uC5D0\uAC8C
      \uBE7C\uC557\uACBC\uB2E4\uACE0 \uD55C\uB2E4. \n\uC790\uC2E0\uC744 \uC4F0\uB7EC\uD2B8\uB9AC\uACE0
      \uB208\uC744 \uC557\uC544\uAC04 \uB4A4 \uCE7C\uB0A0\uB9CC \uB0A8\uAE30\uACE0
      \uAC04 \uC6D0\uC218\uB97C \uCC3E\uB294 \uAC83\uC774 \uAC1C\uC778\uC801 \uBAA9\uD45C.
      \n\uB54C\uBB38\uC5D0 \uADF8 \uC77C\uC5D0 \uD611\uB825\uD574\uC8FC\uACA0\uB2E4\uACE0
      \uD558\uBA74 \uC55E\uB4A4 \uC548 \uAC00\uB9AC\uACE0 \uD611\uC870\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736828
    m_Localized: "\uBC14\uB2E4\uCC98\uB7FC \uB113\uC740 \uB9C8\uC74C\uACFC \uB530\uB73B\uD55C
      \uD488\uC744 \uAC00\uC9C4 M.A.I.D \uC131\uB2E8\uC758 \uC7A5\uC2E0 \uAE30\uC0AC\uC785\uB2C8\uB2E4.
      \n\uADF8\uB140\uAC00 \uB9CC\uB4DC\uB294 \uC694\uB9AC\uB294 \uC0DD\uD654\uD559
      \uBB34\uAE30 \uC218\uC900\uC758 \uD30C\uAD34\uB825\uC744 \uC790\uB791\uD558\uC9C0\uB9CC,
      \n\uC9C0\uCE5C \uB3D9\uB8CC\uB4E4\uC744 \uAF2D \uC548\uC544\uC8FC\uB294 '\uD3ED\uC2E0
      \uD14C\uB77C\uD53C'\uB9CC\uD07C\uC740 \uC138\uACC4 \uCD5C\uACE0\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736827
    m_Localized: "\uD50C\uB808\uC774\uC544\uB370\uC2A4\uC758 \uB9C9\uB0B4\uB85C\uC11C
      \uADC0\uC5EC\uC6C0\uC744 \uB3C5\uCC28\uC9C0\uD558\uC9C0\uB9CC, \uC790\uC874\uAC10\uC774
      \uB192\uACE0 \uC0AC\uACE0\uB97C \uBAB0\uACE0 \uB2E4\uB2C8\uB294 \uB2F9\uB3CC\uD55C
      \uB9D0\uAD04\uB7C9\uC774 \uAE30\uC0AC\uC785\uB2C8\uB2E4. \n\uC791\uC740 \uD0A4\uAC00
      \uCF64\uD50C\uB809\uC2A4\uB77C '\uAF2C\uB9F9\uC774' \uCDE8\uAE09\uC744 \uB2F9\uD558\uBA74
      \uBC18\uB4DC\uC2DC \uAC04\uC2DD\uC744 \uD6D4\uCCD0\uC11C\uB77C\uB3C4 \uBCF5\uC218\uD558\uC9C0\uB9CC,
      \n\uC194\uC9C1\uD558\uACE0 \uBBF8\uC6CC\uD560 \uC218 \uC5C6\uB294 \uB9E4\uB825\uC73C\uB85C
      \uD300\uC758 \uD65C\uB825\uC744 \uBD88\uC5B4\uB123\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736826
    m_Localized: "\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 3\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736825
    m_Localized: "\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 2\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736824
    m_Localized: "\uB9F5 \uBC30\uCE58\uC6A9 \uD558\uD2F0"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736823
    m_Localized: "\uCE74\uB77C"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736822
    m_Localized: "\uC694\uD55C"
    m_Metadata:
      m_Items: []
  - m_Id: 3260753992736821
    m_Localized: "\uC544\uC2A4\uB098"
