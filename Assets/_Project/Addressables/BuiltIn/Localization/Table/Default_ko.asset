  - m_Id: 3067737930977847
    m_Localized: "\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 \uB4DC\uB860 Lv.3"
    m_Metadata:
      m_Items: []
  - m_Id: 3067737930977848
    m_Localized: "\uC0CC\uB4DC \uC2A4\uD1A0\uCEE4"
    m_Metadata:
