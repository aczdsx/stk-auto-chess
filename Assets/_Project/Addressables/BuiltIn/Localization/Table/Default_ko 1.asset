    m_Metadata:
      m_Items: []
  - m_Id: 50052977160
    m_Localized: "\uB9F5 \uBC30\uCE58\uC6A9 \uD558\uD2F0"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977161
    m_Localized: "\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 2\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977162
    m_Localized: "\uC2DC\uB828 \uB358\uC804 \uBCF4\uC2A4 3\uB2E8\uACC4"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977163
    m_Localized: "\uD50C\uB808\uC774\uC544\uB370\uC2A4\uC5D0\uC11C\uB294 \uB9C9\uB0B4
      \uD3EC\uC9C0\uC158\uC744 \uB2F4\uB2F9\uD558\uB294 \uAE30\uC0AC. \r\n\uC5B4\uB9B0
      \uB098\uC774\uC5D0 \uAE30\uC0AC\uAC00 \uB418\uC5C8\uB2E4\uB294 \uC0AC\uC2E4
      \uD558\uB098\uB9CC\uC73C\uB85C \uBAA8\uB450\uC758 \uADC0\uC5EC\uC6C0\uC744
      \uB3C5\uCC28\uC9C0\uD558\uB294\uAC00... \uC2F6\uC5C8\uC9C0\uB9CC \uD65C\uBC1C\uD558\uACE0
      \uD638\uAE30\uC2EC\uC774 \uB9CE\uC740 \uD0D3\uC5D0 \uC774\uB7F0\uC800\uB7F0
      \uC0AC\uAC74 \uC0AC\uACE0\uB3C4 \uD568\uAED8 \uC77C\uC73C\uD0A4\uACE0 \uB2E4\uB140
      \uB298 \uC794\uC18C\uB9AC\uB97C \uB4E3\uB294\uB2E4. \r\n\uC790\uC874\uAC10\uC774
      \uB192\uC73C\uBA70, \uB9C8\uCE58 \uBCF8\uC778\uC774 \uB300\uB2E8\uD55C \uC0AC\uB78C\uC778
      \uC591 \uB9D0\uD558\uACE4 \uD55C\uB2E4. \uB2E4\uC18C \uBC84\uB987\uC5C6\uAC8C
      \uBCF4\uC77C \uC218\uB3C4 \uC788\uC73C\uB098 \uADC0\uC5EC\uC6B0\uB2C8\uAE4C
      \uAD1C\uCC2E\uB2E4\uB294 \uB4EF. \r\n\uACE0\uD5A5\uC5D0 \uB300\uD574\uC11C
      \uC774\uC57C\uAE30\uD558\uBA74 \uC798 \uB300\uB2F5\uD558\uB824\uACE0 \uD558\uC9C0
      \uC54A\uB294\uB2E4. \r\n\uD50C\uB808\uC774\uC544\uB370\uC2A4\uC5D0\uC11C\uB294
      \uC8FC\uB85C \uC544\uD2B8\uB808\uC2DC\uC544, \uD544\uB9AC\uC544\uC640 \uD568\uAED8
      \uD589\uB3D9\uD558\uB294 \uD3B8\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977164
    m_Localized: "\uB113\uACE0 \uD070 \uB9C8\uC74C\uC528, \uC628\uD654\uD55C \uBBF8\uC18C\uB97C
      \uACB8\uBE44\uD55C MAID \uC131\uB2E8\uC758 \uAE30\uC0AC. \uAC00\uC7A5 \uC88B\uC544\uD558\uB294
      \uAC83\uB3C4 \uC694\uB9AC, \uAC00\uC7A5 \uC798\uD558\uB294 \uAC83\uB3C4 \uC694\uB9AC\uC774\uB2E4\u2026
      \uB77C\uACE0, \uBA54\uC774\uB294 \uB9D0\uD55C\uB2E4. \r\n\r\n\uADF8\uB7EC\uB098
      \uADF8\uB7F0 \uADF8\uB140\uC758 \uC8FC\uC7A5\uACFC\uB294 \uB2E4\uB974\uAC8C,
      \uADF8\uB140\uC758 \uC694\uB9AC\uB97C \uB9DB \uBCF8 \uC0AC\uB78C\uC740 \uD654\uC7A5\uC2E4\uACFC
      \uC624\uB79C \uC2DC\uAC04\uC744 \uD568\uAED8 \uBCF4\uB0B4\uAC8C \uB41C\uB2E4.
      \uC74C\uC2DD\uC758 \uB9DB\uB3C4 \uB9DB\uC774\uC9C0\uB9CC, \uC0DD\uAE40\uC0C8
      \uBD80\uD130\uAC00 \uC2EC\uC0C1\uCE58 \uC54A\uC740 \uBD84\uC704\uAE30\uB97C
      \uD48D\uAE34\uB2E4\uB294 \uAC83\uC774 \uAC00\uC7A5 \uD070 \uBB38\uC81C. \uADF8\uB140\uC758
      \uC190\uC5D0\uC11C\uB294 \uC81C\uC544\uBB34\uB9AC \uD3C9\uBC94\uD55C \uC2DD\uC7AC\uB8CC\uB85C
      \uB9CC\uB4E4\uC5B4\uC84C\uB2E4\uACE0 \uD558\uB354\uB77C\uB3C4, \uC9C0\uAD6C\uC0C1\uC5D0\uC11C
      \uB9DB\uBCFC \uC218 \uC5C6\uB294 \uC74C\uC2DD\uC774 \uD0C4\uC0DD\uD55C\uB2E4.
      \uC544\uC774\uB7EC\uB2C8\uD558\uAC8C\uB3C4 \uADF8\uB140 \uC790\uC2E0\uC740
      \uBCF8\uC778\uC774 \uB9CC\uB4E0 \uC694\uB9AC\uB97C \uC544\uBB34\uB9AC \uBA39\uC5B4\uB3C4
      \uBC30\uD0C8\uC774 \uB098\uC9C0 \uC54A\uB294\uB2E4. \r\n\r\n\uC694\uB9AC\uB97C
      \uBABB \uD55C\uB2E4\uB294 \uC810\uC744 \uC81C\uC678\uD558\uACE0\uB294, \uB530\uB73B\uD558\uACE0
      \uB2E4\uC815\uD55C \uC131\uACA9 \uB355\uBD84\uC778\uC9C0 \uC778\uAE30\uAC00
      \uB9CE\uB2E4. \uCD5C\uADFC\uC5D4 \uD0A4\uAC00 \uC791\uC740 \uAE30\uC0AC\uB4E4
      \uC0AC\uC774\uC5D0\uC11C \uADF8\uB140\uC758 \uD488\uC5D0 \uC548\uAE30\uB294
      \uD3ED\uC2E0 \uD14C\uB77C\uD53C\uAC00 \uC720\uD589\uD55C\uB2E4\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977165
    m_Localized: "\uC815\uB9D0\uB85C \uC55E\uC744 \uBCFC \uC218 \uC5C6\uB2E4. \uB54C\uBB38\uC5D0
      \uB298 \uB208\uC744 \uAC10\uACE0 \uB2E4\uB2CC\uB2E4. \uD558\uC9C0\uB9CC \uBAA8\uC885\uC758
      \uCD08\uAC10\uAC01\uC73C\uB85C \uC8FC\uBCC0 \uACF5\uAC04\uC744 \uC778\uC9C0\uD560
      \uC218 \uC788\uB2E4\uB294 \uB4EF. \uB2E8\uB2E8\uD558\uAC8C \uD2B9\uC218 \uCC98\uB9AC\uB418\uC5B4
      \uB9CC\uB4E4\uC5B4\uC9C4 \uC2DC\uB77C\uC0AC\uC57C\uB97C \uC8FC \uBB34\uAE30\uB85C
      \uC0BC\uB294\uB2E4. \n\uC6D0\uB798 \uD574\uB2F9 \uCE7C\uB0A0\uC5D0 \uC81C \uC9DD\uC73C\uB85C
      \uB9CC\uB4E4\uC5B4\uC9C4 \uCE7C\uC9D1\uACFC \uCE7C\uC790\uB8E8, \uCF54\uB4F1\uC774\uAC00
      \uC788\uC73C\uB098 \uB204\uAD70\uAC00\uC5D0\uAC8C \uBE7C\uC557\uACBC\uB2E4\uACE0
      \uD55C\uB2E4. \n\uC790\uC2E0\uC744 \uC4F0\uB7EC\uD2B8\uB9AC\uACE0 \uB208\uC744
      \uC557\uC544\uAC04 \uB4A4 \uCE7C\uB0A0\uB9CC \uB0A8\uAE30\uACE0 \uAC04 \uC6D0\uC218\uB97C
      \uCC3E\uB294 \uAC83\uC774 \uAC1C\uC778\uC801 \uBAA9\uD45C. \n\uB54C\uBB38\uC5D0
      \uADF8 \uC77C\uC5D0 \uD611\uB825\uD574\uC8FC\uACA0\uB2E4\uACE0 \uD558\uBA74
      \uC55E\uB4A4 \uC548 \uAC00\uB9AC\uACE0 \uD611\uC870\uD55C\uB2E4. \n\uB2E4\uB9CC
      \uB208\uC5D0 \uB300\uD574\uC11C \uBB3C\uC5B4\uBCF4\uAC70\uB098 \uD558\uBA74
      \uC2F8\uB298\uD574\uC9C0\uB294 \uD3B8."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977166
    m_Localized: "\uC77C\uBD80\uB7EC \uAC70\uCE5C \uB9D0\uC744 \uB0B4\uBC49\uAC70\uB098,
      \uC637\uC744 \uC5B4\uC815\uCA61\uD558\uAC8C \uC785\uB294 \uB4F1 \uC5D8\uD53C\uC2A4\uC758
      \uCE58\uC548 \uB2F4\uB2F9 \uAE30\uC0AC\uB77C\uACE0\uB294 \uC0DD\uAC01\uD560
      \uC218 \uC5C6\uC744 \uC815\uB3C4\uB85C \uBD88\uB7C9\uC2A4\uB7FD\uAC8C \uBCF4\uC774\uB294
      \uAE30\uC0AC. \uC5B4\uB9B0 \uC2DC\uC808\uBD80\uD130 \uC5C4\uD558\uACE0 \uC9C4\uC911\uD588\uB358
      \uC544\uBC84\uC9C0 \uBC11\uC5D0\uC11C \uC790\uB790\uB358 \uD0D3\uC778\uC9C0
      \uC790\uC720\uC640 \uBC18\uD56D\uC5D0 \uB300\uD55C \uAC08\uB9DD\uC774 \uCEE4
      \uBCF4\uC778\uB2E4. \n\uD558\uC9C0\uB9CC \uC5B4\uC6B8\uB9AC\uC9C0 \uC54A\uB294
      \uC637\uC744 \uC785\uC740 \uB4EF\uD55C \uB290\uB08C\uC774 \uB4DC\uB294 \uAC83\uC740
      \uCC29\uAC01\uC77C\uAE4C? \uADF8\uB140\uC758 \uD589\uB3D9\uC740 \uAC89\uC73C\uB85C
      \uBCF4\uC774\uB294 \uB9D0\uACFC \uC678\uBAA8\uC640 \uB2EC\uB9AC \uC815\uC9C1\uD558\uACE0,
      \uC815\uC758\uB86D\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977167
    m_Localized: "\uC8FC\uBCC0\uC744 \uB530\uB4EF\uD558\uAC8C \uBC1D\uD600\uC8FC\uB294
      \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977168
    m_Localized: "\uC791\uACE0 \uADC0\uC5EC\uC6B4 \uC0C8\uB97C \uB370\uB9AC\uACE0
      \uB2E4\uB2C8\uB294 \uAE30\uC0AC.\r\n\r\n\uC0C8\uC640 \uB300\uD654\uD560 \uC218
      \uC788\uB2E4. \uC815\uD655\uD788\uB294, \uC0C8\uC640 \uAD50\uAC10\uD560 \uC218
      \uC788\uC5B4 \uC758\uC0AC\uC18C\uD1B5\uC774 \uAC00\uB2A5\uD55C \uAC83\uCC98\uB7FC
      \uBCF4\uC778\uB2E4. \uB298 \uC6C3\uB294 \uC5BC\uAD74\uB85C \uAC19\uC740 \uC131\uB2E8
      \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC6B4\uC744 \uBD81\uB3CB\uC6B0\uB294 \uC5ED\uD560\uC744
      \uD574\uB0B4\uBA70, \uADF8\uB140\uC758 \uBC18\uB824 \uC0C8 '\uD53C\uCF54'\uC758
      \uAC1C\uC778\uAE30\uB3C4 \uBE7C\uB193\uC744 \uC218 \uC5C6\uB294 \uADF8\uB140\uC758
      \uC790\uB791\uC774\uB2E4. \r\n\r\n\uC2A4\uD154\uB77C\uB098\uC774\uCE20\uAC00
      \uB41C \uC774\uC720\uB3C4 \uC790\uC2E0\uC758 \uBC18\uB824 \uC0C8 '\uD53C\uCF54'\uC640
      \uD568\uAED8 \uD3C9\uD654\uAC00 \uCC3E\uC544\uC628 \uC544\uB984\uB2E4\uC6B4
      \uC138\uC0C1\uC744 \uC790\uC720\uB86D\uAC8C \uC5EC\uD589\uD558\uACE0 \uC2F6\uC5C8\uAE30
      \uB54C\uBB38\uC774\uB77C\uACE0. \uB2E4\uC18C \uAC00\uBCBC\uC6B4 \uC774\uC720\uB85C
      \uBCF4\uC774\uC9C0\uB9CC, \uD5C8\uBE14\uC740 \uADF8\uB140\uC5D0\uAC8C \uB0A8\uC740
      \uAC00\uC871\uC774 \uBC18\uB824\uC0C8\uBC16\uC5D0 \uC5C6\uB2E4\uB294 \uC810\uC744
      \uBBF8\uB8E8\uC5B4 \uADF8\uB140\uC758 \uAC00\uC871\uB4E4\uC740 \uBAA8\uB450
      \uB124\uD53C\uB9BC\uC5D0\uAC8C \uC8FD\uC784\uB2F9\uD588\uC744 \uAC83\uC73C\uB85C
      \uCD94\uCE21\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977169
    m_Localized: "\uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC758 \uB9C8\uC2A4\uCF54\uD2B8\uACA9
      \uAE30\uC0AC. \uB298 \uBC1D\uC740 \uBBF8\uC18C\uC640 \uC120\uD55C \uC5B8\uD589\uC73C\uB85C
      \uC0AC\uB78C\uB4E4\uC5D0\uAC8C \uC88B\uC740 \uC778\uC0C1\uC744 \uC8FC\uACE0
      \uB2E4\uB2CC\uB2E4.  \uB355\uBD84\uC5D0 \uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC758
      \uB300\uC678\uC801\uC778 \uC774\uBBF8\uC9C0 \uAD00\uB9AC\uC758 1\uB4F1 \uACF5\uC2E0\uC774\uBA70,
      \uD5C8\uBE14 \uB0B4\uC5D0\uC11C\uB294 \uADF8\uB140\uB97C \uBAA8\uB974\uB294
      \uC0AC\uB78C\uC774 \uC5C6\uC744 \uC815\uB3C4\uB85C \uC720\uBA85\uD558\uB2E4.\r\n\r\n\uBB34\uD574\uD558\uACE0
      \uADC0\uC5EC\uC6B4, \uCC9C\uC9C4\uB09C\uB9CC\uD55C \uC18C\uB140. \uC5B4\uB978\uC2A4\uB7FD\uACE0
      \uC0DD\uAC01\uC774 \uAE4A\uC5B4, \uBC30\uB824\uC2EC\uC774 \uB0A8\uB2E4\uB978
      \uAE30\uC0AC. \uD558\uC9C0\uB9CC \uC774 \uAE0D\uC815\uC801\uC778 \uC218\uC2DD\uC5B4\uB4E4\uC740,
      \uC568\uB9AC\uC2A4\uC758 \uC9C4\uC9DC \uB9C8\uC74C\uC744 \uC228\uAE30\uACE0
      \uBC1B\uC544\uB0B8 \uAC83\uB4E4\uC774\uB2E4. \uAC89\uC73C\uB85C\uB294 \uD30C\uB780\uC0C9\uC774
      \uC88B\uB2E4\uACE0 \uD558\uC9C0\uB9CC, \uC0AC\uC2E4\uC740 \uBE68\uAC04\uC0C9\uC744
      \uC88B\uC544\uD55C\uB2E4. \uC138\uB828\uB418\uACE0 \uC2EC\uD50C\uD55C \uB514\uC790\uC778\uC774
      \uC88B\uB2E4\uACE0 \uD558\uC9C0\uB9CC, \uBC29 \uC548\uC5D0\uB294 \uADC0\uC5EC\uC6B4
      \uC778\uD615\uC774 \uAC00\uB4DD\uD558\uB2E4. \uD558\uAE30 \uC2EB\uC740 \uC77C\uC774\uC5C8\uC9C0\uB9CC,
      \uC2EB\uB354\uB77C\uB3C4 \uD574\uC57C\uB9CC \uD55C\uB2E4. \uB124\uD53C\uB9BC\uC740
      \uBB34\uC12D\uC9C0\uB9CC, \uBB34\uC12D\uC9C0 \uC54A\uC740 \uCC99 \uD55C\uB2E4.
      \uC568\uB9AC\uC2A4\uB294 \uCC29\uD558\uB2C8\uAE4C.\r\n\r\n\uC774\uB7EC\uD55C
      \uADF8\uB140\uC758 \uC9C4\uC2EC\uC744 \uC54C\uACE0 \uC788\uB294 \uAE30\uC0AC\uB294
      \uD5C8\uBE14\uC5D0\uC11C\uB3C4 \uC190\uAC00\uB77D \uC548\uC5D0 \uAF3D\uB294\uB2E4\uACE0
      \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977170
    m_Localized: "\uC21C\uC9C4\uD574\uBCF4\uB294 \uAC89\uBAA8\uC2B5\uACFC \uB2E4\uB974\uAC8C
      \uB9E4\uC6B0 \uD749\uD3EC\uD55C \uC2EC\uC131\uC744 \uAC00\uC9C4 \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977171
    m_Localized: "\uB0B4\uBD80\uC5D0\uC11C \uB05D\uC5C6\uC774 \uCE58\uC19F\uB294
      \uC5F4 \uC5D0\uB108\uC9C0\uB85C \uC778\uD574 \uD654\uC0C1\uC744 \uC785\uC5B4\uBC84\uB9AC\uB294
      \uD2B9\uC774\uCCB4\uC9C8\uC744 \uAC00\uC9C4 \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977172
    m_Localized: "\uD638\uAE30\uC2EC\uC744 \uD574\uACB0\uD558\uAE30 \uC704\uD574\uC11C\uB77C\uBA74
      \uC218\uB2E8\uACFC \uBC29\uBC95\uC744 \uAC00\uB9AC\uC9C0 \uC54A\uB294\uB2E4.
      \uADF8\uAC83\uC774 \uC544\uB518\uC758 \uCCA0\uCE59\uC774\uB2E4. \r\n\r\n\uD5E4\uC544\uB9B4
      \uC218 \uC5C6\uB294 \uC2EC\uC5F0, \uD558\uB298\uC744 \uB4A4\uB36E\uC740 \uBCF4\uB77C\uBE5B
      \uAE30\uCCB4, \uC774 \uBAA8\uB4E0 \uC0C1\uD669\uC740 \uBAA8\uD5D8\uC2EC \uAC15\uD55C
      \uC18C\uB140\uB97C \uAC00\uC2B4 \uB6F0\uAC8C \uD588\uB2E4. \uB9C8\uCE58 \uBBF8\uC9C0\uC758
      \uC138\uACC4\uB97C \uC5EC\uD589\uD558\uB294 \uBAA8\uD5D8\uAC00\uCC98\uB7FC,
      \uC544\uB518\uC740 \uC2A4\uC2A4\uB85C\uC5D0\uAC8C \uC8FC\uC5B4\uC9C4 \uC6B4\uBA85\uC744
      \uAE30\uC058\uAC8C \uBC1B\uC544\uB4E4\uC600\uB2E4. \uBAA8\uD5D8 \uC911\uC5D0
      \uC0DD\uAE34 \uC0C1\uCC98\uB294, \uC601\uAD11\uC758 \uC0C1\uCC98\uC5D0 \uBD88\uACFC\uD558\uB2E4.\r\n\r\n\uB2E4\uB9CC,
      \uD638\uAE30\uC2EC\uC774 \uB108\uBB34 \uAC15\uD55C \uD0D3\uC5D0 \uD5C8\uBE14\uC5D0\uC11C
      \uC0AC\uACE0\uB97C \uAC00\uC7A5 \uB9CE\uC774 \uCE58\uACE0 \uB2E4\uB2C8\uB294
      \uAE30\uC0AC\uB85C \uAC70\uB860\uB418\uAE30\uB3C4 \uD55C\uB2E4. \uC544\uCE74\uB370\uBBF8
      \uC131\uB2E8\uC5D0\uC11C \uC77C\uC5B4\uB098\uB294 \uD06C\uACE0 \uC791\uC740
      \uC0AC\uACE0\uB294 \uBCF4\uD1B5 \uC544\uB518\uC744 \uC911\uC2EC\uC73C\uB85C
      \uC77C\uC5B4\uB098\uBA70, \uD55C\uCC3D \uC790\uC2E0\uB9CC\uC758 \uC138\uACC4\uC5D0
      \uBE60\uC838 \uC0AC\uB294 \uC9C8\uD48D\uB178\uB3C4\uC758 \uC2DC\uAE30\uB97C
      \uACAA\uACE0 \uC788\uC5B4 \uC790\uC8FC \uC8FC\uBCC0\uC758 \uCC59\uAE40\uC744
      \uBC1B\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977173
    m_Localized: "\uBD80\uC790\uAC00 \uB418\uACE0 \uC2F6\uC740 \uC5EC\uC6B0 \uC18C\uB140,
      \uB8E8\uD0A4\uB2E4\r\n\r\n\uC138\uC0C1\uC5D0 \uB3C8\uC73C\uB85C \uD574\uACB0\uB418\uC9C0
      \uC54A\uB294 \uC77C\uC740 \uC5C6\uC73C\uBA70, \uB9CC\uC57D \uC548 \uB418\uB294
      \uC77C\uC774 \uC788\uB2E4\uBA74, \uADF8\uAC74 \uB3C8\uC774 \uBD80\uC871\uD588\uB358
      \uD0D3\uC774\uB77C\uACE0 \uBBFF\uB294\uB2E4. \uB9C9\uB9D0\uB85C \uB3C8\uB9CC
      \uC900\uB2E4\uBA74 \uC2E0\uBC1C\uB3C4 \uD565\uC744 \uC218 \uC788\uB2E4\uACE0.
      \uADF8\uB140\uB97C \uC6C0\uC9C1\uC774\uACE0 \uC2F6\uB2E4\uBA74 \uD569\uB2F9\uD55C
      \uB300\uAC00\uB97C \uC9C0\uBD88\uD574\uC57C\uB9CC \uD55C\uB2E4.\r\n\r\n\uC774\uB7EC\uD55C
      \uAC00\uCE58\uAD00 \uB355\uBD84\uC5D0 \uB3C8 \uACC4\uC0B0\uC5D0 \uAD49\uC7A5\uD788
      \uCCA0\uC800\uD55C \uD3B8\uC774\uB2E4. \uB204\uAD70\uAC00\uC5D0\uAC8C \uBE5A\uC9C0\uB294
      \uC77C\uC740 \uC808\uB300 \uB9CC\uB4E4\uC9C0 \uC54A\uC73C\uBA70, \uC735\uD1B5\uC131
      \uC788\uB294 \uCC99 \uB108\uC2A4\uB808\uB294 \uB5A8\uC9C0\uB9CC, \uD589\uB3D9\uC740
      \uD655\uC2E4\uD558\uB2E4. \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB85C\uC11C
      \uC218\uD589\uD558\uB294 \uC784\uBB34 \uB610\uD55C \uADF8\uB140\uC5D0\uAC8C\uB294 
      \u2018\uC77C'\uB85C \uC815\uB9AC\uB418\uAE30 \uB54C\uBB38\uC5D0 \uC608\uC0C1\uCE58
      \uBABB\uD55C \uCD94\uAC00 \uADFC\uBB34 \uB4F1\uC5D0\uB294 \uAD49\uC7A5\uD788
      \uCDE8\uC57D\uD55C \uBAA8\uC2B5\uC744 \uBCF4\uC774\uACE4 \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977174
    m_Localized: "\uB4F1\uC5D0 \uC774\uACE0 \uB2E4\uB2C8\uB294 \uCEE4\uB2E4\uB780
      \uAD00\uC774 \uC778\uC0C1 \uAE4A\uC740 \uAE30\uC0AC. \r\n\r\n\uAC70\uB300\uD558\uACE0
      \uC815\uAD50\uD55C \uAD00\uC774 \uBCF4\uB294 \uC0AC\uB78C\uC73C\uB85C \uD558\uC5EC\uAE08
      \uACF5\uD3EC\uAC10\uC744 \uBD88\uB7EC\uC77C\uC73C\uD0A4\uACE4 \uD558\uC9C0\uB9CC,
      \uADF8 \uC4F0\uC784\uC0C8\uB294 \uC0C1\uB0E5(?)\uD55C \uD3B8\uC774\uB2E4. \uC8FC\uB85C
      \uC6C0\uC9C1\uC77C \uC218 \uC5C6\uB294 \uD658\uC790\uB97C \uC548\uC804\uD558\uAC8C
      \uC62E\uACA8\uC57C \uD560 \uB54C \uC0AC\uC6A9\uD558\uBA70, \uBB34\uD574\uD558\uAC8C
      \uBCF4\uC774\uACE0 \uC2F6\uC5B4\uC11C \uD770\uC0C9 \uAD00\uC5D0 \uC608\uC05C
      \uD551\uD06C\uC0C9\uC73C\uB85C \uC2ED\uC790\uAC00 \uBAA8\uC591\uC744 \uADF8\uB838\uB2E4. 
      \r\n\r\n\uC0AC\uB78C\uB4E4\uC5D0\uAC8C \uBB34\uC11C\uC6C0\uC744 \uC2EC\uC5B4\uC8FC\uB294
      \uAC83 \uCE58\uACE0\uB294, \uBCF8\uC778 \uAC81\uC774 \uB9CE\uC740 \uD3B8\uC774\uB2E4.
      \uC791\uC740 \uC18C\uB9AC\uC5D0\uB3C4 \uC798 \uB180\uB77C\uBA70, \uC0AC\uB78C\uACFC
      \uB300\uD654\uD558\uB294 \uAC83\uC5D0\uB3C4 \uC27D\uAC8C \uD53C\uB85C\uAC10\uC744
      \uB290\uB080\uB2E4. \uAD73\uC774 \uAD00\uC744 \uC774\uACE0 \uB2E4\uB2C8\uB294
      \uC774\uC720\uB294 \uAD00\uC774 \uC8FC\uB294 \uACE0\uC694\uD568\uACFC \uD3B8\uC548\uD568\uC774
      \uC88B\uAE30 \uB54C\uBB38\uC774\uB77C\uACE0 \uD55C\uB2E4. \uB9CC\uC57D \uADF8\uB140\uAC00
      \uAC11\uC790\uAE30 \uBCF4\uC774\uC9C0 \uC54A\uB294\uB2E4\uBA74, \uADF8\uB140
      \uBC29\uC5D0 \uC788\uB294 \uAD00\uC744 \uC5F4\uC5B4\uBCF4\uC790. \uD3B8\uC548\uD55C
      \uC5BC\uAD74\uB85C \uC7A0\uB4E4\uC5B4 \uC788\uB294 \uADF8\uB140\uB97C \uBCFC
      \uC218 \uC788\uC744 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977175
    m_Localized: "\uB530\uC0AC\uB85C\uC6B4 \uD587\uC0B4\uACFC \uAC19\uC740 \uC628\uD654\uD55C
      \uBBF8\uC18C, \uC6B0\uC544\uD55C \uBAB8\uC9D3, \uBD80\uB4DC\uB7EC\uC6B4 \uC5B8\uD589.
      \uC5B4\uB514\uB85C \uBCF4\uB098 \uC131\uC219\uD55C \uC219\uB140\uC758 \uBD84\uC704\uAE30\uB97C
      \uD48D\uAE30\uB294 \uAE30\uC0AC. MAID\uC5D0\uC11C\uB294 \uBA85\uC2E4\uC0C1\uBD80\uD558\uAC8C
      \uB9AC\uB354\uC758 \uC5ED\uD560\uC744 \uB9E1\uACE0 \uC788\uB2E4.\nMAID \uC131\uB2E8\uC5D0
      \uC18D\uD55C \uAE30\uC0AC\uB4E4\uC740 \uC73C\uB808 \uADF8\uB807\uC9C0\uB9CC,
      \uC5D0\uC774\uD504\uB9B4\uC740 \uD2B9\uD788 \uD0C0\uC778\uC5D0 \uB300\uD55C
      \uBC30\uB824\uC2EC\uC774 \uAE4A\uACE0, \uB610 \uC774\uD0C0\uC2EC\uC774 \uB9CE\uC544
      \uBD09\uC0AC\uD558\uB294 \uC77C\uC5D0 \uC775\uC219\uD558\uB2E4. \uD5C8\uBE14\uC758
      \uAC00\uC0AC \uB178\uB3D9, \uC2DC\uC124 \uAD00\uB9AC, \uAE30\uC0AC\uB4E4\uACFC
      \uAD70\uC778, \uC5F0\uAD6C\uC6D0\uB4E4\uC758 \uC2DD\uC0AC\uB97C \uCC45\uC784\uC9C0\uACE0
      \uC788\uB294 \uC131\uB2E8\uC73C\uB85C\uC11C \uB2F9\uC5F0\uD55C \uC77C\uC774\uC9C0\uB9CC,
      \uAD00\uCE21\uC790\uC758 \uC219\uC18C \uAD00\uB9AC\uB3C4 \uB3C4\uB9E1\uC544
      \uD558\uACE0 \uC788\uB2E4. \n\uADF8\uB7EC\uB098 4\uC6D4\uC758 \uD587\uC0B4
      \uAC19\uAE30\uB9CC \uD55C \uC5D0\uC774\uD504\uB9B4\uC758 \uBBF8\uC18C\uC5D0
      \uB118\uC5B4\uAC14\uB2E4\uBA74, \uC6C3\uC74C \uB4A4\uC5D0 \uC228\uC740 \uAC80\uC740
      \uCD1D\uAD6C\uB97C \uC870\uC2EC\uD558\uC790. \uADF8\uB140\uC758 \uD3ED\uC2E0\uD55C
      \uCE58\uB9DB\uD3ED \uC18D\uC5D0\uB294 \uADF8\uB140\uC758 \uC2A4\uD154\uB8F8,
      \uC610\uB85C\uC6B0 \uBC14\uC774\uC62C\uB81B\uC744 \uC228\uAE30\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977176
    m_Localized: "\uC2E4\uD5D8\uD558\uB294 \uAC83 \uC678\uC5D0 \uBAA8\uB4E0 \uAC83\uC744
      \uADC0\uCC2E\uC544\uD558\uB294 \uAD34\uC9DC \uACFC\uD559\uC790. \uBC18\uB300\uB85C
      \uB9D0\uD574, \uAC01\uC885 \uD604\uC0C1 \uAD00\uCC30\uACFC \uBB3C\uC9C8 \uD569\uC131\uC5D0
      \uAD00\uC2EC\uC774 \uB9CE\uC740 \uC2E4\uD5D8 \uB9C8\uB2C8\uC544\uB2E4. \uD2B9\uD788
      \uB9F9\uB3C5\uC131 \uD654\uD559 \uBB3C\uC9C8 \uD569\uC131\uC5D0\uB294 \uADF8\uB140\uB97C
      \uB530\uB77C\uC62C \uC790\uAC00 \uC5C6\uB2E4. \n\uD3C9\uC18C \uD589\uC2E4\uC740
      \uAC8C\uC73C\uB974\uAE30 \uADF8\uC9C0\uC5C6\uB2E4. \uC815\uD655\uD788 \uB9D0\uD574\uC11C,
      \uB9CC\uC0AC\uB97C \uADC0\uCC2E\uC544\uD55C\uB2E4. \uC2EC\uC9C0\uC5B4\uB294
      \uC7A0\uC790\uB294 \uAC83 \uC870\uCC28 \uADC0\uCC2E\uB2E4\uBA70 \uC5D0\uB108\uC9C0
      \uC74C\uB8CC\uB97C \uB4E4\uC774\uD0A4\uAE30 \uBD80\uC9C0\uAE30\uC218. \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB2F5\uC9C0
      \uC54A\uC740 \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uB77C\uACE0 \uD560 \uC218
      \uC788\uB2E4. \uC778\uB958 \uC874\uC18D\uBCF4\uB2E4\uB294 \uB124\uD53C\uB9BC\uC758
      \uAD6C\uC870, \uAC8C\uC774\uD2B8\uC640 \uD558\uB298\uC5D0 \uC0DD\uAE34 \uC774\uC0C1
      \uD604\uC0C1 \uB4F1\uC5D0 \uAD00\uC2EC\uC774 \uB354 \uB9CE\uB2E4. \n\uADF8\uB140\uC758
      \uC8FC\uB41C \uC5F0\uAD6C \uC18C\uC7AC\uC5D0\uB294 \uAD00\uCE21\uC790\uB3C4
      \uD3EC\uD568\uB41C\uB2E4. \uADF8\uB140\uC758 \uC9C1\uAC10\uC774\uC9C0\uB9CC,
      \u2018\uAD00\uCE21\uC790\uC5D0\uAC8C\uB294 \uAE4C\uB3C4 \uAE4C\uB3C4 \uACC4\uC18D
      \uBB34\uC5B8\uAC00 \uB098\uC62C \uAC83\uB9CC \uAC19\uC740 \uB0C4\uC0C8\uAC00
      \uB09C\uB2E4\u2019\uB294 \uB4EF\uD558\uB2E4. \uB355\uBD84\uC5D0 \uAD00\uCE21\uC790\uB294
      \uB77C\uD0A4\uC720\uC5D0\uAC8C \uC774\uB9AC\uC800\uB9AC \uB04C\uB824\uB2E4\uB2C8\uBA70
      \uC2E4\uD5D8\uC6A9 \uC950 \uC2E0\uC138\uAC00 \uB418\uACE4 \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977177
    m_Localized: "\uB9E5\uC8FC\uB294 \uBCA0\uC778\uC5D0\uAC8C \uC788\uC5B4 \uBE7C\uB193\uC744
      \uC218 \uC5C6\uB294 \uC74C\uB8CC\uC774\uB2E4. \uD2B9\uD788 \uBC00\uB9E5\uC8FC\uC5D0
      \uAC01\uBCC4\uD55C \uC560\uC815\uC744 \uAC16\uACE0 \uC788\uC73C\uBA70, \uBA54\uC2DC\uC5D041
      \uC131\uB2E8\uC774 \uBE44\uBC88\uC778 \uB0A0\uC5D4 \uC885\uC885 \uBCA0\uC778\uC758
      \uC591 \uBEA8\uC774 \uBD89\uC5B4\uC9C4 \uBAA8\uC2B5\uC744 \uBCFC \uC218 \uC788\uB2E4.
      \uC5B8\uC820\uAC00 \uBC00\uC744 \uC7AC\uBC30\uD558\uB294 \uB18D\uBD80\uAC00
      \uB418\uC5B4, \uC9C1\uC811 \uC7AC\uBC30\uD55C \uBC00\uB85C \uB9E5\uC8FC\uB97C
      \uB9CC\uB4E4\uC5B4 \uB9C8\uC2DC\uACA0\uB2E4\uB294 \uBC84\uD0B7\uB9AC\uC2A4\uD2B8\uB97C
      \uAC00\uC9C0\uACE0 \uC788\uC744 \uC815\uB3C4. \uC220\uC744 \uC990\uAE30\uACE0,
      \uC798 \uB9C8\uC2DC\uB294 \uD3B8\uC774\uC9C0\uB9CC \uC220\uC5D0 \uCDE8\uD55C
      \uADF8\uB140\uB294 \uC5C4\uCCAD\uB09C \uC794\uC18C\uB9AC\uC7C1\uC774\uAC00
      \uB41C\uB2E4. \uB9CC\uC57D \uD3C9\uC18C\uC5D0 \uADF8\uB140 \uC55E\uC5D0\uC11C
      \uC2E4\uC218\uD55C \uAC83\uC774 \uC788\uB2E4\uBA74, \uC870\uC2EC\uD558\uB3C4\uB85D
      \uD558\uC790. \n\uB178\uB825\uC758 \uC911\uC694\uC131\uC744 \uAD49\uC7A5\uD788
      \uB192\uAC8C \uD3C9\uAC00\uD55C\uB2E4. \uC2A4\uC2A4\uB85C \uBABB \uD558\uB294
      \uAC83\uC774 \uC788\uB2E4\uBA74, \uC5B4\uB5BB\uAC8C \uD574\uC11C\uB4E0 \uC798\uD558\uAC8C
      \uB420 \uB54C\uAE4C\uC9C0 \uACF5\uBD80\uD558\uAC70\uB098, \uC5F0\uC2B5\uD558\uAC70\uB098,
      \uB3C4\uC804\uD55C\uB2E4. \uBC18\uB300\uB85C \uB178\uB825\uC73C\uB85C \uADF9\uBCF5\uD558\uAE30
      \uC5B4\uB824\uC6B4 \uC694\uC18C, \uAD6C\uCCB4\uC801\uC73C\uB85C \uC6B4\uC774
      \uC791\uC6A9\uD558\uB294 \uAC83\uC5D0\uB294 \uC57D\uD55C \uBAA8\uC2B5\uC744
      \uBCF4\uC774\uB294\uB370, \uC774\uC870\uCC28\uB3C4 \uB178\uB825\uC73C\uB85C
      \uADF9\uBCF5\uD558\uACE0\uC790 \uC2DC\uB3C4\uD558\uC9C0\uB9CC, \uB9E4\uBC88
      \uC2E4\uD328\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977178
    m_Localized: "\uAD49\uC7A5\uD55C \uC644\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uB294
      \uC2A4\uD154\uB77C \uB098\uC774\uCE20"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977179
    m_Localized: "\uCC9C\uC7AC \uACFC\uD559\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977180
    m_Localized: "\uC644\uBCBD\uC8FC\uC758 \uC2A4\uB098\uC774\uD37C"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977181
    m_Localized: "\uC131\uD754\uC774 \uC0C8\uACA8\uC9C0\uC9C0 \uC54A\uC740 \uC720\uC77C\uD55C
      \uC2A4\uD154\uB77C\uB098\uC774\uCE20.\n\uAD00\uCE21\uD55C \uBCC4\uC758 \uD574\uC11D\uC5D0\uB294
      \uC131\uACF5\uD588\uC73C\uB098, \uC544\uC774\uB7EC\uB2C8\uD558\uAC8C\uB3C4
      \uADF8 \uBCC4\uC740 \uC54C \uC218 \uC5C6\uC5C8\uB2E4. \uADF8\uAC83\uC774 \uD5C8\uBE14\uC774
      \uB0B4\uB9B0 \uACB0\uB860\uC774\uC5C8\uB2E4. \uC774\uC5D0 \uC544\uD2B8\uB808\uC2DC\uC544\uB294
      \uC2A4\uD154\uB77C\uB098\uC774\uCE20 \uCD5C\uCD08\uC774\uC790 \uC720\uC77C\uD55C
      \u2018\uC131\uD754\u2019\uC774 \uC5C6\uB294 \uAE30\uC0AC\uB85C \uACF5\uD45C\uB418\uC5C8\uACE0,
      \uC774 \uAF2C\uB9AC\uD45C\uB294 \uB298 \uADF8\uB140 \uB4A4\uB97C \uB530\uB77C\uB2E4\uB154\uB2E4.
      <unknown>\uC740 \uC131\uD754\uC774 \uC5C6\uB294 \uAE30\uC0AC, \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uBD99\uC5EC\uC9C4 \uC774\uBA85\uC774\uB2E4. \n\uBE44\uAD50\uC801 \uBCFC \uD488
      \uC5C6\uB294 \uBCC4\uB4E4\uB9CC \uBAA8\uC778\uB2E4\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4
      \uC131\uB2E8\uC5D0 \uC18C\uC18D\uB418\uC5B4 \uC788\uB2E4. \uADF8\uB7EC\uB098
      \uBC16\uC758 \uC2DC\uC120\uACFC\uB294 \uB2E4\uB974\uAC8C \uC131\uB2E8 \uB0B4
      \uC720\uB300\uB294 \uAC74\uAC15\uD558\uB2E4\uB294 \uB4EF. \uB355\uBD84\uC5D0
      \uCC98\uC74C\uC5D4 \uC758\uAE30\uC18C\uCE68\uD558\uACE0 \uC18C\uADF9\uC801\uC778
      \uBAA8\uC2B5\uC758 \uADF8\uB140\uC600\uC9C0\uB9CC, \uB3D9\uB8CC\uB4E4\uACFC
      \uB530\uC2A4\uD55C \uAC10\uC815\uC744 \uB098\uB204\uBA70 \uC810\uCC28 \uBC1D\uC740
      \uBAA8\uC2B5\uC744 \uB418\uCC3E\uC544 \uAC00\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977182
    m_Localized: "\uC30D\uCC3D\uC758 \uB2EC\uC778"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977183
    m_Localized: "\uC804\uC2E0\uC758\uCCB4"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977184
    m_Localized: "\uC0C1\uB0E5\uD55C \uC131\uC815\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uB85C,
      \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC131\uB2E8\uC758 \uB9CF\uC5B8\uB2C8
      \uC5ED\uD560\uC744 \uB9E1\uACE0 \uC788\uB2E4. \r\n\uACFC\uAC70 \uBD88\uBBF8\uC2A4\uB7EC\uC6B4
      \uC77C\uB85C \uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC5D0\uC11C \uD1F4\uCD9C\uB2F9\uD558\uC5EC
      \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC131\uB2E8\uC73C\uB85C \uC62E\uAE34
      \uBCC4. \uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC5D0\uC11C \uC5B4\uB5A4 \uC77C\uC774
      \uC788\uC5C8\uB294\uC9C0, \uC65C \uC62E\uACBC\uB294\uC9C0 \uC544\uBB34\uB7F0
      \uC774\uC57C\uAE30\uB3C4 \uD558\uC9C0 \uC54A\uC558\uB2E4. \uC624\uD788\uB824
      \uADF8\uB140\uB294 \uB2F4\uB2F4\uD55C \uD0DC\uB3C4\uB97C \uBCF4\uC774\uBA70
      \uADF8\uB140\uC758 \uC9C4\uC2EC\uC744 \uB9C8\uC74C \uAE4A\uC740 \uACF3\uC5D0
      \uBC00\uC5B4 \uB123\uC5C8\uB2E4.\r\n\uD50C\uB808\uC774\uC544\uB370\uC2A4\uC758
      \uAE30\uC0AC\uB4E4\uC740 \uADF8\uB7F0 \uADF8\uB140\uB97C \uC544\uBB34\uB7F0
      \uB9D0 \uC5C6\uC774 \uB530\uB73B\uD558\uAC8C \uB9DE\uC774\uD574 \uC8FC\uC5C8\uB2E4.
      \uC900\uBE44\uAC00 \uB420 \uB54C\uAE4C\uC9C0 \uAE30\uB2E4\uB824 \uC8FC\uACA0\uB2E4\uB294
      \uB4EF\uC774. \uC9C0\uAE08\uC740 \uD074\uB808\uC774 \uB610\uD55C \uD50C\uB808\uC774\uC544\uB370\uC2A4\uC758
      \uBCC4\uB4E4\uC5D0\uAC8C \uB9CE\uC774 \uC758\uC9C0\uD558\uB294 \uBAA8\uC2B5\uC744
      \uBCF4\uC778\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977185
    m_Localized: "\uADC0\uCC28\uB2C8\uC998 \uC554\uC0B4\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977186
    m_Localized: "\uC218\uB824\uD55C \uC678\uBAA8\uC640 \uD558\uC580 \uC774\uBBF8\uC9C0,
      \uD0C1\uC6D4\uD55C \uC2E4\uB825\uC73C\uB85C \uC77C\uBC18 \uC2DC\uBBFC\uB4E4
      \uC0AC\uC774\uC5D0\uC11C\uB294 \u2018\uCC9C\uC0AC\u2019\uB85C \uD1B5\uD55C\uB2E4.
      \uADF8\uB7EC\uB098 \uC544\uB984\uB2E4\uC6B4 \uC678\uBAA8\uC5D0 \uADF8\uB7EC\uC9C0
      \uBABB\uD55C \uC131\uACA9\uC744 \uAC00\uC9C0\uACE0 \uC788\uC5B4 \uC774 \uC0AC\uC2E4\uC744
      \uC544\uB294 \uC2A4\uD154\uB77C\uB098\uC774\uCE20 \uC0AC\uC774\uC5D0\uC11C\uB294
      \u2018\uD558\uC580 \uC545\uB9C8\u2019\uB77C\uB294 \uC774\uBA85\uC73C\uB85C
      \uBD88\uB9AC\uACE0 \uC788\uB2E4. \r\n\uBA54\uC2DC\uC5D041\uC131\uB2E8\uC758
      \uB9AC\uB354\uACA9 \uBCC4. \uC804\uD615\uC801\uC778 \uD788\uC5B4\uB85C \uC774\uBBF8\uC9C0\uB97C
      \uD45C\uBC29\uC911\uC778 \uBA54\uC2DC\uC5D041\uC131\uB2E8\uC740 \uC2A4\uD154\uB77C\uB098\uC774\uCE20\uC758
      \uB300\uC678 \uC774\uBBF8\uC9C0\uB97C \uB2F4\uB2F9\uD558\uACE0 \uC788\uB2E4.
      \uC774 \uB54C\uBB38\uC778\uC9C0 \uC624\uB370\uD2B8\uB294 \uC2A4\uC2A4\uB85C\uC5D0\uAC8C\uB3C4,
      \uD0C0\uC778\uC5D0\uAC8C\uB3C4 \uC5C4\uACA9\uD55C \uBAA8\uC2B5\uC744 \uBCF4\uC774\uACE4
      \uD55C\uB2E4. \r\n\uBC1C\uB808\uB294 \uC791\uC740 \uAC00\uC2B4\uACFC \uB9C8\uB978
      \uBAB8\uB9E4\uC758 \uBB34\uC6A9\uC218\uAC00 \uC798 \uC5B4\uC6B8\uB9B0\uB2E4\uB294
      \uB9D0\uC744 \uB4E3\uACE4 \uBAB8\uB9E4\uC5D0 \uC2E0\uACBD\uC744 \uB9CE\uC774
      \uC4F0\uACE0 \uC788\uB2E4. \uADF8\uB7EC\uB098 \uB514\uC800\uD2B8\uC758 \uC720\uD639\uC5D0
      \uC57D\uD55C \uB098\uBA38\uC9C0 \uB2E4\uC774\uC5B4\uD2B8\uB294 \uB9E4\uBC88
      \uC2E4\uD328\uD558\uACE0 \uB9CC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977187
    m_Localized: "\uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC758 \uB300\uD45C\uC801\uC778
      \uBAA8\uBC94 \uAE30\uC0AC. \uC0AC\uB78C\uB4E4\uC5D0\uAC8C\uB294 \u2018\uBD88\uD328\uC758
      \uAE30\uC0AC\u2019\uB77C\uACE0\uB3C4 \uBD88\uB9B0\uB2E4. \r\n\uB9E4\uC0AC\uC5D0
      \uCCA0\uC800\uD558\uACE0 \uC644\uBCBD\uC8FC\uC758 \uC131\uD5A5\uC774 \uAC15\uD558\uB2E4.
      \uC791\uC804\uC744 \uB098\uAC00\uC11C\uB3C4 \uB124\uD53C\uB9BC \uD55C \uB9C8\uB9AC
      \uB193\uCE58\uB294 \uC77C\uC774 \uC5C6\uC73C\uBA70, \uC791\uAC8C\uB294 \uBA38\uB9AC\uC758
      \uB9AC\uBCF8\uC744 \uBB36\uB294 \uC704\uCE58\uAE4C\uC9C0 \uC815\uD574\uC838
      \uC788\uB2E4. \uB098\uC544\uAC00 \uC815\uC758\uB85C\uC6B4 \uC131\uACA9\uAE4C\uC9C0
      \uACB8\uBE44\uD558\uACE0 \uC788\uC73C\uB2C8, \uC0AC\uB78C\uB4E4\uC5D0\uAC8C\uB294
      \uADF8\uC57C\uB9D0\uB85C \uC644\uBCBD\uD55C \uD788\uB85C\uC778\uC774\uB2E4.
      \r\n\uBA54\uC2DC\uC5D041 \uC131\uB2E8\uC758 \uAE30\uC0AC\uB4E4\uC740 \uADF8\uB7F0
      \uADF8\uB140\uB97C \uACA9 \uC5C6\uC774 \uB300\uD558\uB294 \uD3B8\uC774\uC9C0\uB9CC,
      \uD5C8\uBE14\uC758 \uB2E4\uB978 \uAE30\uC0AC\uB4E4\uC740 \uC138\uC774\uB77C\uC5D0\uAC8C
      \uB9D0 \uAC70\uB294 \uAC83\uC870\uCC28 \uC5B4\uB824\uC6CC\uD558\uB294 \uACBD\uC6B0\uAC00
      \uB9CE\uB2E4\uACE0. \uADF8\uB7EC\uB098 \uD55C \uAC78\uC74C \uB2E4\uAC00\uAC00\uBA74,
      \uB204\uAD6C\uBCF4\uB2E4\uB3C4 \uC815\uC758\uB86D\uACE0 \uC120\uB7C9\uD55C
      \uB9C8\uC74C\uC744 \uAC00\uC9C4 \uAE30\uC0AC\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977188
    m_Localized: "\uC720\uC57D\uD574 \uBCF4\uC774\uB294 \uD30C\uAD34\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977189
    m_Localized: "\uBE44\uAD50\uC801 \uC5B4\uB9B0 \uB098\uC774, \uCD5C\uADFC \uC131\uD754\uC774
      \uC0C8\uACA8\uC9C4 \uC218\uC2B5 \uAE30\uC0AC. \uBCF8\uC778\uC774 \uBC1B\uC740
      \uBCC4\uC758 \uD798\uC774 \uB2E4\uB978 \uBCC4\uB4E4\uACFC\uB294 \uB2EC\uB9AC
      \uC5C4\uCCAD\uB09C \uD798\uC744 \uAC00\uC9C0\uACE0 \uC788\uB2E4\uACE0 \uBBFF\uB294\uB2E4.
      \uD2B9\uD788 \uC778\uAC04\uB4E4\uC774 \uAC70\uC8FC\uD558\uB294 \uCC28\uC6D0\uACFC
      \uBB3C\uC9C8\uACC4 \uBC16\uC758 \uC5B4\uB518\uAC00\uC5D0\uC11C \uAC70\uC8FC\uD558\uB294
      \uCD08\uCC28\uC6D0\uC801\uC778 \uC874\uC7AC\uB77C\uACE0 \uC0DD\uAC01\uD558\uBA70,
      \uC54C \uC218 \uC5C6\uB294 \uC5B8\uC5B4\uC758 \uB178\uB798\uB97C \uC678\uC6B0\uACE0
      \uB2E4\uB2C8\uB294 \uB4F1 4\uCC28\uC6D0\uC801\uC778 \uBA74\uBAA8\uB97C \uBCF4\uC778\uB2E4.
      \r\n\r\n\uB7EC\uBE0C\uC758 \uBA38\uB9AC\uCE74\uB77D\uC744 \uD0DC\uC6B0\uBA74
      \uD2B9\uC774\uD55C \uB0C4\uC0C8\uAC00 \uB098\uB294\uB370, \uBC14\uB85C \uC624\uC9D5\uC5B4
      \uAD6C\uC6B4 \uB0C4\uC0C8\uC774\uB2E4. \uB355\uBD84\uC5D0 \uC544\uCE74\uB370\uBBF8
      \uC131\uB2E8\uC758 \uB3D9\uB8CC \uAE30\uC0AC\uB4E4\uC774 \uBC30\uACE0\uD50C\uB54C
      \uC885\uC885 \uBA38\uB9AC\uCE74\uB77D\uC744 \uBAB0\uB798 \uAD6C\uC6CC \uBA39\uB294\uB2E4\uACE0
      \uD55C\uB2E4. \uBB3C\uB860 \uADF8\uB7F0 \uC9D3\uC744 \uD558\uBA74 \uB7EC\uBE0C\uB85C\uBD80\uD130
      \uD5C8\uB77D \uBC1B\uACE0 \uBA39\uC73C\uB77C\uB294 \uC794\uC18C\uB9AC\uB97C
      \uB4E3\uAC8C \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977190
    m_Localized: "\uBCF8\uC778\uC774 \uD480 \uC218 \uC5C6\uB294 \uBB38\uC81C\uB294
      \uC5C6\uB2E4\uACE0 \uC0DD\uAC01\uD558\uB294 \uC790\uC874\uAC10 2000% \uC790\uCE6D
      \uCC9C\uC7AC \uD504\uB85C\uADF8\uB798\uBA38. \r\n\r\n\uD5C8\uBE14\uC758 AI\uC624\uD37C\uB808\uC774\uD130
      ASNA\uB97C \uB9CC\uB4E0 \uC7A5\uBCF8\uC778\uC73C\uB85C, \uC0DD\uD65C\uC758
      \uC9C8\uC744 \uB192\uC5EC\uC900 \uB355\uBD84\uC5D0 \uD5C8\uBE14\uC5D0\uC11C\uC758
      \uC785\uC9C0\uAC00 \uC88B\uB2E4. \uC2A4\uC2A4\uB85C \uCC9C\uC7AC \uD504\uB85C\uADF8\uB798\uBA38\uB77C\uACE0
      \uB9D0\uD558\uACE0 \uB2E4\uB140\uB3C4 \uC544\uBB34\uB3C4 \uBC18\uBC15\uD558\uC9C0
      \uC54A\uB294 \uC774\uC720 \uC911 \uD558\uB098. \uD5C8\uBE14\uC758 \uC790\uCCB4
      \uC2DC\uC2A4\uD15C \uAD6C\uCD95\uC5D0 \uD070 \uB3C4\uC6C0\uC744 \uC8FC\uC5C8\uB358
      \uACF5\uC801\uC744 \uC778\uC815\uBC1B\uC544, \uD5C8\uBE14 \uB0B4\uC5D0\uC11C\uC758
      \uC6C0\uC9C1\uC784\uC774 \uC790\uC720\uB85C\uC6B4 \uD3B8\uC774\uB2E4. \r\n\r\n\uC5B4\uB9B0
      \uC2DC\uC808\uBD80\uD130 \uD568\uAED8 \uC9C0\uB0B4\uC628 \uB9B4\uB9AC\uC2A4\uC5D0
      \uB300\uD55C \uC560\uC815\uC774 \uAE4A\uC740 \uD3B8\uC774\uBA70, \uADF8\uB140\uAC00
      \uC790\uB9AC\uB97C \uC790\uC8FC \uBE44\uC6B0\uB294 \uAC83\uC744 \uD551\uACC4
      \uC0BC\uC544 \uADF8\uB140\uC758 \uC637 \uC2A4\uD0C0\uC77C\uB9C1\uC744 \uB2F4\uB2F9\uD558\uACE0
      \uC788\uB2E4. \uB355\uBD84\uC5D0 \uB9B4\uB9AC\uC2A4\uC758 \uC637\uC7A5\uC5D4
      \uC5D4\uD0A4\uC758 \uC0AC\uC2EC\uC774 \uAC00\uB4DD \uB2F4\uAE34 \uB4DC\uB808\uC2A4\uAC00
      \uAC00\uB4DD\uD558\uB2E4\uACE0 \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977191
    m_Localized: "\uAC00\uBCF4\uB85C \uB0B4\uB824\uC624\uB294 \uB9C8\uAC80\uC744
      \uC18C\uC9C0\uD55C \uC18C\uB140"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977192
    m_Localized: "\uAC71\uC815\uB9C8\uC138\uC694, \uB2F9\uC2E0\uC740 \uCCB4\uD3EC\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977193
    m_Localized: "\uC694\uB9AC\uB294 \uC880 \uBABB\uD574\uB3C4, \uC5B4\uC5FF\uD55C
      \uBA54\uC774\uB4DC\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977194
    m_Localized: "\uC6D0\uCE59\uB300\uB85C \uCC98\uB9AC\uD558\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977195
    m_Localized: "\uBB50! \uB0B4 \uB9D0\uC5D0 \uBD88\uB9CC \uC788\uC5B4?!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977196
    m_Localized: "\uB098\uB294 \uC0AC\uC2E4 \uBE68\uAC04\uC0C9\uC774 \uC81C\uC77C
      \uC88B\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977197
    m_Localized: "\uB208\uC740 \uC783\uC5C8\uC9C0\uB9CC, \uAC10\uAC01\uC740 \uB354
      \uC120\uBA85\uD574\uC84C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977198
    m_Localized: "\uC9C0\uD718\uAD00\uB2D8\uC744 \uB9CC\uB098\uC11C \uB2E4\uD589\uC774\uB77C\uB294
      \uC0DD\uAC01\uC774 \uB4E4\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977199
    m_Localized: "\uAC15\uD568\uC744 \uC99D\uBA85\uD558\uB294 \uAC83\uB9CC\uD07C
      \uC758\uBBF8\uC788\uB294 \uAC74 \uC5C6\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977200
    m_Localized: "\uB450\uB835\uB2C8? \uAFC8\uC5D0\uC11C \uAE68\uC5B4\uBC84\uB9AC\uB294
      \uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977201
    m_Localized: "\uC544\uC8FC \uC870\uC6A9\uD788... \uC7A0\uAE50 \uC7A0\uB4DC\uB294
      \uAC83 \uBFD0\uC774\uB2C8\uAE50"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977202
    m_Localized: "\uD314\uC774 \uBA87 \uAC1C\uB0D0\uACE0 \uBB3C\uC73C\uC2E0\uB2E4\uBA74,
      \uC5EC\uBD84\uAE4C\uC9C0 \uD3EC\uD568\uD574 428\uAC1C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977203
    m_Localized: "\uD638\uAE30\uC2EC\uACFC \uB3C8\uB9CC \uC788\uC73C\uBA74, \uBB50\uB4E0\uC9C0
      \uAC00\uB2A5\uD558\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977204
    m_Localized: "\uB10C \uC18C\uAFC9\uB180\uC774 \uC548 \uB07C\uC6CC\uC904\uAC70\uC57C,
      \uD788\uD788!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977205
    m_Localized: "\uD6C4\uD6D7, \uAD1C\uCC2E\uC544\uC694. \uC624\uB298\uC740 \uADF8\uC800
      \uC548\uBD80\uB97C \uBB3C\uC73C\uB7EC \uC628 \uAC83 \uBFD0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977206
    m_Localized: "\uBE5B\uC774 \uAC00\uC7A5 \uD544\uC694\uD55C \uAC74 \uC5B4\uB460\uC5D0
      \uAC07\uD78C \uC774\uB4E4\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977207
    m_Localized: "\uAE30\uBD84\uC774\uB2E4, \uD2B9\uBCC4\uD788 \uB0B4\uAC00 \uB9CC\uB4E0
      \uBB34\uAE30\uB97C \uC0AC\uC6A9\uD558\uAC8C \uD574\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 50052977208
    m_Localized: "\uBC14\uB78C\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC624\uB294\uAD70\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977209
    m_Localized: "\uB0A0 \uAE38\uB4E4\uC774\uACA0\uB2E4\uACE0? \uC7AC\uBBF8\uC788\uB294
      \uC18C\uB9AC\uB97C \uD558\uB294\uAD6C\uB098, \uAD00\uCE21\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977210
    m_Localized: "\uAE4C, \uAE5C\uC791\uC774\uC57C! \uBCC4 \uC77C\uB3C4 \uC544\uB2CC\uB370
      '\uC5B4? '\uD558\uC9C0 \uB9D0\uB780\uB9D0\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977211
    m_Localized: "\uC65C \uBB34\uC11C\uC6CC\uD558\uB294 \uAC70\uC9C0\uC774... \uC544\uC8FC
      \uC7A0\uAE50 \uB530\uB054\uD560 \uBFD0\uC778\uB370.."
    m_Metadata:
      m_Items: []
  - m_Id: 50052977212
    m_Localized: "\uC2E0\uB150\uC774\uB780 '\uAD73\uAC8C \uBBFF\uB294 \uB9C8\uC74C'\uC774\uC9C0."
    m_Metadata:
      m_Items: []
