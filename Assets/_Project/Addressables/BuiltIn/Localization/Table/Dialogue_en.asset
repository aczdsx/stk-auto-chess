%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 8c07de4e6b118478b9e53f481dac2451, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24195883008
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 751442059264
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 5490640674816
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 6272467329024
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 7011403030528
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788929
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788930
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788931
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788932
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788933
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788934
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788935
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788936
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788937
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788938
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788939
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788940
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788941
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788942
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788943
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788944
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788945
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788946
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788947
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788948
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788949
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788950
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788951
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788952
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788953
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788954
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788955
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788956
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788957
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788958
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788959
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788960
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788961
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788962
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788963
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788964
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788965
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788966
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788967
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788968
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788969
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788970
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788971
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788972
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788973
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788974
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788975
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788976
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788977
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788978
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788979
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788980
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788981
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788982
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788983
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788984
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788985
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788986
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788987
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788988
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788989
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788990
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788991
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788992
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788993
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788994
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788995
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788996
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788997
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788998
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788999
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789000
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789001
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789002
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789003
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789004
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789005
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789006
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789007
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789008
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789009
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789010
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789011
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789012
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789013
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789014
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789015
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789016
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789017
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789018
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789019
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789020
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789021
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789022
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789023
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789024
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789025
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789026
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789027
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789028
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789029
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789030
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789031
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789032
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789033
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789034
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789035
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789036
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789037
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789038
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789039
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789040
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789041
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789042
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789043
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789044
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789045
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789046
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789047
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789048
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789049
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789050
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789051
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789052
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789053
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789054
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789055
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789056
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789057
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789058
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789059
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789060
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789061
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789062
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789063
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789064
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789065
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789066
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789067
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789068
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789069
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789070
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789071
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789072
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789073
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789074
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789075
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789076
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789077
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789078
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789079
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789080
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789081
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789082
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789083
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789084
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789085
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789086
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789087
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789088
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789089
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789090
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789091
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789092
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789093
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789094
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789095
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789096
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789097
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789098
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789099
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789100
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789101
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789102
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789103
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789104
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789105
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789106
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789107
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789108
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789109
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789110
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789111
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789112
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789113
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789114
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789115
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789116
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789117
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789118
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789119
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789120
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789121
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789122
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789123
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789124
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789125
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789126
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789127
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789128
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789129
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789130
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789131
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789132
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789133
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789134
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789135
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789136
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789137
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789138
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789139
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789140
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789141
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789142
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789143
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789144
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789145
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789146
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789147
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789148
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789149
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789150
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789151
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789152
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789153
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789154
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789155
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789156
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789157
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789158
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789159
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789160
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789161
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789162
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789163
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789164
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789165
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789166
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789167
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789168
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789169
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789170
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789171
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789172
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789173
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789174
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789175
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789176
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789177
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789178
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789179
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789180
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789181
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789182
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789183
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789184
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789185
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789186
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789187
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789188
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789189
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789190
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789191
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789192
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789193
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789194
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789195
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789196
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789197
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789198
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789199
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789200
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789201
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789202
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789203
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789204
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789205
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789206
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789207
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789208
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789209
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789210
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789211
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789212
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789213
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789214
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789215
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789216
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789217
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789218
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789219
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789220
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789221
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789222
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789223
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789224
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789225
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789226
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789227
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789228
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789229
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789230
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789231
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789232
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789233
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789234
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789235
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789236
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789237
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789238
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789239
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789240
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789241
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789242
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789243
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789244
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789245
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789246
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789247
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789248
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789249
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789250
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789251
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789252
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789253
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789254
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789255
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789256
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789257
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789258
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789259
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789260
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789261
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789262
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789263
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789264
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789265
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789266
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789267
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789268
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789269
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789270
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789271
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789272
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789273
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789274
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789275
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789276
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789277
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789278
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789279
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789280
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789281
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789282
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789283
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789284
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789285
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789286
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789287
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789288
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789289
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789290
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789291
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789292
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789293
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789294
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789295
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789296
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789297
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789298
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789299
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789300
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789301
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789302
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789303
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789304
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789305
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789306
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789307
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789308
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789309
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789310
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789311
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789312
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789313
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789314
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789315
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789316
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789317
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789318
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789319
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789320
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789321
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789322
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789323
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789324
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789325
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789326
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789327
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789328
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789329
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789330
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789331
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789332
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789333
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789334
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789335
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789336
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789337
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789338
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789339
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789340
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789341
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789342
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789343
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789344
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789345
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789346
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789347
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789348
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789349
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789350
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789351
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789352
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789353
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789354
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789355
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789356
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789357
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789358
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789359
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789360
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789361
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789362
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789363
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789364
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789365
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789366
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789367
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789368
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789369
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789370
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789371
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789372
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789373
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789374
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789375
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789376
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789377
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789378
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789379
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789380
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789381
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789382
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789383
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789384
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789385
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789386
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789387
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789388
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789389
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789390
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789391
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789392
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789393
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789394
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789395
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789396
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789397
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789398
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789399
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789400
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789401
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789402
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789403
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789404
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789405
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789406
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789407
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789408
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789409
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789410
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789411
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789412
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789413
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789414
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789415
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789416
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789417
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789418
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789419
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789420
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789421
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789422
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789423
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789424
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789425
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789426
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789427
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789428
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789429
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789430
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789431
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789432
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789433
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789434
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789435
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789436
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789437
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789438
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789439
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789440
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789441
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789442
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789443
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789444
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789445
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789446
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789447
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789448
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789449
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789450
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789451
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789452
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789453
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789454
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789455
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789456
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789457
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789458
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789459
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789460
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789461
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789462
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789463
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789464
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789465
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789466
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789467
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789468
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789469
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789470
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789471
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789472
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789473
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789474
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789475
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789476
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789477
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789478
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789479
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789480
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789481
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789482
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789483
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789484
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789485
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789486
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789487
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789488
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789489
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789490
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789491
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789492
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789493
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789494
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789495
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789496
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789497
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789498
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789499
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789500
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789501
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789502
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789503
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789504
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789505
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789506
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789507
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789508
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789509
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789510
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789511
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789512
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789513
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789514
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789515
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789516
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789517
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789518
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789519
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789520
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789521
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789522
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789523
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789524
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789525
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789526
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789527
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789528
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789529
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789530
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789531
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789532
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789533
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789534
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789535
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789536
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789537
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789538
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789539
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789540
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789541
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789542
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789543
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789544
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789545
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789546
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789547
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789548
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789549
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789550
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789551
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789552
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789553
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789554
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789555
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789556
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789557
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789558
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789559
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789560
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789561
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789562
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789563
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789564
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789565
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789566
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789567
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789568
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789569
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789570
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789571
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789572
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789573
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789574
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789575
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789576
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789577
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789578
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789579
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789580
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789581
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789582
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789583
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789584
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789585
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789586
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789587
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789588
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789589
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789590
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789591
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789592
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789593
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789594
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789595
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789596
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789597
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789598
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789599
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789600
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789601
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789602
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789603
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789604
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789605
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789606
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789607
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789608
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789609
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789610
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789611
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789612
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789613
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789614
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789615
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789616
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789617
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789618
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789619
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789620
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789621
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789622
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789623
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789624
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789625
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789626
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789627
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789628
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789629
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789630
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789631
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789632
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789633
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789634
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789635
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789636
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789637
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789638
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789639
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789640
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789641
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789642
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789643
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789644
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789645
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789646
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789647
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789648
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789649
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789650
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789651
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886272
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886273
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886274
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886275
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886276
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886277
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886278
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886279
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886280
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886281
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886282
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886283
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886284
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886285
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886286
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886287
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886288
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886289
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886290
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886291
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886292
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886293
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886294
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886295
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886296
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886297
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886298
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886299
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886300
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886301
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886302
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886303
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886304
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886305
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886306
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886307
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886308
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886309
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886310
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886311
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886312
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886313
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886314
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886315
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886316
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886317
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886318
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886319
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886320
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886321
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886322
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886323
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886324
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886325
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886326
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886327
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886328
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886329
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886330
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886331
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886332
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886333
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886334
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886335
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886336
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886337
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886338
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886339
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886340
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886341
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886342
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886343
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886344
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886345
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886346
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886347
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886348
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886349
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886350
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886351
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886352
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886353
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886354
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886355
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886356
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886357
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886358
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886359
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886360
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886361
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886362
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886363
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886364
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886365
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886366
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886367
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886368
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886369
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886370
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886371
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886372
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886373
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886374
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886375
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886376
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886377
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886378
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886379
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886380
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886381
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886382
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886383
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886384
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886385
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886386
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886387
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886388
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886389
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886390
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886391
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886392
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886393
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886394
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886395
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886396
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886397
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886398
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886399
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886400
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886401
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886402
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886403
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886404
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886405
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886406
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886407
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886408
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886409
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886410
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886411
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886412
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886413
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886414
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886415
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886416
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886417
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886418
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886419
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886420
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886421
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886422
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886423
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886424
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886425
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886426
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886427
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886428
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886429
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886430
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886431
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886432
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886433
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886434
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886435
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886436
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886437
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886438
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886439
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886440
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886441
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886442
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886443
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886444
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886445
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886446
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886447
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886448
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886449
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886450
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886451
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886452
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886453
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886454
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886455
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886456
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886457
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886458
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886459
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886460
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886461
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886462
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886463
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886464
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886465
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886466
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886467
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886468
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886469
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886470
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886471
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886472
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886473
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886474
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886475
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886476
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886477
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886478
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886479
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886480
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886481
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886482
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886483
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886484
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886485
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886486
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886487
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886488
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886489
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886490
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886491
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886492
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886493
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886494
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886495
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886496
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886497
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886498
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886499
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886500
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886501
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886502
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886503
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886504
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886505
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886506
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886507
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886508
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886509
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886510
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886511
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886512
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886513
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886514
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886515
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886516
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886517
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886518
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886519
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886520
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886521
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886522
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886523
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886524
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886525
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886526
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886527
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886528
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886529
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886530
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886531
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886532
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886533
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886534
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886535
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886536
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886537
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886538
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886539
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886540
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886541
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886542
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886543
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886544
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886545
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886546
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886547
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886548
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886549
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886550
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886551
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886552
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886553
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886554
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886555
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886556
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886557
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886558
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886559
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886560
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886561
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886562
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886563
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886564
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886565
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886566
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886567
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886568
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886569
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886570
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886571
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886572
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886573
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886574
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886575
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886576
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886577
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886578
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886579
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886580
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886581
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886582
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886583
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886584
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886585
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886586
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886587
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886588
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886589
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886590
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886591
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886592
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886593
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886594
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886595
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886596
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886597
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886598
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886599
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886600
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886601
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886602
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886603
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886604
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886605
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886606
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886607
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886608
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886609
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886610
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886611
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886612
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886613
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886614
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886615
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886616
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886617
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886618
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886619
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886620
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886621
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886622
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886623
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886624
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886625
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886626
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886627
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886628
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886629
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886630
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886631
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886632
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886633
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886634
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886635
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886636
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886637
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886638
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886639
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886640
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886641
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886642
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886643
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886644
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886645
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886646
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886647
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886648
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886649
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886650
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886651
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886652
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886653
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886654
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886655
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886656
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886657
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886658
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886659
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886660
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886661
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886662
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886663
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886664
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886665
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886666
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886667
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886668
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886669
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886670
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886671
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886672
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886673
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886674
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886675
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886676
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886677
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886678
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886679
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886680
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886681
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886682
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886683
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886684
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886685
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886686
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886687
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886688
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886689
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886690
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886691
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886692
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886693
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886694
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886695
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886696
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886697
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886698
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886699
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886700
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886701
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886702
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886703
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886704
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886705
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886706
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886707
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886708
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886709
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886710
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886711
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886712
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886713
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886714
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886715
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886716
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886717
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886718
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886719
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886720
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886721
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886722
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886723
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886724
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886725
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886726
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886727
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886728
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886729
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886730
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886731
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886732
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886733
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886734
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886735
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886736
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886737
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886738
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886739
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886740
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886741
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886742
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886743
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886744
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886745
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886746
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886747
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886748
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886749
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886750
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886751
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886752
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886753
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886754
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886755
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886756
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886757
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886758
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886759
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886760
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886761
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886762
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886763
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886764
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886765
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886766
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886767
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886768
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886769
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886770
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886771
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886772
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886773
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886774
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886775
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886776
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886777
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886778
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886779
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886780
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886781
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886782
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886783
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886784
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886785
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886786
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886787
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886788
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886789
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886790
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886791
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886792
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886793
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886794
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886795
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886796
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886797
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886798
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886799
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886800
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886801
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886802
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886803
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886804
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886805
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886806
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886807
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886808
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886809
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886810
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886811
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886812
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886813
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886814
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886815
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886816
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886817
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886818
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886819
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886820
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886821
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886822
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886823
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886824
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886825
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886826
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886827
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886828
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886829
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886830
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886831
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886832
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886833
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886834
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886835
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886836
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886837
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886838
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886839
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886840
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886841
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886842
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886843
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886844
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886845
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886846
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886847
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886848
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886849
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886850
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886851
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886852
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886853
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886854
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886855
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886856
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886857
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886858
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886859
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886860
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886861
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886862
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886863
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886864
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886865
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886866
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886867
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886868
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886869
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886870
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886871
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886872
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886873
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886874
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886875
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886876
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886877
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886878
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886879
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886880
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886881
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886882
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886883
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886884
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886885
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886886
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886887
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886888
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886889
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886890
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886891
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886892
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886893
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886894
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886895
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886896
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886897
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886898
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886899
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886900
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886901
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886902
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886903
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886904
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886905
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886906
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886907
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886908
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886909
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886910
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886911
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886912
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886913
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886914
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886915
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886916
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886917
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886918
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886919
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886920
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886921
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886922
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886923
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886924
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886925
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886926
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886927
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886928
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886929
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886930
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886931
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886932
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886933
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886934
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886935
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886936
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886937
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886938
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886939
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886940
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886941
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886942
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886943
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886944
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886945
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886946
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886947
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886948
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886949
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886950
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886951
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886952
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886953
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886954
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886955
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886956
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886957
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886958
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886959
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886960
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886961
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886962
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886963
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886964
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886965
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886966
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886967
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886968
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886969
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886970
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886971
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886972
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886973
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886974
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886975
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886976
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886977
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886978
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886979
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886980
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886981
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886982
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886983
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886984
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886985
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886986
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886987
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886988
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886989
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886990
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886991
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886992
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886993
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886994
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886995
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679424
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679425
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679426
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679427
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679428
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679429
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679430
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679431
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679432
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679433
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679434
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679435
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679436
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679437
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679438
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679439
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679440
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679441
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679442
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679443
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679444
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679445
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679446
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679447
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679448
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679449
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679450
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679451
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679452
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679453
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679454
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679455
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679456
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679457
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679458
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679459
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679460
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679461
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679462
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679463
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679464
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679465
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679466
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679467
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679468
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679469
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679470
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679471
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679472
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679473
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679474
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679475
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679476
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679477
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679478
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679479
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679480
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679481
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679482
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679483
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679484
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679485
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679486
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679487
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679488
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679489
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679490
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679491
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679492
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679493
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679494
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679495
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679496
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679497
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679498
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679499
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679500
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679501
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679502
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679503
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679504
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679505
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679506
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679507
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679508
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679509
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679510
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679511
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679512
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679513
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679514
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679515
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679516
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679517
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679518
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679519
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679520
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679521
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679522
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679523
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679524
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679525
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679526
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679527
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679528
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679529
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679530
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679531
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679532
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679533
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679534
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679535
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679536
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679537
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679538
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679539
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679540
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679541
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679542
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679543
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679544
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679545
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679546
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679547
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679548
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679549
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679550
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679551
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679552
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679553
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679554
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679555
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679556
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679557
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679558
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679559
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679560
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679561
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679562
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679563
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679564
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679565
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679566
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679567
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679568
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679569
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679570
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679571
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679572
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679573
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679574
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679575
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679576
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679577
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679578
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679579
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679580
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679581
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679582
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679583
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679584
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679585
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679586
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679587
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679588
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679589
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679590
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679591
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679592
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679593
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679594
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679595
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679596
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679597
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679598
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679599
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679600
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679601
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679602
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679603
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679604
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679605
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679606
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679607
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679608
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679609
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679610
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679611
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679612
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679613
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679614
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679615
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679616
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679617
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679618
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679619
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679620
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679621
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679622
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679623
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679624
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679625
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679626
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679627
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679628
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679629
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679630
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679631
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679632
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679633
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679634
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679635
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679636
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679637
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679638
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679639
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679640
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679641
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679642
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679643
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679644
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679645
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679646
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679647
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679648
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679649
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679650
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679651
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679652
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679653
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679654
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679655
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679656
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679657
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679658
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679659
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679660
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679661
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679662
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679663
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679664
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679665
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679666
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679667
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679668
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679669
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679670
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679671
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679672
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679673
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679674
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679675
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679676
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679677
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679678
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679679
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679680
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679681
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679682
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679683
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679684
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679685
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679686
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679687
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679688
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679689
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679690
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679691
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679692
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679693
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679694
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679695
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679696
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679697
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679698
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679699
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679700
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679701
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679702
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679703
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679704
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679705
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679706
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679707
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679708
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679709
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679710
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679711
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679712
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679713
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679714
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679715
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679716
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679717
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679718
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679719
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679720
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679721
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679722
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679723
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679724
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679725
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679726
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679727
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679728
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679729
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679730
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679731
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679732
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679733
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679734
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679735
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679736
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679737
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679738
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679739
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679740
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679741
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679742
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679743
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679744
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679745
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679746
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679747
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679748
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679749
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679750
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679751
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679752
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679753
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679754
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679755
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679756
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679757
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679758
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679759
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679760
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679761
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679762
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679763
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679764
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679765
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679766
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679767
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679768
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679769
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679770
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679771
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679772
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679773
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679774
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679775
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679776
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679777
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679778
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679779
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679780
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679781
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679782
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679783
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679784
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679785
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679786
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679787
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679788
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679789
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679790
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679791
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679792
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679793
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679794
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679795
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679796
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679797
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679798
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679799
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679800
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679801
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679802
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679803
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679804
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679805
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679806
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679807
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679808
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679809
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679810
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679811
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679812
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679813
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679814
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679815
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679816
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679817
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679818
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679819
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679820
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679821
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679822
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679823
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679824
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679825
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679826
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679827
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679828
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679829
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679830
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679831
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679832
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679833
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679834
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679835
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679836
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679837
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679838
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679839
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679840
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679841
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679842
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679843
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679844
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679845
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679846
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679847
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679848
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679849
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679850
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679851
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679852
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679853
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679854
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679855
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679856
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679857
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679858
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679859
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679860
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679861
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679862
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679863
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679864
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679865
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679866
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679867
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679868
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679869
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679870
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679871
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679872
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679873
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679874
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679875
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679876
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679877
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679878
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679879
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679880
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679881
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679882
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679883
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679884
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679885
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679886
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679887
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679888
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679889
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679890
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679891
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679892
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679893
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679894
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679895
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679896
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679897
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679898
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679899
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679900
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679901
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679902
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679903
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679904
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679905
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679906
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679907
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679908
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679909
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679910
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679911
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679912
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679913
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679914
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679915
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679916
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679917
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679918
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679919
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679920
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679921
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679922
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679923
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679924
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679925
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679926
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679927
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679928
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679929
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679930
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679931
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679932
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679933
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679934
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679935
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679936
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679937
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679938
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679939
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679940
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679941
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679942
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679943
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679944
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679945
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679946
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679947
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679948
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679949
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679950
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679951
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679952
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679953
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679954
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679955
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679956
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679957
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679958
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679959
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679960
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679961
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679962
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679963
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679964
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679965
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679966
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679967
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679968
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679969
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679970
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679971
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679972
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679973
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679974
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679975
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679976
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679977
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679978
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679979
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679980
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679981
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679982
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679983
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679984
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679985
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679986
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679987
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679988
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679989
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679990
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679991
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679992
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679993
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679994
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679995
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679996
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679997
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679998
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679999
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680000
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680001
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680002
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680003
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680004
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680005
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680006
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680007
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680008
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680009
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680010
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680011
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680012
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680013
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680014
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680015
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680016
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680017
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680018
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680019
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680020
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680021
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680022
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680023
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680024
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680025
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680026
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680027
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680028
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680029
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680030
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680031
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680032
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680033
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680034
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680035
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680036
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680037
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680038
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680039
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680040
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680041
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680042
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680043
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680044
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680045
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680046
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680047
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680048
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680049
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680050
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680051
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680052
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680053
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680054
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680055
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680056
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680057
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680058
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680059
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680060
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680061
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680062
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680063
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680064
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680065
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680066
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680067
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680068
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680069
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680070
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680071
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680072
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680073
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680074
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680075
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680076
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680077
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680078
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680079
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680080
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680081
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680082
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680083
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680084
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680085
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680086
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680087
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680088
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680089
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680090
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680091
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680092
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680093
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680094
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680095
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680096
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680097
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680098
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680099
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680100
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680101
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680102
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680103
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680104
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680105
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680106
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680107
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680108
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680109
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680110
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680111
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680112
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680113
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680114
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680115
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680116
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680117
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680118
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680119
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680120
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680121
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680122
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680123
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680124
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680125
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680126
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680127
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680128
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680129
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680130
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680131
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680132
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680133
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680134
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680135
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680136
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680137
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680138
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680139
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680140
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680141
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680142
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680143
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680144
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680145
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680146
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680147
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967650623488
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817792
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817793
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817794
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817795
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817796
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817797
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817798
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817799
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817800
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817801
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817802
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817803
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817804
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817805
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817806
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817807
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817808
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817809
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817810
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817811
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817812
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817813
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817814
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817815
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817816
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817817
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817818
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817819
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817820
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817821
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817822
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817823
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817824
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817825
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817826
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817827
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817828
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817829
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817830
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817831
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817832
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817833
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817834
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817835
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817836
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817837
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817838
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817839
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817840
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817841
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817842
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817843
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817844
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817845
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817846
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817847
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817848
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817849
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817850
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817851
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817852
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817853
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817854
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817855
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817856
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817857
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817858
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817859
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817860
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817861
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817862
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817863
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817864
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817865
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817866
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817867
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817868
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817869
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817870
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817871
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817872
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817873
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817874
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817875
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817876
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817877
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817878
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817879
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817880
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817881
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817882
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817883
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817884
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817885
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817886
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817887
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817888
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817889
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817890
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817891
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817892
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817893
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817894
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817895
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817896
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817897
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817898
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817899
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817900
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817901
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817902
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817903
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817904
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817905
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817906
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817907
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817908
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817909
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817910
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817911
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817912
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817913
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817914
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817915
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817916
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817917
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817918
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817919
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817920
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817921
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817922
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817923
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817924
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817925
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817926
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817927
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817928
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817929
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817930
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817931
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817932
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817933
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817934
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817935
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817936
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817937
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817938
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817939
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817940
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817941
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817942
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817943
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817944
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817945
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817946
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817947
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817948
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817949
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817950
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817951
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817952
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817953
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817954
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817955
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817956
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817957
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817958
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817959
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817960
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817961
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817962
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817963
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817964
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817965
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817966
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817967
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817968
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817969
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817970
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817971
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817972
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817973
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817974
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817975
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817976
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817977
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817978
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817979
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817980
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817981
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817982
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817983
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817984
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817985
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817986
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817987
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817988
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817989
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817990
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817991
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817992
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817993
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817994
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817995
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817996
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817997
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817998
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817999
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818000
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818001
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818002
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818003
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818004
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818005
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818006
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818007
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818008
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818009
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818010
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818011
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818012
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818013
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818014
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818015
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818016
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818017
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818018
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818019
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818020
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818021
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818022
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818023
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818024
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818025
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818026
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818027
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818028
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818029
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818030
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818031
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818032
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818033
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818034
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818035
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818036
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818037
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818038
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818039
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818040
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818041
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818042
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818043
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818044
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818045
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818046
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818047
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818048
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818049
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818050
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818051
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818052
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818053
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818054
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818055
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818056
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818057
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818058
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818059
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818060
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818061
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818062
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818063
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818064
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818065
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818066
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818067
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818068
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818069
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818070
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818071
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818072
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818073
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818074
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818075
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818076
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818077
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818078
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818079
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818080
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818081
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818082
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818083
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818084
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818085
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818086
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818087
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818088
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818089
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818090
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818091
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818092
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818093
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818094
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818095
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818096
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818097
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818098
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818099
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818100
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818101
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818102
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818103
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818104
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818105
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818106
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818107
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818108
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818109
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818110
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818111
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818112
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818113
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818114
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818115
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818116
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818117
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818118
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818119
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818120
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818121
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818122
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818123
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818124
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818125
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818126
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818127
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818128
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818129
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818130
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818131
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818132
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818133
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818134
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818135
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818136
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818137
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818138
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818139
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818140
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818141
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818142
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818143
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818144
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818145
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818146
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818147
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818148
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818149
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818150
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818151
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818152
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818153
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818154
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818155
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818156
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818157
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818158
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818159
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818160
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818161
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818162
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818163
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818164
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818165
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818166
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818167
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818168
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818169
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818170
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818171
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818172
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818173
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818174
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818175
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818176
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818177
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818178
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818179
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818180
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818181
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818182
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818183
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818184
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818185
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818186
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818187
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818188
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818189
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818190
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818191
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818192
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818193
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818194
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818195
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818196
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818197
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818198
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818199
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818200
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818201
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818202
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818203
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818204
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818205
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818206
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818207
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818208
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818209
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818210
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818211
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818212
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818213
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818214
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818215
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818216
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818217
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818218
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818219
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818220
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818221
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818222
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818223
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818224
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818225
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818226
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818227
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818228
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818229
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818230
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818231
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818232
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818233
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818234
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818235
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818236
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818237
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818238
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818239
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818240
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818241
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818242
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818243
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818244
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818245
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818246
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818247
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818248
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818249
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818250
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818251
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818252
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818253
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818254
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818255
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818256
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818257
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818258
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818259
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818260
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818261
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818262
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818263
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818264
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818265
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818266
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818267
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818268
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818269
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818270
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818271
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818272
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818273
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818274
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818275
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818276
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818277
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818278
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818279
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818280
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818281
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818282
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818283
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818284
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818285
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818286
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818287
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818288
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818289
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818290
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818291
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818292
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818293
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818294
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818295
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818296
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818297
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818298
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818299
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818300
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818301
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818302
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818303
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818304
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818305
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818306
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818307
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818308
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818309
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818310
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818311
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818312
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818313
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818314
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818315
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818316
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818317
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818318
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818319
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818320
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818321
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818322
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818323
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818324
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818325
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818326
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818327
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818328
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818329
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818330
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818331
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818332
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818333
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818334
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818335
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818336
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818337
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818338
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818339
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818340
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818341
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818342
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818343
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818344
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818345
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818346
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818347
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818348
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818349
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818350
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818351
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818352
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818353
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818354
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818355
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818356
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818357
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818358
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818359
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818360
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818361
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818362
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818363
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818364
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818365
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818366
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818367
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818368
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818369
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818370
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818371
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818372
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818373
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818374
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818375
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818376
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818377
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818378
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818379
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818380
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818381
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818382
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818383
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818384
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818385
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818386
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818387
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818388
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818389
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818390
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818391
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818392
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818393
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818394
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818395
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818396
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818397
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818398
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818399
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818400
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818401
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818402
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818403
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818404
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818405
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818406
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818407
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818408
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818409
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818410
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818411
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818412
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818413
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818414
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818415
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818416
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818417
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818418
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818419
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818420
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818421
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818422
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818423
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818424
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818425
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818426
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818427
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818428
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818429
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818430
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818431
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818432
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818433
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818434
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818435
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818436
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818437
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818438
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818439
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818440
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818441
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818442
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818443
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818444
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818445
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818446
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818447
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818448
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818449
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818450
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818451
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818452
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818453
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818454
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818455
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818456
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818457
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818458
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818459
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818460
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818461
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818462
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818463
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818464
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818465
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818466
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818467
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818468
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818469
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818470
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818471
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818472
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818473
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818474
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818475
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818476
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818477
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818478
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818479
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818480
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818481
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818482
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818483
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818484
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818485
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818486
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818487
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818488
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818489
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818490
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818491
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818492
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818493
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818494
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818495
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818496
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818497
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818498
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818499
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818500
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818501
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818502
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818503
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818504
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818505
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818506
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818507
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818508
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818509
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818510
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818511
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818512
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818513
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818514
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113728
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113729
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113730
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113731
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113732
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113733
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113734
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113735
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113736
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113737
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113738
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113739
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113740
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113741
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113742
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113743
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113744
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113745
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113746
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113747
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113748
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113749
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113750
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113751
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113752
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113753
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113754
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113755
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113756
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113757
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113758
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113759
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113760
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113761
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113762
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113763
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113764
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113765
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113766
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113767
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113768
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113769
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113770
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113771
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113772
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113773
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113774
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113775
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113776
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113777
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113778
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113779
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113780
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113781
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113782
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113783
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113784
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113785
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113786
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113787
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113788
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113789
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113790
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113791
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113792
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113793
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113794
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113795
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113796
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113797
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113798
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113799
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113800
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113801
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113802
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113803
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113804
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113805
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113806
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113807
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113808
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113809
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113810
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113811
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113812
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113813
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113814
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113815
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113816
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113817
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113818
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113819
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113820
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113821
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113822
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113823
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113824
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113825
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113826
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113827
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113828
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113829
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113830
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113831
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113832
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113833
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113834
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113835
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113836
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113837
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113838
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113839
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113840
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113841
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113842
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113843
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113844
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113845
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113846
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113847
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113848
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113849
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113850
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113851
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113852
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113853
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113854
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113855
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113856
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113857
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113858
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113859
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113860
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113861
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113862
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113863
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113864
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113865
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113866
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113867
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113868
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113869
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113870
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113871
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113872
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113873
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113874
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113875
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113876
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113877
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113878
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113879
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113880
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113881
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113882
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113883
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113884
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113885
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113886
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113887
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113888
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113889
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113890
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113891
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113892
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113893
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113894
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113895
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113896
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113897
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113898
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113899
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113900
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113901
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113902
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113903
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113904
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113905
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113906
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113907
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113908
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113909
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113910
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113911
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113912
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113913
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113914
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113915
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113916
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113917
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113918
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113919
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113920
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113921
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113922
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113923
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113924
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113925
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113926
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113927
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113928
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113929
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113930
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113931
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113932
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113933
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113934
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113935
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113936
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113937
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113938
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113939
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113940
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113941
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113942
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113943
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113944
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113945
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113946
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113947
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113948
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113949
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113950
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113951
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113952
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113953
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113954
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113955
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113956
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113957
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113958
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113959
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113960
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113961
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113962
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113963
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113964
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113965
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113966
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113967
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113968
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113969
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113970
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113971
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113972
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113973
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113974
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113975
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113976
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113977
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113978
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113979
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113980
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113981
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113982
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113983
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113984
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113985
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113986
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113987
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113988
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113989
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113990
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113991
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113992
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113993
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113994
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113995
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113996
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113997
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113998
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113999
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114000
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114001
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114002
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114003
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114004
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114005
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114006
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114007
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114008
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114009
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114010
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114011
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114012
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114013
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114014
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114015
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114016
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114017
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114018
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114019
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114020
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114021
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114022
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114023
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114024
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114025
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114026
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114027
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114028
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114029
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114030
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114031
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114032
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114033
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114034
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114035
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114036
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114037
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114038
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114039
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114040
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114041
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114042
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114043
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114044
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114045
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114046
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114047
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114048
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114049
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114050
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114051
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114052
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114053
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114054
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114055
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114056
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114057
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114058
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114059
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114060
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114061
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114062
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114063
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114064
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114065
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114066
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114067
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114068
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114069
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114070
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114071
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114072
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114073
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114074
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114075
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114076
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114077
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114078
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114079
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114080
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114081
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114082
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114083
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114084
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114085
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114086
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114087
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114088
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114089
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114090
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114091
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114092
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114093
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114094
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114095
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114096
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114097
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114098
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114099
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114100
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114101
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114102
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114103
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114104
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114105
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114106
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114107
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114108
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114109
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114110
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114111
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114112
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114113
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114114
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114115
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114116
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114117
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114118
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114119
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114120
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114121
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114122
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114123
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114124
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114125
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114126
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114127
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114128
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114129
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114130
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114131
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114132
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114133
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114134
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114135
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114136
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114137
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114138
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114139
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114140
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114141
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114142
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114143
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114144
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114145
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114146
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114147
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114148
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114149
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114150
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114151
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114152
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114153
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114154
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114155
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114156
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114157
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114158
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114159
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114160
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114161
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114162
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114163
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114164
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114165
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114166
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114167
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114168
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114169
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114170
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114171
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114172
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114173
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114174
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114175
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114176
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114177
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114178
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114179
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114180
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114181
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114182
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114183
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114184
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114185
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114186
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114187
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114188
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114189
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114190
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114191
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114192
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114193
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114194
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114195
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114196
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114197
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114198
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114199
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114200
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114201
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114202
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114203
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114204
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114205
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114206
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114207
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114208
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114209
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114210
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114211
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114212
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114213
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114214
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114215
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114216
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114217
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114218
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114219
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114220
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114221
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114222
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114223
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114224
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114225
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114226
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114227
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114228
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114229
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114230
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114231
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114232
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114233
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114234
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114235
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114236
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114237
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114238
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114239
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114240
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114241
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114242
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114243
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114244
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114245
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114246
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114247
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114248
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114249
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114250
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114251
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114252
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114253
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114254
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114255
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114256
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114257
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114258
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114259
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114260
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114261
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114262
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114263
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114264
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114265
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114266
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114267
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114268
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114269
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085248
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085249
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085250
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085251
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085252
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085253
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085254
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085255
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085256
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085257
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085258
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085259
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085260
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085261
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085262
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085263
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085264
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085265
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085266
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085267
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085268
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085269
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085270
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085271
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085272
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085273
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085274
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085275
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085276
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085277
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085278
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085279
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085280
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085281
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085282
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085283
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085284
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085285
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085286
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085287
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085288
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085289
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085290
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085291
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085292
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085293
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085294
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085295
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085296
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085297
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085298
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085299
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085300
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085301
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085302
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085303
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085304
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085305
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085306
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085307
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085308
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085309
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085310
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085311
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085312
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085313
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085314
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085315
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085316
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085317
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085318
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085319
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085320
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085321
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085322
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085323
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085324
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085325
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085326
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085327
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085328
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085329
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085330
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085331
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085332
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085333
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085334
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085335
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085336
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085337
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085338
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085339
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085340
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085341
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085342
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085343
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085344
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085345
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085346
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085347
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085348
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085349
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085350
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085351
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085352
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085353
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085354
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085355
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085356
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085357
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085358
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085359
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085360
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085361
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085362
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085363
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085364
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085365
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085366
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085367
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085368
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085369
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085370
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085371
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085372
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085373
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085374
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085375
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085376
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085377
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085378
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085379
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085380
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085381
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085382
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085383
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085384
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085385
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085386
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085387
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085388
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085389
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085390
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085391
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085392
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085393
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085394
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085395
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085396
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085397
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085398
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085399
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085400
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085401
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085402
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085403
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085404
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085405
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085406
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085407
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085408
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085409
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085410
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085411
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085412
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085413
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085414
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085415
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085416
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085417
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085418
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085419
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085420
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085421
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085422
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085423
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085424
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085425
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085426
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085427
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085428
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085429
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878441472000
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054912
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054913
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054914
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054915
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054916
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054917
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054918
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054919
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054920
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054921
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054922
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054923
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054924
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054925
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054926
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054927
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054928
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054929
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054930
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054931
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054932
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054933
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054934
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054935
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054936
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054937
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054938
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054939
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054940
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054941
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054942
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054943
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054944
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054945
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054946
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054947
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054948
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054949
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054950
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054951
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054952
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054953
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054954
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054955
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054956
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054957
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054958
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054959
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054960
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054961
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054962
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054963
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054964
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054965
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054966
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054967
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054968
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054969
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054970
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054971
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054972
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054973
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054974
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054975
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054976
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054977
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054978
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054979
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054980
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054981
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054982
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054983
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054984
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054985
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054986
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054987
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054988
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054989
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054990
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054991
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054992
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054993
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054994
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054995
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054996
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054997
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054998
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054999
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055000
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055001
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055002
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055003
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055004
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055005
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055006
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055007
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055008
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055009
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055010
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055011
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055012
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055013
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055014
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055015
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055016
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055017
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055018
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055019
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055020
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055021
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055022
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055023
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055024
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055025
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055026
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055027
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055028
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055029
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055030
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055031
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055032
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055033
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055034
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055035
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055036
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055037
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055038
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055039
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055040
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055041
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055042
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055043
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055044
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055045
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055046
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055047
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055048
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055049
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055050
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055051
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055052
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055053
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055054
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055055
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055056
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055057
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055058
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055059
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055060
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055061
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055062
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055063
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055064
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055065
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055066
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055067
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055068
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055069
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055070
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055071
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055072
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055073
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055074
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055075
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055076
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055077
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055078
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055079
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055080
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055081
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055082
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055083
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055084
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055085
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055086
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055087
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055088
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055089
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055090
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055091
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055092
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055093
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055094
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055095
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055096
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055097
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055098
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055099
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055100
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055101
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055102
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055103
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055104
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055105
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055106
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055107
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055108
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055109
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055110
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055111
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055112
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055113
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055114
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055115
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055116
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055117
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055118
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055119
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055120
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055121
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055122
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055123
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055124
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055125
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055126
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055127
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055128
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055129
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055130
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055131
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055132
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055133
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055134
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055135
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055136
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055137
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055138
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055139
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055140
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055141
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055142
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055143
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055144
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055145
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055146
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055147
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055148
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055149
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055150
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055151
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055152
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055153
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055154
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055155
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055156
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055157
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055158
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055159
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055160
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055161
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055162
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055163
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055164
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055165
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055166
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055167
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055168
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055169
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055170
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055171
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055172
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055173
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055174
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055175
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055176
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055177
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055178
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055179
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055180
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055181
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055182
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055183
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055184
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055185
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055186
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055187
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055188
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055189
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055190
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055191
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055192
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055193
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055194
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055195
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055196
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055197
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055198
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055199
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055200
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055201
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055202
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055203
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055204
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055205
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055206
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055207
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055208
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055209
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055210
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055211
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055212
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055213
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055214
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055215
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055216
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055217
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055218
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055219
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055220
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055221
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055222
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055223
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055224
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055225
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055226
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055227
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055228
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055229
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055230
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055231
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055232
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055233
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055234
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055235
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055236
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055237
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055238
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055239
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055240
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055241
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055242
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055243
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055244
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055245
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055246
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055247
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055248
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055249
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055250
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055251
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055252
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055253
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055254
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055255
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055256
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055257
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055258
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055259
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055260
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055261
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055262
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055263
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055264
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055265
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055266
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055267
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055268
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055269
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055270
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055271
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055272
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055273
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055274
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055275
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055276
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055277
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055278
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055279
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055280
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055281
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055282
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055283
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055284
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055285
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055286
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055287
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055288
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055289
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055290
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055291
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055292
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055293
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055294
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055295
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055296
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055297
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055298
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055299
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055300
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055301
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055302
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055303
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055304
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055305
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055306
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055307
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055308
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055309
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055310
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055311
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055312
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055313
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055314
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055315
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055316
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055317
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055318
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055319
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055320
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055321
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055322
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055323
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055324
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055325
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055326
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055327
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055328
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055329
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055330
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055331
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055332
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055333
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055334
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055335
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055336
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055337
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055338
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055339
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055340
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055341
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055342
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055343
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055344
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055345
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055346
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055347
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055348
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055349
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055350
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055351
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055352
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055353
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055354
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055355
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055356
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055357
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055358
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055359
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055360
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055361
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055362
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055363
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055364
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055365
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055366
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055367
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055368
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055369
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055370
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055371
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055372
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055373
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055374
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055375
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055376
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055377
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055378
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055379
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055380
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055381
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055382
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055383
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055384
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055385
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055386
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055387
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055388
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055389
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055390
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055391
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055392
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055393
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055394
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055395
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055396
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055397
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055398
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055399
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055400
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055401
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055402
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055403
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055404
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055405
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055406
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055407
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055408
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055409
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055410
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055411
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055412
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055413
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055414
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055415
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055416
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055417
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055418
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055419
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055420
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055421
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055422
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055423
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055424
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055425
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055426
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055427
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055428
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055429
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055430
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055431
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055432
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055433
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055434
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055435
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055436
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055437
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055438
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055439
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055440
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055441
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055442
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055443
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055444
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055445
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055446
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055447
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055448
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055449
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055450
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055451
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055452
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055453
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055454
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055455
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055456
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055457
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055458
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055459
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055460
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055461
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055462
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055463
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055464
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055465
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055466
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055467
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055468
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055469
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055470
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055471
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055472
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055473
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055474
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055475
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055476
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055477
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055478
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055479
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055480
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055481
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055482
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055483
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055484
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055485
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055486
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055487
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055488
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055489
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055490
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055491
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055492
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055493
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055494
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055495
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055496
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055497
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055498
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055499
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055500
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055501
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055502
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055503
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055504
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055505
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055506
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055507
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055508
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055509
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055510
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055511
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055512
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055513
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055514
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055515
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055516
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055517
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055518
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055519
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055520
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055521
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055522
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055523
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055524
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055525
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055526
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055527
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055528
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055529
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055530
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055531
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055532
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055533
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055534
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055535
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055536
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055537
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055538
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055539
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055540
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055541
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055542
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055543
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055544
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055545
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055546
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055547
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055548
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055549
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055550
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055551
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055552
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055553
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055554
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055555
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055556
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055557
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055558
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055559
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055560
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055561
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055562
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055563
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055564
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055565
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055566
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055567
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055568
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055569
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055570
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055571
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055572
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055573
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055574
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055575
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055576
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055577
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055578
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055579
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055580
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055581
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055582
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055583
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055584
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055585
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055586
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055587
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055588
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055589
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055590
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055591
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055592
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055593
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055594
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055595
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055596
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055597
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055598
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055599
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055600
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055601
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055602
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055603
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055604
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055605
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055606
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055607
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055608
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055609
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055610
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055611
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055612
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055613
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055614
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055615
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055616
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055617
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055618
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055619
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055620
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055621
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055622
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055623
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055624
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055625
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055626
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055627
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055628
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055629
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055630
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055631
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055632
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055633
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055634
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543936
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543937
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543938
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543939
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543940
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543941
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543942
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543943
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543944
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543945
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543946
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543947
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543948
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543949
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543950
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543951
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543952
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543953
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543954
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543955
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543956
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543957
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543958
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543959
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543960
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543961
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543962
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543963
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543964
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543965
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543966
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543967
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543968
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543969
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543970
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543971
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543972
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543973
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543974
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543975
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543976
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543977
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543978
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543979
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543980
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543981
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543982
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543983
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543984
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543985
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543986
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543987
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543988
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543989
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543990
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543991
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543992
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543993
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543994
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543995
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543996
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543997
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543998
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543999
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544000
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544001
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544002
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544003
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544004
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544005
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544006
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544007
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544008
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544009
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544010
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544011
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544012
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544013
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544014
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544015
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544016
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544017
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544018
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544019
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544020
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544021
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544022
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544023
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544024
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544025
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544026
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544027
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544028
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544029
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544030
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544031
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544032
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544033
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544034
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544035
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544036
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544037
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544038
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544039
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544040
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544041
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544042
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544043
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544044
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544045
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544046
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544047
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544048
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544049
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544050
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544051
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544052
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544053
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544054
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544055
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544056
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544057
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544058
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544059
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544060
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544061
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544062
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544063
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544064
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544065
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544066
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544067
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544068
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544069
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544070
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544071
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544072
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544073
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544074
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544075
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544076
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544077
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544078
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544079
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544080
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544081
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544082
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544083
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544084
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544085
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544086
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544087
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544088
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544089
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544090
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544091
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544092
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544093
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544094
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544095
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544096
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544097
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544098
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544099
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544100
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544101
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544102
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544103
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544104
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544105
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544106
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544107
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544108
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544109
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544110
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544111
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544112
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544113
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544114
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544115
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544116
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544117
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544118
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544119
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544120
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544121
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544122
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544123
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544124
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544125
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544126
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544127
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544128
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544129
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544130
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544131
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544132
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544133
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544134
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544135
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544136
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544137
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544138
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544139
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544140
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544141
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544142
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544143
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544144
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544145
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544146
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544147
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544148
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544149
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544150
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544151
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544152
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544153
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544154
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544155
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544156
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544157
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544158
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544159
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544160
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544161
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544162
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544163
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544164
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544165
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544166
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544167
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544168
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544169
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544170
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544171
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544172
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544173
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544174
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544175
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544176
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544177
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544178
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544179
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544180
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544181
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544182
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544183
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544184
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544185
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544186
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544187
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544188
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544189
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544190
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544191
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544192
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544193
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544194
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544195
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544196
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544197
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544198
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544199
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544200
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544201
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544202
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544203
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544204
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544205
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544206
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544207
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544208
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544209
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544210
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544211
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544212
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544213
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544214
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544215
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544216
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544217
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544218
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544219
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544220
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544221
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544222
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544223
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544224
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544225
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544226
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544227
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544228
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544229
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544230
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544231
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544232
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544233
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544234
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544235
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544236
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544237
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544238
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544239
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544240
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544241
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544242
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544243
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544244
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544245
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544246
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544247
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544248
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544249
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544250
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544251
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544252
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544253
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544254
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544255
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544256
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544257
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544258
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544259
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544260
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544261
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544262
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544263
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544264
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544265
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544266
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544267
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544268
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544269
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544270
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544271
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544272
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544273
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544274
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544275
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544276
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544277
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544278
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544279
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544280
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544281
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544282
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544283
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544284
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544285
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544286
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544287
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544288
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544289
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544290
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544291
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544292
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544293
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544294
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544295
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544296
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544297
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544298
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544299
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544300
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544301
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544302
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544303
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544304
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544305
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544306
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544307
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544308
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544309
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544310
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544311
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544312
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544313
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544314
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544315
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544316
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544317
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544318
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544319
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544320
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544321
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544322
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544323
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544324
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544325
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544326
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544327
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544328
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544329
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544330
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544331
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544332
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544333
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544334
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544335
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544336
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544337
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544338
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544339
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544340
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544341
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544342
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544343
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544344
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544345
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544346
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544347
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544348
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738240
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738241
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738242
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738243
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738244
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738245
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738246
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738247
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738248
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738249
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738250
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738251
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738252
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738253
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738254
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738255
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738256
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738257
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738258
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738259
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738260
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738261
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738262
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738263
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738264
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738265
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738266
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738267
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738268
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738269
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738270
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738271
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738272
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738273
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738274
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738275
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738276
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738277
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738278
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738279
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738280
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738281
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738282
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738283
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738284
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738285
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738286
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738287
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738288
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738289
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738290
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738291
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738292
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738293
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738294
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738295
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738296
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738297
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738298
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738299
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738300
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738301
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738302
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738303
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738304
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738305
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738306
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738307
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738308
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738309
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738310
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738311
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738312
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738313
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738314
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738315
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738316
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738317
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738318
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738319
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738320
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738321
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738322
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738323
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738324
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738325
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738326
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738327
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738328
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738329
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738330
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738331
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738332
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738333
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738334
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738335
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738336
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738337
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738338
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738339
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738340
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738341
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738342
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738343
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738344
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738345
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738346
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738347
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738348
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738349
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738350
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738351
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738352
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738353
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738354
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738355
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738356
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738357
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738358
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738359
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738360
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738361
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738362
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738363
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738364
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738365
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738366
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738367
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738368
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738369
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738370
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738371
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738372
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738373
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738374
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738375
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738376
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738377
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738378
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738379
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738380
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738381
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738382
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738383
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738384
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738385
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738386
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738387
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738388
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738389
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738390
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738391
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738392
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738393
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738394
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738395
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738396
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738397
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738398
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738399
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738400
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738401
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738402
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738403
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738404
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738405
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738406
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738407
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738408
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738409
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738410
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738411
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738412
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738413
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738414
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738415
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738416
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738417
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738418
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738419
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738420
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738421
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738422
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738423
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738424
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738425
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738426
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738427
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738428
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738429
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738430
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738431
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738432
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738433
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738434
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738435
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738436
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738437
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738438
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738439
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738440
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738441
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738442
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738443
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738444
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738445
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738446
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738447
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738448
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738449
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738450
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738451
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738452
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738453
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738454
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738455
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738456
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738457
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738458
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738459
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738460
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738461
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738462
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738463
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738464
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738465
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738466
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738467
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738468
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738469
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738470
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738471
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738472
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738473
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738474
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738475
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738476
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738477
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738478
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738479
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738480
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738481
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738482
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738483
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738484
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738485
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738486
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738487
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738488
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738489
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738490
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738491
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738492
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738493
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738494
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738495
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738496
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738497
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738498
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738499
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738500
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738501
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738502
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738503
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738504
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738505
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738506
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738507
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738508
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738509
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738510
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738511
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738512
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738513
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738514
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738515
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738516
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738517
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738518
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738519
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738520
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738521
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738522
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738523
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738524
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738525
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738526
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738527
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738528
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738529
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738530
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738531
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738532
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738533
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738534
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738535
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738536
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738537
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738538
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738539
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738540
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738541
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738542
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738543
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738544
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738545
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738546
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738547
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738548
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738549
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738550
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266304
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266305
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266306
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266307
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266308
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266309
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266310
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266311
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266312
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266313
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266314
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266315
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266316
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266317
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266318
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266319
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266320
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266321
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266322
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266323
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266324
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266325
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266326
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266327
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266328
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266329
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266330
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266331
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266332
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266333
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266334
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266335
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266336
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266337
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266338
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266339
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266340
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266341
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266342
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266343
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266344
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266345
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266346
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266347
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266348
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266349
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266350
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266351
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266352
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266353
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266354
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266355
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266356
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266357
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266358
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266359
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266360
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266361
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266362
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266363
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266364
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266365
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266366
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266367
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266368
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266369
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266370
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266371
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266372
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266373
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266374
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266375
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266376
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266377
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266378
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266379
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266380
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266381
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266382
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266383
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266384
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266385
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266386
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266387
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266388
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266389
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266390
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266391
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266392
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266393
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266394
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266395
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266396
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266397
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266398
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266399
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266400
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266401
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266402
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266403
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266404
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266405
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266406
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266407
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266408
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266409
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266410
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266411
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266412
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266413
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266414
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266415
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266416
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266417
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266418
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266419
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266420
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266421
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266422
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266423
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266424
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266425
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266426
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266427
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266428
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266429
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266430
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266431
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266432
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266433
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266434
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266435
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266436
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266437
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266438
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266439
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266440
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266441
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266442
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266443
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266444
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266445
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266446
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266447
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266448
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266449
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266450
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266451
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266452
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266453
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266454
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266455
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266456
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266457
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266458
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266459
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266460
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266461
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266462
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266463
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266464
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266465
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266466
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266467
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266468
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266469
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266470
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266471
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266472
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266473
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266474
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266475
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266476
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266477
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266478
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266479
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266480
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266481
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266482
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266483
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266484
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266485
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266486
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266487
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266488
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266489
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266490
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266491
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266492
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266493
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266494
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266495
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266496
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266497
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266498
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266499
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266500
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266501
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266502
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266503
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266504
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266505
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266506
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266507
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266508
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266509
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266510
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266511
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266512
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266513
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266514
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266515
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266516
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266517
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266518
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266519
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266520
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266521
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266522
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266523
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266524
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266525
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266526
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266527
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266528
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266529
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266530
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266531
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266532
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266533
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266534
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266535
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266536
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266537
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266538
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266539
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266540
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266541
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266542
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266543
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266544
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266545
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266546
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266547
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266548
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266549
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266550
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266551
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266552
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266553
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266554
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266555
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266556
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266557
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266558
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266559
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266560
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266561
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266562
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266563
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266564
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266565
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266566
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266567
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266568
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266569
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266570
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266571
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266572
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266573
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266574
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266575
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266576
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266577
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266578
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266579
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266580
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266581
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266582
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266583
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266584
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266585
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266586
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266587
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266588
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266589
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266590
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266591
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266592
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266593
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266594
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266595
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266596
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266597
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266598
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266599
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266600
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266601
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266602
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266603
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266604
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266605
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266606
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266607
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266608
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266609
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266610
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266611
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266612
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266613
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266614
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266615
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266616
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266617
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266618
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266619
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266620
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266621
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266622
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266623
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266624
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266625
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266626
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266627
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266628
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266629
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266630
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266631
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266632
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266633
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266634
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266635
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266636
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266637
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266638
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266639
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266640
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266641
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266642
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266643
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266644
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266645
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266646
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266647
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266648
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266649
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266650
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266651
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266652
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266653
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266654
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266655
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266656
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266657
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266658
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266659
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266660
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266661
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266662
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266663
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266664
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266665
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266666
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266667
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266668
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266669
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266670
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266671
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266672
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266673
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266674
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266675
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266676
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266677
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266678
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266679
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266680
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266681
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266682
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266683
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266684
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266685
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266686
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266687
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266688
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266689
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266690
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266691
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266692
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266693
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266694
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266695
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266696
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266697
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266698
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266699
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266700
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266701
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266702
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266703
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266704
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266705
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266706
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266707
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266708
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266709
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266710
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266711
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266712
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266713
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266714
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266715
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266716
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266717
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266718
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266719
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266720
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266721
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266722
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266723
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266724
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266725
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266726
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266727
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266728
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266729
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266730
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266731
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266732
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266733
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266734
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266735
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266736
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266737
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266738
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266739
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266740
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266741
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266742
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266743
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266744
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266745
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266746
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266747
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266748
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266749
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266750
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266751
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266752
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266753
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266754
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266755
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266756
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266757
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266758
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266759
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266760
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266761
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266762
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266763
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266764
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266765
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266766
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266767
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266768
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266769
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266770
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266771
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266772
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266773
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266774
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266775
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266776
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266777
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266778
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266779
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266780
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266781
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266782
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266783
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266784
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266785
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266786
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266787
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266788
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266789
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266790
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266791
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266792
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266793
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266794
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266795
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266796
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266797
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266798
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266799
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266800
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266801
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266802
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266803
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266804
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266805
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266806
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266807
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266808
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266809
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266810
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266811
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266812
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266813
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266814
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266815
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266816
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266817
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266818
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266819
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266820
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266821
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266822
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266823
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266824
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266825
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266826
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266827
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266828
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266829
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266830
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266831
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266832
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266833
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266834
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266835
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266836
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266837
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266838
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266839
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266840
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266841
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266842
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266843
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266844
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266845
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266846
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266847
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266848
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266849
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266850
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266851
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266852
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266853
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266854
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266855
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266856
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266857
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266858
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266859
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266860
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266861
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266862
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266863
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266864
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266865
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266866
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266867
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266868
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266869
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266870
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266871
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266872
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266873
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266874
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266875
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266876
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266877
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266878
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266879
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266880
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266881
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266882
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266883
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266884
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266885
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266886
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266887
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266888
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266889
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266890
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266891
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266892
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266893
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266894
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266895
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266896
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266897
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266898
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266899
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266900
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266901
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266902
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266903
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266904
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266905
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266906
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266907
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266908
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266909
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266910
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266911
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266912
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266913
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266914
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266915
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266916
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266917
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266918
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266919
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266920
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266921
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266922
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266923
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266924
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266925
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266926
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266927
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266928
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266929
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266930
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266931
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266932
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266933
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266934
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266935
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266936
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266937
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266938
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266939
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266940
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266941
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266942
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266943
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266944
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266945
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266946
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266947
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266948
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266949
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266950
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266951
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266952
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266953
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266954
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266955
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266956
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266957
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266958
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266959
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266960
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266961
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266962
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266963
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266964
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266965
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266966
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266967
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266968
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266969
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266970
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266971
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266972
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266973
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266974
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266975
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266976
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266977
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266978
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266979
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266980
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266981
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266982
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266983
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266984
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266985
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266986
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266987
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266988
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266989
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266990
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266991
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266992
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266993
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266994
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266995
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266996
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266997
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266998
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266999
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267000
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267001
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267002
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267003
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267004
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267005
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267006
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267007
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267008
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267009
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267010
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267011
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267012
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267013
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267014
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267015
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267016
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267017
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267018
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267019
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267020
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267021
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267022
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267023
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267024
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267025
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267026
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267027
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046208
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046209
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046210
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046211
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046212
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046213
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046214
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046215
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046216
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046217
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046218
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046219
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046220
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046221
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046222
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046223
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046224
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046225
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046226
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046227
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046228
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046229
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046230
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046231
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046232
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046233
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046234
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046235
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046236
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046237
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046238
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046239
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046240
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046241
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046242
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046243
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046244
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046245
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046246
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046247
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046248
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046249
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046250
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046251
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046252
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046253
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046254
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046255
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046256
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046257
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046258
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046259
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046260
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046261
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046262
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046263
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046264
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046265
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046266
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046267
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046268
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046269
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046270
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046271
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046272
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046273
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046274
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046275
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046276
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046277
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046278
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046279
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046280
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046281
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046282
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046283
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046284
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046285
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046286
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046287
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046288
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046289
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046290
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046291
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046292
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046293
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046294
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046295
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046296
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046297
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046298
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046299
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046300
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046301
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046302
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046303
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046304
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046305
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046306
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046307
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046308
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046309
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046310
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046311
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046312
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046313
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046314
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046315
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046316
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046317
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046318
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046319
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046320
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046321
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046322
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046323
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046324
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046325
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046326
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046327
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046328
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046329
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046330
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046331
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046332
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046333
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046334
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046335
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046336
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046337
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046338
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046339
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046340
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046341
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046342
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046343
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046344
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046345
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046346
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046347
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046348
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046349
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046350
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046351
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046352
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046353
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046354
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046355
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046356
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046357
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046358
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046359
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046360
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046361
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046362
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046363
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046364
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046365
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046366
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046367
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046368
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046369
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046370
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046371
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046372
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046373
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046374
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046375
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046376
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046377
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046378
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046379
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046380
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046381
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046382
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046383
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046384
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046385
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046386
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046387
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046388
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046389
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046390
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046391
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046392
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046393
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046394
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046395
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046396
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046397
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046398
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046399
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046400
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046401
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046402
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046403
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046404
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046405
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046406
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046407
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046408
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046409
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046410
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046411
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046412
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046413
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046414
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046415
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046416
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046417
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046418
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046419
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046420
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046421
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046422
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046423
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046424
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046425
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046426
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046427
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046428
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046429
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046430
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046431
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046432
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046433
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046434
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046435
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046436
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046437
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046438
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046439
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046440
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046441
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046442
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046443
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046444
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046445
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046446
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046447
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046448
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046449
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046450
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046451
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046452
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046453
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046454
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046455
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046456
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046457
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046458
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046459
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046460
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046461
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046462
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046463
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046464
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046465
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046466
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046467
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046468
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046469
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046470
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046471
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046472
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046473
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046474
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046475
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046476
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046477
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046478
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046479
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046480
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046481
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046482
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046483
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046484
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046485
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046486
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046487
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046488
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046489
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046490
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046491
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046492
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046493
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046494
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046495
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046496
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046497
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046498
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046499
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046500
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046501
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046502
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046503
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046504
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046505
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046506
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046507
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046508
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046509
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046510
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046511
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046512
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046513
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046514
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046515
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046516
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046517
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046518
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046519
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046520
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046521
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046522
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046523
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046524
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046525
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046526
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046527
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046528
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046529
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046530
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046531
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046532
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046533
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046534
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046535
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046536
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046537
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046538
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046539
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046540
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046541
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046542
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046543
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046544
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046545
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046546
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046547
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046548
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046549
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046550
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046551
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046552
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046553
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046554
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046555
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046556
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046557
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046558
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046559
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046560
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046561
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046562
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046563
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046564
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046565
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046566
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046567
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046568
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046569
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046570
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046571
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046572
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046573
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046574
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046575
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046576
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046577
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046578
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046579
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046580
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046581
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046582
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046583
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046584
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046585
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046586
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046587
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046588
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046589
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046590
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046591
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046592
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046593
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046594
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046595
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046596
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046597
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046598
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046599
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046600
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046601
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046602
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046603
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046604
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046605
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046606
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046607
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046608
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046609
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046610
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046611
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046612
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046613
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046614
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046615
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046616
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046617
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046618
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046619
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046620
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046621
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046622
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046623
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046624
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046625
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046626
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046627
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046628
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046629
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046630
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046631
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046632
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046633
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046634
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046635
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046636
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046637
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046638
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046639
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046640
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046641
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046642
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046643
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046644
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046645
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046646
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046647
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046648
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046649
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046650
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046651
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046652
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046653
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046654
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046655
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046656
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046657
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046658
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046659
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046660
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046661
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046662
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046663
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046664
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046665
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046666
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046667
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046668
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046669
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046670
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046671
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046672
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046673
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046674
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046675
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046676
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046677
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046678
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046679
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046680
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046681
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046682
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046683
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046684
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046685
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046686
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046687
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046688
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046689
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046690
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046691
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046692
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046693
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046694
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046695
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046696
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046697
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046698
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046699
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046700
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046701
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046702
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046703
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046704
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046705
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046706
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046707
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046708
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046709
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046710
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046711
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046712
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046713
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046714
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046715
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046716
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046717
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046718
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046719
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046720
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046721
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046722
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046723
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046724
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046725
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046726
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046727
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046728
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046729
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046730
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046731
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046732
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046733
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046734
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046735
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046736
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046737
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046738
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046739
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046740
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046741
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046742
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046743
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046744
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046745
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046746
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046747
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046748
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046749
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046750
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046751
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046752
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046753
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046754
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046755
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046756
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046757
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046758
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046759
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046760
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046761
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046762
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046763
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046764
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240512
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240513
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240514
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240515
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240516
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240517
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240518
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240519
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240520
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240521
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240522
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240523
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240524
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240525
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240526
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240527
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240528
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240529
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240530
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240531
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240532
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240533
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240534
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240535
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240536
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240537
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240538
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240539
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240540
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240541
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240542
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240543
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240544
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240545
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240546
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240547
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240548
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240549
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240550
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240551
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240552
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240553
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240554
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240555
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240556
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240557
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240558
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240559
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240560
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240561
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240562
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240563
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240564
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240565
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240566
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240567
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240568
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240569
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240570
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240571
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240572
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240573
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240574
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240575
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240576
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240577
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240578
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240579
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240580
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240581
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240582
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240583
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240584
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240585
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240586
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240587
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240588
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240589
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240590
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240591
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240592
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240593
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240594
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240595
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240596
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240597
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240598
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240599
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240600
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240601
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240602
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240603
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240604
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240605
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240606
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240607
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240608
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240609
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240610
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240611
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240612
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240613
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240614
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240615
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240616
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240617
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240618
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240619
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240620
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240621
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240622
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240623
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240624
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240625
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240626
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240627
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240628
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240629
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240630
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240631
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240632
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240633
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240634
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240635
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240636
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240637
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240638
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240639
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240640
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240641
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240642
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240643
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240644
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240645
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240646
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240647
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240648
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240649
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240650
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240651
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240652
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240653
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240654
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240655
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240656
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240657
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240658
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240659
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240660
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240661
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240662
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240663
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240664
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240665
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240666
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240667
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240668
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240669
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240670
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240671
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240672
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240673
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240674
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240675
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240676
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240677
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240678
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983477964800
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159104
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159105
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159106
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159107
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159108
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159109
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159110
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159111
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159112
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159113
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159114
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159115
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159116
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159117
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159118
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159119
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159120
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159121
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159122
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159123
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159124
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159125
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159126
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159127
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159128
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159129
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159130
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159131
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159132
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159133
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159134
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159135
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159136
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159137
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159138
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159139
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159140
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159141
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159142
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159143
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159144
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159145
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159146
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159147
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159148
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159149
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159150
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159151
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159152
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159153
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159154
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159155
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159156
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159157
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159158
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159159
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159160
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159161
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159162
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159163
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159164
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159165
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159166
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159167
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159168
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159169
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159170
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159171
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159172
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159173
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159174
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159175
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159176
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159177
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159178
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159179
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159180
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159181
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159182
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159183
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159184
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159185
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159186
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159187
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159188
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159189
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159190
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159191
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159192
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159193
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159194
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159195
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159196
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159197
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159198
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159199
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159200
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159201
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159202
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159203
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159204
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159205
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159206
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159207
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159208
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159209
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159210
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159211
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159212
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159213
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159214
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159215
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159216
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159217
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159218
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159219
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159220
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159221
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159222
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159223
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159224
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159225
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159226
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159227
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159228
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159229
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159230
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159231
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159232
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159233
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159234
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159235
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159236
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159237
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159238
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159239
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159240
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159241
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159242
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159243
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159244
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159245
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159246
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159247
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159248
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159249
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159250
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159251
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159252
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159253
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159254
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159255
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159256
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159257
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159258
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159259
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159260
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159261
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159262
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159263
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159264
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159265
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159266
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159267
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159268
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159269
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159270
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159271
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159272
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159273
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159274
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159275
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159276
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159277
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159278
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159279
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159280
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159281
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159282
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159283
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159284
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159285
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159286
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159287
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159288
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159289
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159290
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159291
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159292
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159293
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159294
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159295
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159296
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159297
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159298
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159299
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159300
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159301
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159302
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159303
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159304
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159305
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159306
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159307
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159308
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159309
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159310
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159311
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159312
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159313
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159314
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159315
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159316
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159317
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159318
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159319
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159320
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159321
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159322
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159323
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159324
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159325
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159326
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159327
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159328
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159329
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159330
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159331
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159332
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159333
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159334
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159335
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159336
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159337
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159338
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159339
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159340
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159341
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159342
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159343
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159344
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159345
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159346
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159347
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159348
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159349
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159350
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159351
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159352
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159353
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159354
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159355
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159356
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159357
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159358
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159359
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159360
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159361
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159362
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159363
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159364
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159365
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159366
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159367
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159368
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159369
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159370
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159371
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159372
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159373
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159374
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159375
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159376
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159377
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159378
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159379
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159380
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159381
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159382
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159383
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159384
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159385
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159386
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159387
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159388
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159389
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159390
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159391
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159392
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159393
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159394
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159395
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159396
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159397
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159398
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159399
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159400
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159401
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159402
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159403
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159404
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159405
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159406
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159407
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159408
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159409
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159410
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159411
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159412
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159413
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159414
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159415
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159416
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159417
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159418
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159419
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159420
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159421
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159422
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159423
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159424
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159425
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159426
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159427
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159428
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159429
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159430
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159431
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159432
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159433
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159434
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159435
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159436
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159437
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159438
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159439
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159440
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159441
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159442
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159443
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159444
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159445
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159446
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159447
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159448
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159449
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159450
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159451
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159452
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159453
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159454
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159455
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159456
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159457
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159458
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159459
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159460
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159461
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159462
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159463
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159464
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159465
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159466
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159467
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159468
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159469
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159470
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159471
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159472
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159473
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159474
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159475
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159476
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159477
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159478
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159479
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159480
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159481
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159482
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159483
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159484
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159485
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159486
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159487
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159488
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159489
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159490
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159491
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159492
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159493
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159494
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159495
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159496
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159497
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159498
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159499
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159500
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159501
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159502
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159503
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159504
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159505
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159506
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159507
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159508
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159509
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159510
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159511
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159512
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159513
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159514
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159515
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159516
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159517
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159518
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159519
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159520
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159521
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159522
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159523
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159524
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159525
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159526
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159527
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159528
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159529
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159530
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159531
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159532
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159533
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159534
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159535
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159536
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159537
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159538
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159539
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159540
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159541
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159542
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159543
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159544
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159545
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159546
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159547
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159548
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159549
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159550
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159551
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159552
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159553
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159554
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159555
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159556
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159557
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159558
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159559
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159560
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159561
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159562
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159563
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159564
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159565
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159566
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159567
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159568
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159569
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159570
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159571
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159572
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159573
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159574
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159575
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159576
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159577
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159578
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159579
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159580
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159581
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159582
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159583
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159584
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159585
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159586
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159587
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159588
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159589
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159590
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159591
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159592
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159593
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159594
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159595
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159596
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159597
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159598
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159599
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159600
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159601
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159602
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159603
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159604
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159605
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159606
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159607
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159608
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159609
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159610
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159611
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159612
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159613
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159614
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159615
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159616
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159617
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159618
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159619
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159620
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159621
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159622
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159623
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159624
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159625
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159626
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159627
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159628
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159629
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159630
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159631
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159632
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159633
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159634
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159635
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159636
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159637
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159638
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159639
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159640
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159641
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159642
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159643
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159644
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159645
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159646
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159647
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159648
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159649
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159650
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159651
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159652
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159653
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159654
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159655
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159656
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159657
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159658
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159659
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159660
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159661
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159662
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159663
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159664
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159665
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159666
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159667
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159668
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159669
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159670
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159671
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159672
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159673
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159674
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159675
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159676
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159677
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159678
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159679
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159680
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159681
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159682
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159683
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159684
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159685
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159686
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159687
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159688
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159689
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159690
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159691
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159692
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159693
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159694
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159695
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159696
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159697
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159698
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159699
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159700
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159701
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159702
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159703
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159704
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159705
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159706
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159707
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159708
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159709
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159710
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159711
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159712
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159713
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159714
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159715
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159716
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159717
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159718
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159719
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159720
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159721
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159722
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159723
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159724
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159725
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159726
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159727
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159728
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159729
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159730
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159731
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159732
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159733
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159734
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159735
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159736
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159737
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159738
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159739
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159740
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159741
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159742
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159743
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159744
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159745
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159746
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159747
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159748
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159749
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159750
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159751
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159752
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159753
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159754
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159755
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159756
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159757
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159758
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159759
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159760
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159761
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159762
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159763
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159764
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159765
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159766
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159767
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159768
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159769
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159770
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159771
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159772
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159773
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159774
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159775
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159776
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159777
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159778
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159779
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159780
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159781
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159782
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159783
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159784
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159785
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159786
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159787
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159788
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159789
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159790
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159791
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159792
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159793
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159794
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159795
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159796
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159797
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159798
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159799
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159800
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159801
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159802
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159803
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159804
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159805
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159806
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159807
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159808
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159809
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159810
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159811
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159812
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159813
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159814
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159815
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159816
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159817
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159818
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159819
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159820
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159821
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159822
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159823
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159824
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159825
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159826
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159827
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159828
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159829
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159830
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159831
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159832
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159833
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159834
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159835
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159836
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159837
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159838
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159839
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159840
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159841
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159842
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159843
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159844
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159845
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159846
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159847
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159848
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159849
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159850
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159851
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159852
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159853
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159854
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159855
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159856
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907754999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570907755105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726016
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726017
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726018
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726019
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726020
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726021
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726022
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726023
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726024
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726025
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726026
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726027
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726028
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726029
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726030
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726031
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726032
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726033
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726034
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726035
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726036
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726037
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726038
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726039
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726040
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726041
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726042
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726043
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726044
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726045
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726046
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726047
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726048
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726049
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726050
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726051
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726052
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726053
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726054
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726055
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726056
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726057
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726058
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726059
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726060
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726061
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726062
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726063
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726064
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726065
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726066
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726067
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726068
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726069
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726070
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726071
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726072
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726073
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726074
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726075
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726076
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726077
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726078
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726079
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726080
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726081
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726082
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726083
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726084
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726085
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726086
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726087
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726088
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726089
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726090
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726091
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726092
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726093
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726094
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726095
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726096
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726097
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726098
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726099
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726100
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726101
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726102
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726103
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726104
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726105
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726106
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726107
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726108
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726109
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726110
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726111
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726112
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726113
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726114
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726115
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726116
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726117
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726118
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726119
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726120
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726121
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726122
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726123
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726124
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726125
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726126
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726127
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726128
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726129
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726130
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726131
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726132
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726133
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726134
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726135
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726136
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726137
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726138
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726139
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726140
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726141
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726142
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726143
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726144
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726145
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726146
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726147
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726148
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726149
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726150
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726151
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726152
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726153
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726154
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726155
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726156
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726157
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726158
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1821570928726159
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
