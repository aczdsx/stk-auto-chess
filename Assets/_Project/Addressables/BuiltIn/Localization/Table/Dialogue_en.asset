%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 8c07de4e6b118478b9e53f481dac2451, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24195883008
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 751442059264
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 5490640674816
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 6272467329024
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 7011403030528
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788929
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788930
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788931
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788932
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788933
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788934
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788935
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788936
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788937
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788938
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788939
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788940
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788941
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788942
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788943
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788944
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788945
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788946
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788947
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788948
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788949
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788950
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788951
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788952
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788953
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788954
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788955
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788956
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788957
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788958
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788959
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788960
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788961
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788962
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788963
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788964
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788965
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788966
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788967
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788968
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788969
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788970
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788971
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788972
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788973
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788974
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788975
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788976
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788977
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788978
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788979
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788980
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788981
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788982
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788983
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788984
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788985
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788986
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788987
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788988
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788989
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788990
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788991
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788992
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788993
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788994
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788995
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788996
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788997
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788998
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788999
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789000
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789001
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789002
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789003
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789004
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789005
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789006
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789007
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789008
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789009
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789010
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789011
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789012
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789013
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789014
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789015
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789016
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789017
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789018
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789019
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789020
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789021
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789022
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789023
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789024
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789025
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789026
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789027
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789028
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789029
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789030
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789031
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789032
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789033
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789034
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789035
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789036
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789037
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789038
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789039
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789040
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789041
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789042
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789043
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789044
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789045
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789046
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789047
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789048
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789049
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789050
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789051
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789052
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789053
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789054
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789055
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789056
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789057
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789058
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789059
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789060
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789061
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789062
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789063
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789064
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789065
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789066
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789067
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789068
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789069
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789070
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789071
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789072
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789073
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789074
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789075
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789076
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789077
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789078
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789079
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789080
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789081
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789082
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789083
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789084
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789085
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789086
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789087
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789088
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789089
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789090
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789091
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789092
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789093
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789094
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789095
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789096
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789097
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789098
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789099
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789100
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789101
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789102
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789103
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789104
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789105
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789106
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789107
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789108
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789109
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789110
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789111
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789112
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789113
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789114
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789115
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789116
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789117
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789118
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789119
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789120
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789121
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789122
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789123
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789124
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789125
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789126
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789127
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789128
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789129
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789130
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789131
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789132
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789133
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789134
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789135
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789136
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789137
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789138
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789139
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789140
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789141
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789142
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789143
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789144
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789145
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789146
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789147
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789148
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789149
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789150
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789151
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789152
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789153
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789154
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789155
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789156
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789157
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789158
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789159
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789160
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789161
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789162
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789163
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789164
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789165
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789166
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789167
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789168
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789169
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789170
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789171
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789172
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789173
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789174
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789175
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789176
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789177
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789178
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789179
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789180
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789181
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789182
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789183
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789184
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789185
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789186
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789187
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789188
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789189
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789190
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789191
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789192
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789193
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789194
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789195
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789196
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789197
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789198
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789199
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789200
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789201
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789202
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789203
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789204
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789205
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789206
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789207
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789208
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789209
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789210
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789211
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789212
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789213
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789214
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789215
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789216
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789217
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789218
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789219
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789220
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789221
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789222
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789223
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789224
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789225
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789226
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789227
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789228
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789229
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789230
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789231
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789232
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789233
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789234
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789235
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789236
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789237
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789238
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789239
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789240
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789241
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789242
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789243
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789244
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789245
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789246
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789247
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789248
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789249
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789250
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789251
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789252
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789253
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789254
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789255
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789256
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789257
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789258
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789259
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789260
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789261
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789262
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789263
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789264
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789265
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789266
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789267
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789268
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789269
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789270
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789271
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789272
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789273
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789274
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789275
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789276
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789277
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789278
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789279
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789280
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789281
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789282
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789283
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789284
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789285
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789286
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789287
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789288
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789289
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789290
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789291
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789292
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789293
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789294
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789295
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789296
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789297
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789298
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789299
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789300
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789301
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789302
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789303
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789304
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789305
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789306
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789307
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789308
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789309
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789310
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789311
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789312
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789313
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789314
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789315
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789316
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789317
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789318
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789319
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789320
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789321
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789322
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789323
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789324
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789325
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789326
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789327
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789328
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789329
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789330
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789331
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789332
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789333
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789334
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789335
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789336
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789337
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789338
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789339
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789340
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789341
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789342
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789343
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789344
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789345
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789346
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789347
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789348
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789349
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789350
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789351
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789352
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789353
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789354
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789355
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789356
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789357
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789358
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789359
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789360
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789361
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789362
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789363
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789364
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789365
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789366
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789367
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789368
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789369
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789370
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789371
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789372
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789373
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789374
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789375
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789376
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789377
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789378
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789379
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789380
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789381
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789382
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789383
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789384
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789385
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789386
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789387
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789388
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789389
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789390
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789391
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789392
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789393
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789394
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789395
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789396
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789397
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789398
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789399
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789400
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789401
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789402
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789403
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789404
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789405
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789406
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789407
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789408
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789409
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789410
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789411
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789412
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789413
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789414
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789415
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789416
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789417
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789418
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789419
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789420
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789421
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789422
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789423
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789424
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789425
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789426
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789427
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789428
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789429
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789430
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789431
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789432
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789433
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789434
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789435
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789436
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789437
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789438
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789439
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789440
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789441
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789442
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789443
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789444
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789445
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789446
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789447
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789448
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789449
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789450
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789451
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789452
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789453
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789454
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789455
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789456
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789457
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789458
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789459
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789460
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789461
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789462
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789463
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789464
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789465
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789466
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789467
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789468
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789469
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789470
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789471
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789472
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789473
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789474
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789475
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789476
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789477
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789478
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789479
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789480
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789481
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789482
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789483
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789484
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789485
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789486
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789487
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789488
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789489
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789490
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789491
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789492
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789493
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789494
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789495
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789496
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789497
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789498
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789499
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789500
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789501
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789502
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789503
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789504
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789505
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789506
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789507
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789508
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789509
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789510
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789511
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789512
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789513
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789514
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789515
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789516
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789517
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789518
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789519
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789520
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789521
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789522
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789523
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789524
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789525
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789526
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789527
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789528
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789529
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789530
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789531
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789532
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789533
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789534
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789535
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789536
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789537
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789538
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789539
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789540
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789541
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789542
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789543
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789544
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789545
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789546
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789547
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789548
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789549
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789550
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789551
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789552
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789553
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789554
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789555
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789556
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789557
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789558
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789559
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789560
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789561
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789562
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789563
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789564
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789565
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789566
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789567
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789568
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789569
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789570
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789571
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789572
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789573
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789574
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789575
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789576
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789577
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789578
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789579
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789580
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789581
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789582
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789583
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789584
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789585
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789586
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789587
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789588
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789589
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789590
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789591
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789592
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789593
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789594
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789595
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789596
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789597
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789598
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789599
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789600
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789601
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789602
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789603
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789604
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789605
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789606
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789607
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789608
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789609
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789610
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789611
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789612
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789613
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789614
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789615
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789616
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789617
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789618
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789619
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789620
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789621
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789622
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789623
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789624
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789625
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789626
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789627
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789628
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789629
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789630
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789631
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789632
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789633
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789634
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789635
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789636
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789637
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789638
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789639
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789640
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789641
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789642
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789643
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789644
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789645
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789646
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789647
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789648
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789649
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789650
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789651
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886272
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886273
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886274
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886275
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886276
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886277
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886278
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886279
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886280
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886281
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886282
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886283
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886284
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886285
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886286
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886287
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886288
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886289
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886290
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886291
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886292
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886293
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886294
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886295
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886296
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886297
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886298
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886299
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886300
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886301
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886302
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886303
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886304
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886305
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886306
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886307
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886308
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886309
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886310
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886311
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886312
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886313
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886314
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886315
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886316
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886317
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886318
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886319
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886320
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886321
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886322
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886323
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886324
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886325
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886326
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886327
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886328
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886329
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886330
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886331
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886332
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886333
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886334
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886335
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886336
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886337
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886338
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886339
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886340
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886341
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886342
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886343
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886344
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886345
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886346
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886347
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886348
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886349
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886350
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886351
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886352
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886353
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886354
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886355
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886356
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886357
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886358
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886359
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886360
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886361
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886362
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886363
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886364
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886365
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886366
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886367
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886368
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886369
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886370
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886371
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886372
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886373
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886374
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886375
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886376
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886377
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886378
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886379
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886380
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886381
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886382
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886383
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886384
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886385
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886386
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886387
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886388
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886389
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886390
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886391
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886392
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886393
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886394
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886395
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886396
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886397
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886398
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886399
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886400
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886401
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886402
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886403
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886404
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886405
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886406
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886407
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886408
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886409
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886410
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886411
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886412
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886413
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886414
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886415
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886416
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886417
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886418
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886419
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886420
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886421
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886422
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886423
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886424
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886425
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886426
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886427
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886428
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886429
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886430
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886431
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886432
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886433
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886434
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886435
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886436
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886437
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886438
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886439
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886440
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886441
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886442
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886443
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886444
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886445
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886446
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886447
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886448
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886449
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886450
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886451
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886452
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886453
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886454
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886455
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886456
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886457
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886458
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886459
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886460
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886461
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886462
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886463
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886464
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886465
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886466
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886467
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886468
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886469
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886470
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886471
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886472
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886473
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886474
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886475
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886476
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886477
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886478
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886479
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886480
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886481
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886482
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886483
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886484
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886485
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886486
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886487
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886488
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886489
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886490
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886491
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886492
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886493
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886494
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886495
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886496
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886497
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886498
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886499
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886500
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886501
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886502
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886503
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886504
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886505
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886506
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886507
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886508
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886509
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886510
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886511
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886512
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886513
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886514
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886515
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886516
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886517
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886518
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886519
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886520
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886521
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886522
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886523
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886524
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886525
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886526
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886527
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886528
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886529
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886530
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886531
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886532
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886533
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886534
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886535
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886536
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886537
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886538
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886539
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886540
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886541
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886542
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886543
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886544
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886545
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886546
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886547
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886548
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886549
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886550
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886551
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886552
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886553
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886554
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886555
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886556
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886557
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886558
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886559
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886560
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886561
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886562
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886563
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886564
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886565
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886566
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886567
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886568
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886569
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886570
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886571
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886572
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886573
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886574
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886575
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886576
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886577
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886578
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886579
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886580
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886581
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886582
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886583
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886584
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886585
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886586
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886587
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886588
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886589
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886590
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886591
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886592
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886593
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886594
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886595
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886596
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886597
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886598
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886599
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886600
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886601
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886602
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886603
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886604
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886605
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886606
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886607
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886608
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886609
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886610
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886611
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886612
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886613
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886614
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886615
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886616
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886617
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886618
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886619
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886620
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886621
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886622
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886623
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886624
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886625
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886626
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886627
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886628
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886629
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886630
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886631
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886632
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886633
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886634
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886635
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886636
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886637
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886638
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886639
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886640
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886641
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886642
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886643
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886644
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886645
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886646
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886647
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886648
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886649
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886650
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886651
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886652
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886653
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886654
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886655
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886656
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886657
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886658
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886659
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886660
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886661
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886662
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886663
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886664
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886665
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886666
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886667
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886668
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886669
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886670
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886671
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886672
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886673
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886674
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886675
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886676
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886677
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886678
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886679
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886680
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886681
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886682
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886683
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886684
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886685
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886686
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886687
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886688
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886689
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886690
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886691
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886692
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886693
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886694
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886695
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886696
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886697
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886698
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886699
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886700
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886701
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886702
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886703
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886704
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886705
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886706
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886707
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886708
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886709
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886710
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886711
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886712
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886713
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886714
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886715
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886716
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886717
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886718
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886719
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886720
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886721
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886722
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886723
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886724
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886725
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886726
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886727
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886728
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886729
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886730
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886731
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886732
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886733
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886734
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886735
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886736
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886737
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886738
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886739
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886740
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886741
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886742
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886743
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886744
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886745
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886746
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886747
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886748
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886749
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886750
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886751
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886752
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886753
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886754
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886755
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886756
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886757
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886758
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886759
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886760
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886761
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886762
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886763
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886764
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886765
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886766
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886767
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886768
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886769
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886770
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886771
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886772
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886773
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886774
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886775
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886776
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886777
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886778
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886779
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886780
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886781
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886782
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886783
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886784
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886785
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886786
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886787
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886788
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886789
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886790
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886791
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886792
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886793
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886794
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886795
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886796
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886797
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886798
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886799
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886800
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886801
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886802
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886803
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886804
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886805
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886806
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886807
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886808
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886809
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886810
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886811
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886812
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886813
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886814
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886815
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886816
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886817
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886818
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886819
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886820
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886821
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886822
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886823
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886824
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886825
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886826
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886827
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886828
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886829
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886830
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886831
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886832
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886833
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886834
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886835
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886836
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886837
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886838
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886839
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886840
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886841
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886842
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886843
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886844
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886845
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886846
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886847
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886848
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886849
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886850
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886851
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886852
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886853
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886854
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886855
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886856
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886857
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886858
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886859
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886860
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886861
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886862
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886863
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886864
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886865
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886866
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886867
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886868
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886869
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886870
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886871
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886872
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886873
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886874
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886875
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886876
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886877
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886878
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886879
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886880
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886881
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886882
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886883
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886884
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886885
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886886
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886887
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886888
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886889
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886890
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886891
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886892
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886893
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886894
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886895
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886896
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886897
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886898
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886899
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886900
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886901
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886902
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886903
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886904
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886905
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886906
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886907
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886908
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886909
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886910
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886911
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886912
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886913
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886914
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886915
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886916
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886917
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886918
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886919
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886920
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886921
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886922
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886923
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886924
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886925
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886926
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886927
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886928
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886929
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886930
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886931
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886932
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886933
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886934
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886935
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886936
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886937
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886938
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886939
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886940
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886941
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886942
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886943
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886944
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886945
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886946
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886947
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886948
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886949
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886950
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886951
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886952
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886953
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886954
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886955
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886956
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886957
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886958
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886959
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886960
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886961
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886962
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886963
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886964
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886965
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886966
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886967
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886968
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886969
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886970
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886971
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886972
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886973
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886974
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886975
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886976
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886977
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886978
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886979
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886980
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886981
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886982
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886983
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886984
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886985
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886986
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886987
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886988
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886989
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886990
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886991
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886992
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886993
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886994
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886995
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679424
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679425
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679426
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679427
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679428
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679429
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679430
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679431
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679432
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679433
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679434
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679435
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679436
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679437
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679438
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679439
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679440
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679441
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679442
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679443
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679444
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679445
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679446
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679447
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679448
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679449
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679450
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679451
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679452
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679453
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679454
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679455
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679456
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679457
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679458
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679459
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679460
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679461
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679462
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679463
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679464
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679465
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679466
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679467
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679468
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679469
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679470
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679471
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679472
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679473
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679474
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679475
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679476
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679477
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679478
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679479
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679480
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679481
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679482
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679483
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679484
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679485
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679486
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679487
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679488
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679489
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679490
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679491
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679492
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679493
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679494
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679495
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679496
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679497
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679498
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679499
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679500
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679501
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679502
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679503
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679504
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679505
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679506
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679507
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679508
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679509
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679510
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679511
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679512
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679513
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679514
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679515
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679516
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679517
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679518
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679519
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679520
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679521
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679522
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679523
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679524
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679525
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679526
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679527
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679528
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679529
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679530
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679531
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679532
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679533
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679534
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679535
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679536
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679537
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679538
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679539
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679540
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679541
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679542
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679543
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679544
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679545
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679546
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679547
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679548
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679549
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679550
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679551
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679552
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679553
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679554
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679555
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679556
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679557
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679558
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679559
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679560
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679561
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679562
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679563
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679564
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679565
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679566
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679567
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679568
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679569
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679570
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679571
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679572
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679573
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679574
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679575
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679576
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679577
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679578
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679579
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679580
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679581
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679582
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679583
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679584
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679585
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679586
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679587
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679588
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679589
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679590
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679591
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679592
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679593
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679594
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679595
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679596
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679597
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679598
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679599
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679600
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679601
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679602
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679603
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679604
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679605
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679606
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679607
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679608
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679609
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679610
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679611
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679612
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679613
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679614
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679615
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679616
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679617
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679618
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679619
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679620
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679621
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679622
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679623
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679624
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679625
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679626
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679627
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679628
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679629
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679630
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679631
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679632
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679633
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679634
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679635
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679636
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679637
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679638
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679639
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679640
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679641
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679642
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679643
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679644
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679645
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679646
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679647
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679648
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679649
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679650
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679651
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679652
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679653
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679654
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679655
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679656
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679657
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679658
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679659
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679660
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679661
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679662
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679663
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679664
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679665
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679666
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679667
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679668
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679669
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679670
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679671
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679672
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679673
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679674
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679675
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679676
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679677
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679678
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679679
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679680
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679681
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679682
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679683
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679684
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679685
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679686
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679687
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679688
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679689
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679690
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679691
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679692
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679693
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679694
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679695
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679696
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679697
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679698
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679699
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679700
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679701
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679702
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679703
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679704
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679705
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679706
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679707
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679708
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679709
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679710
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679711
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679712
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679713
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679714
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679715
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679716
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679717
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679718
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679719
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679720
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679721
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679722
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679723
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679724
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679725
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679726
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679727
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679728
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679729
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679730
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679731
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679732
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679733
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679734
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679735
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679736
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679737
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679738
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679739
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679740
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679741
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679742
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679743
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679744
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679745
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679746
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679747
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679748
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679749
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679750
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679751
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679752
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679753
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679754
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679755
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679756
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679757
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679758
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679759
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679760
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679761
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679762
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679763
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679764
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679765
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679766
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679767
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679768
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679769
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679770
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679771
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679772
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679773
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679774
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679775
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679776
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679777
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679778
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679779
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679780
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679781
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679782
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679783
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679784
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679785
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679786
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679787
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679788
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679789
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679790
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679791
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679792
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679793
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679794
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679795
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679796
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679797
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679798
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679799
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679800
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679801
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679802
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679803
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679804
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679805
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679806
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679807
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679808
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679809
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679810
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679811
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679812
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679813
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679814
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679815
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679816
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679817
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679818
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679819
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679820
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679821
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679822
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679823
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679824
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679825
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679826
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679827
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679828
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679829
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679830
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679831
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679832
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679833
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679834
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679835
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679836
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679837
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679838
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679839
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679840
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679841
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679842
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679843
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679844
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679845
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679846
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679847
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679848
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679849
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679850
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679851
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679852
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679853
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679854
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679855
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679856
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679857
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679858
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679859
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679860
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679861
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679862
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679863
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679864
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679865
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679866
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679867
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679868
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679869
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679870
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679871
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679872
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679873
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679874
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679875
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679876
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679877
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679878
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679879
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679880
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679881
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679882
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679883
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679884
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679885
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679886
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679887
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679888
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679889
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679890
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679891
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679892
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679893
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679894
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679895
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679896
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679897
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679898
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679899
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679900
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679901
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679902
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679903
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679904
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679905
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679906
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679907
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679908
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679909
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679910
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679911
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679912
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679913
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679914
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679915
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679916
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679917
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679918
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679919
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679920
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679921
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679922
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679923
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679924
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679925
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679926
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679927
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679928
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679929
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679930
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679931
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679932
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679933
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679934
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679935
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679936
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679937
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679938
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679939
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679940
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679941
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679942
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679943
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679944
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679945
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679946
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679947
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679948
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679949
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679950
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679951
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679952
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679953
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679954
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679955
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679956
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679957
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679958
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679959
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679960
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679961
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679962
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679963
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679964
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679965
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679966
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679967
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679968
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679969
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679970
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679971
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679972
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679973
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679974
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679975
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679976
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679977
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679978
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679979
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679980
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679981
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679982
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679983
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679984
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679985
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679986
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679987
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679988
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679989
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679990
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679991
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679992
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679993
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679994
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679995
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679996
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679997
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679998
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679999
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680000
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680001
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680002
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680003
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680004
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680005
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680006
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680007
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680008
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680009
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680010
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680011
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680012
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680013
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680014
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680015
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680016
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680017
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680018
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680019
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680020
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680021
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680022
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680023
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680024
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680025
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680026
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680027
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680028
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680029
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680030
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680031
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680032
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680033
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680034
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680035
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680036
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680037
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680038
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680039
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680040
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680041
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680042
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680043
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680044
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680045
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680046
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680047
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680048
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680049
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680050
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680051
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680052
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680053
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680054
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680055
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680056
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680057
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680058
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680059
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680060
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680061
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680062
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680063
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680064
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680065
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680066
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680067
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680068
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680069
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680070
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680071
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680072
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680073
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680074
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680075
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680076
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680077
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680078
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680079
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680080
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680081
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680082
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680083
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680084
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680085
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680086
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680087
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680088
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680089
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680090
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680091
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680092
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680093
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680094
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680095
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680096
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680097
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680098
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680099
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680100
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680101
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680102
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680103
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680104
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680105
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680106
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680107
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680108
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680109
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680110
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680111
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680112
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680113
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680114
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680115
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680116
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680117
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680118
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680119
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680120
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680121
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680122
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680123
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680124
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680125
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680126
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680127
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680128
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680129
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680130
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680131
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680132
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680133
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680134
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680135
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680136
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680137
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680138
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680139
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680140
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680141
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680142
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680143
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680144
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680145
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680146
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680147
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967650623488
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817792
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817793
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817794
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817795
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817796
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817797
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817798
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817799
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817800
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817801
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817802
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817803
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817804
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817805
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817806
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817807
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817808
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817809
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817810
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817811
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817812
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817813
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817814
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817815
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817816
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817817
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817818
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817819
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817820
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817821
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817822
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817823
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817824
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817825
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817826
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817827
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817828
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817829
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817830
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817831
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817832
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817833
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817834
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817835
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817836
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817837
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817838
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817839
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817840
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817841
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817842
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817843
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817844
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817845
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817846
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817847
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817848
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817849
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817850
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817851
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817852
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817853
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817854
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817855
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817856
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817857
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817858
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817859
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817860
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817861
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817862
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817863
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817864
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817865
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817866
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817867
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817868
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817869
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817870
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817871
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817872
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817873
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817874
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817875
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817876
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817877
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817878
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817879
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817880
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817881
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817882
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817883
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817884
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817885
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817886
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817887
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817888
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817889
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817890
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817891
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817892
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817893
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817894
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817895
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817896
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817897
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817898
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817899
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817900
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817901
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817902
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817903
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817904
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817905
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817906
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817907
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817908
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817909
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817910
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817911
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817912
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817913
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817914
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817915
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817916
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817917
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817918
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817919
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817920
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817921
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817922
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817923
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817924
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817925
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817926
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817927
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817928
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817929
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817930
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817931
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817932
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817933
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817934
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817935
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817936
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817937
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817938
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817939
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817940
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817941
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817942
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817943
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817944
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817945
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817946
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817947
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817948
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817949
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817950
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817951
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817952
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817953
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817954
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817955
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817956
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817957
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817958
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817959
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817960
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817961
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817962
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817963
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817964
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817965
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817966
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817967
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817968
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817969
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817970
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817971
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817972
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817973
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817974
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817975
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817976
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817977
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817978
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817979
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817980
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817981
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817982
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817983
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817984
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817985
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817986
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817987
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817988
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817989
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817990
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817991
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817992
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817993
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817994
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817995
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817996
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817997
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817998
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817999
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818000
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818001
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818002
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818003
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818004
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818005
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818006
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818007
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818008
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818009
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818010
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818011
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818012
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818013
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818014
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818015
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818016
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818017
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818018
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818019
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818020
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818021
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818022
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818023
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818024
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818025
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818026
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818027
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818028
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818029
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818030
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818031
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818032
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818033
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818034
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818035
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818036
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818037
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818038
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818039
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818040
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818041
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818042
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818043
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818044
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818045
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818046
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818047
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818048
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818049
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818050
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818051
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818052
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818053
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818054
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818055
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818056
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818057
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818058
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818059
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818060
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818061
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818062
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818063
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818064
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818065
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818066
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818067
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818068
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818069
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818070
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818071
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818072
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818073
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818074
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818075
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818076
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818077
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818078
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818079
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818080
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818081
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818082
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818083
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818084
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818085
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818086
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818087
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818088
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818089
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818090
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818091
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818092
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818093
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818094
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818095
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818096
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818097
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818098
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818099
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818100
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818101
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818102
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818103
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818104
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818105
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818106
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818107
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818108
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818109
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818110
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818111
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818112
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818113
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818114
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818115
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818116
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818117
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818118
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818119
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818120
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818121
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818122
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818123
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818124
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818125
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818126
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818127
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818128
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818129
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818130
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818131
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818132
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818133
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818134
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818135
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818136
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818137
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818138
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818139
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818140
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818141
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818142
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818143
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818144
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818145
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818146
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818147
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818148
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818149
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818150
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818151
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818152
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818153
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818154
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818155
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818156
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818157
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818158
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818159
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818160
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818161
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818162
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818163
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818164
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818165
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818166
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818167
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818168
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818169
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818170
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818171
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818172
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818173
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818174
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818175
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818176
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818177
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818178
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818179
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818180
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818181
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818182
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818183
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818184
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818185
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818186
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818187
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818188
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818189
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818190
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818191
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818192
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818193
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818194
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818195
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818196
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818197
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818198
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818199
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818200
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818201
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818202
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818203
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818204
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818205
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818206
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818207
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818208
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818209
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818210
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818211
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818212
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818213
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818214
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818215
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818216
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818217
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818218
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818219
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818220
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818221
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818222
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818223
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818224
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818225
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818226
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818227
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818228
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818229
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818230
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818231
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818232
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818233
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818234
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818235
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818236
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818237
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818238
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818239
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818240
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818241
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818242
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818243
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818244
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818245
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818246
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818247
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818248
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818249
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818250
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818251
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818252
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818253
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818254
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818255
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818256
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818257
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818258
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818259
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818260
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818261
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818262
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818263
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818264
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818265
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818266
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818267
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818268
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818269
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818270
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818271
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818272
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818273
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818274
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818275
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818276
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818277
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818278
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818279
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818280
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818281
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818282
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818283
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818284
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818285
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818286
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818287
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818288
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818289
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818290
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818291
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818292
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818293
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818294
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818295
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818296
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818297
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818298
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818299
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818300
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818301
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818302
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818303
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818304
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818305
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818306
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818307
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818308
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818309
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818310
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818311
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818312
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818313
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818314
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818315
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818316
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818317
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818318
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818319
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818320
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818321
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818322
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818323
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818324
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818325
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818326
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818327
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818328
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818329
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818330
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818331
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818332
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818333
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818334
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818335
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818336
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818337
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818338
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818339
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818340
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818341
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818342
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818343
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818344
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818345
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818346
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818347
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818348
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818349
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818350
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818351
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818352
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818353
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818354
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818355
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818356
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818357
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818358
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818359
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818360
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818361
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818362
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818363
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818364
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818365
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818366
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818367
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818368
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818369
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818370
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818371
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818372
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818373
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818374
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818375
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818376
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818377
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818378
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818379
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818380
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818381
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818382
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818383
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818384
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818385
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818386
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818387
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818388
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818389
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818390
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818391
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818392
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818393
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818394
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818395
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818396
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818397
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818398
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818399
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818400
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818401
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818402
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818403
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818404
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818405
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818406
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818407
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818408
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818409
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818410
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818411
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818412
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818413
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818414
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818415
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818416
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818417
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818418
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818419
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818420
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818421
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818422
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818423
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818424
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818425
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818426
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818427
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818428
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818429
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818430
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818431
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818432
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818433
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818434
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818435
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818436
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818437
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818438
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818439
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818440
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818441
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818442
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818443
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818444
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818445
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818446
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818447
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818448
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818449
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818450
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818451
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818452
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818453
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818454
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818455
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818456
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818457
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818458
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818459
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818460
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818461
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818462
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818463
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818464
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818465
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818466
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818467
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818468
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818469
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818470
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818471
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818472
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818473
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818474
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818475
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818476
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818477
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818478
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818479
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818480
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818481
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818482
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818483
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818484
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818485
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818486
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818487
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818488
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818489
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818490
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818491
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818492
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818493
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818494
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818495
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818496
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818497
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818498
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818499
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818500
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818501
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818502
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818503
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818504
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818505
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818506
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818507
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818508
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818509
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818510
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818511
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818512
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818513
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818514
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549459746816
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329728
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329729
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329730
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329731
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329732
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329733
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329734
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329735
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329736
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329737
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329738
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329739
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329740
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329741
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329742
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329743
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329744
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329745
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329746
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329747
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329748
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329749
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329750
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329751
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329752
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329753
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329754
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329755
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329756
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329757
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329758
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329759
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329760
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329761
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329762
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329763
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329764
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329765
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329766
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329767
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329768
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329769
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329770
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329771
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329772
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329773
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329774
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329775
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329776
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329777
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329778
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329779
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329780
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329781
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329782
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329783
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329784
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329785
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329786
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329787
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329788
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329789
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329790
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329791
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329792
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329793
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329794
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329795
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329796
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329797
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329798
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329799
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329800
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329801
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329802
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329803
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329804
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329805
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329806
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329807
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329808
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329809
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329810
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329811
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329812
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329813
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329814
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329815
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329816
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329817
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329818
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329819
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329820
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329821
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329822
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329823
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329824
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329825
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329826
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329827
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329828
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329829
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329830
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329831
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329832
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329833
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329834
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329835
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329836
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329837
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329838
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329839
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329840
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329841
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329842
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329843
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329844
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329845
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329846
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329847
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329848
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329849
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329850
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329851
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329852
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329853
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329854
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329855
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329856
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329857
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329858
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329859
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329860
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329861
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329862
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329863
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329864
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329865
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329866
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329867
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329868
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329869
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329870
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329871
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329872
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329873
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329874
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329875
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329876
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329877
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329878
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329879
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329880
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329881
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329882
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329883
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329884
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329885
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329886
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329887
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329888
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329889
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329890
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329891
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329892
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329893
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329894
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329895
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329896
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329897
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329898
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329899
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329900
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329901
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329902
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329903
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329904
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329905
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329906
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329907
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329908
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329909
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329910
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329911
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329912
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329913
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329914
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329915
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329916
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329917
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329918
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329919
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329920
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329921
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329922
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329923
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329924
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329925
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329926
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329927
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329928
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329929
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329930
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329931
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329932
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329933
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329934
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329935
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329936
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329937
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329938
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329939
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329940
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329941
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329942
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329943
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329944
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329945
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329946
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329947
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329948
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329949
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329950
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329951
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329952
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329953
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329954
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329955
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329956
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329957
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329958
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329959
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329960
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329961
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329962
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329963
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329964
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329965
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329966
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329967
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329968
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329969
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329970
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329971
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329972
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329973
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329974
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329975
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329976
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329977
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329978
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329979
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329980
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329981
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329982
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329983
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329984
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329985
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329986
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329987
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329988
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329989
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329990
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329991
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329992
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329993
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329994
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329995
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329996
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329997
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329998
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 472549472329999
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330000
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330001
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330002
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330003
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330004
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330005
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330006
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330007
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330008
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330009
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330010
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330011
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330012
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330013
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330014
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330015
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330016
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330017
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330018
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330019
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330020
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330021
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330022
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330023
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330024
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330025
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330026
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330027
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330028
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330029
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330030
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330031
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330032
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330033
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330034
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330035
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330036
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330037
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330038
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330039
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330040
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330041
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330042
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330043
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330044
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330045
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330046
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330047
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330048
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330049
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330050
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330051
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330052
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330053
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330054
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330055
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330056
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330057
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330058
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330059
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330060
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330061
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330062
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330063
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330064
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330065
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330066
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330067
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330068
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330069
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330070
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330071
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330072
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330073
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330074
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330075
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330076
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330077
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330078
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330079
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330080
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330081
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330082
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330083
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330084
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330085
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330086
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330087
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330088
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330089
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330090
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330091
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330092
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330093
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330094
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330095
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330096
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330097
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330098
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330099
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330100
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330101
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330102
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330103
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330104
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330105
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330106
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330107
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330108
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330109
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330110
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330111
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330112
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330113
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330114
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330115
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330116
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330117
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330118
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330119
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330120
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330121
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330122
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330123
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330124
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330125
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330126
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330127
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330128
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330129
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330130
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330131
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330132
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330133
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330134
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330135
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330136
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330137
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330138
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330139
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330140
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330141
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330142
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330143
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330144
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330145
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330146
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330147
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330148
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330149
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330150
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330151
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330152
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330153
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549472330154
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524032
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524033
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524034
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524035
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524036
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524037
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524038
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524039
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524040
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524041
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524042
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524043
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524044
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524045
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524046
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524047
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524048
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524049
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524050
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524051
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524052
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524053
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524054
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524055
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524056
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524057
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524058
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524059
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524060
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524061
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524062
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524063
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524064
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524065
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524066
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524067
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524068
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524069
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524070
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524071
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524072
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524073
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524074
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524075
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524076
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524077
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524078
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524079
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524080
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524081
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524082
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524083
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524084
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524085
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524086
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524087
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524088
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524089
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524090
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524091
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524092
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524093
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524094
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524095
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524096
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524097
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524098
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524099
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524100
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524101
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524102
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524103
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524104
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524105
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524106
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524107
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524108
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524109
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524110
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524111
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524112
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524113
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524114
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524115
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524116
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524117
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524118
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524119
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524120
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524121
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524122
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524123
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524124
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524125
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524126
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524127
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524128
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524129
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524130
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524131
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524132
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524133
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524134
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524135
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524136
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524137
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524138
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524139
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524140
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524141
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524142
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524143
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524144
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524145
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524146
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524147
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524148
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524149
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524150
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524151
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524152
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524153
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524154
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524155
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524156
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524157
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524158
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524159
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524160
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524161
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524162
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524163
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524164
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524165
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524166
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524167
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524168
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524169
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524170
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524171
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524172
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524173
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524174
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524175
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524176
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524177
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524178
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524179
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524180
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524181
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524182
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524183
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524184
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524185
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524186
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524187
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524188
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524189
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524190
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524191
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524192
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524193
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524194
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524195
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524196
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524197
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524198
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524199
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524200
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524201
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524202
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524203
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524204
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524205
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524206
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524207
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524208
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524209
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524210
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524211
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524212
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524213
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524214
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524215
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524216
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524217
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524218
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524219
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524220
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524221
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524222
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524223
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524224
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524225
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524226
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524227
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524228
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524229
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524230
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524231
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524232
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524233
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524234
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524235
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524236
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524237
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524238
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524239
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524240
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524241
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524242
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524243
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524244
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524245
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524246
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524247
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524248
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524249
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524250
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524251
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524252
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524253
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524254
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524255
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524256
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524257
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524258
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524259
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524260
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524261
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524262
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524263
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524264
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524265
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524266
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524267
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524268
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524269
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524270
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524271
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524272
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524273
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524274
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524275
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524276
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524277
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524278
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524279
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524280
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524281
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524282
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524283
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524284
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524285
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524286
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524287
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524288
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524289
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524290
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524291
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524292
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524293
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524294
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524295
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524296
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524297
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524298
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524299
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524300
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524301
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524302
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524303
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524304
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524305
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524306
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524307
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524308
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524309
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524310
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524311
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524312
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524313
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524314
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524315
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524316
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524317
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524318
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524319
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524320
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524321
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524322
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524323
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524324
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524325
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524326
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 472549476524327
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539776
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539777
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539778
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539779
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539780
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539781
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539782
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539783
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539784
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539785
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539786
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539787
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539788
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539789
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539790
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539791
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539792
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539793
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539794
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539795
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539796
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539797
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539798
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539799
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539800
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539801
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539802
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539803
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539804
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539805
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539806
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539807
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539808
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539809
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539810
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539811
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539812
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539813
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539814
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539815
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539816
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539817
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539818
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539819
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539820
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539821
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539822
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539823
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539824
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539825
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539826
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539827
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539828
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539829
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539830
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539831
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539832
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539833
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539834
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539835
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539836
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539837
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539838
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539839
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539840
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539841
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539842
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539843
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539844
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539845
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539846
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539847
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539848
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539849
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539850
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539851
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539852
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539853
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539854
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539855
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539856
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539857
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539858
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539859
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539860
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539861
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539862
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539863
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539864
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539865
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539866
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539867
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539868
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539869
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539870
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539871
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539872
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539873
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539874
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539875
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539876
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539877
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539878
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539879
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539880
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539881
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539882
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539883
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539884
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539885
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539886
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539887
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539888
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539889
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539890
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539891
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539892
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539893
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539894
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539895
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539896
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539897
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539898
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539899
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539900
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539901
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539902
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539903
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539904
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539905
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539906
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539907
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539908
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539909
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539910
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539911
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539912
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539913
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539914
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539915
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539916
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539917
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539918
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539919
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539920
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539921
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539922
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539923
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539924
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539925
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539926
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539927
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539928
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539929
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539930
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539931
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539932
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539933
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539934
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539935
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539936
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539937
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539938
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539939
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539940
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539941
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539942
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539943
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539944
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539945
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539946
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539947
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539948
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539949
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539950
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539951
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539952
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539953
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539954
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539955
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539956
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539957
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539958
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539959
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539960
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539961
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539962
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539963
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539964
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539965
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539966
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539967
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539968
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539969
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539970
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539971
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539972
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539973
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539974
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539975
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539976
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539977
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539978
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539979
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539980
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539981
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539982
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539983
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539984
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539985
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539986
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539987
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539988
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539989
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539990
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539991
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539992
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539993
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539994
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539995
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539996
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539997
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539998
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774539999
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540000
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540001
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540002
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540003
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540004
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540005
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540006
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540007
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540008
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540009
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540010
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540011
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540012
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540013
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540014
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540015
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540016
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540017
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540018
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540019
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540020
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540021
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540022
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540023
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540024
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540025
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540026
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540027
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540028
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540029
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540030
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540031
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540032
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540033
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540034
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540035
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540036
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540037
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540038
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540039
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540040
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540041
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540042
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540043
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540044
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540045
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540046
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540047
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540048
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540049
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540050
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540051
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540052
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540053
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540054
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540055
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540056
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540057
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540058
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540059
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540060
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540061
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540062
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540063
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540064
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540065
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540066
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540067
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540068
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540069
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540070
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540071
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540072
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540073
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540074
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540075
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540076
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540077
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540078
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540079
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540080
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540081
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540082
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540083
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540084
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540085
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540086
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540087
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540088
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540089
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540090
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540091
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540092
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540093
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540094
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540095
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540096
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540097
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540098
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540099
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540100
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540101
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540102
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540103
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540104
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540105
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540106
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540107
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540108
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540109
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540110
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540111
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540112
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540113
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540114
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540115
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540116
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540117
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540118
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540119
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540120
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540121
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540122
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540123
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540124
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540125
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540126
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540127
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540128
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540129
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540130
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540131
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540132
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540133
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540134
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540135
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540136
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540137
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540138
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540139
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540140
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540141
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540142
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540143
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540144
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540145
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540146
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540147
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540148
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540149
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540150
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540151
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540152
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540153
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540154
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540155
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540156
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540157
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540158
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540159
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540160
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540161
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540162
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540163
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540164
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540165
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540166
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540167
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540168
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540169
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540170
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540171
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540172
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540173
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540174
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540175
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540176
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540177
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540178
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540179
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540180
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540181
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540182
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540183
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540184
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540185
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540186
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540187
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540188
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540189
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540190
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540191
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540192
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540193
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540194
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540195
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540196
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540197
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540198
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540199
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540200
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540201
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540202
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540203
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540204
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540205
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540206
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540207
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540208
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540209
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540210
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540211
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540212
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540213
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540214
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540215
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540216
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540217
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540218
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540219
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540220
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540221
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540222
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540223
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540224
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540225
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540226
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540227
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540228
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540229
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540230
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540231
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540232
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540233
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540234
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540235
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540236
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540237
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540238
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540239
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540240
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540241
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540242
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540243
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540244
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540245
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540246
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540247
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540248
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540249
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540250
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540251
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540252
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540253
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540254
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540255
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540256
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540257
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540258
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540259
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540260
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540261
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540262
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540263
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540264
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540265
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540266
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540267
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540268
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540269
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540270
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540271
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540272
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540273
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540274
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540275
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540276
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540277
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540278
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540279
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540280
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540281
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540282
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540283
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540284
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540285
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540286
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540287
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540288
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540289
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540290
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540291
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783774540292
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734080
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734081
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734082
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734083
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734084
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734085
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734086
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734087
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734088
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734089
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734090
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734091
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734092
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734093
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734094
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734095
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734096
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734097
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734098
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734099
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734100
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734101
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734102
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734103
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734104
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734105
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734106
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734107
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734108
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734109
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734110
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734111
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734112
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734113
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734114
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734115
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734116
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734117
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734118
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734119
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734120
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734121
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734122
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734123
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734124
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734125
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734126
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734127
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734128
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734129
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734130
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734131
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734132
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734133
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734134
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734135
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734136
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734137
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734138
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734139
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734140
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734141
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734142
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734143
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734144
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734145
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734146
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734147
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734148
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734149
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734150
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734151
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734152
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734153
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734154
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734155
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734156
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734157
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734158
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734159
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734160
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734161
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734162
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734163
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734164
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734165
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734166
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734167
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734168
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734169
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734170
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734171
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734172
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734173
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734174
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734175
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734176
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734177
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734178
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734179
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734180
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734181
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734182
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734183
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734184
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734185
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734186
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734187
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734188
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734189
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734190
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734191
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734192
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734193
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734194
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734195
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734196
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734197
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734198
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734199
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734200
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734201
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734202
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734203
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734204
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734205
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734206
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734207
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734208
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734209
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734210
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734211
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734212
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734213
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734214
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734215
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734216
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734217
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734218
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734219
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734220
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734221
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734222
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734223
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734224
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734225
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734226
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734227
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734228
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734229
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734230
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734231
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734232
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734233
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734234
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734235
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734236
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734237
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734238
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734239
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734240
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734241
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734242
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734243
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734244
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734245
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734246
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734247
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734248
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734249
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734250
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734251
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734252
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734253
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734254
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734255
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734256
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734257
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734258
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734259
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734260
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734261
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734262
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734263
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734264
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734265
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734266
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734267
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734268
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734269
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734270
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734271
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734272
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734273
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734274
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734275
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734276
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734277
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734278
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734279
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734280
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734281
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734282
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734283
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734284
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734285
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 472783778734286
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336625086464
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863680
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863681
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863682
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863683
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863684
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863685
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863686
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863687
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863688
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863689
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863690
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863691
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863692
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863693
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863694
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863695
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863696
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863697
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863698
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863699
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863700
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863701
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863702
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863703
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863704
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863705
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863706
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863707
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863708
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863709
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863710
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863711
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863712
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863713
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863714
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863715
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863716
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863717
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863718
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863719
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863720
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863721
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863722
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863723
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863724
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863725
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863726
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863727
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863728
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863729
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863730
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863731
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863732
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863733
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863734
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863735
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863736
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863737
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863738
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863739
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863740
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863741
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863742
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863743
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863744
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863745
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863746
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863747
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863748
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863749
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863750
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863751
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863752
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863753
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863754
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863755
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863756
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863757
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863758
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863759
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863760
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863761
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863762
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863763
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863764
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863765
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863766
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863767
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863768
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863769
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863770
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863771
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863772
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863773
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863774
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863775
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863776
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863777
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863778
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863779
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863780
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863781
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863782
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863783
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863784
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863785
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863786
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863787
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863788
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863789
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863790
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863791
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863792
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863793
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863794
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863795
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863796
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863797
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863798
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863799
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863800
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863801
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863802
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863803
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863804
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863805
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863806
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863807
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863808
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863809
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863810
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863811
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863812
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863813
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863814
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863815
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863816
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863817
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863818
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863819
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863820
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863821
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863822
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863823
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863824
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863825
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863826
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863827
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863828
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863829
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863830
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863831
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863832
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863833
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863834
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863835
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863836
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863837
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863838
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863839
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863840
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863841
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863842
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863843
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863844
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863845
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863846
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863847
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863848
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863849
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863850
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863851
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863852
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863853
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863854
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863855
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863856
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863857
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863858
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863859
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863860
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863861
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863862
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863863
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863864
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863865
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863866
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863867
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863868
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863869
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863870
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863871
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863872
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863873
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863874
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863875
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863876
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863877
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863878
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863879
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863880
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863881
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863882
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863883
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863884
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863885
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863886
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863887
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863888
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863889
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863890
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863891
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863892
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863893
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863894
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863895
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863896
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863897
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863898
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863899
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863900
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863901
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863902
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863903
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863904
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863905
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863906
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863907
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863908
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863909
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863910
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863911
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863912
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863913
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863914
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863915
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863916
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863917
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863918
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863919
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863920
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863921
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863922
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863923
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863924
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863925
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863926
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863927
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863928
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863929
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863930
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863931
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863932
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863933
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863934
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863935
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863936
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863937
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863938
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863939
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863940
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863941
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863942
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863943
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863944
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863945
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863946
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863947
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863948
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863949
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863950
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863951
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863952
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863953
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863954
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863955
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863956
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863957
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863958
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863959
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863960
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863961
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863962
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863963
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863964
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863965
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863966
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863967
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863968
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863969
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863970
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863971
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863972
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863973
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863974
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863975
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863976
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863977
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863978
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863979
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863980
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863981
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863982
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863983
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863984
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863985
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863986
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863987
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863988
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863989
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863990
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863991
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863992
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863993
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863994
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863995
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863996
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863997
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863998
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641863999
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864000
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864001
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864002
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864003
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864004
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864005
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864006
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864007
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864008
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864009
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864010
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864011
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864012
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864013
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864014
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864015
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864016
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864017
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864018
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864019
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864020
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864021
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864022
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864023
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864024
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864025
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864026
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864027
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864028
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864029
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864030
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864031
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864032
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864033
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864034
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864035
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864036
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864037
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864038
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864039
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864040
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864041
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864042
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864043
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864044
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864045
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864046
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864047
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864048
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864049
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864050
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864051
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864052
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864053
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864054
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864055
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864056
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864057
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864058
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864059
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864060
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864061
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864062
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864063
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864064
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864065
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864066
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864067
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864068
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864069
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864070
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864071
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864072
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864073
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864074
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864075
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864076
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864077
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864078
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864079
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864080
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864081
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864082
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864083
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864084
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864085
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864086
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864087
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864088
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864089
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864090
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864091
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864092
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864093
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864094
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864095
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864096
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864097
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864098
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864099
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864100
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864101
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864102
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864103
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864104
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864105
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864106
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864107
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864108
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864109
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864110
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864111
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864112
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864113
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864114
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864115
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864116
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864117
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864118
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864119
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864120
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864121
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864122
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864123
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864124
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864125
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864126
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864127
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864128
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864129
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864130
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864131
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864132
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864133
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864134
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864135
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864136
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864137
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864138
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864139
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864140
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864141
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864142
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864143
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864144
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864145
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864146
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864147
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864148
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864149
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864150
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864151
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864152
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864153
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864154
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864155
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864156
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864157
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864158
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864159
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864160
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864161
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864162
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864163
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864164
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864165
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864166
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864167
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864168
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864169
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864170
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864171
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864172
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864173
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864174
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864175
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864176
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864177
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864178
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864179
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864180
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864181
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864182
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864183
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864184
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864185
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864186
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864187
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864188
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864189
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864190
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864191
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864192
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864193
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864194
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864195
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864196
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864197
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864198
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864199
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864200
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864201
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864202
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864203
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864204
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864205
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864206
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864207
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864208
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864209
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864210
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864211
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864212
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864213
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864214
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864215
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864216
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864217
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864218
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864219
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864220
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864221
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864222
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864223
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864224
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864225
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864226
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864227
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864228
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864229
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864230
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864231
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864232
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864233
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864234
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864235
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864236
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864237
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864238
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864239
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864240
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864241
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864242
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864243
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864244
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864245
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864246
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864247
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864248
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864249
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864250
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864251
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864252
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864253
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864254
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864255
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864256
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864257
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864258
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864259
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864260
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864261
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864262
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864263
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864264
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864265
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864266
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864267
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864268
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864269
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864270
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864271
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864272
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864273
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864274
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864275
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864276
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864277
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864278
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864279
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864280
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864281
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864282
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864283
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864284
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864285
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864286
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864287
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864288
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864289
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864290
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864291
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864292
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864293
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864294
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864295
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864296
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864297
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864298
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864299
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864300
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864301
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864302
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864303
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864304
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864305
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864306
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864307
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864308
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864309
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864310
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864311
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864312
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864313
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864314
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864315
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864316
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864317
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864318
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864319
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864320
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864321
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864322
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864323
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864324
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864325
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864326
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864327
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864328
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864329
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864330
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864331
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864332
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864333
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864334
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864335
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864336
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864337
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864338
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864339
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864340
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864341
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864342
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864343
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864344
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864345
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864346
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864347
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864348
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864349
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864350
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864351
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864352
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864353
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864354
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864355
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864356
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864357
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864358
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864359
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864360
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864361
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864362
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864363
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864364
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864365
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864366
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864367
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864368
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864369
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864370
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864371
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864372
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864373
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864374
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864375
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864376
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864377
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864378
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864379
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864380
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864381
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864382
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864383
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864384
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864385
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864386
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864387
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864388
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864389
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864390
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864391
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864392
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864393
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864394
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864395
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864396
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864397
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864398
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864399
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864400
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864401
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 475336641864402
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733430747136
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524352
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524353
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524354
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524355
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524356
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524357
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524358
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524359
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524360
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524361
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524362
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524363
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524364
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524365
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524366
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524367
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524368
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524369
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524370
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524371
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524372
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524373
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524374
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524375
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524376
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524377
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524378
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524379
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524380
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524381
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524382
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524383
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524384
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524385
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524386
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524387
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524388
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524389
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524390
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524391
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524392
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524393
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524394
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524395
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524396
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524397
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524398
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524399
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524400
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524401
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524402
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524403
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524404
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524405
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524406
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524407
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524408
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524409
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524410
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524411
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524412
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524413
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524414
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524415
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524416
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524417
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524418
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524419
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524420
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524421
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524422
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524423
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524424
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524425
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524426
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524427
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524428
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524429
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524430
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524431
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524432
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524433
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524434
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524435
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524436
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524437
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524438
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524439
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524440
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524441
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524442
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524443
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524444
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524445
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524446
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524447
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524448
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524449
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524450
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524451
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524452
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524453
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524454
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524455
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524456
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524457
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524458
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524459
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524460
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524461
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524462
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524463
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524464
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524465
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524466
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524467
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524468
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524469
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524470
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524471
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524472
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524473
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524474
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524475
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524476
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524477
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524478
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524479
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524480
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524481
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524482
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524483
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524484
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524485
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524486
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524487
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524488
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524489
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524490
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524491
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524492
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524493
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524494
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524495
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524496
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524497
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524498
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524499
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524500
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524501
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524502
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524503
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524504
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524505
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524506
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524507
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524508
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524509
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524510
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524511
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524512
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524513
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524514
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524515
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524516
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524517
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524518
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524519
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524520
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524521
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524522
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524523
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524524
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524525
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524526
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524527
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524528
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524529
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524530
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524531
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524532
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524533
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524534
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524535
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524536
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524537
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524538
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524539
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524540
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524541
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524542
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524543
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524544
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524545
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524546
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524547
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524548
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524549
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524550
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524551
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524552
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524553
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524554
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524555
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524556
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524557
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524558
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524559
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524560
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524561
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524562
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524563
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524564
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524565
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524566
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524567
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524568
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524569
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524570
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524571
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524572
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524573
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524574
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524575
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524576
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524577
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524578
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524579
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524580
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524581
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524582
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524583
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524584
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524585
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524586
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524587
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524588
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524589
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524590
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524591
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524592
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524593
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524594
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524595
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524596
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524597
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524598
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524599
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524600
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524601
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524602
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524603
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524604
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524605
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524606
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524607
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524608
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524609
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524610
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524611
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524612
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524613
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524614
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524615
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524616
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524617
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524618
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524619
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524620
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524621
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524622
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524623
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524624
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524625
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524626
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524627
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524628
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524629
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524630
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524631
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524632
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524633
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524634
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524635
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524636
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524637
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524638
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524639
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524640
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524641
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524642
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524643
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524644
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524645
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524646
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524647
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524648
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524649
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524650
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524651
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524652
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524653
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524654
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524655
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524656
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524657
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524658
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524659
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524660
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524661
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524662
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524663
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524664
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524665
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524666
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524667
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524668
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524669
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524670
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524671
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524672
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524673
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524674
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524675
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524676
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524677
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524678
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524679
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524680
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524681
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524682
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524683
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524684
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524685
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524686
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524687
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524688
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524689
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524690
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524691
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524692
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524693
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524694
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524695
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524696
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524697
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524698
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524699
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524700
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524701
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524702
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524703
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524704
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524705
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524706
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524707
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524708
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524709
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524710
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524711
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524712
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524713
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524714
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524715
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524716
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524717
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524718
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524719
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524720
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524721
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524722
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524723
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524724
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524725
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524726
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524727
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524728
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524729
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524730
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524731
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524732
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524733
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524734
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524735
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524736
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524737
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524738
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524739
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524740
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524741
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524742
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524743
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524744
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524745
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524746
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524747
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524748
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524749
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524750
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524751
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524752
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524753
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524754
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524755
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524756
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524757
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524758
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524759
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524760
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524761
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524762
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524763
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524764
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524765
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524766
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524767
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524768
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524769
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524770
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524771
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524772
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524773
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524774
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524775
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524776
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524777
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524778
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524779
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524780
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524781
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 477733447524782
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718656
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718657
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718658
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718659
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718660
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718661
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718662
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718663
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718664
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718665
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718666
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718667
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718668
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718669
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718670
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718671
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718672
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718673
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718674
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718675
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718676
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718677
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718678
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718679
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718680
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718681
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718682
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718683
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718684
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718685
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718686
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718687
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718688
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718689
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718690
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718691
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718692
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718693
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718694
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718695
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718696
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718697
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718698
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718699
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718700
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718701
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718702
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718703
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718704
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718705
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718706
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718707
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718708
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718709
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718710
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718711
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718712
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718713
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718714
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718715
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718716
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718717
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718718
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718719
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718720
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718721
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718722
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718723
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718724
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718725
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718726
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718727
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718728
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718729
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718730
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718731
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718732
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718733
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718734
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718735
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718736
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718737
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718738
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718739
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718740
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718741
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718742
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718743
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718744
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718745
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718746
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718747
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718748
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718749
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718750
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718751
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718752
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718753
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718754
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718755
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718756
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718757
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718758
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718759
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718760
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718761
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718762
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718763
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718764
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718765
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718766
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718767
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718768
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718769
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718770
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718771
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718772
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718773
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718774
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718775
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718776
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718777
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718778
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718779
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718780
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718781
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718782
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718783
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718784
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718785
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718786
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718787
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718788
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718789
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718790
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718791
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718792
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718793
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718794
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718795
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718796
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718797
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718798
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718799
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718800
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718801
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718802
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718803
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718804
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718805
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718806
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718807
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718808
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718809
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718810
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718811
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718812
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718813
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718814
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718815
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718816
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718817
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718818
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718819
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718820
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718821
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718822
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718823
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718824
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718825
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718826
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718827
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718828
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718829
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718830
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718831
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718832
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718833
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718834
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718835
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718836
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718837
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718838
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718839
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718840
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718841
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718842
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718843
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718844
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718845
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718846
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718847
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718848
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718849
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718850
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718851
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718852
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718853
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718854
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718855
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718856
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718857
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718858
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718859
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718860
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718861
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718862
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718863
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718864
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718865
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718866
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718867
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718868
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718869
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718870
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718871
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718872
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718873
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718874
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718875
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718876
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718877
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718878
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718879
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718880
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718881
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718882
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718883
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718884
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718885
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718886
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718887
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718888
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718889
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718890
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718891
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718892
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718893
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718894
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718895
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718896
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718897
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718898
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718899
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718900
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718901
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718902
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718903
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718904
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718905
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718906
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718907
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718908
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718909
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718910
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718911
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718912
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718913
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718914
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718915
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718916
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718917
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718918
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718919
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718920
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718921
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718922
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718923
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718924
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718925
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718926
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718927
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718928
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718929
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718930
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718931
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718932
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718933
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718934
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718935
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718936
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718937
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718938
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718939
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718940
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718941
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718942
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718943
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718944
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718945
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718946
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 477733451718947
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
