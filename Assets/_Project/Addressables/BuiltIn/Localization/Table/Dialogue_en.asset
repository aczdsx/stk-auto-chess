%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 8c07de4e6b118478b9e53f481dac2451, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24195883008
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 751442059264
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 5490640674816
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 6272467329024
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 7011403030528
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788929
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788930
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788931
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788932
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788933
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788934
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788935
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788936
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788937
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788938
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788939
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788940
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788941
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788942
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788943
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788944
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788945
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788946
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788947
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788948
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788949
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788950
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788951
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788952
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788953
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788954
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788955
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788956
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788957
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788958
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788959
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788960
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788961
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788962
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788963
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788964
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788965
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788966
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788967
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788968
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788969
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788970
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788971
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788972
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788973
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788974
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788975
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788976
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788977
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788978
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788979
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788980
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788981
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788982
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788983
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788984
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788985
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788986
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788987
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788988
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788989
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788990
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788991
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788992
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788993
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788994
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788995
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788996
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788997
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788998
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788999
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789000
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789001
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789002
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789003
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789004
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789005
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789006
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789007
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789008
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789009
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789010
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789011
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789012
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789013
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789014
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789015
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789016
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789017
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789018
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789019
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789020
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789021
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789022
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789023
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789024
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789025
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789026
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789027
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789028
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789029
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789030
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789031
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789032
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789033
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789034
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789035
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789036
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789037
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789038
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789039
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789040
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789041
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789042
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789043
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789044
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789045
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789046
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789047
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789048
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789049
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789050
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789051
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789052
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789053
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789054
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789055
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789056
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789057
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789058
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789059
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789060
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789061
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789062
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789063
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789064
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789065
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789066
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789067
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789068
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789069
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789070
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789071
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789072
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789073
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789074
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789075
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789076
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789077
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789078
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789079
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789080
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789081
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789082
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789083
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789084
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789085
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789086
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789087
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789088
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789089
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789090
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789091
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789092
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789093
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789094
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789095
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789096
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789097
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789098
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789099
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789100
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789101
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789102
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789103
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789104
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789105
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789106
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789107
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789108
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789109
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789110
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789111
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789112
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789113
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789114
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789115
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789116
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789117
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789118
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789119
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789120
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789121
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789122
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789123
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789124
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789125
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789126
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789127
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789128
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789129
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789130
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789131
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789132
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789133
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789134
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789135
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789136
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789137
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789138
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789139
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789140
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789141
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789142
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789143
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789144
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789145
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789146
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789147
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789148
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789149
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789150
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789151
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789152
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789153
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789154
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789155
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789156
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789157
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789158
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789159
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789160
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789161
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789162
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789163
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789164
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789165
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789166
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789167
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789168
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789169
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789170
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789171
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789172
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789173
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789174
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789175
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789176
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789177
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789178
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789179
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789180
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789181
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789182
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789183
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789184
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789185
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789186
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789187
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789188
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789189
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789190
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789191
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789192
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789193
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789194
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789195
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789196
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789197
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789198
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789199
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789200
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789201
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789202
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789203
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789204
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789205
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789206
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789207
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789208
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789209
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789210
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789211
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789212
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789213
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789214
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789215
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789216
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789217
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789218
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789219
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789220
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789221
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789222
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789223
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789224
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789225
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789226
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789227
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789228
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789229
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789230
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789231
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789232
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789233
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789234
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789235
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789236
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789237
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789238
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789239
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789240
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789241
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789242
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789243
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789244
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789245
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789246
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789247
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789248
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789249
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789250
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789251
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789252
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789253
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789254
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789255
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789256
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789257
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789258
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789259
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789260
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789261
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789262
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789263
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789264
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789265
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789266
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789267
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789268
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789269
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789270
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789271
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789272
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789273
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789274
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789275
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789276
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789277
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789278
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789279
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789280
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789281
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789282
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789283
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789284
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789285
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789286
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789287
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789288
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789289
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789290
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789291
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789292
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789293
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789294
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789295
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789296
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789297
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789298
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789299
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789300
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789301
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789302
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789303
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789304
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789305
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789306
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789307
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789308
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789309
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789310
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789311
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789312
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789313
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789314
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789315
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789316
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789317
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789318
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789319
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789320
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789321
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789322
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789323
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789324
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789325
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789326
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789327
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789328
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789329
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789330
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789331
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789332
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789333
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789334
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789335
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789336
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789337
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789338
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789339
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789340
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789341
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789342
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789343
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789344
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789345
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789346
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789347
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789348
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789349
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789350
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789351
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789352
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789353
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789354
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789355
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789356
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789357
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789358
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789359
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789360
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789361
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789362
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789363
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789364
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789365
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789366
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789367
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789368
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789369
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789370
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789371
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789372
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789373
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789374
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789375
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789376
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789377
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789378
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789379
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789380
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789381
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789382
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789383
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789384
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789385
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789386
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789387
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789388
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789389
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789390
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789391
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789392
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789393
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789394
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789395
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789396
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789397
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789398
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789399
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789400
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789401
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789402
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789403
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789404
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789405
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789406
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789407
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789408
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789409
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789410
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789411
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789412
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789413
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789414
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789415
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789416
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789417
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789418
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789419
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789420
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789421
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789422
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789423
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789424
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789425
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789426
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789427
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789428
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789429
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789430
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789431
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789432
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789433
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789434
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789435
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789436
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789437
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789438
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789439
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789440
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789441
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789442
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789443
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789444
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789445
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789446
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789447
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789448
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789449
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789450
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789451
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789452
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789453
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789454
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789455
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789456
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789457
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789458
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789459
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789460
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789461
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789462
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789463
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789464
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789465
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789466
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789467
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789468
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789469
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789470
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789471
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789472
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789473
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789474
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789475
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789476
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789477
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789478
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789479
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789480
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789481
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789482
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789483
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789484
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789485
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789486
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789487
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789488
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789489
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789490
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789491
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789492
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789493
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789494
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789495
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789496
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789497
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789498
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789499
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789500
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789501
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789502
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789503
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789504
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789505
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789506
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789507
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789508
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789509
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789510
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789511
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789512
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789513
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789514
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789515
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789516
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789517
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789518
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789519
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789520
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789521
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789522
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789523
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789524
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789525
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789526
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789527
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789528
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789529
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789530
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789531
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789532
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789533
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789534
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789535
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789536
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789537
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789538
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789539
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789540
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789541
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789542
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789543
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789544
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789545
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789546
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789547
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789548
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789549
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789550
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789551
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789552
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789553
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789554
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789555
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789556
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789557
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789558
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789559
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789560
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789561
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789562
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789563
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789564
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789565
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789566
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789567
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789568
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789569
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789570
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789571
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789572
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789573
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789574
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789575
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789576
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789577
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789578
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789579
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789580
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789581
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789582
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789583
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789584
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789585
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789586
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789587
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789588
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789589
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789590
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789591
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789592
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789593
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789594
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789595
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789596
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789597
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789598
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789599
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789600
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789601
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789602
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789603
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789604
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789605
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789606
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789607
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789608
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789609
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789610
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789611
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789612
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789613
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789614
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789615
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789616
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789617
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789618
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789619
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789620
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789621
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789622
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789623
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789624
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789625
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789626
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789627
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789628
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789629
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789630
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789631
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789632
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789633
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789634
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789635
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789636
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789637
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789638
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789639
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789640
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789641
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789642
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789643
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789644
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789645
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789646
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789647
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789648
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789649
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789650
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789651
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369322999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 346911369323219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886272
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886273
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886274
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886275
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886276
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886277
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886278
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886279
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886280
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886281
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886282
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886283
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886284
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886285
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886286
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886287
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886288
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886289
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886290
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886291
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886292
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886293
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886294
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886295
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886296
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886297
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886298
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886299
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886300
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886301
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886302
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886303
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886304
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886305
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886306
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886307
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886308
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886309
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886310
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886311
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886312
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886313
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886314
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886315
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886316
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886317
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886318
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886319
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886320
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886321
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886322
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886323
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886324
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886325
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886326
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886327
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886328
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886329
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886330
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886331
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886332
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886333
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886334
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886335
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886336
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886337
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886338
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886339
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886340
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886341
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886342
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886343
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886344
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886345
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886346
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886347
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886348
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886349
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886350
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886351
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886352
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886353
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886354
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886355
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886356
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886357
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886358
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886359
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886360
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886361
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886362
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886363
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886364
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886365
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886366
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886367
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886368
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886369
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886370
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886371
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886372
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886373
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886374
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886375
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886376
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886377
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886378
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886379
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886380
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886381
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886382
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886383
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886384
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886385
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886386
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886387
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886388
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886389
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886390
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886391
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886392
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886393
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886394
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886395
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886396
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886397
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886398
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886399
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886400
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886401
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886402
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886403
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886404
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886405
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886406
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886407
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886408
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886409
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886410
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886411
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886412
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886413
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886414
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886415
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886416
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886417
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886418
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886419
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886420
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886421
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886422
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886423
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886424
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886425
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886426
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886427
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886428
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886429
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886430
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886431
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886432
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886433
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886434
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886435
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886436
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886437
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886438
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886439
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886440
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886441
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886442
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886443
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886444
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886445
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886446
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886447
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886448
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886449
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886450
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886451
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886452
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886453
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886454
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886455
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886456
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886457
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886458
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886459
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886460
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886461
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886462
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886463
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886464
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886465
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886466
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886467
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886468
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886469
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886470
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886471
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886472
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886473
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886474
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886475
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886476
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886477
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886478
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886479
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886480
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886481
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886482
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886483
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886484
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886485
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886486
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886487
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886488
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886489
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886490
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886491
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886492
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886493
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886494
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886495
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886496
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886497
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886498
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886499
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886500
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886501
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886502
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886503
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886504
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886505
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886506
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886507
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886508
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886509
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886510
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886511
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886512
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886513
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886514
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886515
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886516
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886517
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886518
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886519
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886520
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886521
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886522
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886523
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886524
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886525
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886526
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886527
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886528
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886529
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886530
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886531
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886532
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886533
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886534
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886535
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886536
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886537
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886538
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886539
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886540
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886541
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886542
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886543
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886544
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886545
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886546
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886547
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886548
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886549
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886550
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886551
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886552
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886553
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886554
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886555
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886556
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886557
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886558
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886559
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886560
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886561
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886562
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886563
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886564
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886565
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886566
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886567
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886568
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886569
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886570
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886571
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886572
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886573
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886574
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886575
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886576
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886577
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886578
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886579
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886580
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886581
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886582
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886583
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886584
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886585
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886586
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886587
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886588
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886589
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886590
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886591
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886592
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886593
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886594
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886595
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886596
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886597
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886598
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886599
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886600
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886601
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886602
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886603
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886604
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886605
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886606
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886607
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886608
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886609
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886610
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886611
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886612
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886613
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886614
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886615
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886616
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886617
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886618
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886619
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886620
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886621
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886622
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886623
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886624
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886625
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886626
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886627
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886628
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886629
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886630
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886631
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886632
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886633
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886634
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886635
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886636
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886637
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886638
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886639
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886640
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886641
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886642
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886643
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886644
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886645
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886646
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886647
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886648
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886649
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886650
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886651
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886652
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886653
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886654
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886655
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886656
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886657
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886658
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886659
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886660
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886661
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886662
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886663
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886664
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886665
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886666
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886667
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886668
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886669
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886670
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886671
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886672
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886673
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886674
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886675
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886676
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886677
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886678
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886679
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886680
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886681
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886682
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886683
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886684
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886685
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886686
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886687
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886688
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886689
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886690
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886691
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886692
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886693
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886694
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886695
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886696
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886697
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886698
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886699
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886700
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886701
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886702
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886703
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886704
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886705
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886706
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886707
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886708
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886709
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886710
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886711
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886712
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886713
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886714
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886715
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886716
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886717
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886718
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886719
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886720
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886721
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886722
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886723
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886724
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886725
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886726
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886727
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886728
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886729
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886730
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886731
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886732
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886733
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886734
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886735
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886736
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886737
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886738
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886739
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886740
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886741
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886742
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886743
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886744
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886745
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886746
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886747
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886748
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886749
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886750
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886751
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886752
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886753
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886754
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886755
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886756
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886757
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886758
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886759
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886760
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886761
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886762
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886763
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886764
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886765
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886766
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886767
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886768
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886769
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886770
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886771
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886772
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886773
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886774
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886775
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886776
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886777
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886778
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886779
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886780
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886781
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886782
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886783
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886784
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886785
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886786
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886787
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886788
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886789
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886790
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886791
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886792
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886793
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886794
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886795
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886796
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886797
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886798
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886799
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886800
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886801
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886802
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886803
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886804
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886805
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886806
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886807
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886808
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886809
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886810
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886811
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886812
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886813
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886814
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886815
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886816
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886817
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886818
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886819
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886820
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886821
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886822
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886823
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886824
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886825
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886826
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886827
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886828
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886829
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886830
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886831
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886832
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886833
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886834
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886835
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886836
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886837
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886838
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886839
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886840
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886841
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886842
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886843
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886844
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886845
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886846
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886847
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886848
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886849
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886850
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886851
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886852
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886853
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886854
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886855
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886856
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886857
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886858
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886859
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886860
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886861
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886862
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886863
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886864
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886865
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886866
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886867
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886868
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886869
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886870
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886871
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886872
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886873
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886874
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886875
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886876
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886877
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886878
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886879
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886880
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886881
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886882
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886883
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886884
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886885
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886886
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886887
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886888
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886889
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886890
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886891
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886892
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886893
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886894
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886895
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886896
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886897
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886898
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886899
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886900
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886901
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886902
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886903
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886904
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886905
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886906
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886907
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886908
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886909
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886910
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886911
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886912
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886913
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886914
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886915
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886916
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886917
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886918
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886919
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886920
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886921
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886922
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886923
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886924
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886925
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886926
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886927
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886928
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886929
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886930
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886931
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886932
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886933
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886934
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886935
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886936
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886937
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886938
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886939
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886940
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886941
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886942
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886943
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886944
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886945
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886946
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886947
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886948
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886949
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886950
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886951
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886952
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886953
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886954
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886955
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886956
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886957
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886958
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886959
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886960
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886961
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886962
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886963
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886964
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886965
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886966
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886967
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886968
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886969
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886970
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886971
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886972
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886973
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886974
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886975
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886976
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886977
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886978
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886979
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886980
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886981
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886982
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886983
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886984
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886985
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886986
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886987
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886988
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886989
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886990
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886991
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886992
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886993
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886994
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 456392744886995
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679424
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679425
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679426
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679427
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679428
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679429
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679430
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679431
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679432
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679433
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679434
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679435
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679436
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679437
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679438
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679439
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679440
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679441
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679442
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679443
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679444
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679445
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679446
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679447
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679448
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679449
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679450
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679451
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679452
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679453
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679454
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679455
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679456
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679457
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679458
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679459
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679460
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679461
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679462
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679463
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679464
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679465
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679466
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679467
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679468
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679469
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679470
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679471
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679472
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679473
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679474
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679475
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679476
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679477
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679478
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679479
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679480
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679481
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679482
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679483
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679484
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679485
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679486
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679487
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679488
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679489
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679490
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679491
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679492
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679493
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679494
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679495
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679496
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679497
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679498
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679499
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679500
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679501
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679502
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679503
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679504
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679505
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679506
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679507
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679508
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679509
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679510
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679511
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679512
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679513
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679514
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679515
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679516
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679517
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679518
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679519
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679520
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679521
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679522
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679523
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679524
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679525
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679526
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679527
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679528
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679529
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679530
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679531
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679532
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679533
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679534
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679535
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679536
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679537
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679538
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679539
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679540
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679541
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679542
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679543
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679544
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679545
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679546
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679547
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679548
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679549
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679550
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679551
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679552
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679553
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679554
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679555
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679556
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679557
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679558
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679559
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679560
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679561
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679562
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679563
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679564
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679565
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679566
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679567
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679568
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679569
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679570
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679571
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679572
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679573
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679574
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679575
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679576
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679577
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679578
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679579
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679580
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679581
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679582
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679583
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679584
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679585
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679586
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679587
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679588
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679589
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679590
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679591
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679592
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679593
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679594
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679595
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679596
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679597
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679598
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679599
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679600
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679601
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679602
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679603
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679604
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679605
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679606
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679607
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679608
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679609
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679610
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679611
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679612
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679613
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679614
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679615
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679616
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679617
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679618
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679619
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679620
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679621
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679622
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679623
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679624
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679625
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679626
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679627
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679628
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679629
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679630
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679631
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679632
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679633
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679634
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679635
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679636
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679637
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679638
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679639
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679640
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679641
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679642
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679643
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679644
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679645
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679646
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679647
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679648
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679649
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679650
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679651
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679652
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679653
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679654
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679655
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679656
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679657
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679658
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679659
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679660
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679661
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679662
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679663
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679664
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679665
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679666
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679667
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679668
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679669
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679670
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679671
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679672
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679673
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679674
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679675
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679676
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679677
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679678
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679679
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679680
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679681
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679682
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679683
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679684
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679685
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679686
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679687
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679688
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679689
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679690
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679691
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679692
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679693
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679694
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679695
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679696
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679697
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679698
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679699
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679700
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679701
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679702
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679703
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679704
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679705
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679706
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679707
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679708
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679709
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679710
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679711
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679712
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679713
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679714
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679715
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679716
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679717
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679718
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679719
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679720
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679721
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679722
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679723
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679724
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679725
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679726
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679727
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679728
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679729
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679730
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679731
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679732
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679733
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679734
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679735
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679736
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679737
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679738
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679739
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679740
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679741
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679742
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679743
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679744
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679745
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679746
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679747
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679748
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679749
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679750
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679751
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679752
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679753
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679754
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679755
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679756
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679757
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679758
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679759
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679760
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679761
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679762
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679763
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679764
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679765
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679766
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679767
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679768
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679769
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679770
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679771
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679772
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679773
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679774
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679775
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679776
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679777
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679778
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679779
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679780
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679781
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679782
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679783
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679784
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679785
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679786
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679787
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679788
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679789
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679790
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679791
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679792
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679793
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679794
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679795
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679796
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679797
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679798
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679799
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679800
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679801
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679802
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679803
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679804
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679805
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679806
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679807
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679808
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679809
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679810
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679811
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679812
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679813
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679814
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679815
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679816
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679817
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679818
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679819
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679820
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679821
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679822
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679823
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679824
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679825
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679826
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679827
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679828
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679829
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679830
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679831
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679832
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679833
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679834
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679835
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679836
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679837
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679838
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679839
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679840
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679841
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679842
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679843
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679844
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679845
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679846
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679847
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679848
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679849
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679850
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679851
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679852
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679853
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679854
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679855
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679856
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679857
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679858
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679859
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679860
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679861
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679862
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679863
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679864
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679865
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679866
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679867
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679868
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679869
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679870
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679871
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679872
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679873
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679874
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679875
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679876
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679877
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679878
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679879
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679880
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679881
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679882
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679883
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679884
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679885
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679886
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679887
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679888
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679889
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679890
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679891
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679892
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679893
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679894
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679895
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679896
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679897
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679898
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679899
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679900
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679901
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679902
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679903
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679904
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679905
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679906
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679907
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679908
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679909
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679910
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679911
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679912
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679913
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679914
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679915
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679916
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679917
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679918
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679919
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679920
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679921
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679922
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679923
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679924
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679925
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679926
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679927
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679928
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679929
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679930
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679931
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679932
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679933
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679934
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679935
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679936
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679937
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679938
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679939
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679940
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679941
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679942
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679943
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679944
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679945
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679946
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679947
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679948
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679949
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679950
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679951
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679952
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679953
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679954
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679955
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679956
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679957
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679958
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679959
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679960
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679961
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679962
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679963
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679964
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679965
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679966
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679967
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679968
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679969
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679970
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679971
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679972
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679973
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679974
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679975
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679976
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679977
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679978
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679979
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679980
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679981
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679982
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679983
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679984
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679985
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679986
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679987
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679988
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679989
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679990
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679991
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679992
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679993
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679994
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679995
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679996
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679997
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679998
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032679999
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680000
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680001
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680002
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680003
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680004
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680005
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680006
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680007
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680008
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680009
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680010
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680011
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680012
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680013
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680014
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680015
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680016
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680017
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680018
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680019
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680020
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680021
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680022
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680023
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680024
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680025
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680026
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680027
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680028
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680029
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680030
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680031
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680032
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680033
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680034
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680035
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680036
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680037
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680038
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680039
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680040
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680041
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680042
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680043
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680044
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680045
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680046
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680047
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680048
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680049
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680050
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680051
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680052
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680053
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680054
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680055
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680056
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680057
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680058
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680059
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680060
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680061
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680062
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680063
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680064
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680065
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680066
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680067
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680068
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680069
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680070
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680071
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680072
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680073
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680074
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680075
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680076
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680077
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680078
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680079
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680080
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680081
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680082
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680083
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680084
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680085
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680086
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680087
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680088
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680089
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680090
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680091
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680092
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680093
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680094
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680095
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680096
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680097
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680098
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680099
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680100
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680101
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680102
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680103
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680104
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680105
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680106
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680107
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680108
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680109
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680110
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680111
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680112
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680113
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680114
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680115
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680116
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680117
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680118
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680119
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680120
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680121
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680122
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680123
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680124
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680125
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680126
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680127
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680128
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680129
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680130
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680131
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680132
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680133
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680134
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680135
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680136
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680137
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680138
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680139
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680140
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680141
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680142
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680143
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680144
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680145
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680146
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464089032680147
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967650623488
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817792
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817793
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817794
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817795
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817796
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817797
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817798
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817799
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817800
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817801
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817802
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817803
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817804
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817805
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817806
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817807
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817808
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817809
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817810
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817811
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817812
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817813
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817814
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817815
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817816
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817817
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817818
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817819
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817820
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817821
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817822
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817823
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817824
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817825
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817826
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817827
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817828
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817829
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817830
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817831
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817832
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817833
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817834
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817835
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817836
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817837
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817838
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817839
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817840
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817841
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817842
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817843
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817844
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817845
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817846
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817847
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817848
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817849
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817850
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817851
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817852
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817853
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817854
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817855
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817856
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817857
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817858
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817859
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817860
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817861
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817862
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817863
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817864
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817865
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817866
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817867
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817868
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817869
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817870
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817871
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817872
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817873
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817874
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817875
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817876
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817877
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817878
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817879
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817880
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817881
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817882
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817883
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817884
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817885
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817886
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817887
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817888
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817889
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817890
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817891
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817892
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817893
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817894
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817895
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817896
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817897
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817898
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817899
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817900
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817901
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817902
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817903
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817904
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817905
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817906
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817907
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817908
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817909
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817910
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817911
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817912
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817913
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817914
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817915
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817916
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817917
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817918
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817919
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817920
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817921
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817922
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817923
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817924
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817925
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817926
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817927
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817928
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817929
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817930
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817931
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817932
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817933
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817934
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817935
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817936
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817937
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817938
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817939
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817940
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817941
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817942
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817943
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817944
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817945
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817946
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817947
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817948
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817949
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817950
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817951
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817952
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817953
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817954
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817955
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817956
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817957
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817958
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817959
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817960
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817961
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817962
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817963
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817964
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817965
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817966
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817967
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817968
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817969
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817970
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817971
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817972
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817973
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817974
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817975
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817976
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817977
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817978
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817979
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817980
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817981
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817982
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817983
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817984
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817985
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817986
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817987
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817988
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817989
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817990
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817991
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817992
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817993
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817994
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817995
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817996
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817997
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817998
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654817999
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818000
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818001
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818002
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818003
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818004
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818005
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818006
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818007
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818008
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818009
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818010
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818011
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818012
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818013
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818014
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818015
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818016
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818017
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818018
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818019
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818020
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818021
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818022
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818023
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818024
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818025
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818026
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818027
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818028
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818029
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818030
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818031
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818032
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818033
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818034
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818035
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818036
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818037
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818038
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818039
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818040
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818041
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818042
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818043
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818044
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818045
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818046
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818047
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818048
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818049
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818050
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818051
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818052
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818053
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818054
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818055
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818056
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818057
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818058
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818059
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818060
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818061
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818062
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818063
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818064
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818065
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818066
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818067
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818068
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818069
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818070
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818071
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818072
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818073
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818074
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818075
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818076
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818077
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818078
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818079
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818080
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818081
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818082
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818083
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818084
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818085
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818086
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818087
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818088
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818089
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818090
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818091
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818092
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818093
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818094
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818095
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818096
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818097
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818098
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818099
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818100
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818101
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818102
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818103
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818104
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818105
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818106
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818107
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818108
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818109
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818110
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818111
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818112
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818113
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818114
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818115
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818116
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818117
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818118
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818119
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818120
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818121
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818122
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818123
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818124
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818125
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818126
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818127
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818128
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818129
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818130
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818131
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818132
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818133
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818134
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818135
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818136
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818137
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818138
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818139
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818140
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818141
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818142
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818143
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818144
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818145
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818146
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818147
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818148
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818149
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818150
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818151
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818152
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818153
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818154
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818155
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818156
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818157
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818158
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818159
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818160
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818161
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818162
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818163
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818164
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818165
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818166
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818167
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818168
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818169
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818170
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818171
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818172
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818173
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818174
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818175
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818176
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818177
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818178
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818179
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818180
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818181
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818182
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818183
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818184
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818185
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818186
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818187
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818188
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818189
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818190
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818191
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818192
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818193
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818194
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818195
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818196
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818197
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818198
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818199
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818200
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818201
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818202
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818203
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818204
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818205
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818206
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818207
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818208
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818209
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818210
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818211
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818212
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818213
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818214
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818215
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818216
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818217
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818218
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818219
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818220
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818221
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818222
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818223
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818224
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818225
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818226
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818227
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818228
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818229
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818230
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818231
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818232
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818233
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818234
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818235
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818236
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818237
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818238
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818239
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818240
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818241
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818242
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818243
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818244
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818245
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818246
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818247
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818248
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818249
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818250
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818251
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818252
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818253
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818254
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818255
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818256
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818257
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818258
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818259
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818260
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818261
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818262
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818263
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818264
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818265
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818266
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818267
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818268
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818269
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818270
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818271
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818272
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818273
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818274
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818275
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818276
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818277
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818278
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818279
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818280
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818281
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818282
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818283
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818284
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818285
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818286
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818287
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818288
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818289
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818290
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818291
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818292
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818293
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818294
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818295
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818296
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818297
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818298
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818299
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818300
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818301
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818302
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818303
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818304
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818305
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818306
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818307
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818308
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818309
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818310
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818311
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818312
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818313
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818314
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818315
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818316
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818317
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818318
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818319
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818320
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818321
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818322
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818323
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818324
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818325
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818326
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818327
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818328
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818329
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818330
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818331
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818332
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818333
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818334
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818335
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818336
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818337
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818338
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818339
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818340
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818341
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818342
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818343
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818344
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818345
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818346
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818347
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818348
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818349
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818350
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818351
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818352
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818353
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818354
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818355
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818356
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818357
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818358
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818359
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818360
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818361
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818362
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818363
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818364
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818365
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818366
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818367
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818368
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818369
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818370
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818371
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818372
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818373
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818374
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818375
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818376
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818377
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818378
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818379
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818380
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818381
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818382
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818383
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818384
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818385
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818386
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818387
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818388
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818389
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818390
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818391
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818392
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818393
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818394
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818395
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818396
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818397
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818398
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818399
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818400
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818401
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818402
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818403
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818404
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818405
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818406
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818407
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818408
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818409
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818410
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818411
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818412
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818413
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818414
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818415
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818416
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818417
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818418
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818419
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818420
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818421
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818422
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818423
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818424
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818425
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818426
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818427
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818428
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818429
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818430
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818431
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818432
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818433
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818434
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818435
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818436
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818437
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818438
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818439
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818440
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818441
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818442
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818443
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818444
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818445
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818446
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818447
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818448
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818449
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818450
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818451
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818452
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818453
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818454
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818455
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818456
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818457
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818458
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818459
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818460
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818461
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818462
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818463
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818464
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818465
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818466
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818467
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818468
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818469
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818470
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818471
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818472
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818473
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818474
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818475
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818476
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818477
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818478
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818479
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818480
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818481
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818482
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818483
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818484
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818485
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818486
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818487
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818488
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818489
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818490
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818491
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818492
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818493
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818494
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818495
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818496
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818497
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818498
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818499
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818500
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818501
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818502
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818503
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818504
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818505
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818506
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818507
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818508
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818509
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818510
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818511
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818512
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818513
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 466967654818514
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330496
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330497
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330498
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330499
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330500
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330501
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330502
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330503
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330504
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330505
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330506
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330507
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330508
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330509
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330510
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330511
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330512
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330513
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330514
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330515
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330516
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330517
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330518
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330519
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330520
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330521
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330522
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330523
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330524
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330525
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330526
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330527
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330528
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330529
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330530
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330531
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330532
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330533
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330534
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330535
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330536
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330537
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330538
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330539
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330540
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330541
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330542
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330543
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330544
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330545
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330546
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330547
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330548
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330549
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330550
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330551
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330552
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330553
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330554
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330555
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330556
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330557
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330558
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330559
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330560
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330561
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330562
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330563
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330564
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330565
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330566
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330567
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330568
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330569
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330570
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330571
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330572
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330573
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330574
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330575
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330576
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330577
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330578
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330579
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330580
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330581
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330582
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330583
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330584
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330585
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330586
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330587
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330588
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330589
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330590
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330591
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330592
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330593
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330594
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330595
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330596
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330597
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330598
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330599
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330600
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330601
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330602
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330603
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330604
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330605
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330606
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330607
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330608
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330609
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330610
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330611
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330612
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330613
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330614
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330615
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330616
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330617
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330618
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330619
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330620
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330621
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330622
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330623
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330624
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330625
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330626
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330627
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330628
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330629
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330630
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330631
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330632
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330633
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330634
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330635
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330636
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330637
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330638
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330639
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330640
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330641
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330642
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330643
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330644
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330645
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330646
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330647
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330648
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330649
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330650
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330651
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330652
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330653
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330654
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330655
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330656
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330657
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330658
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330659
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330660
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330661
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330662
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330663
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330664
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330665
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330666
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330667
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330668
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330669
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330670
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330671
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330672
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330673
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330674
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330675
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330676
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330677
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330678
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330679
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330680
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330681
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330682
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330683
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330684
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330685
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330686
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330687
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330688
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330689
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330690
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330691
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330692
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330693
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330694
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330695
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330696
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330697
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330698
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330699
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330700
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330701
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330702
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330703
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330704
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330705
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330706
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330707
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330708
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330709
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330710
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330711
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330712
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330713
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330714
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330715
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330716
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330717
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330718
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330719
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330720
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330721
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330722
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330723
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330724
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330725
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330726
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330727
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330728
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330729
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330730
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330731
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330732
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330733
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330734
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330735
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330736
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330737
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330738
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330739
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330740
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330741
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330742
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330743
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330744
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330745
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330746
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330747
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330748
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330749
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330750
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330751
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330752
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330753
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330754
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330755
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330756
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330757
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330758
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330759
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330760
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330761
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330762
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330763
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330764
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330765
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330766
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330767
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330768
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330769
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330770
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330771
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330772
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330773
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330774
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330775
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330776
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330777
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330778
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330779
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330780
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330781
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330782
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330783
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330784
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330785
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330786
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330787
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330788
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330789
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330790
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330791
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330792
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330793
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330794
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330795
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330796
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330797
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330798
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330799
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330800
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330801
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330802
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330803
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330804
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330805
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330806
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330807
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330808
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330809
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330810
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330811
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330812
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330813
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330814
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330815
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330816
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330817
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330818
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330819
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330820
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330821
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330822
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330823
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330824
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330825
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330826
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330827
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330828
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330829
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330830
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330831
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330832
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330833
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330834
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330835
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330836
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330837
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330838
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330839
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330840
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330841
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330842
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330843
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330844
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330845
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330846
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330847
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330848
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330849
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330850
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330851
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330852
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330853
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330854
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330855
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330856
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330857
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330858
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330859
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330860
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330861
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330862
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330863
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330864
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330865
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330866
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330867
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330868
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330869
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330870
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330871
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330872
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330873
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330874
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330875
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330876
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330877
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330878
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330879
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330880
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330881
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330882
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330883
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330884
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330885
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330886
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330887
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330888
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330889
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330890
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330891
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330892
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330893
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330894
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330895
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330896
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330897
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330898
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330899
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330900
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330901
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330902
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330903
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330904
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330905
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330906
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330907
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330908
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330909
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330910
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330911
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330912
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330913
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330914
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330915
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330916
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330917
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330918
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330919
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330920
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330921
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330922
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330923
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330924
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330925
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330926
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330927
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330928
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330929
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330930
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330931
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330932
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330933
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330934
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330935
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330936
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330937
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330938
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330939
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330940
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330941
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330942
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330943
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330944
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330945
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330946
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330947
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330948
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330949
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330950
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330951
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330952
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330953
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330954
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330955
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330956
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330957
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330958
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330959
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330960
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330961
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330962
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330963
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330964
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330965
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330966
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330967
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330968
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330969
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330970
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330971
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330972
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330973
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330974
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330975
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330976
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330977
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330978
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330979
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330980
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330981
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330982
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330983
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330984
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330985
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330986
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330987
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330988
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330989
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330990
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330991
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330992
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330993
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330994
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330995
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330996
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330997
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330998
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772330999
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331000
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331001
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331002
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331003
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331004
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331005
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331006
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331007
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331008
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331009
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331010
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331011
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331012
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331013
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331014
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331015
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331016
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331017
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331018
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331019
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331020
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331021
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331022
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331023
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331024
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331025
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331026
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331027
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331028
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331029
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331030
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331031
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331032
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331033
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331034
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331035
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331036
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331037
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331038
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331039
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331040
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331041
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331042
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331043
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331044
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331045
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331046
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331047
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331048
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331049
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331050
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331051
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331052
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331053
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331054
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331055
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331056
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331057
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331058
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331059
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331060
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331061
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331062
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331063
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331064
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331065
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331066
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331067
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331068
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331069
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331070
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331071
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331072
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331073
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331074
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331075
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331076
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331077
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331078
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331079
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331080
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331081
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331082
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331083
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331084
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331085
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331086
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331087
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331088
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331089
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331090
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331091
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331092
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331093
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331094
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331095
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331096
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331097
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331098
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331099
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331100
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331101
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331102
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331103
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331104
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331105
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331106
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331107
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331108
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331109
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331110
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331111
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331112
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331113
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331114
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331115
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331116
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331117
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331118
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331119
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331120
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331121
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331122
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331123
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331124
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331125
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331126
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331127
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331128
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331129
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331130
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331131
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331132
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331133
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331134
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331135
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331136
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331137
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331138
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331139
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331140
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331141
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331142
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331143
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331144
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331145
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331146
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331147
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331148
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331149
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331150
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331151
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331152
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331153
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331154
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331155
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331156
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331157
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331158
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331159
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331160
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331161
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331162
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331163
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331164
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331165
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331166
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331167
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331168
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331169
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331170
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331171
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331172
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331173
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331174
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331175
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331176
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331177
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331178
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331179
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331180
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331181
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331182
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331183
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331184
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331185
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331186
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331187
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331188
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331189
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331190
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331191
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331192
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331193
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331194
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331195
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331196
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331197
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331198
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331199
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331200
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331201
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331202
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331203
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331204
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331205
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331206
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331207
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331209
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331210
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331211
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331212
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331213
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331214
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331215
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331216
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331217
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331218
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 473102772331219
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113728
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113729
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113730
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113731
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113732
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113733
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113734
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113735
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113736
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113737
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113738
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113739
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113740
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113741
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113742
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113743
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113744
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113745
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113746
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113747
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113748
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113749
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113750
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113751
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113752
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113753
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113754
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113755
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113756
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113757
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113758
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113759
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113760
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113761
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113762
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113763
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113764
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113765
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113766
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113767
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113768
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113769
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113770
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113771
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113772
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113773
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113774
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113775
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113776
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113777
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113778
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113779
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113780
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113781
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113782
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113783
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113784
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113785
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113786
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113787
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113788
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113789
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113790
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113791
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113792
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113793
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113794
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113795
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113796
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113797
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113798
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113799
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113800
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113801
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113802
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113803
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113804
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113805
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113806
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113807
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113808
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113809
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113810
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113811
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113812
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113813
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113814
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113815
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113816
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113817
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113818
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113819
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113820
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113821
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113822
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113823
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113824
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113825
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113826
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113827
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113828
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113829
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113830
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113831
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113832
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113833
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113834
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113835
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113836
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113837
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113838
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113839
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113840
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113841
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113842
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113843
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113844
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113845
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113846
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113847
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113848
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113849
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113850
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113851
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113852
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113853
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113854
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113855
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113856
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113857
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113858
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113859
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113860
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113861
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113862
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113863
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113864
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113865
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113866
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113867
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113868
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113869
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113870
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113871
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113872
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113873
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113874
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113875
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113876
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113877
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113878
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113879
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113880
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113881
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113882
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113883
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113884
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113885
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113886
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113887
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113888
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113889
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113890
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113891
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113892
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113893
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113894
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113895
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113896
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113897
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113898
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113899
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113900
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113901
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113902
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113903
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113904
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113905
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113906
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113907
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113908
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113909
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113910
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113911
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113912
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113913
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113914
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113915
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113916
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113917
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113918
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113919
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113920
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113921
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113922
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113923
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113924
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113925
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113926
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113927
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113928
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113929
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113930
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113931
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113932
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113933
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113934
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113935
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113936
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113937
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113938
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113939
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113940
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113941
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113942
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113943
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113944
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113945
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113946
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113947
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113948
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113949
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113950
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113951
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113952
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113953
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113954
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113955
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113956
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113957
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113958
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113959
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113960
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113961
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113962
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113963
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113964
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113965
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113966
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113967
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113968
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113969
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113970
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113971
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113972
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113973
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113974
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113975
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113976
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113977
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113978
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113979
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113980
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113981
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113982
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113983
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113984
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113985
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113986
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113987
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113988
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113989
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113990
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113991
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113992
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113993
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113994
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113995
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113996
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113997
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113998
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111113999
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114000
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114001
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114002
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114003
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114004
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114005
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114006
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114007
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114008
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114009
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114010
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114011
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114012
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114013
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114014
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114015
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114016
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114017
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114018
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114019
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114020
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114021
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114022
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114023
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114024
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114025
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114026
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114027
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114028
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114029
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114030
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114031
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114032
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114033
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114034
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114035
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114036
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114037
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114038
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114039
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114040
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114041
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114042
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114043
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114044
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114045
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114046
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114047
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114048
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114049
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114050
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114051
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114052
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114053
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114054
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114055
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114056
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114057
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114058
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114059
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114060
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114061
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114062
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114063
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114064
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114065
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114066
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114067
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114068
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114069
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114070
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114071
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114072
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114073
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114074
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114075
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114076
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114077
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114078
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114079
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114080
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114081
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114082
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114083
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114084
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114085
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114086
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114087
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114088
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114089
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114090
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114091
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114092
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114093
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114094
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114095
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114096
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114097
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114098
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114099
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114100
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114101
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114102
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114103
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114104
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114105
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114106
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114107
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114108
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114109
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114110
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114111
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114112
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114113
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114114
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114115
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114116
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114117
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114118
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114119
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114120
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114121
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114122
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114123
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114124
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114125
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114126
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114127
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114128
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114129
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114130
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114131
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114132
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114133
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114134
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114135
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114136
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114137
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114138
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114139
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114140
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114141
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114142
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114143
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114144
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114145
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114146
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114147
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114148
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114149
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114150
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114151
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114152
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114153
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114154
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114155
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114156
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114157
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114158
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114159
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114160
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114161
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114162
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114163
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114164
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114165
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114166
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114167
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114168
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114169
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114170
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114171
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114172
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114173
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114174
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114175
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114176
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114177
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114178
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114179
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114180
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114181
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114182
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114183
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114184
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114185
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114186
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114187
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114188
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114189
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114190
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114191
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114192
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114193
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114194
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114195
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114196
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114197
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114198
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114199
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114200
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114201
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114202
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114203
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114204
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114205
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114206
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114207
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114208
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114209
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114210
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114211
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114212
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114213
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114214
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114215
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114216
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114217
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114218
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114219
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114220
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114221
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114222
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114223
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114224
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114225
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114226
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114227
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114228
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114229
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114230
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114231
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114232
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114233
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114234
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114235
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114236
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114237
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114238
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114239
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114240
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114241
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114242
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114243
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114244
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114245
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114246
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114247
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114248
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114249
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114250
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114251
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114252
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114253
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114254
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114255
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114256
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114257
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114258
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114259
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114260
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114261
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114262
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114263
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114264
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114265
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114266
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114267
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114268
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417111114269
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085248
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085249
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085250
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085251
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085252
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085253
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085254
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085255
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085256
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085257
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085258
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085259
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085260
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085261
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085262
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085263
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085264
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085265
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085266
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085267
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085268
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085269
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085270
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085271
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085272
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085273
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085274
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085275
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085276
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085277
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085278
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085279
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085280
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085281
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085282
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085283
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085284
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085285
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085286
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085287
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085288
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085289
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085290
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085291
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085292
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085293
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085294
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085295
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085296
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085297
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085298
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085299
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085300
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085301
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085302
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085303
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085304
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085305
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085306
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085307
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085308
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085309
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085310
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085311
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085312
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085313
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085314
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085315
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085316
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085317
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085318
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085319
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085320
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085321
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085322
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085323
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085324
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085325
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085326
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085327
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085328
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085329
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085330
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085331
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085332
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085333
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085334
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085335
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085336
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085337
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085338
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085339
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085340
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085341
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085342
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085343
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085344
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085345
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085346
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085347
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085348
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085349
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085350
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085351
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085352
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085353
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085354
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085355
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085356
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085357
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085358
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085359
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085360
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085361
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085362
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085363
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085364
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085365
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085366
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085367
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085368
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085369
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085370
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085371
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085372
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085373
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085374
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085375
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085376
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085377
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085378
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085379
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085380
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085381
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085382
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085383
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085384
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085385
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085386
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085387
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085388
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085389
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085390
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085391
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085392
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085393
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085394
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085395
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085396
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085397
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085398
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085399
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085400
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085401
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085402
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085403
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085404
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085405
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085406
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085407
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085408
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085409
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085410
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085411
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085412
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085413
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085414
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085415
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085416
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085417
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085418
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085419
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085420
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085421
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085422
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085423
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085424
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085425
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085426
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085427
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085428
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 645417132085429
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878441472000
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054912
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054913
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054914
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054915
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054916
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054917
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054918
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054919
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054920
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054921
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054922
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054923
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054924
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054925
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054926
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054927
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054928
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054929
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054930
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054931
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054932
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054933
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054934
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054935
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054936
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054937
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054938
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054939
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054940
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054941
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054942
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054943
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054944
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054945
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054946
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054947
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054948
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054949
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054950
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054951
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054952
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054953
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054954
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054955
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054956
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054957
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054958
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054959
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054960
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054961
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054962
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054963
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054964
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054965
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054966
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054967
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054968
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054969
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054970
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054971
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054972
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054973
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054974
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054975
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054976
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054977
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054978
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054979
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054980
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054981
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054982
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054983
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054984
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054985
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054986
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054987
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054988
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054989
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054990
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054991
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054992
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054993
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054994
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054995
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054996
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054997
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054998
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454054999
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055000
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055001
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055002
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055003
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055004
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055005
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055006
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055007
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055008
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055009
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055010
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055011
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055012
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055013
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055014
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055015
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055016
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055017
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055018
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055019
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055020
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055021
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055022
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055023
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055024
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055025
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055026
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055027
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055028
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055029
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055030
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055031
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055032
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055033
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055034
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055035
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055036
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055037
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055038
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055039
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055040
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055041
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055042
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055043
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055044
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055045
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055046
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055047
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055048
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055049
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055050
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055051
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055052
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055053
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055054
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055055
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055056
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055057
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055058
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055059
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055060
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055061
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055062
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055063
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055064
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055065
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055066
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055067
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055068
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055069
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055070
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055071
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055072
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055073
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055074
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055075
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055076
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055077
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055078
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055079
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055080
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055081
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055082
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055083
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055084
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055085
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055086
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055087
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055088
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055089
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055090
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055091
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055092
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055093
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055094
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055095
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055096
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055097
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055098
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055099
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055100
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055101
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055102
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055103
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055104
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055105
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055106
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055107
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055108
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055109
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055110
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055111
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055112
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055113
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055114
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055115
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055116
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055117
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055118
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055119
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055120
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055121
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055122
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055123
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055124
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055125
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055126
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055127
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055128
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055129
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055130
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055131
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055132
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055133
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055134
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055135
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055136
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055137
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055138
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055139
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055140
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055141
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055142
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055143
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055144
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055145
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055146
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055147
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055148
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055149
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055150
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055151
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055152
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055153
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055154
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055155
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055156
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055157
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055158
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055159
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055160
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055161
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055162
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055163
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055164
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055165
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055166
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055167
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055168
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055169
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055170
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055171
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055172
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055173
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055174
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055175
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055176
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055177
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055178
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055179
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055180
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055181
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055182
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055183
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055184
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055185
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055186
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055187
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055188
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055189
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055190
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055191
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055192
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055193
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055194
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055195
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055196
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055197
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055198
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055199
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055200
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055201
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055202
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055203
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055204
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055205
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055206
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055207
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055208
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055209
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055210
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055211
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055212
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055213
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055214
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055215
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055216
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055217
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055218
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055219
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055220
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055221
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055222
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055223
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055224
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055225
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055226
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055227
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055228
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055229
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055230
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055231
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055232
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055233
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055234
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055235
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055236
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055237
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055238
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055239
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055240
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055241
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055242
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055243
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055244
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055245
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055246
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055247
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055248
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055249
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055250
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055251
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055252
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055253
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055254
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055255
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055256
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055257
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055258
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055259
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055260
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055261
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055262
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055263
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055264
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055265
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055266
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055267
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055268
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055269
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055270
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055271
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055272
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055273
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055274
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055275
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055276
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055277
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055278
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055279
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055280
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055281
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055282
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055283
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055284
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055285
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055286
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055287
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055288
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055289
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055290
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055291
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055292
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055293
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055294
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055295
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055296
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055297
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055298
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055299
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055300
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055301
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055302
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055303
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055304
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055305
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055306
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055307
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055308
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055309
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055310
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055311
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055312
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055313
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055314
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055315
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055316
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055317
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055318
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055319
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055320
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055321
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055322
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055323
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055324
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055325
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055326
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055327
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055328
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055329
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055330
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055331
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055332
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055333
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055334
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055335
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055336
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055337
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055338
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055339
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055340
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055341
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055342
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055343
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055344
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055345
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055346
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055347
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055348
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055349
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055350
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055351
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055352
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055353
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055354
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055355
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055356
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055357
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055358
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055359
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055360
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055361
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055362
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055363
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055364
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055365
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055366
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055367
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055368
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055369
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055370
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055371
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055372
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055373
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055374
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055375
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055376
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055377
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055378
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055379
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055380
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055381
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055382
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055383
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055384
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055385
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055386
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055387
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055388
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055389
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055390
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055391
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055392
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055393
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055394
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055395
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055396
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055397
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055398
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055399
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055400
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055401
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055402
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055403
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055404
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055405
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055406
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055407
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055408
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055409
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055410
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055411
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055412
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055413
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055414
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055415
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055416
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055417
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055418
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055419
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055420
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055421
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055422
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055423
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055424
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055425
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055426
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055427
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055428
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055429
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055430
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055431
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055432
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055433
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055434
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055435
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055436
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055437
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055438
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055439
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055440
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055441
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055442
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055443
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055444
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055445
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055446
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055447
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055448
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055449
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055450
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055451
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055452
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055453
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055454
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055455
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055456
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055457
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055458
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055459
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055460
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055461
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055462
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055463
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055464
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055465
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055466
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055467
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055468
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055469
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055470
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055471
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055472
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055473
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055474
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055475
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055476
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055477
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055478
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055479
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055480
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055481
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055482
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055483
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055484
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055485
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055486
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055487
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055488
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055489
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055490
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055491
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055492
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055493
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055494
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055495
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055496
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055497
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055498
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055499
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055500
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055501
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055502
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055503
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055504
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055505
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055506
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055507
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055508
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055509
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055510
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055511
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055512
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055513
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055514
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055515
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055516
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055517
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055518
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055519
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055520
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055521
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055522
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055523
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055524
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055525
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055526
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055527
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055528
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055529
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055530
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055531
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055532
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055533
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055534
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055535
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055536
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055537
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055538
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055539
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055540
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055541
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055542
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055543
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055544
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055545
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055546
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055547
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055548
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055549
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055550
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055551
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055552
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055553
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055554
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055555
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055556
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055557
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055558
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055559
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055560
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055561
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055562
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055563
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055564
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055565
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055566
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055567
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055568
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055569
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055570
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055571
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055572
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055573
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055574
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055575
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055576
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055577
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055578
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055579
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055580
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055581
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055582
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055583
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055584
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055585
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055586
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055587
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055588
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055589
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055590
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055591
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055592
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055593
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055594
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055595
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055596
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055597
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055598
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055599
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055600
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055601
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055602
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055603
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055604
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055605
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055606
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055607
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055608
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055609
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055610
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055611
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055612
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055613
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055614
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055615
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055616
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055617
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055618
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055619
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055620
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055621
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055622
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055623
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055624
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055625
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055626
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055627
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055628
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055629
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055630
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055631
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055632
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055633
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 699878454055634
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543936
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543937
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543938
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543939
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543940
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543941
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543942
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543943
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543944
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543945
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543946
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543947
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543948
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543949
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543950
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543951
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543952
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543953
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543954
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543955
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543956
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543957
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543958
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543959
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543960
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543961
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543962
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543963
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543964
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543965
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543966
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543967
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543968
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543969
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543970
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543971
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543972
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543973
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543974
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543975
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543976
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543977
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543978
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543979
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543980
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543981
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543982
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543983
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543984
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543985
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543986
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543987
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543988
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543989
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543990
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543991
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543992
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543993
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543994
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543995
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543996
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543997
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543998
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725543999
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544000
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544001
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544002
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544003
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544004
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544005
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544006
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544007
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544008
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544009
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544010
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544011
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544012
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544013
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544014
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544015
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544016
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544017
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544018
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544019
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544020
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544021
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544022
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544023
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544024
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544025
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544026
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544027
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544028
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544029
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544030
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544031
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544032
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544033
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544034
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544035
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544036
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544037
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544038
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544039
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544040
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544041
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544042
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544043
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544044
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544045
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544046
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544047
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544048
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544049
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544050
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544051
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544052
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544053
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544054
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544055
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544056
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544057
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544058
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544059
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544060
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544061
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544062
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544063
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544064
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544065
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544066
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544067
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544068
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544069
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544070
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544071
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544072
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544073
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544074
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544075
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544076
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544077
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544078
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544079
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544080
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544081
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544082
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544083
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544084
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544085
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544086
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544087
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544088
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544089
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544090
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544091
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544092
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544093
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544094
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544095
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544096
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544097
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544098
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544099
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544100
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544101
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544102
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544103
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544104
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544105
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544106
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544107
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544108
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544109
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544110
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544111
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544112
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544113
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544114
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544115
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544116
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544117
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544118
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544119
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544120
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544121
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544122
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544123
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544124
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544125
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544126
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544127
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544128
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544129
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544130
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544131
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544132
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544133
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544134
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544135
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544136
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544137
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544138
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544139
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544140
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544141
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544142
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544143
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544144
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544145
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544146
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544147
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544148
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544149
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544150
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544151
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544152
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544153
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544154
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544155
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544156
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544157
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544158
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544159
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544160
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544161
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544162
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544163
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544164
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544165
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544166
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544167
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544168
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544169
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544170
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544171
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544172
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544173
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544174
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544175
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544176
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544177
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544178
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544179
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544180
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544181
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544182
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544183
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544184
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544185
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544186
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544187
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544188
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544189
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544190
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544191
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544192
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544193
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544194
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544195
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544196
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544197
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544198
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544199
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544200
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544201
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544202
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544203
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544204
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544205
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544206
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544207
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544208
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544209
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544210
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544211
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544212
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544213
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544214
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544215
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544216
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544217
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544218
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544219
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544220
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544221
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544222
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544223
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544224
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544225
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544226
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544227
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544228
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544229
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544230
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544231
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544232
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544233
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544234
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544235
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544236
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544237
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544238
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544239
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544240
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544241
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544242
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544243
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544244
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544245
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544246
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544247
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544248
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544249
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544250
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544251
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544252
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544253
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544254
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544255
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544256
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544257
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544258
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544259
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544260
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544261
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544262
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544263
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544264
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544265
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544266
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544267
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544268
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544269
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544270
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544271
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544272
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544273
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544274
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544275
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544276
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544277
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544278
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544279
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544280
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544281
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544282
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544283
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544284
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544285
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544286
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544287
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544288
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544289
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544290
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544291
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544292
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544293
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544294
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544295
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544296
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544297
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544298
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544299
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544300
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544301
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544302
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544303
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544304
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544305
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544306
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544307
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544308
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544309
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544310
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544311
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544312
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544313
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544314
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544315
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544316
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544317
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544318
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544319
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544320
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544321
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544322
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544323
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544324
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544325
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544326
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544327
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544328
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544329
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544330
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544331
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544332
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544333
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544334
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544335
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544336
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544337
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544338
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544339
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544340
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544341
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544342
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544343
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544344
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544345
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544346
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544347
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330725544348
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738240
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738241
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738242
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738243
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738244
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738245
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738246
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738247
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738248
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738249
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738250
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738251
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738252
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738253
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738254
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738255
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738256
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738257
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738258
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738259
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738260
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738261
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738262
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738263
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738264
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738265
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738266
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738267
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738268
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738269
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738270
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738271
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738272
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738273
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738274
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738275
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738276
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738277
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738278
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738279
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738280
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738281
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738282
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738283
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738284
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738285
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738286
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738287
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738288
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738289
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738290
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738291
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738292
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738293
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738294
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738295
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738296
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738297
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738298
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738299
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738300
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738301
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738302
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738303
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738304
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738305
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738306
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738307
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738308
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738309
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738310
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738311
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738312
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738313
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738314
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738315
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738316
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738317
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738318
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738319
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738320
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738321
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738322
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738323
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738324
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738325
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738326
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738327
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738328
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738329
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738330
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738331
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738332
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738333
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738334
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738335
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738336
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738337
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738338
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738339
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738340
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738341
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738342
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738343
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738344
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738345
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738346
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738347
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738348
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738349
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738350
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738351
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738352
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738353
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738354
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738355
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738356
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738357
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738358
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738359
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738360
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738361
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738362
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738363
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738364
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738365
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738366
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738367
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738368
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738369
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738370
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738371
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738372
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738373
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738374
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738375
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738376
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738377
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738378
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738379
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738380
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738381
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738382
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738383
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738384
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738385
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738386
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738387
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738388
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738389
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738390
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738391
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738392
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738393
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738394
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738395
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738396
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738397
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738398
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738399
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738400
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738401
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738402
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738403
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738404
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738405
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738406
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738407
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738408
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738409
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738410
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738411
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738412
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738413
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738414
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738415
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738416
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738417
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738418
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738419
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738420
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738421
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738422
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738423
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738424
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738425
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738426
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738427
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738428
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738429
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738430
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738431
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738432
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738433
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738434
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738435
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738436
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738437
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738438
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738439
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738440
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738441
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738442
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738443
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738444
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738445
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738446
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738447
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738448
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738449
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738450
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738451
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738452
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738453
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738454
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738455
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738456
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738457
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738458
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738459
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738460
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738461
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738462
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738463
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738464
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738465
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738466
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738467
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738468
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738469
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738470
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738471
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738472
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738473
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738474
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738475
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738476
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738477
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738478
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738479
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738480
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738481
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738482
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738483
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738484
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738485
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738486
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738487
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738488
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738489
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738490
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738491
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738492
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738493
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738494
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738495
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738496
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738497
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738498
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738499
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738500
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738501
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738502
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738503
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738504
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738505
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738506
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738507
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738508
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738509
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738510
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738511
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738512
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738513
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738514
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738515
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738516
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738517
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738518
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738519
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738520
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738521
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738522
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738523
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738524
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738525
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738526
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738527
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738528
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738529
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738530
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738531
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738532
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738533
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738534
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738535
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738536
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738537
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738538
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738539
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738540
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738541
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738542
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738543
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738544
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738545
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738546
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738547
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738548
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738549
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 697330729738550
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266304
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266305
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266306
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266307
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266308
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266309
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266310
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266311
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266312
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266313
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266314
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266315
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266316
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266317
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266318
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266319
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266320
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266321
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266322
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266323
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266324
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266325
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266326
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266327
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266328
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266329
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266330
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266331
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266332
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266333
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266334
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266335
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266336
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266337
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266338
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266339
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266340
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266341
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266342
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266343
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266344
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266345
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266346
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266347
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266348
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266349
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266350
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266351
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266352
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266353
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266354
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266355
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266356
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266357
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266358
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266359
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266360
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266361
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266362
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266363
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266364
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266365
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266366
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266367
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266368
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266369
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266370
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266371
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266372
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266373
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266374
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266375
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266376
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266377
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266378
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266379
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266380
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266381
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266382
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266383
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266384
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266385
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266386
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266387
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266388
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266389
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266390
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266391
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266392
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266393
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266394
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266395
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266396
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266397
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266398
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266399
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266400
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266401
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266402
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266403
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266404
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266405
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266406
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266407
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266408
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266409
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266410
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266411
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266412
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266413
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266414
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266415
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266416
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266417
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266418
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266419
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266420
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266421
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266422
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266423
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266424
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266425
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266426
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266427
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266428
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266429
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266430
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266431
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266432
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266433
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266434
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266435
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266436
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266437
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266438
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266439
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266440
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266441
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266442
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266443
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266444
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266445
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266446
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266447
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266448
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266449
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266450
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266451
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266452
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266453
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266454
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266455
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266456
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266457
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266458
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266459
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266460
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266461
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266462
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266463
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266464
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266465
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266466
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266467
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266468
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266469
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266470
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266471
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266472
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266473
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266474
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266475
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266476
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266477
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266478
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266479
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266480
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266481
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266482
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266483
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266484
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266485
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266486
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266487
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266488
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266489
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266490
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266491
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266492
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266493
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266494
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266495
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266496
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266497
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266498
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266499
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266500
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266501
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266502
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266503
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266504
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266505
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266506
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266507
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266508
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266509
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266510
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266511
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266512
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266513
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266514
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266515
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266516
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266517
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266518
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266519
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266520
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266521
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266522
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266523
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266524
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266525
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266526
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266527
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266528
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266529
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266530
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266531
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266532
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266533
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266534
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266535
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266536
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266537
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266538
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266539
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266540
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266541
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266542
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266543
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266544
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266545
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266546
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266547
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266548
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266549
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266550
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266551
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266552
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266553
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266554
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266555
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266556
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266557
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266558
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266559
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266560
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266561
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266562
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266563
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266564
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266565
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266566
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266567
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266568
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266569
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266570
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266571
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266572
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266573
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266574
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266575
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266576
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266577
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266578
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266579
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266580
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266581
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266582
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266583
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266584
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266585
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266586
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266587
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266588
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266589
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266590
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266591
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266592
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266593
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266594
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266595
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266596
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266597
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266598
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266599
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266600
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266601
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266602
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266603
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266604
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266605
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266606
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266607
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266608
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266609
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266610
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266611
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266612
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266613
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266614
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266615
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266616
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266617
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266618
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266619
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266620
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266621
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266622
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266623
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266624
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266625
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266626
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266627
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266628
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266629
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266630
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266631
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266632
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266633
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266634
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266635
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266636
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266637
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266638
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266639
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266640
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266641
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266642
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266643
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266644
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266645
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266646
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266647
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266648
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266649
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266650
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266651
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266652
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266653
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266654
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266655
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266656
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266657
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266658
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266659
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266660
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266661
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266662
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266663
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266664
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266665
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266666
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266667
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266668
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266669
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266670
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266671
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266672
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266673
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266674
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266675
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266676
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266677
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266678
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266679
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266680
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266681
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266682
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266683
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266684
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266685
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266686
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266687
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266688
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266689
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266690
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266691
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266692
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266693
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266694
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266695
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266696
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266697
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266698
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266699
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266700
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266701
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266702
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266703
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266704
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266705
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266706
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266707
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266708
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266709
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266710
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266711
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266712
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266713
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266714
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266715
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266716
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266717
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266718
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266719
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266720
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266721
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266722
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266723
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266724
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266725
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266726
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266727
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266728
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266729
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266730
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266731
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266732
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266733
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266734
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266735
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266736
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266737
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266738
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266739
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266740
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266741
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266742
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266743
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266744
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266745
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266746
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266747
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266748
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266749
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266750
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266751
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266752
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266753
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266754
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266755
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266756
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266757
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266758
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266759
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266760
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266761
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266762
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266763
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266764
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266765
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266766
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266767
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266768
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266769
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266770
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266771
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266772
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266773
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266774
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266775
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266776
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266777
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266778
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266779
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266780
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266781
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266782
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266783
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266784
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266785
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266786
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266787
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266788
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266789
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266790
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266791
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266792
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266793
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266794
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266795
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266796
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266797
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266798
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266799
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266800
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266801
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266802
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266803
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266804
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266805
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266806
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266807
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266808
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266809
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266810
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266811
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266812
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266813
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266814
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266815
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266816
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266817
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266818
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266819
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266820
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266821
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266822
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266823
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266824
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266825
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266826
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266827
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266828
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266829
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266830
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266831
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266832
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266833
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266834
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266835
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266836
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266837
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266838
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266839
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266840
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266841
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266842
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266843
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266844
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266845
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266846
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266847
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266848
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266849
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266850
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266851
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266852
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266853
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266854
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266855
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266856
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266857
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266858
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266859
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266860
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266861
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266862
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266863
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266864
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266865
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266866
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266867
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266868
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266869
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266870
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266871
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266872
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266873
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266874
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266875
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266876
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266877
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266878
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266879
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266880
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266881
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266882
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266883
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266884
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266885
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266886
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266887
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266888
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266889
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266890
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266891
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266892
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266893
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266894
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266895
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266896
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266897
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266898
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266899
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266900
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266901
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266902
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266903
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266904
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266905
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266906
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266907
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266908
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266909
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266910
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266911
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266912
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266913
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266914
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266915
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266916
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266917
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266918
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266919
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266920
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266921
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266922
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266923
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266924
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266925
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266926
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266927
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266928
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266929
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266930
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266931
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266932
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266933
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266934
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266935
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266936
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266937
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266938
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266939
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266940
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266941
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266942
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266943
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266944
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266945
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266946
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266947
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266948
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266949
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266950
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266951
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266952
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266953
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266954
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266955
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266956
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266957
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266958
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266959
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266960
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266961
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266962
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266963
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266964
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266965
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266966
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266967
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266968
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266969
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266970
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266971
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266972
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266973
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266974
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266975
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266976
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266977
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266978
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266979
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266980
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266981
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266982
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266983
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266984
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266985
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266986
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266987
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266988
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266989
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266990
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266991
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266992
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266993
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266994
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266995
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266996
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266997
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266998
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551266999
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267000
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267001
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267002
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267003
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267004
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267005
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267006
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267007
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267008
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267009
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267010
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267011
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267012
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267013
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267014
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267015
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267016
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267017
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267018
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267019
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267020
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267021
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267022
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267023
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267024
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267025
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267026
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 712172551267027
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046208
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046209
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046210
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046211
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046212
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046213
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046214
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046215
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046216
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046217
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046218
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046219
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046220
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046221
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046222
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046223
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046224
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046225
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046226
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046227
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046228
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046229
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046230
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046231
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046232
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046233
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046234
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046235
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046236
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046237
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046238
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046239
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046240
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046241
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046242
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046243
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046244
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046245
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046246
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046247
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046248
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046249
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046250
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046251
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046252
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046253
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046254
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046255
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046256
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046257
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046258
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046259
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046260
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046261
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046262
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046263
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046264
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046265
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046266
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046267
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046268
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046269
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046270
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046271
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046272
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046273
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046274
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046275
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046276
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046277
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046278
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046279
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046280
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046281
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046282
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046283
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046284
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046285
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046286
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046287
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046288
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046289
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046290
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046291
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046292
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046293
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046294
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046295
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046296
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046297
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046298
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046299
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046300
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046301
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046302
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046303
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046304
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046305
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046306
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046307
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046308
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046309
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046310
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046311
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046312
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046313
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046314
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046315
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046316
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046317
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046318
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046319
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046320
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046321
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046322
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046323
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046324
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046325
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046326
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046327
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046328
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046329
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046330
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046331
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046332
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046333
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046334
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046335
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046336
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046337
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046338
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046339
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046340
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046341
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046342
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046343
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046344
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046345
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046346
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046347
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046348
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046349
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046350
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046351
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046352
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046353
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046354
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046355
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046356
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046357
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046358
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046359
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046360
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046361
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046362
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046363
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046364
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046365
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046366
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046367
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046368
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046369
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046370
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046371
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046372
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046373
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046374
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046375
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046376
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046377
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046378
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046379
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046380
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046381
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046382
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046383
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046384
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046385
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046386
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046387
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046388
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046389
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046390
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046391
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046392
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046393
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046394
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046395
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046396
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046397
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046398
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046399
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046400
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046401
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046402
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046403
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046404
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046405
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046406
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046407
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046408
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046409
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046410
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046411
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046412
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046413
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046414
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046415
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046416
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046417
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046418
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046419
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046420
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046421
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046422
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046423
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046424
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046425
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046426
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046427
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046428
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046429
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046430
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046431
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046432
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046433
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046434
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046435
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046436
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046437
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046438
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046439
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046440
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046441
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046442
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046443
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046444
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046445
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046446
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046447
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046448
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046449
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046450
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046451
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046452
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046453
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046454
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046455
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046456
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046457
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046458
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046459
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046460
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046461
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046462
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046463
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046464
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046465
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046466
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046467
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046468
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046469
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046470
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046471
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046472
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046473
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046474
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046475
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046476
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046477
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046478
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046479
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046480
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046481
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046482
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046483
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046484
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046485
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046486
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046487
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046488
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046489
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046490
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046491
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046492
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046493
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046494
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046495
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046496
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046497
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046498
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046499
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046500
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046501
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046502
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046503
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046504
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046505
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046506
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046507
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046508
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046509
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046510
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046511
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046512
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046513
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046514
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046515
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046516
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046517
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046518
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046519
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046520
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046521
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046522
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046523
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046524
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046525
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046526
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046527
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046528
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046529
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046530
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046531
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046532
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046533
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046534
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046535
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046536
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046537
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046538
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046539
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046540
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046541
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046542
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046543
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046544
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046545
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046546
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046547
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046548
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046549
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046550
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046551
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046552
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046553
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046554
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046555
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046556
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046557
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046558
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046559
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046560
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046561
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046562
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046563
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046564
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046565
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046566
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046567
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046568
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046569
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046570
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046571
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046572
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046573
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046574
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046575
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046576
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046577
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046578
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046579
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046580
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046581
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046582
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046583
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046584
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046585
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046586
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046587
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046588
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046589
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046590
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046591
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046592
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046593
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046594
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046595
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046596
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046597
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046598
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046599
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046600
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046601
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046602
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046603
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046604
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046605
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046606
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046607
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046608
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046609
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046610
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046611
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046612
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046613
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046614
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046615
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046616
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046617
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046618
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046619
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046620
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046621
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046622
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046623
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046624
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046625
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046626
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046627
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046628
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046629
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046630
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046631
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046632
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046633
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046634
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046635
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046636
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046637
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046638
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046639
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046640
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046641
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046642
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046643
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046644
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046645
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046646
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046647
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046648
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046649
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046650
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046651
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046652
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046653
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046654
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046655
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046656
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046657
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046658
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046659
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046660
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046661
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046662
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046663
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046664
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046665
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046666
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046667
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046668
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046669
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046670
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046671
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046672
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046673
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046674
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046675
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046676
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046677
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046678
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046679
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046680
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046681
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046682
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046683
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046684
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046685
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046686
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046687
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046688
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046689
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046690
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046691
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046692
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046693
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046694
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046695
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046696
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046697
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046698
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046699
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046700
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046701
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046702
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046703
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046704
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046705
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046706
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046707
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046708
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046709
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046710
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046711
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046712
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046713
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046714
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046715
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046716
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046717
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046718
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046719
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046720
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046721
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046722
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046723
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046724
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046725
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046726
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046727
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046728
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046729
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046730
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046731
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046732
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046733
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046734
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046735
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046736
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046737
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046738
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046739
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046740
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046741
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046742
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046743
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046744
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046745
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046746
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046747
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046748
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046749
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046750
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046751
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046752
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046753
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046754
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046755
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046756
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046757
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046758
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046759
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046760
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046761
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046762
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046763
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619262046764
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240512
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240513
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240514
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240515
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240516
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240517
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240518
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240519
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240520
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240521
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240522
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240523
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240524
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240525
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240526
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240527
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240528
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240529
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240530
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240531
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240532
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240533
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240534
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240535
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240536
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240537
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240538
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240539
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240540
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240541
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240542
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240543
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240544
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240545
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240546
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240547
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240548
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240549
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240550
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240551
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240552
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240553
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240554
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240555
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240556
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240557
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240558
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240559
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240560
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240561
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240562
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240563
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240564
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240565
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240566
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240567
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240568
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240569
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240570
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240571
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240572
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240573
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240574
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240575
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240576
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240577
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240578
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240579
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240580
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240581
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240582
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240583
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240584
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240585
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240586
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240587
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240588
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240589
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240590
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240591
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240592
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240593
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240594
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240595
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240596
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240597
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240598
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240599
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240600
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240601
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240602
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240603
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240604
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240605
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240606
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240607
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240608
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240609
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240610
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240611
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240612
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240613
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240614
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240615
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240616
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240617
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240618
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240619
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240620
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240621
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240622
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240623
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240624
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240625
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240626
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240627
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240628
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240629
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240630
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240631
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240632
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240633
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240634
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240635
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240636
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240637
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240638
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240639
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240640
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240641
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240642
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240643
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240644
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240645
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240646
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240647
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240648
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240649
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240650
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240651
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240652
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240653
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240654
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240655
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240656
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240657
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240658
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240659
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240660
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240661
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240662
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240663
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240664
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240665
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240666
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240667
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240668
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240669
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240670
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240671
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240672
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240673
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240674
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240675
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240676
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240677
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1791619266240678
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983477964800
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159104
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159105
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159106
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159107
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159108
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159109
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159110
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159111
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159112
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159113
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159114
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159115
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159116
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159117
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159118
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159119
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159120
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159121
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159122
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159123
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159124
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159125
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159126
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159127
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159128
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159129
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159130
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159131
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159132
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159133
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159134
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159135
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159136
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159137
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159138
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159139
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159140
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159141
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159142
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159143
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159144
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159145
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159146
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159147
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159148
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159149
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159150
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159151
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159152
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159153
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159154
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159155
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159156
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159157
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159158
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159159
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159160
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159161
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159162
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159163
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159164
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159165
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159166
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159167
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159168
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159169
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159170
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159171
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159172
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159173
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159174
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159175
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159176
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159177
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159178
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159179
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159180
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159181
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159182
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159183
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159184
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159185
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159186
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159187
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159188
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159189
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159190
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159191
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159192
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159193
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159194
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159195
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159196
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159197
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159198
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159199
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159200
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159201
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159202
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159203
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159204
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159205
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159206
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159207
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159208
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159209
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159210
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159211
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159212
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159213
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159214
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159215
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159216
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159217
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159218
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159219
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159220
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159221
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159222
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159223
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159224
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159225
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159226
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159227
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159228
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159229
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159230
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159231
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159232
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159233
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159234
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159235
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159236
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159237
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159238
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159239
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159240
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159241
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159242
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159243
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159244
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159245
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159246
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159247
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159248
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159249
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159250
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159251
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159252
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159253
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159254
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159255
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159256
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159257
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159258
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159259
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159260
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159261
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159262
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159263
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159264
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159265
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159266
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159267
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159268
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159269
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159270
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159271
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159272
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159273
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159274
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159275
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159276
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159277
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159278
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159279
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159280
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159281
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159282
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159283
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159284
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159285
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159286
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159287
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159288
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159289
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159290
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159291
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159292
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159293
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159294
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159295
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159296
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159297
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159298
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159299
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159300
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159301
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159302
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159303
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159304
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159305
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159306
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159307
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159308
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159309
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159310
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159311
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159312
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159313
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159314
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159315
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159316
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159317
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159318
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159319
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159320
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159321
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159322
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159323
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159324
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159325
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159326
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159327
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159328
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159329
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159330
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159331
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159332
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159333
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159334
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159335
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159336
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159337
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159338
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159339
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159340
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159341
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159342
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159343
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159344
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159345
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159346
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159347
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159348
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159349
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159350
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159351
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159352
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159353
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159354
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159355
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159356
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159357
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159358
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159359
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159360
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159361
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159362
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159363
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159364
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159365
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159366
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159367
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159368
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159369
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159370
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159371
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159372
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159373
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159374
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159375
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159376
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159377
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159378
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159379
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159380
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159381
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159382
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159383
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159384
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159385
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159386
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159387
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159388
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159389
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159390
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159391
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159392
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159393
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159394
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159395
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159396
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159397
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159398
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159399
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159400
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159401
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159402
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159403
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159404
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159405
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159406
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159407
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159408
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159409
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159410
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159411
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159412
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159413
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159414
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159415
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159416
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159417
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159418
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159419
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159420
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159421
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159422
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159423
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159424
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159425
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159426
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159427
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159428
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159429
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159430
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159431
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159432
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159433
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159434
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159435
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159436
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159437
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159438
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159439
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159440
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159441
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159442
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159443
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159444
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159445
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159446
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159447
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159448
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159449
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159450
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159451
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159452
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159453
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159454
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159455
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159456
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159457
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159458
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159459
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159460
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159461
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159462
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159463
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159464
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159465
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159466
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159467
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159468
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159469
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159470
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159471
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159472
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159473
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159474
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159475
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159476
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159477
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159478
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159479
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159480
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159481
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159482
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159483
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159484
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159485
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159486
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159487
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159488
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159489
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159490
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159491
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159492
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159493
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159494
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159495
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159496
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159497
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159498
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159499
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159500
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159501
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159502
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159503
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159504
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159505
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159506
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159507
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159508
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159509
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159510
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159511
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159512
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159513
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159514
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159515
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159516
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159517
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159518
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159519
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159520
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159521
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159522
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159523
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159524
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159525
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159526
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159527
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159528
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159529
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159530
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159531
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159532
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159533
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159534
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159535
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159536
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159537
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159538
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159539
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159540
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159541
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159542
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159543
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159544
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159545
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159546
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159547
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159548
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159549
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159550
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159551
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159552
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159553
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159554
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159555
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159556
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159557
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159558
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159559
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159560
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159561
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159562
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159563
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159564
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159565
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159566
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159567
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159568
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159569
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159570
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159571
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159572
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159573
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159574
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159575
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159576
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159577
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159578
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159579
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159580
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159581
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159582
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159583
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159584
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159585
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159586
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159587
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159588
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159589
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159590
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159591
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159592
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159593
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159594
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159595
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159596
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159597
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159598
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159599
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159600
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159601
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159602
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159603
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159604
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159605
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159606
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159607
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159608
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159609
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159610
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159611
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159612
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159613
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159614
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159615
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159616
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159617
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159618
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159619
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159620
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159621
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159622
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159623
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159624
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159625
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159626
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159627
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159628
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159629
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159630
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159631
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159632
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159633
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159634
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159635
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159636
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159637
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159638
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159639
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159640
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159641
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159642
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159643
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159644
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159645
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159646
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159647
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159648
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159649
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159650
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159651
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159652
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159653
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159654
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159655
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159656
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159657
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159658
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159659
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159660
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159661
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159662
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159663
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159664
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159665
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159666
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159667
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159668
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159669
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159670
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159671
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159672
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159673
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159674
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159675
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159676
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159677
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159678
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159679
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159680
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159681
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159682
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159683
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159684
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159685
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159686
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159687
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159688
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159689
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159690
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159691
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159692
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159693
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159694
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159695
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159696
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159697
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159698
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159699
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159700
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159701
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159702
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159703
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159704
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159705
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159706
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159707
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159708
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159709
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159710
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159711
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159712
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159713
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159714
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159715
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159716
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159717
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159718
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159719
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159720
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159721
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159722
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159723
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159724
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159725
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159726
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159727
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159728
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159729
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159730
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159731
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159732
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159733
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159734
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159735
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159736
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159737
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159738
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159739
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159740
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159741
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159742
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159743
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159744
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159745
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159746
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159747
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159748
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159749
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159750
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159751
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159752
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159753
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159754
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159755
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159756
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159757
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159758
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159759
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159760
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159761
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159762
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159763
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159764
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159765
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159766
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159767
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159768
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159769
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159770
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159771
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159772
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159773
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159774
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159775
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159776
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159777
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159778
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159779
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159780
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159781
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159782
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159783
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159784
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159785
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159786
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159787
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159788
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159789
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159790
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159791
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159792
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159793
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159794
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159795
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159796
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159797
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159798
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159799
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159800
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159801
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159802
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159803
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159804
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159805
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159806
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159807
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159808
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159809
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159810
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159811
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159812
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159813
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159814
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159815
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159816
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159817
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159818
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159819
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159820
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159821
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159822
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159823
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159824
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159825
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159826
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159827
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159828
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159829
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159830
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159831
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159832
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159833
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159834
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159835
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159836
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159837
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159838
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159839
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159840
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159841
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159842
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159843
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159844
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159845
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159846
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159847
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159848
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159849
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159850
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159851
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159852
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159853
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159854
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159855
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1793983482159856
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803312861184
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444096
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444097
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444098
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444099
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444100
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444101
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444102
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444103
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444104
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444105
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444106
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444107
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444108
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444109
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444110
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444111
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444112
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444113
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444114
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444115
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444116
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444117
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444118
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444119
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444120
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444121
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444122
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444123
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444124
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444125
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444126
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444127
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444128
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444129
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444130
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444131
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444132
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444133
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444134
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444135
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444136
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444137
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444138
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444139
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444140
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444141
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444142
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444143
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444144
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444145
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444146
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444147
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444148
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444149
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444150
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444151
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444152
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444153
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444154
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444155
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444156
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444157
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444158
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444159
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444160
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444161
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444162
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444163
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444164
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444165
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444166
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444167
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444168
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444169
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444170
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444171
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444172
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444173
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444174
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444175
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444176
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444177
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444178
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444179
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444180
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444181
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444182
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444183
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444184
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444185
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444186
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444187
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444188
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444189
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444190
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444191
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444192
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444193
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444194
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444195
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444196
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444197
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444198
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444199
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444200
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444201
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444202
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444203
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444204
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444205
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444206
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444207
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444208
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444209
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444210
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444211
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444212
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444213
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444214
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444215
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444216
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444217
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444218
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444219
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444220
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444221
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444222
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444223
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444224
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444225
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444226
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444227
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444228
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444229
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444230
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444231
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444232
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444233
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444234
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444235
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444236
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444237
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444238
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444239
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444240
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444241
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444242
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444243
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444244
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444245
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444246
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444247
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444248
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444249
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444250
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444251
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444252
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444253
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444254
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444255
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444256
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444257
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444258
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444259
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444260
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444261
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444262
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444263
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444264
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444265
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444266
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444267
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444268
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444269
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444270
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444271
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444272
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444273
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444274
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444275
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444276
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444277
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444278
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444279
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444280
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444281
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444282
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444283
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444284
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444285
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444286
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444287
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444288
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444289
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444290
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444291
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444292
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444293
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444294
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444295
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444296
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444297
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444298
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444299
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444300
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444301
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444302
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444303
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444304
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444305
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444306
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444307
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444308
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444309
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444310
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444311
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444312
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444313
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444314
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444315
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444316
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444317
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444318
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444319
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444320
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444321
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444322
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444323
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444324
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444325
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444326
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444327
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444328
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444329
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444330
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444331
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444332
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444333
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444334
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444335
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444336
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444337
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444338
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444339
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444340
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444341
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444342
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444343
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444344
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444345
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444346
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444347
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444348
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444349
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444350
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444351
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444352
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444353
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444354
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444355
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444356
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444357
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444358
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444359
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444360
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444361
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444362
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444363
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444364
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444365
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444366
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444367
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444368
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444369
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444370
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444371
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444372
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444373
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444374
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444375
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444376
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444377
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444378
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444379
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444380
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444381
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444382
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444383
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444384
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444385
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444386
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444387
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444388
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444389
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444390
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444391
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444392
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444393
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444394
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444395
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444396
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444397
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444398
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444399
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444400
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444401
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444402
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444403
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444404
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444405
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444406
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444407
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444408
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444409
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444410
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444411
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444412
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444413
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444414
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444415
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444416
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444417
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444418
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444419
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444420
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444421
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444422
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444423
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444424
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444425
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444426
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444427
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444428
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444429
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444430
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444431
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444432
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444433
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444434
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444435
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444436
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444437
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444438
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444439
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444440
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444441
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444442
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444443
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444444
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444445
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444446
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444447
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444448
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444449
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444450
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444451
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444452
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444453
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444454
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444455
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444456
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444457
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444458
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444459
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444460
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444461
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444462
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444463
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444464
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444465
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444466
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444467
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444468
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444469
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444470
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444471
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444472
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444473
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444474
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444475
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444476
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444477
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444478
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444479
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444480
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444481
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444482
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444483
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444484
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444485
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444486
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444487
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444488
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444489
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444490
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444491
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444492
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444493
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444494
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444495
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444496
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444497
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444498
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444499
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444500
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444501
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444502
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444503
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444504
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444505
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444506
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444507
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444508
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444509
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444510
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444511
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444512
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444513
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444514
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444515
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444516
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444517
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444518
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444519
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444520
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444521
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444522
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444523
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444524
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444525
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444526
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444527
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444528
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444529
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444530
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444531
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444532
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444533
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444534
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444535
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444536
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444537
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444538
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444539
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444540
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444541
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444542
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444543
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444544
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444545
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444546
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444547
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444548
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444549
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444550
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444551
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444552
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444553
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444554
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444555
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444556
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444557
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444558
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444559
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444560
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444561
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444562
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444563
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444564
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444565
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444566
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444567
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444568
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444569
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444570
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444571
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444572
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444573
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444574
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444575
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444576
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444577
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444578
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444579
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444580
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444581
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444582
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444583
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444584
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444585
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444586
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444587
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444588
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444589
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444590
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444591
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444592
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444593
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444594
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444595
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444596
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444597
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444598
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444599
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444600
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444601
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444602
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444603
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444604
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444605
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444606
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444607
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444608
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444609
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444610
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444611
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444612
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444613
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444614
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444615
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444616
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444617
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444618
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444619
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444620
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444621
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444622
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444623
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444624
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444625
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444626
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444627
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444628
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444629
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444630
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444631
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444632
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444633
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444634
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444635
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444636
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444637
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444638
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444639
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444640
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444641
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444642
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444643
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444644
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444645
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444646
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444647
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444648
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444649
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444650
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444651
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444652
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444653
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444654
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444655
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444656
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444657
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444658
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444659
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444660
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444661
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444662
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444663
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444664
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444665
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444666
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444667
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444668
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444669
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444670
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444671
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444672
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444673
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444674
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444675
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444676
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444677
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444678
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444679
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444680
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444681
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444682
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444683
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444684
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444685
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444686
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444687
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444688
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444689
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444690
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444691
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444692
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444693
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444694
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444695
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444696
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444697
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444698
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444699
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444700
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444701
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444702
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444703
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444704
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444705
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444706
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444707
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444708
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444709
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444710
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444711
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444712
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444713
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444714
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444715
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444716
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444717
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444718
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444719
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444720
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444721
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444722
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444723
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444724
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444725
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444726
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444727
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444728
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444729
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444730
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444731
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444732
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444733
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444734
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444735
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444736
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444737
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444738
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444739
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444740
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 1822803325444741
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638400
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638401
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638402
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638403
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638404
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638405
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638406
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638407
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638408
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638409
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638410
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638411
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638412
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638413
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638414
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638415
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638416
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638417
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638418
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638419
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638420
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638421
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638422
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638423
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638424
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638425
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638426
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638427
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638428
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638429
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638430
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638431
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638432
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638433
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638434
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638435
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638436
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638437
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638438
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638439
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638440
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638441
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638442
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638443
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638444
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638445
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638446
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638447
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638448
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638449
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638450
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638451
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638452
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638453
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638454
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638455
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638456
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638457
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638458
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638459
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638460
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638461
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638462
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638463
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638464
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638465
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638466
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638467
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638468
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638469
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638470
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638471
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638472
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638473
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638474
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638475
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638476
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638477
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638478
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638479
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638480
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638481
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638482
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638483
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638484
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638485
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638486
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638487
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638488
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638489
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638490
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638491
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638492
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638493
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638494
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638495
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638496
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638497
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638498
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638499
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638500
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638501
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638502
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638503
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638504
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638505
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1822803329638506
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154752
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154753
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154754
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154755
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154756
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154757
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154758
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154759
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154760
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154761
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154762
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154763
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154764
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154765
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154766
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154767
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154768
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154769
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154770
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154771
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154772
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154773
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154774
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154775
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154776
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154777
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154778
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154779
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154780
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154781
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154782
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154783
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154784
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154785
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154786
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154787
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154788
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154789
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154790
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154791
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154792
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154793
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154794
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154795
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154796
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154797
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154798
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154799
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154800
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154801
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154802
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154803
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154804
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154805
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154806
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154807
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154808
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154809
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154810
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154811
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154812
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154813
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154814
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154815
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154816
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154817
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154818
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154819
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154820
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154821
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154822
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154823
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154824
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154825
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154826
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154827
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154828
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154829
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154830
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154831
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154832
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154833
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154834
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154835
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154836
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154837
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154838
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154839
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154840
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154841
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154842
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154843
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154844
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154845
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154846
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154847
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154848
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154849
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154850
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154851
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154852
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154853
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154854
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154855
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154856
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154857
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154858
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154859
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154860
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154861
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154862
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154863
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154864
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154865
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154866
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154867
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154868
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154869
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154870
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154871
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154872
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154873
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154874
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154875
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154876
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154877
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154878
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154879
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154880
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154881
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154882
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154883
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154884
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154885
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154886
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154887
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154888
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154889
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154890
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154891
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154892
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154893
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154894
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154895
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154896
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154897
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154898
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154899
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154900
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154901
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154902
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154903
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154904
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154905
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154906
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154907
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154908
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154909
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154910
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154911
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154912
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154913
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154914
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154915
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154916
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154917
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154918
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154919
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154920
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154921
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154922
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154923
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154924
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154925
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154926
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154927
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154928
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154929
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154930
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154931
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154932
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154933
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154934
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154935
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154936
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154937
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154938
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154939
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154940
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154941
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154942
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154943
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154944
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154945
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154946
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154947
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154948
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154949
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154950
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154951
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154952
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154953
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154954
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154955
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154956
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154957
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154958
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154959
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154960
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154961
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154962
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154963
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154964
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154965
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154966
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154967
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154968
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154969
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154970
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154971
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154972
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154973
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154974
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154975
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154976
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154977
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154978
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154979
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154980
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154981
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154982
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154983
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154984
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154985
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154986
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154987
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154988
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154989
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154990
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154991
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154992
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154993
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154994
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154995
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154996
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154997
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154998
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390154999
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155000
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155001
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155002
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155003
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155004
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155005
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155006
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155007
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155008
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155009
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155010
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155011
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155012
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155013
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155014
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155015
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155016
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155017
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155018
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155019
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155020
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155021
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155022
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155023
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155024
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155025
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155026
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155027
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155028
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155029
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155030
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155031
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155032
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155033
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155034
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155035
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155036
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155037
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155038
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155039
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155040
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155041
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155042
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155043
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155044
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155045
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155046
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155047
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155048
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155049
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155050
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155051
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155052
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155053
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155054
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155055
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155056
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155057
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155058
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155059
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155060
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155061
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155062
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155063
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155064
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155065
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155066
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155067
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155068
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155069
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155070
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155071
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155072
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155073
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155074
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155075
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155076
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155077
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155078
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155079
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155080
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155081
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155082
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155083
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155084
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155085
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155086
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155087
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155088
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155089
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155090
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155091
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155092
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155093
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155094
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155095
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155096
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155097
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155098
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155099
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155100
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155101
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155102
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155103
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155104
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155105
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155106
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155107
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155108
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155109
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155110
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155111
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155112
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155113
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155114
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155115
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155116
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155117
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155118
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155119
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155120
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155121
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155122
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155123
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155124
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155125
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155126
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155127
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155128
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155129
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155130
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155131
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155132
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155133
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155134
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155135
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155136
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155137
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155138
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155139
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155140
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155141
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155142
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155143
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155144
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155145
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155146
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155147
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155148
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155149
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155150
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155151
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155152
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155153
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155154
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155155
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155156
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155157
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155158
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155159
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155160
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155161
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155162
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155163
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155164
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155165
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155166
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155167
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155168
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155169
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155170
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155171
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155172
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155173
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155174
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155175
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155176
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155177
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155178
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155179
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155180
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155181
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155182
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155183
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155184
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155185
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155186
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155187
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155188
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155189
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155190
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155191
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155192
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155193
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155194
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155195
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155196
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155197
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155198
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155199
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155200
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155201
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155202
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155203
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155204
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155205
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155206
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155207
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155208
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155209
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155210
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155211
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155212
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155213
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155214
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155215
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155216
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155217
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155218
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155219
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155220
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155221
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155222
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155223
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155224
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155225
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155226
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155227
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155228
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155229
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155230
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155231
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155232
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155233
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155234
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155235
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155236
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155237
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155238
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155239
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155240
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155241
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155242
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155243
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155244
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155245
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155246
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155247
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155248
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155249
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155250
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155251
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155252
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155253
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155254
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155255
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155256
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155257
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155258
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155259
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155260
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155261
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155262
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155263
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155264
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155265
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155266
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155267
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155268
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155269
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155270
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155271
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155272
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155273
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155274
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155275
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155276
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155277
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155278
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155279
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155280
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155281
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155282
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155283
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155284
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155285
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155286
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155287
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155288
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155289
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155290
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155291
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155292
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155293
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155294
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155295
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155296
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155297
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155298
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155299
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155300
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155301
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155302
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155303
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155304
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155305
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155306
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155307
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155308
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155309
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155310
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155311
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155312
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155313
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155314
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155315
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155316
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155317
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155318
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155319
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155320
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155321
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155322
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155323
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155324
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155325
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155326
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155327
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155328
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155329
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155330
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155331
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155332
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155333
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155334
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155335
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155336
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155337
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155338
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155339
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155340
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155341
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155342
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155343
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155344
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155345
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155346
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155347
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155348
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155349
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155350
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155351
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155352
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155353
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155354
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155355
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155356
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155357
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155358
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155359
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155360
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155361
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155362
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155363
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155364
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155365
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155366
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155367
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155368
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155369
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155370
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155371
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155372
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155373
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155374
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155375
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155376
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155377
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155378
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155379
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155380
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155381
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155382
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155383
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155384
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155385
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155386
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155387
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155388
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155389
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155390
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155391
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155392
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155393
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155394
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155395
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155396
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155397
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155398
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155399
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155400
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155401
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155402
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155403
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155404
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155405
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155406
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155407
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155408
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155409
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155410
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155411
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155412
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155413
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155414
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155415
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155416
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155417
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155418
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155419
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155420
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155421
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155422
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155423
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155424
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155425
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155426
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155427
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155428
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155429
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155430
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155431
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155432
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155433
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155434
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155435
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155436
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155437
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155438
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155439
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155440
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155441
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155442
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155443
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155444
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155445
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155446
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155447
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155448
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155449
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155450
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155451
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155452
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155453
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155454
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155455
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155456
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155457
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155458
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155459
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155460
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155461
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155462
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155463
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155464
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155465
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155466
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155467
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155468
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155469
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155470
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155471
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155472
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155473
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155474
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155475
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155476
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155477
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155478
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155479
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155480
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155481
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155482
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155483
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155484
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155485
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155486
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155487
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155488
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155489
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155490
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155491
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155492
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155493
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155494
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155495
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155496
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155497
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155498
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155499
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155500
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155501
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155502
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155503
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155504
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155505
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155506
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155507
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155508
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155509
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155510
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155511
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155512
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155513
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155514
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155515
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155516
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155517
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155518
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155519
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155520
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155521
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155522
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155523
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155524
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155525
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155526
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155527
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155528
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155529
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155530
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155531
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155532
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155533
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155534
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155535
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155536
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155537
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155538
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155539
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155540
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155541
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155542
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155543
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155544
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155545
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155546
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155547
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155548
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155549
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155550
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155551
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155552
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155553
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155554
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155555
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155556
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155557
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155558
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155559
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155560
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155561
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155562
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155563
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155564
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155565
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155566
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155567
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155568
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155569
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155570
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155571
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155572
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155573
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155574
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155575
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155576
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155577
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155578
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155579
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155580
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155581
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155582
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155583
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155584
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155585
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155586
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155587
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155588
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155589
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155590
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155591
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155592
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155593
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155594
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155595
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155596
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155597
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155598
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155599
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155600
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155601
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155602
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155603
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155604
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155605
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155606
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155607
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155608
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155609
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155610
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155611
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155612
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155613
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155614
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155615
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155616
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155617
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155618
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155619
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155620
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155621
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155622
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155623
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155624
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155625
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155626
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155627
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155628
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155629
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155630
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155631
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155632
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155633
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155634
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155635
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155636
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155637
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155638
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155639
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155640
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155641
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155642
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155643
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155644
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155645
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155646
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155647
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155648
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155649
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155650
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155651
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155652
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155653
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155654
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155655
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155656
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155657
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155658
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155659
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155660
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155661
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155662
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155663
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155664
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155665
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155666
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155667
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155668
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155669
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155670
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155671
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155672
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155673
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155674
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155675
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155676
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155677
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155678
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155679
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155680
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155681
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155682
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155683
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155684
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155685
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155686
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155687
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155688
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155689
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155690
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155691
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155692
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155693
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2088687390155694
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239232
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239233
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239234
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239235
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239236
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239237
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239238
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239239
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239240
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239241
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239242
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239243
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239244
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239245
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239246
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239247
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239248
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239249
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239250
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239251
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239252
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239253
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239254
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239255
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239256
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239257
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239258
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239259
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239260
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239261
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239262
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239263
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972278239264
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433536
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433537
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433538
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433539
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433540
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433541
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433542
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433543
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433544
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433545
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433546
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433547
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433548
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433549
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433550
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433551
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433552
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433553
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433554
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433555
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433556
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433557
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433558
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433559
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433560
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433561
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433562
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433563
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433564
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433565
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433566
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433567
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433568
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433569
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433570
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433571
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433572
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433573
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433574
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433575
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433576
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433577
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433578
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433579
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433580
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433581
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433582
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433583
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433584
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433585
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433586
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433587
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433588
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433589
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433590
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433591
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433592
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433593
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433594
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433595
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433596
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433597
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433598
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433599
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433600
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433601
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433602
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433603
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433604
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433605
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433606
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433607
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433608
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433609
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433610
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433611
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433612
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433613
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433614
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433615
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433616
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433617
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433618
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433619
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433620
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433621
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433622
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433623
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433624
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433625
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433626
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433627
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433628
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433629
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433630
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433631
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433632
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433633
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433634
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433635
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433636
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433637
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433638
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433639
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433640
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433641
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433642
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433643
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433644
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433645
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433646
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433647
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433648
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433649
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433650
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433651
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433652
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433653
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433654
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433655
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433656
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433657
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433658
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433659
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433660
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433661
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433662
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433663
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433664
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433665
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433666
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433667
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433668
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433669
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433670
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433671
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433672
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433673
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433674
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433675
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433676
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433677
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433678
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433679
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433680
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433681
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433682
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433683
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433684
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433685
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433686
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433687
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433688
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433689
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433690
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433691
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433692
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433693
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433694
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433695
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433696
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433697
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433698
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433699
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433700
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433701
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433702
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433703
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433704
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433705
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433706
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433707
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433708
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433709
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433710
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433711
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433712
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433713
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433714
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433715
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433716
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433717
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433718
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433719
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433720
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433721
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433722
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433723
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433724
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433725
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433726
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433727
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433728
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433729
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433730
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433731
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433732
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433733
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433734
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433735
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433736
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433737
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433738
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433739
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433740
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433741
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433742
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433743
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433744
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433745
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433746
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433747
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433748
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433749
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433750
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433751
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433752
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433753
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433754
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433755
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433756
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433757
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433758
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433759
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433760
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433761
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433762
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433763
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433764
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433765
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433766
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433767
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433768
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433769
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433770
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433771
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433772
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433773
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433774
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433775
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433776
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433777
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433778
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433779
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433780
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433781
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433782
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433783
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433784
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433785
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433786
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433787
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433788
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433789
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433790
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433791
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433792
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433793
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433794
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433795
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433796
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433797
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433798
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433799
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433800
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433801
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433802
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433803
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433804
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433805
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433806
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433807
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433808
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433809
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433810
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433811
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433812
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433813
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433814
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433815
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433816
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433817
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433818
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433819
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433820
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433821
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433822
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433823
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433824
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433825
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433826
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433827
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433828
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433829
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433830
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433831
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433832
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433833
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433834
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433835
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433836
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433837
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433838
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433839
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433840
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433841
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433842
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433843
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433844
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433845
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433846
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433847
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433848
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433849
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433850
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433851
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433852
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433853
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433854
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433855
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433856
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433857
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433858
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433859
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433860
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433861
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433862
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433863
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433864
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433865
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433866
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433867
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433868
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433869
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433870
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433871
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433872
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433873
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433874
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433875
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433876
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433877
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433878
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433879
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433880
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433881
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433882
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433883
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433884
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433885
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433886
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433887
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433888
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433889
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433890
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433891
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433892
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433893
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433894
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433895
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433896
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433897
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433898
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433899
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433900
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433901
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433902
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433903
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433904
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433905
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433906
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433907
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433908
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433909
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433910
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433911
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433912
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433913
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433914
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433915
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433916
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433917
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433918
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433919
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433920
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433921
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433922
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433923
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433924
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433925
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433926
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433927
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433928
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433929
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433930
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433931
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433932
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433933
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433934
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433935
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433936
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433937
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433938
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433939
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433940
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433941
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433942
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433943
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433944
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433945
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433946
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433947
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433948
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433949
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433950
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433951
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433952
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433953
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433954
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433955
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433956
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433957
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433958
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433959
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433960
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433961
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433962
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433963
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433964
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433965
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433966
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433967
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433968
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433969
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433970
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433971
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433972
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433973
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433974
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433975
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433976
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433977
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433978
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433979
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433980
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433981
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433982
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433983
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433984
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433985
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433986
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433987
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433988
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433989
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433990
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433991
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433992
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433993
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433994
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433995
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433996
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433997
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433998
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282433999
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434000
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434001
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434002
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434003
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434004
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434005
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434006
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434007
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434008
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434009
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434010
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434011
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434012
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434013
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434014
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434015
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434016
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434017
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434018
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434019
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434020
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434021
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434022
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434023
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434024
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434025
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434026
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434027
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434028
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434029
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434030
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434031
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434032
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434033
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434034
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434035
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434036
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434037
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434038
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434039
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434040
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434041
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434042
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434043
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434044
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434045
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434046
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434047
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434048
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434049
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434050
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434051
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434052
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434053
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434054
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434055
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434056
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434057
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434058
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434059
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434060
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434061
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434062
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434063
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434064
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434065
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434066
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434067
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434068
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434069
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434070
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434071
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434072
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434073
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434074
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434075
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434076
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434077
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434078
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434079
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434080
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434081
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434082
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434083
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434084
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434085
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434086
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434087
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434088
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434089
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434090
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434091
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434092
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434093
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434094
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434095
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434096
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434097
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434098
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434099
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434100
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434101
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434102
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434103
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434104
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434105
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434106
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434107
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434108
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434109
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434110
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434111
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434112
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434113
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434114
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434115
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434116
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434117
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434118
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434119
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434120
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434121
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434122
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434123
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434124
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434125
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434126
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434127
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434128
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434129
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434130
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434131
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434132
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434133
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434134
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434135
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434136
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434137
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434138
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434139
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434140
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434141
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434142
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434143
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434144
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434145
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434146
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434147
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434148
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434149
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434150
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434151
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434152
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434153
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434154
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434155
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434156
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434157
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434158
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434159
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434160
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434161
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434162
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434163
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434164
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434165
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434166
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434167
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434168
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434169
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434170
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434171
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434172
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434173
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434174
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434175
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434176
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434177
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434178
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434179
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434180
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434181
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434182
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434183
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434184
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434185
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434186
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434187
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434188
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434189
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434190
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434191
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434192
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434193
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434194
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434195
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434196
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434197
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434198
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434199
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434200
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434201
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434202
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434203
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434204
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434205
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434206
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434207
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434208
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434209
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434210
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434211
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434212
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434213
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434214
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434215
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434216
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434217
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434218
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434219
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434220
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434221
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434222
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434223
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434224
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434225
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434226
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434227
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434228
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434229
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434230
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434231
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434232
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434233
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434234
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434235
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434236
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434237
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434238
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434239
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434240
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434241
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434242
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434243
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434244
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434245
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434246
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434247
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434248
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434249
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434250
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434251
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434252
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434253
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434254
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434255
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434256
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434257
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434258
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434259
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434260
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434261
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434262
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434263
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434264
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434265
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434266
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434267
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434268
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434269
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434270
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434271
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434272
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434273
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434274
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434275
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434276
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434277
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434278
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434279
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434280
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434281
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434282
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434283
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434284
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434285
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434286
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434287
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434288
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434289
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434290
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434291
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434292
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434293
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434294
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434295
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434296
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434297
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434298
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434299
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434300
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434301
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434302
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434303
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434304
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434305
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434306
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434307
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434308
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434309
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434310
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434311
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434312
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434313
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434314
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434315
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434316
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434317
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434318
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434319
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434320
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434321
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434322
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434323
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434324
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434325
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434326
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434327
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434328
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434329
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434330
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434331
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434332
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434333
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434334
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434335
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434336
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434337
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434338
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434339
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434340
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434341
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434342
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434343
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434344
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434345
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434346
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434347
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434348
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434349
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434350
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434351
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434352
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434353
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434354
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434355
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434356
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434357
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434358
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434359
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434360
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972282434361
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627840
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627841
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627842
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627843
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627844
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627845
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627846
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627847
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627848
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627849
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627850
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627851
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627852
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627853
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627854
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627855
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627856
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627857
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627858
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627859
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627860
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627861
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627862
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627863
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627864
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627865
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627866
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627867
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627868
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627869
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627870
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627871
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627872
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627873
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627874
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627875
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627876
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627877
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627878
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627879
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627880
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627881
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627882
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627883
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627884
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627885
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627886
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627887
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627888
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627889
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627890
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627891
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627892
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627893
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627894
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627895
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627896
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627897
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627898
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627899
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627900
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627901
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627902
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627903
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627904
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627905
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627906
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627907
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627908
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627909
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627910
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627911
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627912
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627913
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627914
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627915
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627916
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627917
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627918
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627919
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627920
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627921
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627922
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2213972286627923
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739136
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739137
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739138
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739139
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739140
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739141
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739142
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739143
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739144
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739145
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739146
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739147
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739148
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739149
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739150
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739151
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739152
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739153
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739154
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739155
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739156
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739157
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739158
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739159
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739160
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739161
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739162
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739163
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739164
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739165
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739166
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739167
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739168
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739169
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739170
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739171
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739172
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739173
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739174
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739175
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739176
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739177
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739178
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739179
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739180
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739181
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739182
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739183
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739184
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739185
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739186
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739187
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739188
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739189
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739190
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739191
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739192
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739193
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739194
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739195
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739196
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739197
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739198
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739199
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739200
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739201
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739202
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739203
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739204
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739205
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739206
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739207
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739208
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739209
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739210
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739211
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739212
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739213
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739214
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739215
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739216
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739217
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739218
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739219
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739220
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739221
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739222
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739223
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739224
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739225
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739226
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739227
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739228
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739229
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739230
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739231
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739232
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739233
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739234
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739235
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739236
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739237
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739238
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739239
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739240
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739241
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739242
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739243
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739244
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739245
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739246
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739247
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739248
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739249
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739250
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739251
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739252
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739253
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739254
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739255
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739256
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739257
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739258
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739259
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739260
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739261
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739262
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739263
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739264
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739265
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739266
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739267
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739268
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739269
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739270
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739271
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739272
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739273
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739274
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739275
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739276
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739277
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739278
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739279
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739280
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739281
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739282
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739283
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739284
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739285
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739286
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739287
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739288
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739289
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739290
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739291
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739292
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739293
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739294
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739295
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739296
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739297
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739298
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739299
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739300
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739301
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739302
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739303
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739304
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739305
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739306
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739307
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739308
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739309
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739310
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739311
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739312
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739313
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739314
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739315
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739316
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739317
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739318
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739319
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739320
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739321
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739322
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739323
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739324
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739325
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739326
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739327
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739328
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739329
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739330
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739331
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739332
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739333
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739334
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739335
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739336
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739337
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739338
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739339
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739340
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739341
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739342
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739343
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739344
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739345
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739346
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739347
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739348
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739349
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739350
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739351
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739352
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739353
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739354
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739355
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739356
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739357
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739358
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739359
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739360
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739361
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739362
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739363
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739364
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739365
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739366
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739367
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739368
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739369
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739370
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739371
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739372
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739373
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739374
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739375
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739376
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739377
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739378
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739379
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739380
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739381
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739382
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739383
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739384
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739385
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739386
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739387
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739388
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739389
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739390
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739391
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739392
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739393
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739394
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739395
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739396
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739397
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739398
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739399
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739400
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739401
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739402
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739403
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739404
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739405
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739406
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739407
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739408
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739409
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739410
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739411
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739412
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739413
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739414
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739415
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739416
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739417
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739418
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739419
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739420
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739421
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739422
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739423
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739424
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739425
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739426
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739427
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739428
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739429
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739430
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739431
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739432
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739433
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739434
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739435
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739436
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739437
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739438
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739439
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739440
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739441
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739442
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739443
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739444
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739445
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739446
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739447
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739448
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739449
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739450
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739451
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739452
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739453
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739454
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739455
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739456
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739457
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739458
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739459
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739460
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739461
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739462
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739463
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739464
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739465
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739466
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739467
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739468
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739469
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739470
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739471
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739472
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739473
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739474
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739475
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739476
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739477
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739478
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739479
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739480
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739481
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739482
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739483
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739484
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739485
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739486
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739487
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739488
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739489
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739490
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739491
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739492
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739493
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739494
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739495
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739496
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739497
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739498
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739499
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739500
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739501
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739502
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739503
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739504
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739505
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739506
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739507
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739508
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739509
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739510
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739511
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739512
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739513
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739514
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739515
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739516
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739517
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739518
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739519
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739520
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739521
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739522
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739523
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739524
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739525
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739526
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739527
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739528
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739529
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739530
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739531
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739532
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739533
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739534
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739535
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739536
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739537
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739538
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739539
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739540
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739541
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739542
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739543
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739544
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739545
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739546
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739547
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739548
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739549
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739550
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739551
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739552
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739553
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739554
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739555
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739556
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739557
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739558
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739559
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739560
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739561
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739562
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739563
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739564
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739565
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739566
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739567
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739568
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739569
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739570
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739571
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739572
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739573
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739574
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739575
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739576
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739577
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739578
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739579
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739580
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739581
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739582
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739583
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739584
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739585
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739586
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739587
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739588
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739589
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739590
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739591
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739592
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739593
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739594
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739595
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739596
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739597
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739598
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739599
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739600
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739601
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739602
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739603
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739604
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739605
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739606
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739607
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739608
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739609
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739610
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739611
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739612
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739613
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739614
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739615
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739616
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739617
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739618
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739619
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739620
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739621
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739622
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739623
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739624
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739625
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739626
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739627
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739628
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739629
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739630
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739631
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739632
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739633
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739634
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739635
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739636
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739637
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739638
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739639
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497419739640
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933440
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933441
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933442
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933443
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933444
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933445
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933446
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933447
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933448
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933449
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933450
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933451
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933452
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933453
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933454
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933455
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933456
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933457
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933458
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933459
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933460
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933461
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933462
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933463
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933464
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933465
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933466
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933467
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933468
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933469
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933470
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933471
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933472
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933473
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933474
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933475
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933476
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933477
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933478
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933479
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933480
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933481
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933482
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933483
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933484
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933485
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933486
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933487
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933488
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933489
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933490
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933491
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933492
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933493
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933494
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933495
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933496
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933497
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933498
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933499
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933500
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933501
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933502
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933503
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933504
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933505
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933506
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933507
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933508
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933509
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933510
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933511
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933512
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933513
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933514
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933515
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933516
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933517
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933518
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933519
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933520
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933521
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933522
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933523
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933524
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933525
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933526
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933527
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933528
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933529
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933530
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933531
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933532
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933533
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933534
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933535
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933536
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933537
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933538
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933539
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933540
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933541
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933542
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933543
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933544
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933545
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933546
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933547
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933548
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933549
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933550
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933551
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933552
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933553
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933554
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933555
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933556
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933557
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933558
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933559
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933560
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933561
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933562
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933563
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933564
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933565
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933566
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933567
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933568
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933569
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933570
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933571
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933572
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933573
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933574
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933575
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933576
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933577
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933578
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933579
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933580
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933581
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933582
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933583
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933584
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933585
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933586
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933587
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933588
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933589
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933590
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933591
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933592
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933593
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933594
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933595
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933596
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933597
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933598
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933599
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933600
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933601
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933602
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933603
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933604
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933605
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933606
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933607
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933608
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933609
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933610
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933611
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933612
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933613
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933614
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933615
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933616
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933617
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933618
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933619
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933620
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933621
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933622
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933623
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933624
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933625
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933626
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933627
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933628
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933629
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933630
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933631
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933632
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933633
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933634
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933635
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933636
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933637
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933638
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933639
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933640
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933641
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933642
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933643
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933644
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933645
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933646
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933647
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933648
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933649
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933650
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933651
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933652
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933653
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933654
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933655
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933656
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933657
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933658
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933659
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933660
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933661
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933662
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933663
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933664
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933665
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933666
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933667
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933668
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933669
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933670
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933671
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933672
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933673
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933674
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933675
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933676
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933677
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933678
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933679
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933680
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933681
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933682
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933683
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933684
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933685
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933686
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933687
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933688
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933689
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933690
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933691
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933692
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933693
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933694
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933695
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933696
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933697
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933698
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933699
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933700
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933701
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933702
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933703
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933704
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933705
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933706
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933707
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933708
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933709
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933710
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933711
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933712
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933713
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933714
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933715
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933716
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933717
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933718
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933719
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933720
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933721
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933722
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933723
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933724
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933725
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933726
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933727
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933728
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933729
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933730
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933731
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933732
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933733
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933734
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933735
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933736
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933737
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933738
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933739
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933740
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933741
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933742
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933743
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933744
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933745
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933746
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933747
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933748
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933749
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933750
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933751
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933752
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933753
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933754
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933755
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933756
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933757
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933758
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933759
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933760
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933761
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933762
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933763
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933764
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933765
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933766
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933767
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933768
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933769
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933770
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933771
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933772
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933773
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933774
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933775
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933776
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933777
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933778
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933779
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933780
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933781
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933782
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933783
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933784
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933785
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933786
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933787
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933788
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933789
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933790
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933791
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933792
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933793
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933794
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933795
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933796
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933797
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933798
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933799
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933800
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933801
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933802
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933803
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933804
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933805
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933806
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933807
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933808
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933809
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933810
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933811
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933812
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933813
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933814
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933815
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933816
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933817
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933818
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933819
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933820
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933821
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933822
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933823
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933824
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933825
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933826
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933827
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933828
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933829
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933830
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933831
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933832
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933833
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933834
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933835
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933836
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933837
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933838
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933839
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933840
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933841
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933842
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933843
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933844
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933845
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933846
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933847
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933848
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933849
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933850
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933851
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933852
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933853
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933854
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933855
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933856
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933857
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933858
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933859
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933860
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933861
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933862
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933863
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933864
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933865
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933866
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933867
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933868
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933869
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933870
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933871
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933872
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933873
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933874
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933875
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933876
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2448497423933877
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207956119552
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702464
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702465
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702466
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702467
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702468
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702469
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702470
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702471
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702472
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702473
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702474
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702475
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702476
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702477
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702478
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702479
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702480
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702481
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702482
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702483
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702484
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702485
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702486
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702487
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702488
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702489
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702490
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702491
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702492
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702493
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702494
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702495
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702496
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702497
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702498
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702499
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702500
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702501
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702502
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702503
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702504
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702505
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702506
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702507
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702508
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702509
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702510
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702511
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702512
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702513
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702514
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702515
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702516
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702517
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702518
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702519
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702520
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702521
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702522
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702523
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702524
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702525
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702526
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702527
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702528
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702529
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702530
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702531
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702532
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702533
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702534
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702535
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702536
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702537
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702538
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702539
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702540
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702541
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702542
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702543
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702544
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702545
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702546
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702547
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702548
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702549
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702550
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702551
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702552
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702553
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702554
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702555
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702556
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702557
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702558
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702559
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702560
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702561
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702562
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702563
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702564
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702565
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702566
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702567
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702568
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702569
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702570
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702571
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702572
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702573
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702574
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702575
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702576
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702577
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702578
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702579
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702580
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702581
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702582
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702583
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702584
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702585
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702586
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702587
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702588
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702589
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702590
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702591
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702592
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702593
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702594
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702595
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702596
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702597
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702598
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702599
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702600
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702601
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702602
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702603
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702604
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702605
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702606
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702607
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702608
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702609
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702610
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702611
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702612
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702613
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702614
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702615
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702616
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702617
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702618
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702619
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702620
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702621
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702622
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702623
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702624
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702625
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702626
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702627
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702628
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702629
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702630
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702631
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702632
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702633
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702634
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702635
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702636
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702637
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702638
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702639
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702640
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702641
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702642
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702643
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702644
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702645
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702646
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702647
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702648
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702649
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702650
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702651
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702652
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702653
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702654
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702655
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702656
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702657
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702658
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702659
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702660
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702661
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702662
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702663
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702664
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702665
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702666
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702667
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702668
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702669
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702670
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702671
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702672
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702673
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702674
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702675
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702676
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702677
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702678
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207968702679
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091072
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091073
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091074
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091075
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091076
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091077
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091078
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091079
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091080
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091081
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091082
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091083
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091084
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091085
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091086
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091087
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091088
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091089
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091090
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091091
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091092
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091093
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091094
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091095
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091096
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091097
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091098
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091099
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091100
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091101
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091102
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091103
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091104
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091105
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091106
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091107
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091108
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091109
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091110
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091111
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091112
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091113
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091114
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091115
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091116
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091117
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091118
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091119
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091120
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091121
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091122
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091123
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091124
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091125
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091126
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091127
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091128
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091129
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091130
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091131
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091132
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091133
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091134
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091135
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091136
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091137
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091138
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091139
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091140
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091141
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091142
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091143
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091144
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091145
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091146
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091147
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091148
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091149
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091150
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091151
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091152
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091153
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091154
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091155
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091156
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091157
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091158
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091159
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091160
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091161
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091162
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091163
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091164
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091165
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091166
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091167
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091168
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091169
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091170
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091171
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091172
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091173
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091174
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091175
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091176
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091177
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091178
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091179
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091180
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091181
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091182
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091183
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091184
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091185
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091186
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091187
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091188
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091189
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091190
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091191
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091192
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091193
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091194
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091195
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091196
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091197
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091198
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091199
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091200
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091201
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091202
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091203
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091204
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091205
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091206
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091207
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091208
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091209
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091210
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091211
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091212
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091213
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091214
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091215
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091216
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091217
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091218
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091219
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091220
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091221
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091222
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091223
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091224
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091225
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091226
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091227
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091228
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091229
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091230
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091231
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091232
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091233
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091234
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091235
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091236
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091237
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091238
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091239
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091240
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091241
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091242
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091243
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091244
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091245
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091246
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091247
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091248
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091249
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091250
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091251
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091252
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091253
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091254
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091255
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091256
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091257
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091258
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091259
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091260
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091261
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091262
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091263
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091264
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091265
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091266
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091267
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091268
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091269
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091270
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091271
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091272
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091273
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091274
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091275
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091276
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091277
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091278
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091279
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091280
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091281
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091282
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091283
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091284
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091285
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091286
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091287
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091288
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091289
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091290
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091291
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091292
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091293
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091294
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091295
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091296
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091297
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091298
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091299
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091300
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091301
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091302
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091303
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091304
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091305
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091306
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091307
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091308
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091309
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091310
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091311
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091312
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091313
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091314
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091315
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091316
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091317
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091318
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091319
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091320
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091321
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091322
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091323
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091324
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091325
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091326
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091327
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091328
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091329
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091330
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091331
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091332
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091333
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091334
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091335
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091336
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091337
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091338
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091339
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091340
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091341
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091342
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091343
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091344
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091345
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091346
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091347
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091348
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091349
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091350
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091351
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091352
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091353
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091354
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091355
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091356
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091357
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091358
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091359
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091360
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091361
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091362
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091363
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091364
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091365
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091366
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091367
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091368
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091369
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091370
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091371
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091372
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091373
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091374
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091375
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091376
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091377
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091378
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091379
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091380
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091381
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091382
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091383
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091384
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091385
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091386
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091387
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091388
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091389
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091390
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091391
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091392
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091393
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091394
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091395
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091396
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091397
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091398
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091399
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091400
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091401
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091402
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091403
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091404
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091405
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091406
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091407
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091408
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091409
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091410
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091411
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091412
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091413
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091414
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091415
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091416
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091417
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091418
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091419
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091420
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091421
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091422
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091423
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091424
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091425
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091426
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091427
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091428
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091429
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091430
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091431
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091432
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091433
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091434
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091435
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091436
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091437
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091438
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091439
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091440
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091441
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091442
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091443
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091444
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091445
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091446
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091447
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091448
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091449
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091450
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091451
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091452
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091453
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091454
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091455
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091456
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091457
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091458
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091459
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091460
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091461
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091462
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091463
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091464
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091465
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091466
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091467
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091468
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091469
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091470
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091471
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091472
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091473
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091474
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091475
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091476
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091477
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091478
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091479
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091480
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091481
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091482
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091483
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091484
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091485
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091486
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091487
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091488
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091489
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091490
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091491
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091492
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091493
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091494
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091495
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091496
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091497
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091498
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091499
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091500
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091501
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091502
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091503
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091504
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091505
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091506
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091507
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091508
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091509
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091510
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091511
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091512
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091513
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091514
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091515
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091516
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091517
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091518
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091519
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091520
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091521
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091522
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091523
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091524
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091525
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091526
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091527
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091528
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091529
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091530
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091531
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091532
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091533
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091534
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091535
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091536
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091537
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091538
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091539
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091540
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091541
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091542
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091543
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091544
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091545
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091546
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091547
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091548
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091549
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091550
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091551
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091552
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091553
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091554
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091555
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091556
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091557
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091558
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091559
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091560
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091561
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091562
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091563
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091564
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091565
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091566
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091567
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091568
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091569
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091570
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091571
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091572
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091573
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091574
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091575
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091576
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091577
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091578
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091579
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091580
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091581
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091582
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091583
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091584
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091585
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091586
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091587
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091588
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091589
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091590
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091591
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091592
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091593
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091594
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091595
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091596
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091597
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091598
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091599
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091600
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091601
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091602
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091603
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091604
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091605
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091606
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091607
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091608
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091609
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091610
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091611
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091612
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091613
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091614
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091615
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091616
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091617
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091618
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091619
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091620
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091621
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091622
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091623
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091624
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091625
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091626
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091627
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091628
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091629
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091630
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091631
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091632
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091633
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091634
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091635
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091636
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091637
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091638
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091639
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091640
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091641
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091642
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091643
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091644
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091645
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091646
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091647
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091648
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091649
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091650
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091651
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091652
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091653
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091654
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091655
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091656
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091657
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091658
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091659
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091660
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091661
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091662
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091663
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091664
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091665
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091666
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091667
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091668
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091669
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091670
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091671
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091672
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091673
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091674
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091675
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091676
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091677
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091678
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091679
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091680
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091681
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091682
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091683
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091684
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091685
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091686
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091687
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091688
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091689
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091690
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091691
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091692
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091693
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091694
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091695
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091696
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091697
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091698
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091699
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091700
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091701
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091702
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091703
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091704
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091705
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091706
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091707
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091708
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091709
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091710
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091711
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091712
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091713
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091714
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091715
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091716
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091717
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091718
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091719
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091720
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091721
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091722
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091723
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091724
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091725
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091726
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091727
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091728
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091729
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091730
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091731
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091732
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091733
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091734
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091735
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091736
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091737
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091738
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091739
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091740
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091741
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091742
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091743
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091744
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091745
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091746
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091747
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091748
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091749
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091750
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091751
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091752
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091753
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091754
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091755
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091756
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091757
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091758
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091759
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091760
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091761
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091762
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091763
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091764
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091765
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091766
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091767
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091768
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091769
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091770
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091771
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091772
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091773
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091774
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091775
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091776
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091777
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091778
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091779
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091780
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091781
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091782
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091783
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091784
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091785
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091786
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091787
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091788
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091789
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091790
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091791
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091792
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091793
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091794
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091795
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091796
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2452207977091797
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186880
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186881
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186882
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186883
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186884
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186885
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186886
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186887
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186888
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186889
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186890
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186891
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186892
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186893
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186894
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186895
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186896
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186897
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186898
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186899
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186900
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186901
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186902
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186903
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186904
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186905
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186906
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186907
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186908
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186909
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186910
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186911
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186912
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186913
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186914
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186915
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186916
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186917
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186918
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186919
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186920
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186921
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186922
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186923
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186924
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186925
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186926
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186927
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186928
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186929
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186930
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186931
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186932
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186933
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186934
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186935
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186936
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186937
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186938
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186939
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186940
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186941
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186942
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186943
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186944
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186945
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186946
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186947
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186948
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186949
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186950
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186951
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186952
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186953
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186954
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186955
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186956
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186957
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186958
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186959
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186960
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186961
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186962
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186963
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186964
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186965
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186966
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186967
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186968
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186969
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186970
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186971
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186972
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186973
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186974
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186975
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186976
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186977
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186978
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186979
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186980
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186981
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186982
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186983
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186984
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186985
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186986
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186987
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186988
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186989
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186990
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186991
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186992
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186993
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186994
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186995
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186996
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186997
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186998
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680186999
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187000
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187001
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187002
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187003
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187004
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187005
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187006
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187007
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187008
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187009
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187010
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187011
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187012
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187013
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187014
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187015
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187016
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187017
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187018
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187019
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187020
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187021
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187022
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187023
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187024
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187025
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187026
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187027
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187028
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187029
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187030
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187031
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187032
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187033
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187034
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187035
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187036
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187037
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187038
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187039
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187040
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187041
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187042
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187043
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187044
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187045
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187046
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187047
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187048
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187049
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187050
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187051
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187052
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187053
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187054
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187055
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187056
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187057
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187058
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187059
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187060
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187061
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187062
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187063
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187064
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187065
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187066
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187067
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187068
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187069
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187070
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187071
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187072
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187073
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187074
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187075
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187076
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187077
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187078
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187079
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187080
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187081
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187082
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187083
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187084
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187085
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187086
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187087
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187088
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187089
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187090
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187091
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187092
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187093
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187094
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187095
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187096
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187097
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187098
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187099
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187100
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187101
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187102
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187103
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187104
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187105
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187106
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187107
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187108
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187109
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187110
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187111
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187112
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187113
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187114
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187115
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187116
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187117
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187118
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187119
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187120
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187121
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187122
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187123
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187124
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187125
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187126
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187127
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187128
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187129
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187130
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187131
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187132
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187133
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187134
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187135
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187136
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187137
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187138
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187139
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187140
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187141
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187142
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187143
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187144
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187145
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187146
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187147
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187148
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187149
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187150
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187151
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187152
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187153
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187154
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187155
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187156
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187157
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187158
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187159
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187160
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187161
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187162
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187163
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187164
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187165
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187166
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187167
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187168
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187169
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187170
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187171
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187172
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187173
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187174
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187175
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187176
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187177
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187178
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187179
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187180
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187181
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187182
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187183
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187184
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187185
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187186
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187187
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187188
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187189
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187190
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187191
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187192
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187193
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187194
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187195
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187196
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187197
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187198
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187199
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187200
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187201
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187202
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187203
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187204
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187205
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187206
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187207
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187208
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187209
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187210
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187211
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187212
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187213
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187214
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187215
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187216
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187217
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187218
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187219
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187220
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187221
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187222
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187223
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187224
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187225
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187226
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187227
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187228
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187229
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187230
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187231
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187232
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187233
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187234
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187235
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187236
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187237
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187238
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187239
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187240
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187241
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187242
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187243
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187244
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187245
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187246
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187247
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187248
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187249
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187250
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187251
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187252
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187253
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187254
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187255
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187256
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187257
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187258
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187259
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187260
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187261
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187262
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187263
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187264
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187265
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187266
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187267
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187268
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187269
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187270
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187271
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187272
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187273
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187274
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187275
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187276
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187277
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187278
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187279
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187280
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187281
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187282
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187283
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187284
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187285
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187286
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187287
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187288
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187289
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187290
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187291
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187292
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187293
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187294
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187295
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187296
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187297
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187298
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187299
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187300
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187301
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187302
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187303
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187304
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187305
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187306
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187307
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187308
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187309
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187310
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187311
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187312
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187313
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187314
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187315
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187316
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187317
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187318
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187319
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187320
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187321
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187322
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187323
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187324
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187325
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187326
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187327
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187328
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187329
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187330
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187331
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187332
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187333
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187334
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187335
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187336
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187337
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187338
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187339
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187340
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187341
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187342
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187343
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187344
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187345
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187346
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187347
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187348
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187349
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187350
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187351
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187352
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187353
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187354
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187355
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187356
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187357
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187358
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187359
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187360
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187361
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187362
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187363
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187364
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187365
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187366
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187367
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187368
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187369
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187370
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187371
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187372
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187373
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187374
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187375
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187376
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187377
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187378
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187379
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187380
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187381
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187382
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187383
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187384
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187385
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187386
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187387
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187388
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187389
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187390
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187391
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187392
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187393
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187394
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187395
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187396
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187397
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187398
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187399
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187400
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187401
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187402
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187403
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187404
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187405
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187406
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187407
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187408
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187409
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187410
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187411
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187412
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187413
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187414
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187415
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187416
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187417
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187418
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187419
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187420
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187421
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187422
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187423
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187424
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187425
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187426
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187427
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187428
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187429
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187430
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187431
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187432
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187433
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187434
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187435
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187436
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187437
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187438
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187439
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187440
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187441
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187442
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187443
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187444
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187445
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187446
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187447
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187448
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187449
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187450
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187451
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187452
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187453
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187454
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187455
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187456
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187457
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187458
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187459
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187460
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187461
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187462
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187463
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187464
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187465
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187466
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187467
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187468
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187469
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187470
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187471
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187472
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187473
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187474
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187475
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187476
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187477
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187478
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187479
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187480
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187481
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187482
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187483
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187484
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187485
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187486
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187487
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187488
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187489
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187490
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187491
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187492
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187493
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187494
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187495
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187496
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187497
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187498
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187499
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187500
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187501
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187502
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187503
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187504
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187505
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187506
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187507
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187508
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187509
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187510
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187511
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187512
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187513
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187514
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187515
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187516
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187517
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187518
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187519
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187520
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187521
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187522
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187523
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187524
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187525
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187526
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187527
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187528
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187529
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187530
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187531
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187532
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187533
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187534
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187535
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187536
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187537
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187538
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187539
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187540
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187541
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187542
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187543
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187544
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187545
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187546
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187547
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187548
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187549
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187550
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187551
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187552
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187553
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187554
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187555
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187556
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187557
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187558
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187559
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187560
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187561
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187562
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187563
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187564
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187565
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187566
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187567
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187568
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187569
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187570
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187571
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187572
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187573
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187574
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187575
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187576
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187577
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187578
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187579
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187580
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187581
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187582
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187583
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187584
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187585
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187586
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187587
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187588
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187589
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187590
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187591
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187592
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187593
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187594
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187595
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187596
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187597
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187598
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187599
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187600
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187601
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187602
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187603
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187604
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187605
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187606
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187607
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187608
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187609
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187610
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187611
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187612
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187613
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187614
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187615
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187616
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187617
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187618
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187619
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187620
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187621
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187622
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187623
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187624
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187625
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187626
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187627
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187628
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187629
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187630
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187631
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187632
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187633
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187634
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187635
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187636
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187637
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187638
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187639
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187640
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187641
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187642
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187643
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187644
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187645
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187646
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187647
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187648
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187649
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187650
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187651
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187652
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187653
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187654
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187655
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187656
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187657
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187658
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187659
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187660
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187661
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187662
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187663
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187664
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187665
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187666
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187667
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187668
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187669
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187670
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187671
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187672
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187673
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187674
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187675
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187676
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187677
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187678
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187679
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187680
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187681
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187682
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187683
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187684
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187685
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187686
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187687
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187688
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187689
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187690
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187691
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187692
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187693
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187694
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187695
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187696
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187697
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187698
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187699
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187700
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187701
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187702
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187703
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187704
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187705
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187706
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187707
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187708
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187709
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187710
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187711
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187712
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187713
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187714
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187715
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187716
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187717
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187718
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187719
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187720
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187721
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187722
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187723
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187724
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187725
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187726
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187727
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187728
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187729
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187730
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187731
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187732
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187733
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187734
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187735
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187736
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187737
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187738
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187739
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187740
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187741
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187742
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187743
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187744
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187745
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187746
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187747
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187748
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187749
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187750
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187751
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187752
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187753
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187754
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187755
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187756
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187757
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187758
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187759
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187760
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187761
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187762
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187763
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187764
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187765
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187766
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187767
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187768
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187769
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187770
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187771
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187772
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187773
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187774
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187775
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187776
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187777
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187778
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187779
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187780
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187781
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187782
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187783
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187784
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187785
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187786
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187787
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187788
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187789
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187790
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187791
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187792
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187793
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187794
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187795
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187796
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187797
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187798
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187799
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187800
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187801
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187802
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187803
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187804
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187805
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187806
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187807
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187808
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187809
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187810
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187811
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187812
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187813
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187814
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187815
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187816
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187817
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187818
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187819
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187820
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187821
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2525966680187822
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801279885312
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662528
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662529
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662530
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662531
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662532
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662533
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662534
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662535
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662536
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662537
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662538
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662539
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662540
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662541
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662542
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662543
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662544
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662545
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662546
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662547
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662548
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662549
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662550
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662551
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662552
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662553
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662554
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662555
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662556
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662557
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662558
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662559
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662560
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662561
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662562
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662563
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662564
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662565
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662566
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662567
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662568
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662569
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662570
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662571
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662572
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662573
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662574
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662575
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662576
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662577
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662578
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662579
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662580
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662581
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662582
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662583
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662584
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662585
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662586
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662587
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662588
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662589
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662590
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662591
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662592
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662593
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662594
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662595
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662596
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662597
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662598
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662599
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662600
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662601
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662602
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662603
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662604
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662605
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662606
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662607
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662608
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662609
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662610
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662611
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662612
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662613
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662614
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662615
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662616
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662617
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662618
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662619
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662620
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662621
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662622
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662623
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662624
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662625
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662626
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662627
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662628
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662629
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662630
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662631
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662632
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662633
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662634
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662635
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662636
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662637
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662638
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662639
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662640
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662641
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662642
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662643
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662644
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662645
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662646
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662647
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662648
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662649
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662650
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662651
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662652
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662653
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662654
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662655
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662656
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662657
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662658
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662659
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662660
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662661
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662662
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662663
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662664
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662665
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662666
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662667
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662668
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662669
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662670
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662671
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662672
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662673
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662674
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662675
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662676
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662677
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662678
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662679
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662680
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662681
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662682
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662683
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662684
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662685
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662686
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662687
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662688
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662689
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662690
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662691
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662692
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662693
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662694
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662695
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662696
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662697
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662698
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662699
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662700
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662701
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662702
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662703
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662704
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662705
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662706
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662707
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662708
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662709
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662710
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662711
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662712
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662713
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662714
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662715
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662716
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662717
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662718
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662719
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662720
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662721
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662722
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662723
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662724
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662725
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662726
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662727
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662728
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662729
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662730
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662731
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662732
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662733
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662734
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662735
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662736
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662737
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662738
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662739
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662740
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662741
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662742
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662743
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662744
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662745
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662746
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662747
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662748
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662749
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662750
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662751
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662752
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662753
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662754
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662755
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662756
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662757
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662758
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662759
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662760
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662761
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662762
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662763
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662764
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662765
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662766
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662767
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662768
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662769
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662770
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662771
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662772
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662773
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662774
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662775
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662776
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662777
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662778
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662779
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662780
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662781
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662782
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662783
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662784
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662785
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662786
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662787
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662788
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662789
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662790
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662791
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662792
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662793
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662794
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662795
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662796
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662797
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662798
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662799
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662800
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662801
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662802
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662803
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662804
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662805
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662806
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662807
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662808
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662809
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662810
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662811
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662812
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662813
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662814
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662815
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662816
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662817
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662818
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662819
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662820
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662821
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662822
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662823
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662824
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662825
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662826
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662827
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662828
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662829
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662830
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662831
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662832
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662833
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662834
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662835
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662836
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662837
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662838
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662839
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662840
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662841
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662842
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662843
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662844
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662845
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662846
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662847
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662848
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662849
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662850
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662851
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662852
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662853
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662854
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662855
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662856
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662857
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662858
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662859
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662860
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662861
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662862
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662863
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662864
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662865
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662866
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662867
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662868
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662869
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662870
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662871
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662872
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662873
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662874
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662875
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662876
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662877
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662878
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662879
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662880
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662881
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662882
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662883
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662884
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662885
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662886
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662887
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662888
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662889
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662890
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662891
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662892
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662893
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662894
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662895
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662896
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662897
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662898
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662899
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662900
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662901
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662902
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662903
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662904
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662905
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662906
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662907
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662908
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662909
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662910
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662911
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662912
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662913
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662914
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662915
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662916
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662917
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662918
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662919
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662920
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662921
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662922
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662923
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662924
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662925
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662926
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662927
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662928
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662929
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662930
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662931
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662932
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662933
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662934
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662935
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662936
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662937
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662938
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662939
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662940
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662941
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662942
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662943
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662944
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662945
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662946
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662947
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662948
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662949
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662950
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662951
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662952
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662953
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662954
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662955
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662956
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662957
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662958
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662959
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662960
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662961
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662962
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662963
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662964
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662965
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662966
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662967
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662968
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662969
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662970
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662971
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662972
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662973
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662974
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662975
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662976
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662977
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662978
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662979
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662980
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662981
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662982
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662983
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662984
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662985
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662986
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662987
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662988
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662989
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662990
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662991
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662992
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662993
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662994
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662995
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662996
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662997
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662998
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296662999
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663000
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663001
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663002
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663003
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663004
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663005
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663006
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663007
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663008
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663009
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663010
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663011
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663012
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663013
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663014
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663015
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663016
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663017
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663018
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663019
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663020
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663021
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663022
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663023
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663024
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663025
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663026
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663027
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663028
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663029
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663030
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663031
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663032
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663033
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663034
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663035
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663036
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663037
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663038
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663039
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663040
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663041
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663042
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663043
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663044
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663045
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663046
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663047
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663048
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663049
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663050
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663051
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663052
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663053
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663054
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663055
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663056
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663057
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663058
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663059
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663060
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663061
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663062
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663063
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663064
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663065
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663066
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663067
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663068
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663069
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663070
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663071
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663072
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663073
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663074
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663075
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663076
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663077
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663078
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663079
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663080
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663081
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663082
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663083
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663084
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663085
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663086
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663087
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663088
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663089
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663090
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663091
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663092
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663093
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663094
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663095
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663096
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663097
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663098
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663099
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663100
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663101
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663102
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663103
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663104
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663105
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663106
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663107
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663108
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663109
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663110
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663111
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663112
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663113
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663114
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663115
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663116
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663117
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663118
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663119
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663120
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663121
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663122
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663123
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663124
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663125
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663126
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663127
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663128
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663129
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663130
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663131
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663132
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663133
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663134
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663135
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663136
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663137
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663138
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663139
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663140
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663141
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663142
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663143
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663144
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663145
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663146
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663147
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663148
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663149
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663150
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663151
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663152
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663153
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663154
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663155
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663156
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663157
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663158
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663159
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663160
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663161
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663162
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663163
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663164
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663165
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663166
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663167
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663168
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663169
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663170
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663171
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663172
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663173
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663174
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663175
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663176
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663177
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663178
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663179
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663180
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663181
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663182
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663183
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663184
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663185
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663186
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663187
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663188
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663189
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663190
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663191
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663192
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663193
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663194
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663195
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663196
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663197
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663198
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663199
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663200
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663201
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663202
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663203
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663204
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663205
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663206
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663207
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663208
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663209
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663210
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663211
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663212
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663213
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663214
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663215
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663216
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663217
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663218
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663219
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663220
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663221
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663222
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663223
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663224
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663225
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663226
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663227
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663228
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663229
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663230
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663231
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663232
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663233
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663234
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663235
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663236
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663237
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663238
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663239
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663240
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663241
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663242
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663243
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663244
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663245
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663246
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663247
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663248
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663249
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663250
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663251
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663252
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663253
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663254
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663255
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663256
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663257
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663258
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663259
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663260
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663261
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663262
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663263
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663264
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663265
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663266
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663267
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663268
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663269
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663270
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663271
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663272
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663273
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663274
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663275
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663276
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663277
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663278
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663279
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663280
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663281
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663282
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663283
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663284
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663285
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663286
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663287
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663288
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663289
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663290
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663291
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663292
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663293
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663294
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663295
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663296
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663297
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663298
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663299
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663300
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663301
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663302
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663303
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663304
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663305
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663306
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663307
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663308
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663309
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663310
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663311
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663312
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663313
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663314
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663315
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663316
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663317
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663318
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663319
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663320
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663321
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663322
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663323
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663324
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663325
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663326
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663327
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663328
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663329
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663330
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663331
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663332
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663333
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663334
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663335
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663336
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663337
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663338
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663339
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801296663340
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245440
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245441
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245442
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245443
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245444
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245445
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245446
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245447
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245448
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245449
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245450
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245451
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245452
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245453
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245454
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245455
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245456
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245457
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245458
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245459
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245460
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245461
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245462
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245463
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245464
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245465
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245466
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245467
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245468
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245469
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245470
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245471
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245472
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245473
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245474
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245475
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245476
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245477
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245478
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245479
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245480
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245481
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245482
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245483
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245484
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245485
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245486
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245487
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245488
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245489
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245490
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245491
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245492
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245493
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245494
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245495
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245496
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245497
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245498
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245499
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245500
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245501
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245502
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245503
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245504
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245505
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245506
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245507
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245508
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245509
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245510
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245511
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245512
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245513
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245514
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245515
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245516
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245517
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245518
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245519
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245520
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245521
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245522
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245523
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245524
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245525
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245526
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245527
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245528
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245529
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245530
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245531
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245532
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245533
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245534
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245535
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245536
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245537
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245538
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245539
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245540
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245541
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245542
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245543
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245544
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245545
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245546
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245547
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245548
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245549
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245550
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245551
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245552
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245553
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245554
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245555
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245556
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245557
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245558
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245559
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245560
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245561
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245562
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245563
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245564
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245565
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245566
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245567
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2529801309245568
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514048
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514049
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514050
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514051
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514052
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514053
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514054
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514055
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514056
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514057
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514058
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514059
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514060
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514061
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514062
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514063
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514064
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514065
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514066
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514067
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514068
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514069
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514070
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514071
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514072
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514073
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514074
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514075
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514076
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514077
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514078
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514079
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514080
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514081
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514082
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514083
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514084
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514085
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514086
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514087
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514088
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514089
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514090
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514091
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514092
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514093
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514094
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514095
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514096
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514097
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092960514098
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708352
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708353
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708354
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708355
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708356
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708357
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708358
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708359
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708360
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708361
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708362
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708363
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708364
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708365
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708366
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708367
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708368
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708369
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708370
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708371
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708372
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708373
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708374
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708375
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708376
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708377
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708378
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708379
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708380
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708381
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708382
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708383
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708384
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708385
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708386
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708387
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708388
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708389
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708390
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708391
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708392
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708393
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708394
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708395
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708396
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708397
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708398
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708399
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708400
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708401
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708402
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708403
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708404
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708405
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708406
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708407
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708408
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708409
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708410
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708411
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708412
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708413
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708414
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708415
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708416
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708417
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708418
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708419
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708420
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708421
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708422
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708423
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708424
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708425
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708426
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708427
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708428
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708429
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708430
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708431
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708432
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708433
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708434
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708435
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708436
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708437
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708438
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708439
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708440
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708441
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708442
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708443
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708444
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708445
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708446
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708447
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708448
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708449
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708450
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708451
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708452
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708453
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708454
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708455
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708456
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708457
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708458
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708459
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708460
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708461
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708462
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708463
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708464
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708465
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708466
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708467
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708468
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708469
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708470
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708471
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708472
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708473
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708474
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708475
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708476
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708477
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708478
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708479
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708480
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708481
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708482
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708483
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708484
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708485
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708486
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708487
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708488
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708489
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708490
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708491
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708492
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708493
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708494
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708495
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708496
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708497
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708498
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708499
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708500
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708501
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708502
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708503
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708504
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708505
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708506
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708507
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708508
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708509
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708510
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708511
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708512
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708513
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708514
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708515
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708516
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708517
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708518
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708519
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708520
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708521
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708522
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708523
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708524
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708525
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708526
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708527
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708528
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708529
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708530
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708531
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708532
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708533
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708534
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708535
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708536
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708537
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708538
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708539
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708540
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708541
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708542
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708543
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708544
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708545
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708546
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708547
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708548
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708549
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708550
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708551
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708552
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708553
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708554
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708555
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708556
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708557
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708558
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708559
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708560
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708561
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708562
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708563
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708564
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708565
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708566
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708567
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708568
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708569
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708570
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708571
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708572
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708573
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708574
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708575
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708576
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708577
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708578
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708579
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708580
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708581
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708582
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708583
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708584
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708585
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708586
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708587
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708588
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708589
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708590
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708591
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708592
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708593
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708594
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708595
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708596
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708597
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708598
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708599
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708600
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708601
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708602
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708603
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708604
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708605
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708606
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708607
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708608
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708609
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708610
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708611
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708612
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708613
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708614
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708615
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708616
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708617
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708618
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708619
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708620
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708621
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708622
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708623
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708624
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708625
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708626
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708627
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708628
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708629
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708630
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708631
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708632
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708633
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708634
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708635
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708636
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708637
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708638
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708639
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708640
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708641
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708642
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708643
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708644
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708645
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708646
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708647
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708648
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708649
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708650
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708651
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708652
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708653
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708654
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708655
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708656
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708657
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708658
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708659
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708660
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708661
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708662
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708663
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708664
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708665
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708666
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708667
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708668
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708669
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708670
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708671
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708672
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708673
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708674
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708675
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708676
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708677
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708678
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708679
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708680
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708681
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708682
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708683
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708684
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708685
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708686
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708687
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708688
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708689
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708690
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708691
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708692
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708693
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708694
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708695
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708696
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708697
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708698
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708699
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708700
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708701
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708702
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708703
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708704
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708705
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708706
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708707
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708708
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708709
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708710
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708711
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708712
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708713
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708714
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708715
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708716
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708717
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708718
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708719
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708720
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708721
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708722
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708723
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708724
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708725
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708726
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708727
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708728
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708729
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708730
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708731
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708732
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708733
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708734
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708735
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708736
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708737
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708738
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708739
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708740
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708741
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708742
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708743
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708744
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708745
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708746
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708747
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708748
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708749
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708750
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708751
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708752
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708753
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708754
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708755
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708756
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708757
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708758
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708759
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708760
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708761
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708762
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708763
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708764
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708765
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708766
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708767
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708768
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708769
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708770
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708771
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708772
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708773
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708774
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708775
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708776
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708777
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708778
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708779
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708780
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708781
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708782
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708783
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708784
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708785
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708786
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708787
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708788
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708789
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708790
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708791
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708792
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708793
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708794
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708795
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708796
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708797
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708798
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708799
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708800
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708801
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708802
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708803
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708804
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708805
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708806
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708807
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708808
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708809
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708810
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708811
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708812
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708813
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708814
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708815
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708816
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708817
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708818
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708819
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708820
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708821
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708822
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708823
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708824
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708825
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708826
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708827
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708828
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708829
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708830
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708831
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708832
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708833
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708834
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708835
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708836
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708837
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708838
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708839
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708840
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708841
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708842
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708843
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708844
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708845
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708846
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708847
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708848
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708849
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708850
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708851
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708852
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708853
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708854
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708855
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708856
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708857
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708858
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708859
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708860
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708861
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708862
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708863
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708864
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708865
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708866
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708867
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708868
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708869
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708870
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708871
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708872
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708873
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708874
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708875
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708876
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708877
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708878
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708879
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708880
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708881
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708882
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708883
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708884
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708885
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708886
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708887
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708888
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708889
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708890
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708891
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708892
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708893
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708894
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708895
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708896
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708897
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708898
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708899
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708900
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708901
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708902
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708903
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708904
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708905
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708906
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708907
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708908
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708909
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708910
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708911
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708912
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708913
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708914
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708915
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708916
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708917
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708918
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708919
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708920
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708921
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708922
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708923
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708924
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708925
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708926
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708927
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708928
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708929
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708930
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708931
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708932
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708933
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708934
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708935
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708936
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708937
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708938
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708939
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708940
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708941
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708942
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708943
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708944
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708945
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708946
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708947
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708948
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708949
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708950
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708951
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708952
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708953
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708954
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708955
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708956
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708957
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708958
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708959
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708960
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708961
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708962
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708963
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708964
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708965
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708966
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708967
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708968
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708969
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708970
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708971
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708972
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708973
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708974
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708975
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708976
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708977
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708978
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708979
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708980
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708981
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708982
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708983
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708984
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708985
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708986
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708987
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708988
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708989
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708990
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708991
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708992
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708993
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708994
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708995
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708996
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708997
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708998
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964708999
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709000
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709001
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709002
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709003
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709004
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709005
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709006
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709007
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709008
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709009
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709010
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709011
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709012
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709013
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709014
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709015
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709016
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709017
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709018
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709019
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709020
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709021
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709022
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709023
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709024
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709025
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709026
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709027
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709028
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709029
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709030
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709031
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709032
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709033
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709034
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709035
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709036
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709037
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709038
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709039
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709040
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709041
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709042
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709043
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709044
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709045
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709046
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709047
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709048
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709049
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709050
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709051
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709052
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709053
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709054
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709055
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709056
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709057
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709058
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709059
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709060
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709061
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709062
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709063
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709064
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709065
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709066
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709067
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709068
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709069
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709070
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709071
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709072
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709073
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709074
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709075
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709076
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709077
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709078
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709079
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709080
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709081
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709082
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709083
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709084
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709085
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709086
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709087
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709088
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709089
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709090
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709091
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709092
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709093
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709094
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709095
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709096
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709097
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709098
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709099
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709100
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709101
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709102
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709103
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709104
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709105
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709106
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709107
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709108
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709109
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709110
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709111
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709112
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709113
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709114
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709115
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709116
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709117
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709118
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709119
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709120
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709121
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709122
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709123
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709124
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709125
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709126
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709127
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709128
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709129
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709130
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709131
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709132
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709133
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709134
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709135
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709136
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709137
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709138
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709139
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709140
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709141
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709142
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709143
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709144
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709145
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709146
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709147
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709148
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709149
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709150
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709151
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709152
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709153
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709154
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709155
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709156
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709157
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709158
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709159
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709160
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709161
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709162
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709163
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709164
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709165
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709166
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709167
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709168
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709169
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709170
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709171
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709172
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709173
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709174
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709175
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709176
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709177
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709178
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709179
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709180
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709181
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709182
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709183
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709184
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709185
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709186
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709187
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709188
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709189
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709190
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709191
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709192
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709193
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709194
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709195
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709196
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709197
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709198
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709199
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709200
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709201
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709202
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709203
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709204
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709205
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709206
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709207
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709208
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709209
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709210
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709211
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709212
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709213
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709214
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709215
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709216
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709217
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709218
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709219
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709220
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709221
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709222
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709223
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709224
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709225
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709226
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709227
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709228
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709229
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709230
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709231
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709232
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709233
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709234
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709235
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709236
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709237
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709238
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709239
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709240
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709241
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709242
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2544092964709243
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714960822272
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988096
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988097
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988098
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988099
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988100
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988101
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988102
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988103
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988104
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988105
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988106
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988107
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988108
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988109
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988110
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988111
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988112
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988113
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988114
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988115
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988116
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988117
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988118
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988119
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988120
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988121
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988122
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988123
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988124
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988125
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988126
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988127
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988128
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988129
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988130
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988131
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988132
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988133
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988134
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988135
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988136
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988137
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988138
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988139
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988140
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988141
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988142
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988143
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988144
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988145
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988146
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988147
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988148
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988149
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988150
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988151
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988152
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988153
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988154
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988155
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988156
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988157
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988158
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988159
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988160
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988161
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988162
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988163
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988164
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988165
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988166
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988167
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988168
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988169
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988170
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988171
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988172
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988173
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988174
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988175
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988176
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988177
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988178
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988179
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988180
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988181
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988182
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988183
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988184
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988185
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988186
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988187
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988188
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988189
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988190
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988191
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988192
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988193
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988194
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988195
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988196
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988197
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988198
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988199
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988200
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988201
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988202
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988203
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988204
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988205
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988206
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988207
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988208
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988209
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988210
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988211
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988212
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988213
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988214
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988215
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988216
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988217
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988218
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988219
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988220
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988221
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988222
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988223
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988224
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988225
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988226
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988227
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988228
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988229
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988230
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988231
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988232
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988233
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988234
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988235
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988236
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988237
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988238
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988239
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988240
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988241
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988242
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988243
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988244
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988245
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988246
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988247
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988248
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988249
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988250
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988251
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988252
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988253
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988254
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988255
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988256
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988257
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988258
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988259
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988260
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988261
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988262
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988263
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988264
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988265
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988266
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988267
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988268
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988269
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988270
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988271
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988272
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988273
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988274
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988275
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988276
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988277
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988278
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988279
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988280
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988281
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988282
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988283
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988284
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988285
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988286
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988287
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988288
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988289
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988290
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988291
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988292
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988293
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988294
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988295
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988296
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988297
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988298
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988299
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988300
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988301
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988302
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988303
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988304
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988305
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988306
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988307
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988308
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988309
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988310
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988311
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988312
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988313
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988314
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988315
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988316
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988317
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988318
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988319
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988320
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988321
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988322
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988323
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988324
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988325
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988326
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988327
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988328
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988329
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988330
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988331
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988332
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988333
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988334
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988335
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988336
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988337
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988338
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988339
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988340
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988341
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988342
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988343
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988344
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988345
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988346
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988347
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988348
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988349
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988350
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988351
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988352
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988353
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988354
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988355
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988356
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988357
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988358
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988359
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988360
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988361
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988362
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988363
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988364
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988365
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988366
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988367
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988368
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988369
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988370
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988371
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988372
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988373
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988374
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988375
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988376
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988377
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988378
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988379
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988380
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988381
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988382
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988383
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988384
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988385
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988386
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988387
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988388
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988389
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988390
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988391
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988392
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988393
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988394
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988395
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988396
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988397
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988398
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988399
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988400
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988401
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988402
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988403
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988404
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988405
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988406
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988407
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988408
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988409
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988410
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988411
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988412
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988413
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988414
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988415
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988416
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988417
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988418
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988419
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988420
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988421
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988422
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988423
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988424
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988425
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988426
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988427
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988428
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988429
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988430
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988431
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988432
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988433
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988434
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988435
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988436
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988437
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988438
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988439
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988440
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988441
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988442
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988443
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988444
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988445
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988446
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988447
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988448
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988449
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988450
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988451
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988452
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988453
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988454
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988455
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988456
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988457
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988458
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988459
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988460
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988461
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988462
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988463
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988464
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988465
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988466
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988467
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988468
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988469
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988470
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988471
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988472
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988473
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988474
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988475
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988476
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988477
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988478
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988479
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988480
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988481
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988482
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988483
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988484
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988485
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988486
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988487
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988488
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988489
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988490
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988491
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988492
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988493
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988494
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988495
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988496
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988497
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988498
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988499
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988500
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988501
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988502
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988503
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988504
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988505
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988506
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988507
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988508
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988509
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988510
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988511
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988512
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988513
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988514
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988515
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988516
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988517
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988518
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988519
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988520
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988521
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988522
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988523
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988524
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988525
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988526
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988527
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988528
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988529
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988530
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988531
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988532
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988533
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988534
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988535
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988536
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988537
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988538
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988539
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988540
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988541
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988542
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988543
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988544
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988545
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988546
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988547
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988548
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988549
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988550
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988551
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988552
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988553
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988554
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988555
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988556
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988557
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988558
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988559
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988560
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988561
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988562
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988563
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988564
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988565
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988566
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988567
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988568
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988569
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988570
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988571
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988572
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988573
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988574
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988575
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988576
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988577
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988578
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988579
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988580
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988581
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988582
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988583
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988584
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988585
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988586
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988587
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988588
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988589
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988590
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988591
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988592
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988593
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988594
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988595
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988596
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988597
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988598
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988599
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988600
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988601
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988602
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988603
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988604
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988605
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988606
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988607
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988608
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988609
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988610
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988611
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988612
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988613
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988614
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988615
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988616
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988617
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988618
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988619
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988620
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988621
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988622
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988623
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988624
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988625
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988626
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988627
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988628
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988629
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988630
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988631
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988632
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988633
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988634
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988635
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988636
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988637
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988638
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988639
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988640
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988641
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988642
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988643
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988644
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988645
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988646
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988647
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988648
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988649
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988650
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988651
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988652
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988653
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988654
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988655
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988656
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988657
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988658
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988659
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988660
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988661
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988662
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988663
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988664
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988665
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988666
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988667
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988668
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988669
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988670
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988671
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988672
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988673
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988674
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988675
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988676
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988677
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988678
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988679
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988680
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988681
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988682
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988683
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988684
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988685
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988686
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988687
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988688
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988689
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988690
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988691
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988692
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988693
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988694
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988695
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988696
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988697
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988698
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988699
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988700
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988701
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988702
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988703
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988704
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988705
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988706
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988707
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988708
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988709
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988710
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988711
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988712
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988713
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988714
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988715
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988716
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988717
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988718
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988719
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988720
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988721
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988722
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988723
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988724
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988725
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988726
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988727
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988728
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988729
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988730
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988731
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988732
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988733
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988734
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988735
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988736
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988737
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988738
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988739
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988740
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988741
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988742
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988743
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988744
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988745
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988746
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988747
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988748
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988749
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988750
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988751
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988752
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988753
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988754
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988755
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988756
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988757
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988758
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988759
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988760
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988761
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988762
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988763
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988764
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988765
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988766
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988767
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988768
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988769
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988770
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988771
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988772
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988773
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988774
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988775
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988776
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988777
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988778
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988779
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988780
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988781
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988782
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988783
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988784
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988785
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988786
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988787
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988788
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988789
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988790
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988791
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988792
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988793
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988794
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988795
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988796
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988797
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988798
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988799
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988800
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988801
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988802
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988803
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988804
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988805
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988806
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988807
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988808
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988809
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988810
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988811
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988812
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988813
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988814
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988815
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988816
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988817
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988818
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988819
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988820
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988821
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988822
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988823
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988824
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988825
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988826
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988827
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988828
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988829
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988830
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988831
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988832
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988833
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988834
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988835
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988836
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988837
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988838
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988839
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988840
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988841
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988842
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988843
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988844
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988845
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988846
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988847
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988848
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988849
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988850
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988851
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988852
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988853
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988854
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988855
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988856
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988857
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988858
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988859
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988860
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988861
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988862
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988863
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988864
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988865
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988866
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988867
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988868
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988869
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988870
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988871
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988872
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988873
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988874
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988875
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988876
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988877
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988878
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988879
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988880
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988881
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988882
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988883
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988884
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988885
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988886
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988887
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988888
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988889
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988890
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988891
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988892
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988893
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988894
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988895
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988896
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988897
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988898
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988899
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988900
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988901
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988902
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988903
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988904
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988905
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988906
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988907
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988908
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988909
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988910
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988911
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988912
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988913
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988914
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988915
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988916
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988917
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988918
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988919
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988920
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988921
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988922
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988923
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988924
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988925
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988926
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988927
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988928
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988929
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988930
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988931
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988932
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988933
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988934
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988935
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988936
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988937
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988938
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988939
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988940
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988941
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988942
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988943
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988944
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988945
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988946
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988947
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988948
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988949
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988950
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988951
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988952
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988953
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988954
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988955
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988956
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988957
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988958
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988959
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988960
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988961
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988962
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988963
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988964
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988965
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988966
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988967
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988968
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988969
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988970
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988971
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988972
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988973
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988974
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988975
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988976
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988977
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988978
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988979
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988980
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988981
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988982
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988983
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988984
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988985
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988986
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988987
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988988
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988989
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988990
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988991
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988992
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988993
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988994
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988995
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988996
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988997
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988998
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985988999
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989000
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989001
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989002
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989003
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989004
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989005
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989006
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989007
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989008
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989009
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989010
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989011
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989012
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989013
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989014
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989015
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989016
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989017
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989018
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989019
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989020
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989021
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989022
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989023
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989024
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989025
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989026
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989027
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989028
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989029
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989030
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989031
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989032
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989033
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989034
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989035
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989036
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2600714985989037
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457132924928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702144
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702145
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702146
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702147
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702148
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702149
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702150
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702151
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702152
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702153
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702154
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702155
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702156
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702157
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702158
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702159
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702160
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702161
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702162
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702163
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702164
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702165
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702166
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702167
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702168
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702169
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702170
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702171
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702172
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702173
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702174
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702175
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702176
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702177
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702178
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702179
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702180
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702181
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702182
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702183
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702184
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702185
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702186
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702187
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702188
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702189
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702190
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702191
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702192
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702193
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702194
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702195
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702196
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702197
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702198
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702199
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702200
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702201
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702202
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702203
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702204
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702205
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702206
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702207
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702208
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702209
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702210
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702211
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702212
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702213
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702214
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702215
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702216
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702217
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702218
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702219
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702220
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702221
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702222
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702223
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702224
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702225
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702226
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702227
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702228
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702229
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702230
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702231
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702232
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702233
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702234
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702235
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702236
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702237
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702238
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702239
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702240
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702241
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702242
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702243
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702244
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702245
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702246
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702247
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702248
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702249
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702250
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702251
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702252
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702253
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702254
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702255
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702256
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702257
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702258
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702259
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702260
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702261
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702262
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702263
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702264
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702265
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702266
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702267
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702268
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702269
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702270
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702271
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702272
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702273
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702274
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702275
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702276
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702277
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702278
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457149702279
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896448
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896449
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896450
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896451
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896452
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896453
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896454
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896455
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896456
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896457
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896458
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896459
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896460
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896461
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896462
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896463
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896464
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896465
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896466
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896467
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896468
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896469
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896470
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896471
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896472
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896473
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896474
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896475
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896476
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896477
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896478
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896479
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896480
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896481
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896482
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896483
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896484
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896485
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896486
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896487
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896488
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896489
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896490
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896491
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896492
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896493
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896494
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896495
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896496
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896497
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896498
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896499
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896500
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896501
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896502
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896503
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896504
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896505
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896506
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896507
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896508
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896509
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896510
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896511
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896512
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896513
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896514
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896515
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896516
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896517
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896518
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896519
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896520
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896521
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896522
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896523
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896524
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896525
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896526
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896527
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896528
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896529
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896530
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896531
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896532
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896533
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896534
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896535
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896536
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896537
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896538
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896539
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896540
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896541
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896542
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896543
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896544
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896545
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896546
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896547
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896548
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896549
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896550
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896551
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896552
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896553
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896554
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896555
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896556
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896557
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896558
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896559
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896560
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896561
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896562
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896563
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896564
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896565
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896566
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896567
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896568
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896569
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896570
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896571
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896572
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896573
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896574
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896575
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896576
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896577
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896578
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896579
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896580
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896581
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896582
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896583
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896584
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896585
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896586
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896587
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896588
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896589
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896590
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896591
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896592
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896593
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896594
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896595
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896596
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896597
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896598
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896599
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896600
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896601
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896602
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896603
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896604
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896605
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896606
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896607
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896608
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896609
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896610
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896611
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896612
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896613
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896614
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896615
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896616
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896617
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896618
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896619
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896620
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896621
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896622
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896623
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896624
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896625
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896626
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896627
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896628
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896629
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896630
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896631
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896632
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896633
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896634
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896635
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896636
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896637
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896638
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896639
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896640
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896641
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896642
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896643
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896644
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896645
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896646
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896647
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896648
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896649
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896650
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896651
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896652
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896653
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896654
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896655
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896656
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896657
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896658
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896659
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896660
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896661
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896662
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896663
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896664
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896665
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896666
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896667
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896668
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896669
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896670
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896671
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896672
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896673
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896674
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896675
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896676
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896677
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896678
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896679
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896680
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896681
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896682
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896683
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896684
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896685
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896686
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896687
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896688
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896689
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896690
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896691
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896692
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896693
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896694
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896695
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896696
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896697
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896698
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896699
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896700
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896701
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896702
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896703
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896704
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896705
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896706
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896707
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896708
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896709
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896710
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896711
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896712
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896713
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896714
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896715
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896716
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896717
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896718
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896719
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896720
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896721
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896722
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896723
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896724
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896725
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896726
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896727
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896728
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896729
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896730
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896731
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896732
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896733
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896734
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896735
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896736
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896737
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896738
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896739
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896740
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896741
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896742
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896743
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896744
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896745
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896746
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896747
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896748
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896749
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896750
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896751
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896752
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896753
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896754
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896755
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896756
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896757
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896758
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896759
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896760
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896761
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896762
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896763
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896764
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896765
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896766
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896767
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896768
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896769
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896770
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896771
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896772
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896773
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896774
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896775
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896776
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896777
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896778
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896779
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896780
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896781
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896782
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896783
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896784
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896785
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896786
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896787
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896788
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896789
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896790
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896791
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896792
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896793
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896794
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896795
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896796
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896797
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896798
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896799
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896800
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896801
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896802
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896803
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896804
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896805
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896806
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896807
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896808
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896809
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896810
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896811
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896812
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896813
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896814
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896815
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896816
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896817
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896818
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896819
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896820
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896821
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896822
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896823
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896824
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896825
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896826
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896827
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896828
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896829
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896830
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896831
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896832
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896833
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896834
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896835
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896836
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896837
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896838
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896839
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896840
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896841
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896842
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896843
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896844
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896845
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896846
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896847
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896848
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896849
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896850
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896851
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896852
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896853
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896854
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896855
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896856
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896857
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896858
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896859
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896860
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896861
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896862
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896863
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896864
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896865
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896866
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896867
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896868
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896869
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896870
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896871
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896872
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896873
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896874
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896875
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896876
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896877
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896878
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896879
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896880
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896881
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896882
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896883
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896884
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896885
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896886
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896887
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896888
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896889
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896890
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896891
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896892
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896893
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896894
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896895
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896896
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896897
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896898
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896899
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896900
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896901
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896902
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896903
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896904
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896905
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896906
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896907
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896908
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896909
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896910
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896911
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896912
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896913
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896914
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896915
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896916
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896917
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896918
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896919
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896920
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896921
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896922
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896923
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896924
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896925
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896926
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896927
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896928
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896929
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896930
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896931
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896932
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896933
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896934
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896935
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896936
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896937
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896938
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896939
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896940
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896941
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896942
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896943
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896944
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896945
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896946
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896947
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896948
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896949
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896950
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896951
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896952
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896953
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896954
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896955
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896956
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896957
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896958
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896959
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896960
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896961
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896962
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896963
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896964
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896965
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896966
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896967
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896968
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896969
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896970
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896971
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896972
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896973
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896974
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896975
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896976
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896977
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896978
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896979
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896980
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896981
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896982
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896983
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896984
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896985
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896986
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896987
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896988
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896989
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896990
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896991
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896992
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896993
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896994
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896995
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896996
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896997
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896998
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153896999
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897000
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897001
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897002
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897003
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897004
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897005
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897006
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897007
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897008
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897009
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897010
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897011
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897012
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897013
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897014
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897015
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897016
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897017
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897018
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897019
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897020
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897021
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897022
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897023
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897024
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897025
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897026
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897027
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897028
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897029
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897030
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897031
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897032
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897033
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897034
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897035
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897036
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897037
    m_Localized: "\uC6B0\uC120 \uC800 [\uC544\uD2B8\uB808\uC2DC\uC544]\uB97C \uC120\uD0DD\uD574\uC11C
      \uC804\uC7A5\uC5D0 \uBC30\uCE58\uD574\uBCF4\uB3C4\uB85D \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897038
    m_Localized: "\uAC00\uC774\uB4DC: \uC544\uD2B8\uB808\uC2DC\uC544\uB294 \uAC15\uB825\uD55C
      \uBB3C\uB9AC \uACF5\uACA9\uB825\uC744 \uC9C0\uB2CC \uAE30\uC0AC\uB85C\uC11C
      \uB9CE\uC740 \uC218\uC758 \uC801\uB4E4\uC744 \uC0C1\uB300\uD558\uB294\uB370
      \uD2B9\uD654\uB41C \uAE30\uC220\uC744 \uAD6C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897039
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897040
    m_Localized: "\uC800\uB294 \uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694. \uC81C\uAC00
      \uC5BC\uB978 \uC815\uB9AC\uD560\uAC8C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897041
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897042
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897043
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC5B4\uC694.
      \uC804\uD22C \uC911 \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C
      \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74 \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897044
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897045
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897046
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897047
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897048
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897049
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897050
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897051
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897052
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897053
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897054
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897055
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uC2DC\uB108\uC9C0\uB97C \uC77C\uC73C\uCF1C
      \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897056
    m_Localized: "\uC0DD\uC131\uB41C \uBCC4\uB625\uBCC4\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897057
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!? \uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897058
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897059
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897060
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897061
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897062
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897063
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897064
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897065
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897066
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897067
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897068
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897069
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897070
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897071
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897072
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C \uB2A5\uB825\uC774\uB77C\uBA74 \uCDA9\uBD84\uD788
      \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uD14C\uB9AC\uC544\uC758
      \uC0AC\uC6A9 \uC2B9\uC778\uC744 \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897073
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897074
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC704\uCE58\uB97C \uC870\uC815\uD574 \uC801\uC744
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897075
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \uC18D\uC131\uB825 \uC2DC\uB108\uC9C0\uB97C
      \uBC1B\uC544 \uBAA8\uB4E0 \uAE30\uC0AC \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897076
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \n\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897077
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897078
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897079
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897080
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897081
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897082
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897083
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897084
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897085
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897086
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897087
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897088
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897089
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897090
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897091
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897092
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897093
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897094
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897095
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897096
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897097
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897098
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897099
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897100
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897101
    m_Localized: "\uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897102
    m_Localized: "\uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C
      \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897103
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897104
    m_Localized: "\uC6D0\uB798 \uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \uC774\uBC88\uC5D4 \uC774\uBC88\uC5D4 \uD2B9\uBCC4\uD788
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897105
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897106
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897107
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897108
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
      \uD604\uC7AC\uAE4C\uC9C0 \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758
      \uC0C1\uD0DC\uB97C \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897109
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897110
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897111
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897112
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897113
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897114
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897115
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897116
    m_Localized: "\uADF8\uB7FC \uAE30\uC0AC\uB4E4\uC758 \uC900\uBE44\uB3C4 \uC644\uB8CC
      \uB418\uC5C8\uACA0\uB2E4. \uD074\uB808\uC774\uC528\uAC00 \uB9C8\uC9C0\uB9C9
      \uBAA9\uC801\uC9C0\uB85C \uC124\uC815\uD55C '\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C
      \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897117
    m_Localized: "\uC751! \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC790!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897118
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!\n\uC2B9\uBB34\uC6D0
      \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49 \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897119
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897120
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897121
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897122
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897123
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897124
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897125
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897126
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897127
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897128
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897129
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897130
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897131
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897132
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897133
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897134
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897135
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897136
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897137
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897138
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897139
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897140
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897141
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897142
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897143
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897144
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897145
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB974\uACE0, \uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C
      \uD1B5\uD574 \uCD5C\uB300 \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744
      \uC62C\uB824\uC904 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897146
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897147
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897148
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897149
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897150
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897151
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uBB34\uC18D\uC131, \uBD88\uC18D\uC131,
      \uBC14\uB78C\uC18D\uC131, \uB300\uC9C0\uC18D\uC131, \uC804\uAE30\uC18D\uC131,\uBB3C\uC18D\uC131
      \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897152
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897153
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897154
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897155
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897156
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897157
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897158
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897159
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897160
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897161
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897162
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897163
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897164
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897165
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897166
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897167
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897168
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694! \uCD08\uC6D4\uC5D0
      \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00 \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0,
      Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897169
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897170
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897171
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897172
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897173
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897174
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897175
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897176
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897177
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694. \uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897178
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897179
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897180
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897181
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897182
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897183
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897184
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897185
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897186
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897187
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897188
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897189
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897190
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897191
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897192
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897193
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897194
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897195
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897196
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897197
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897198
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897199
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897200
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897201
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897202
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897203
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897204
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897205
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897206
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897207
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. '\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897208
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897209
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897210
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897211
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897212
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897213
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897214
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897215
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897216
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897217
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897218
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897219
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897220
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897221
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897222
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897223
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897224
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897225
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897226
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897227
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897228
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897229
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897230
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897231
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897232
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897233
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897234
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897235
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897236
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897237
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897238
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897239
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897240
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897241
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897242
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897243
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897244
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897245
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897246
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897247
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897248
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897249
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897250
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897251
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897252
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \uADFC\uC811\uD574
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uAC70\uB098, \uC801\uB4E4\uC5D0\uAC8C \uCDA9\uB3CC\uC744
      \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2792457153897253
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083176706048
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483264
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483265
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483266
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483267
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483268
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483269
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483270
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483271
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483272
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483273
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483274
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483275
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483276
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483277
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483278
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483279
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483280
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483281
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483282
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483283
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483284
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483285
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483286
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483287
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483288
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483289
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483290
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483291
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483292
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483293
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483294
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483295
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483296
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483297
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483298
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483299
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483300
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483301
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483302
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483303
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483304
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483305
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483306
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483307
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483308
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483309
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483310
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483311
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483312
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483313
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483314
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483315
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483316
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483317
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483318
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483319
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483320
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483321
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483322
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483323
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483324
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483325
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483326
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483327
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483328
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483329
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483330
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483331
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483332
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483333
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483334
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483335
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483336
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483337
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483338
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483339
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483340
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483341
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483342
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483343
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483344
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483345
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483346
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483347
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483348
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483349
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483350
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483351
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483352
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483353
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483354
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483355
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483356
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483357
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483358
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483359
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483360
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483361
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483362
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483363
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483364
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483365
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483366
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483367
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483368
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483369
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483370
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483371
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483372
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483373
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483374
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483375
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483376
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483377
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483378
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483379
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483380
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483381
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483382
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483383
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483384
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483385
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483386
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483387
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483388
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483389
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483390
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483391
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483392
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483393
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483394
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483395
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483396
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483397
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483398
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483399
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483400
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483401
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483402
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483403
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483404
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483405
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483406
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483407
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483408
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483409
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483410
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483411
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483412
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483413
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483414
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483415
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483416
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483417
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483418
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483419
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483420
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483421
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483422
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483423
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483424
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483425
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483426
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483427
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483428
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483429
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483430
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483431
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483432
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483433
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483434
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483435
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483436
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483437
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483438
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483439
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483440
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483441
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483442
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483443
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483444
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483445
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483446
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483447
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483448
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483449
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483450
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483451
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483452
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483453
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483454
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483455
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483456
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483457
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483458
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483459
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483460
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483461
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483462
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483463
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483464
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483465
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483466
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483467
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483468
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483469
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483470
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483471
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483472
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483473
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483474
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483475
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483476
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483477
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483478
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483479
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483480
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483481
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483482
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483483
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483484
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483485
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483486
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483487
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483488
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483489
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483490
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483491
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483492
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483493
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483494
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483495
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483496
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483497
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483498
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483499
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483500
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483501
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483502
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483503
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483504
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483505
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483506
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483507
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483508
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483509
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483510
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483511
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483512
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483513
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483514
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483515
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483516
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483517
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483518
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483519
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483520
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483521
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483522
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483523
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483524
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483525
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483526
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483527
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483528
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483529
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483530
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483531
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483532
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483533
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483534
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483535
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483536
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483537
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483538
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483539
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483540
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483541
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483542
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483543
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483544
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483545
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483546
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483547
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483548
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483549
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483550
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483551
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483552
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483553
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483554
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483555
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483556
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483557
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483558
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483559
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483560
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483561
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483562
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483563
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483564
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483565
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483566
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483567
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483568
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483569
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483570
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483571
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483572
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483573
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483574
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483575
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483576
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483577
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483578
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483579
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483580
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483581
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483582
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483583
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483584
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483585
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483586
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483587
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483588
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483589
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483590
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483591
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483592
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483593
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483594
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483595
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483596
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483597
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483598
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483599
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483600
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483601
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483602
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483603
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483604
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483605
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483606
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483607
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483608
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483609
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483610
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483611
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483612
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483613
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483614
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483615
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483616
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483617
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483618
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483619
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483620
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483621
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483622
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483623
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483624
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483625
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483626
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483627
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483628
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483629
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483630
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483631
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483632
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483633
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483634
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483635
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483636
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483637
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483638
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483639
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483640
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483641
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483642
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483643
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483644
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483645
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483646
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483647
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483648
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483649
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483650
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483651
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483652
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483653
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483654
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483655
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483656
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483657
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483658
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483659
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483660
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483661
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483662
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483663
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483664
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483665
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483666
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483667
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483668
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483669
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483670
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483671
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483672
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483673
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483674
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483675
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483676
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483677
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483678
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483679
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483680
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483681
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483682
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483683
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483684
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483685
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483686
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483687
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483688
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483689
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483690
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483691
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483692
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483693
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483694
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483695
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483696
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483697
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483698
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483699
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483700
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483701
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483702
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483703
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483704
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483705
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483706
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483707
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483708
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483709
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483710
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483711
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483712
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483713
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483714
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483715
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483716
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483717
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483718
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483719
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483720
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483721
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483722
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483723
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483724
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483725
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483726
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483727
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483728
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483729
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483730
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483731
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483732
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483733
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483734
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483735
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483736
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483737
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483738
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483739
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483740
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483741
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483742
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483743
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483744
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483745
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483746
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483747
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483748
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483749
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483750
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483751
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483752
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483753
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483754
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483755
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483756
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483757
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483758
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483759
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483760
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483761
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483762
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483763
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483764
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483765
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483766
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483767
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483768
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483769
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483770
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483771
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483772
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483773
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483774
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483775
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483776
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483777
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483778
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483779
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483780
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483781
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483782
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483783
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483784
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483785
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483786
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483787
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483788
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483789
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483790
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483791
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483792
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483793
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483794
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483795
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483796
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483797
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483798
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483799
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483800
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483801
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483802
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483803
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483804
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483805
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483806
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483807
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483808
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483809
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483810
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483811
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483812
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483813
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483814
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483815
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483816
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483817
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483818
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483819
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483820
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483821
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483822
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483823
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483824
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483825
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483826
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483827
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483828
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483829
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483830
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483831
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483832
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483833
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483834
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483835
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483836
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483837
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483838
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483839
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483840
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483841
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483842
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483843
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483844
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483845
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483846
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483847
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483848
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483849
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483850
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483851
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483852
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483853
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483854
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483855
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483856
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483857
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483858
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483859
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483860
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483861
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483862
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483863
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483864
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483865
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483866
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483867
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483868
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483869
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483870
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483871
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483872
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483873
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483874
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483875
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483876
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483877
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483878
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483879
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483880
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483881
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483882
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483883
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483884
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483885
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483886
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483887
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483888
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483889
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483890
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483891
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483892
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483893
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483894
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483895
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483896
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483897
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483898
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483899
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483900
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483901
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483902
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483903
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483904
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483905
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483906
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483907
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483908
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483909
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483910
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483911
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483912
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483913
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483914
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483915
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483916
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483917
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483918
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483919
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483920
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483921
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483922
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483923
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483924
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483925
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483926
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483927
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483928
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483929
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483930
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483931
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483932
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483933
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483934
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483935
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483936
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483937
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483938
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483939
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483940
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483941
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483942
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483943
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483944
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483945
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483946
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483947
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483948
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483949
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483950
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483951
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483952
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483953
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483954
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483955
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483956
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483957
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483958
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483959
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483960
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483961
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483962
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483963
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483964
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483965
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483966
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483967
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483968
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483969
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483970
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483971
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483972
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483973
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483974
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483975
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483976
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483977
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483978
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483979
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483980
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483981
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483982
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483983
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483984
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483985
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483986
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483987
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483988
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483989
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483990
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483991
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483992
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483993
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483994
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483995
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483996
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483997
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483998
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193483999
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083193484000
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677568
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677569
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677570
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677571
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677572
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677573
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677574
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677575
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677576
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677577
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677578
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677579
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677580
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677581
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677582
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677583
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677584
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677585
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677586
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677587
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677588
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677589
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677590
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677591
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677592
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677593
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677594
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677595
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677596
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677597
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677598
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677599
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677600
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677601
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677602
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677603
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677604
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677605
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677606
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677607
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677608
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677609
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677610
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677611
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677612
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677613
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677614
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677615
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677616
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677617
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677618
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677619
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677620
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677621
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677622
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677623
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677624
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677625
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677626
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677627
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677628
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677629
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677630
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677631
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677632
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677633
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677634
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677635
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677636
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677637
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677638
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677639
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677640
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677641
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677642
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677643
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677644
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677645
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677646
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677647
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677648
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677649
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677650
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677651
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677652
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677653
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677654
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677655
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677656
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677657
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677658
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677659
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677660
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677661
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677662
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677663
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677664
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677665
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677666
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677667
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677668
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677669
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677670
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677671
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677672
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677673
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677674
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677675
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677676
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677677
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677678
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677679
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677680
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677681
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677682
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677683
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677684
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677685
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677686
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677687
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677688
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677689
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677690
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677691
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677692
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677693
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677694
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677695
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677696
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677697
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677698
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677699
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677700
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677701
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677702
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677703
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677704
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677705
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677706
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677707
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677708
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677709
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677710
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677711
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677712
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677713
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677714
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677715
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677716
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677717
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677718
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677719
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677720
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677721
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677722
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677723
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677724
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677725
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677726
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677727
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677728
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677729
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677730
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677731
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677732
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677733
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677734
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677735
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677736
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677737
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677738
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677739
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677740
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677741
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677742
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677743
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677744
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677745
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677746
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677747
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677748
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677749
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677750
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677751
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677752
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677753
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677754
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677755
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677756
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677757
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677758
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677759
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677760
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677761
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677762
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677763
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677764
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677765
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677766
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677767
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677768
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677769
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677770
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677771
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677772
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677773
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677774
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677775
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677776
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677777
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677778
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2825083197677779
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007969857536
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023360
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023361
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023362
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023363
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023364
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023365
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023366
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023367
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023368
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023369
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023370
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023371
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023372
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023373
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023374
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023375
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023376
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023377
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023378
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023379
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023380
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023381
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023382
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023383
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023384
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023385
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023386
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023387
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023388
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023389
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023390
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023391
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023392
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023393
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023394
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023395
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023396
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023397
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023398
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023399
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023400
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023401
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023402
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023403
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023404
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023405
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023406
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023407
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023408
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023409
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023410
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023411
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023412
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023413
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023414
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023415
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023416
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023417
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023418
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023419
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023420
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023421
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023422
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023423
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023424
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023425
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023426
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023427
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023428
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023429
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023430
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023431
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023432
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023433
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023434
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023435
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023436
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023437
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023438
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023439
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023440
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023441
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023442
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023443
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023444
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023445
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023446
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023447
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023448
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023449
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023450
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023451
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023452
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023453
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023454
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023455
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023456
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023457
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023458
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023459
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023460
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023461
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023462
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023463
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023464
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023465
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023466
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023467
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023468
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023469
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023470
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023471
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023472
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023473
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023474
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023475
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023476
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023477
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023478
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023479
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007995023480
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217664
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217665
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217666
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217667
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217668
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217669
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217670
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217671
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217672
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217673
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217674
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217675
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217676
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217677
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217678
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217679
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217680
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217681
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217682
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217683
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217684
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217685
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217686
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217687
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217688
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217689
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217690
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217691
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217692
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217693
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217694
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217695
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217696
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217697
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217698
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217699
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217700
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217701
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217702
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217703
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217704
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217705
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217706
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217707
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217708
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217709
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217710
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217711
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217712
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217713
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217714
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217715
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217716
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217717
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217718
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217719
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217720
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217721
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217722
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217723
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217724
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217725
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217726
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217727
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217728
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217729
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217730
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217731
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217732
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217733
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217734
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217735
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217736
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217737
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217738
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217739
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217740
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217741
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217742
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217743
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217744
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217745
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217746
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217747
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217748
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217749
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217750
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217751
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217752
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217753
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217754
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217755
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217756
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217757
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217758
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217759
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217760
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217761
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217762
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217763
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217764
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217765
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217766
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217767
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217768
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217769
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217770
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217771
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217772
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217773
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217774
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217775
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217776
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217777
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217778
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217779
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217780
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217781
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217782
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217783
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217784
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217785
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217786
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217787
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217788
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217789
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217790
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217791
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217792
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217793
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217794
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217795
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217796
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217797
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217798
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217799
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217800
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217801
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217802
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217803
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217804
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217805
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217806
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217807
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217808
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217809
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217810
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217811
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217812
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217813
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217814
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217815
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217816
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217817
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217818
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217819
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217820
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217821
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217822
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217823
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217824
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217825
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217826
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217827
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217828
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217829
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217830
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217831
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217832
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217833
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217834
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217835
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217836
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217837
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217838
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217839
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217840
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217841
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217842
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217843
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217844
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217845
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217846
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217847
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217848
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217849
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217850
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217851
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217852
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217853
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217854
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217855
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217856
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217857
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217858
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217859
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217860
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217861
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217862
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217863
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217864
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217865
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217866
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217867
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217868
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217869
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217870
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217871
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217872
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217873
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217874
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217875
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217876
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217877
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217878
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217879
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217880
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217881
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217882
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217883
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217884
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217885
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217886
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217887
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217888
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217889
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217890
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217891
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217892
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217893
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217894
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217895
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217896
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217897
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217898
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217899
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217900
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217901
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217902
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217903
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217904
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217905
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217906
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217907
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217908
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217909
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217910
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217911
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217912
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217913
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217914
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217915
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217916
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217917
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217918
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217919
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217920
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217921
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217922
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217923
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217924
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217925
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217926
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217927
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217928
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217929
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217930
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217931
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217932
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217933
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217934
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217935
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217936
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217937
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217938
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217939
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217940
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217941
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217942
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217943
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217944
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217945
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217946
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217947
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217948
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217949
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217950
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217951
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217952
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217953
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217954
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217955
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217956
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217957
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217958
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217959
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217960
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217961
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217962
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217963
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217964
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217965
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217966
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217967
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217968
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217969
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217970
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217971
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217972
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217973
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217974
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217975
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217976
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217977
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217978
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217979
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217980
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217981
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217982
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217983
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217984
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217985
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217986
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217987
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217988
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217989
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217990
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217991
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217992
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217993
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217994
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217995
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217996
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217997
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217998
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999217999
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218000
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218001
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218002
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218003
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218004
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218005
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218006
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218007
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218008
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218009
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218010
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218011
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218012
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218013
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218014
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218015
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218016
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218017
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218018
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218019
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218020
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218021
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218022
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218023
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218024
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218025
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218026
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218027
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218028
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218029
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218030
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218031
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218032
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218033
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218034
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218035
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218036
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218037
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218038
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218039
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218040
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218041
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218042
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218043
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218044
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218045
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218046
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218047
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218048
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218049
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218050
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218051
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218052
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218053
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218054
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218055
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218056
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218057
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218058
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218059
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218060
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218061
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218062
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218063
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218064
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218065
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218066
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218067
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218068
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218069
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218070
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218071
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218072
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218073
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218074
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218075
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218076
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218077
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218078
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218079
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218080
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218081
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218082
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218083
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218084
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218085
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218086
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218087
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218088
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218089
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218090
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218091
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218092
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218093
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218094
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218095
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218096
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218097
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218098
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218099
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218100
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218101
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218102
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218103
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218104
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218105
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218106
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218107
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218108
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218109
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218110
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218111
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218112
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218113
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218114
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218115
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218116
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218117
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218118
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218119
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218120
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218121
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218122
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218123
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218124
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218125
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218126
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218127
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218128
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218129
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218130
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218131
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218132
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218133
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218134
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218135
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218136
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218137
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218138
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218139
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218140
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218141
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218142
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218143
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218144
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218145
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218146
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218147
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218148
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218149
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218150
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218151
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218152
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218153
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218154
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218155
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218156
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218157
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218158
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218159
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218160
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218161
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218162
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218163
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218164
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218165
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218166
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218167
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218168
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218169
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218170
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218171
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218172
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218173
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218174
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218175
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218176
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218177
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218178
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218179
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218180
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218181
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218182
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218183
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218184
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218185
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218186
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218187
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218188
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218189
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218190
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218191
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218192
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218193
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218194
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218195
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218196
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218197
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218198
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218199
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218200
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218201
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218202
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218203
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218204
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218205
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218206
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218207
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218208
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218209
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218210
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218211
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218212
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218213
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218214
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218215
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218216
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218217
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218218
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218219
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218220
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218221
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218222
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218223
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218224
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218225
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218226
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218227
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218228
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218229
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218230
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218231
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218232
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218233
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218234
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218235
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218236
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218237
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218238
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218239
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218240
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218241
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218242
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218243
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218244
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218245
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218246
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218247
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218248
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218249
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218250
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218251
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218252
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218253
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218254
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218255
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218256
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218257
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218258
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218259
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218260
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218261
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218262
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218263
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218264
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218265
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218266
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218267
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218268
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218269
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218270
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218271
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218272
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218273
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218274
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218275
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218276
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218277
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218278
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218279
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218280
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218281
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218282
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218283
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218284
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218285
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218286
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218287
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218288
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218289
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218290
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218291
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218292
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218293
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218294
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218295
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218296
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218297
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218298
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218299
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218300
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218301
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218302
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218303
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218304
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218305
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218306
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218307
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218308
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218309
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218310
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218311
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218312
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218313
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218314
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218315
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218316
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218317
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218318
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218319
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218320
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218321
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218322
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218323
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218324
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218325
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218326
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218327
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218328
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218329
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218330
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218331
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218332
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218333
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218334
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218335
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218336
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218337
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218338
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218339
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218340
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218341
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218342
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218343
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218344
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218345
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218346
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218347
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218348
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218349
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218350
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218351
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218352
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218353
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218354
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218355
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218356
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218357
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218358
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218359
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218360
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218361
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218362
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218363
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218364
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218365
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218366
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218367
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218368
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218369
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218370
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218371
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218372
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218373
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218374
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218375
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218376
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218377
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218378
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218379
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218380
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218381
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218382
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218383
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218384
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218385
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218386
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218387
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218388
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218389
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218390
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218391
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218392
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218393
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218394
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218395
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218396
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218397
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218398
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218399
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218400
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218401
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218402
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218403
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218404
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218405
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218406
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218407
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218408
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218409
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218410
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218411
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218412
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218413
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218414
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218415
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218416
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218417
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218418
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218419
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218420
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218421
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218422
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218423
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218424
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218425
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218426
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218427
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218428
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218429
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218430
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218431
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218432
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218433
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218434
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218435
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218436
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218437
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218438
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218439
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218440
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218441
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218442
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218443
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218444
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218445
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218446
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218447
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218448
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218449
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218450
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218451
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218452
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218453
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218454
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218455
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218456
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218457
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218458
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218459
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218460
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218461
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218462
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218463
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218464
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218465
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218466
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218467
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218468
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218469
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218470
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218471
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218472
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218473
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218474
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218475
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218476
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218477
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218478
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218479
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218480
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218481
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218482
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218483
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218484
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218485
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218486
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218487
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218488
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218489
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218490
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2888007999218491
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006891470848
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053760
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053761
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053762
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053763
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053764
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053765
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053766
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053767
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053768
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053769
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053770
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053771
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053772
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053773
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053774
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053775
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053776
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053777
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053778
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053779
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053780
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053781
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053782
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053783
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053784
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053785
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053786
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053787
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053788
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053789
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053790
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053791
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053792
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053793
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053794
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053795
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053796
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053797
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053798
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053799
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053800
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053801
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053802
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053803
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053804
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053805
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053806
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053807
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053808
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053809
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053810
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053811
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053812
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053813
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053814
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053815
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053816
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053817
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053818
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053819
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053820
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053821
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053822
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053823
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053824
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053825
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053826
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053827
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053828
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053829
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053830
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053831
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053832
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053833
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053834
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053835
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053836
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053837
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053838
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053839
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053840
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053841
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053842
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053843
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053844
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053845
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053846
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053847
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053848
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053849
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053850
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053851
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053852
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053853
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053854
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053855
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053856
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053857
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053858
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053859
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053860
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053861
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053862
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053863
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053864
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053865
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053866
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053867
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053868
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053869
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053870
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053871
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053872
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053873
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053874
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053875
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053876
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053877
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053878
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053879
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053880
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053881
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053882
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053883
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053884
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053885
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053886
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053887
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053888
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053889
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053890
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053891
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053892
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053893
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053894
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053895
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053896
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053897
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053898
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053899
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053900
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053901
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053902
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053903
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053904
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053905
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053906
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053907
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053908
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053909
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053910
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053911
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053912
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053913
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053914
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053915
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053916
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053917
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053918
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053919
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053920
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053921
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053922
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053923
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053924
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053925
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053926
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053927
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053928
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053929
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053930
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053931
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053932
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053933
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053934
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053935
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053936
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053937
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053938
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053939
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053940
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053941
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053942
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053943
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053944
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053945
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053946
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053947
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053948
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053949
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053950
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053951
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053952
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053953
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053954
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053955
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053956
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053957
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053958
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053959
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053960
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053961
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053962
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053963
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053964
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053965
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053966
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053967
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053968
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053969
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053970
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053971
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053972
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053973
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053974
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053975
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053976
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053977
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053978
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053979
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053980
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053981
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053982
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053983
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053984
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053985
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053986
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053987
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053988
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053989
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053990
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053991
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053992
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053993
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053994
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053995
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053996
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053997
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053998
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904053999
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054000
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054001
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054002
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054003
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054004
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054005
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054006
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054007
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054008
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054009
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054010
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054011
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054012
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054013
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054014
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054015
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054016
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054017
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054018
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054019
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054020
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054021
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054022
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054023
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054024
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054025
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054026
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054027
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054028
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054029
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054030
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054031
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054032
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054033
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054034
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054035
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054036
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054037
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054038
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054039
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054040
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054041
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054042
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054043
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054044
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054045
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054046
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054047
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054048
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054049
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054050
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054051
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054052
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054053
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054054
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054055
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054056
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054057
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054058
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054059
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054060
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054061
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054062
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054063
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054064
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054065
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054066
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054067
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054068
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054069
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054070
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054071
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054072
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054073
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054074
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054075
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054076
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054077
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054078
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054079
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054080
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054081
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054082
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054083
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054084
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054085
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054086
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054087
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054088
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054089
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054090
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054091
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054092
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054093
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054094
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054095
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054096
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054097
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054098
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054099
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054100
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054101
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054102
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054103
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054104
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054105
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054106
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054107
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054108
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054109
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054110
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054111
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054112
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054113
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054114
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054115
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054116
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054117
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054118
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054119
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054120
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054121
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054122
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054123
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054124
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054125
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054126
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054127
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054128
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054129
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054130
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054131
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054132
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054133
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054134
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054135
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054136
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054137
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054138
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054139
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054140
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054141
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054142
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054143
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054144
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054145
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054146
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054147
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054148
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054149
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054150
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054151
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054152
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054153
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054154
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054155
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054156
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054157
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054158
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054159
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054160
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054161
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054162
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054163
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054164
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054165
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054166
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054167
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054168
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054169
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054170
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054171
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054172
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054173
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054174
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054175
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054176
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054177
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054178
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054179
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054180
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054181
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054182
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054183
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054184
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054185
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054186
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054187
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054188
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054189
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054190
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054191
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054192
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054193
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054194
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054195
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054196
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054197
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054198
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054199
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054200
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054201
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054202
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054203
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054204
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054205
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054206
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054207
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054208
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054209
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054210
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054211
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054212
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054213
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054214
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054215
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054216
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054217
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054218
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054219
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054220
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054221
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054222
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054223
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054224
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054225
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054226
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054227
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054228
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054229
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054230
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054231
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054232
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054233
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054234
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054235
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054236
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054237
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054238
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054239
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054240
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054241
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054242
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054243
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054244
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054245
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054246
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054247
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054248
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054249
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054250
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054251
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054252
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054253
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054254
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054255
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054256
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054257
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054258
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054259
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054260
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054261
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054262
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054263
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054264
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054265
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054266
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054267
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054268
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054269
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054270
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054271
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054272
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054273
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054274
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054275
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054276
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054277
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054278
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054279
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054280
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054281
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054282
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054283
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054284
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054285
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054286
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054287
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054288
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054289
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054290
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054291
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054292
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054293
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054294
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054295
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054296
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054297
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054298
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054299
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054300
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054301
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054302
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054303
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054304
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054305
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054306
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054307
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054308
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054309
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054310
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054311
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054312
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054313
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054314
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054315
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054316
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054317
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054318
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054319
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054320
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054321
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054322
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054323
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054324
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054325
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054326
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054327
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054328
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054329
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054330
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054331
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054332
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054333
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054334
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054335
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054336
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054337
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054338
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054339
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054340
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054341
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054342
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054343
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054344
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054345
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054346
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054347
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054348
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054349
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054350
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054351
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054352
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054353
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054354
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054355
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006904054356
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442368
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442369
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442370
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442371
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442372
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442373
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442374
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442375
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442376
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442377
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442378
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442379
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442380
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442381
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442382
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442383
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442384
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442385
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442386
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442387
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442388
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442389
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442390
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442391
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442392
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442393
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442394
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442395
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442396
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442397
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442398
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442399
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442400
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442401
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442402
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442403
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442404
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442405
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442406
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442407
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442408
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442409
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442410
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442411
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442412
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442413
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442414
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442415
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442416
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442417
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442418
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442419
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442420
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442421
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442422
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442423
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442424
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442425
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442426
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442427
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442428
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442429
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442430
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442431
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442432
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442433
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442434
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442435
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442436
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442437
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442438
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442439
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442440
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442441
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442442
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442443
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442444
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442445
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442446
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442447
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442448
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442449
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442450
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442451
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442452
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442453
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442454
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442455
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442456
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442457
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442458
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442459
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442460
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442461
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442462
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442463
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442464
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442465
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442466
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442467
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442468
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442469
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442470
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442471
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442472
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442473
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442474
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442475
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442476
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442477
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442478
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442479
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442480
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442481
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442482
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442483
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442484
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442485
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442486
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442487
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442488
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442489
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442490
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442491
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442492
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442493
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442494
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442495
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442496
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442497
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442498
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442499
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442500
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442501
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442502
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442503
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442504
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442505
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442506
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442507
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442508
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442509
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442510
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442511
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442512
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442513
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442514
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442515
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442516
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442517
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442518
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442519
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442520
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442521
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442522
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442523
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442524
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442525
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442526
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442527
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442528
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442529
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442530
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442531
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442532
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442533
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442534
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442535
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442536
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442537
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442538
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442539
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442540
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442541
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442542
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442543
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442544
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442545
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442546
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442547
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442548
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442549
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442550
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442551
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442552
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442553
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442554
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442555
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442556
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442557
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442558
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442559
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442560
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442561
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442562
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442563
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442564
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442565
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442566
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442567
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442568
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442569
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442570
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442571
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442572
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442573
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442574
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442575
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442576
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442577
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442578
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442579
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442580
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442581
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442582
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442583
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442584
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442585
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442586
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442587
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442588
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442589
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442590
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442591
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442592
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442593
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442594
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442595
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442596
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442597
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442598
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442599
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442600
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442601
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442602
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442603
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442604
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442605
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442606
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442607
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442608
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442609
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442610
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442611
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442612
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442613
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442614
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442615
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442616
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442617
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442618
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442619
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442620
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442621
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442622
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442623
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442624
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442625
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442626
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442627
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442628
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442629
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442630
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442631
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442632
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442633
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442634
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442635
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442636
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442637
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442638
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442639
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442640
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442641
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442642
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442643
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442644
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442645
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442646
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442647
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442648
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442649
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442650
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442651
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442652
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442653
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442654
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442655
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442656
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442657
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442658
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442659
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442660
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442661
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442662
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442663
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442664
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442665
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442666
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442667
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442668
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442669
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442670
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442671
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442672
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442673
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442674
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442675
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442676
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442677
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442678
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442679
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442680
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442681
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442682
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442683
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442684
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442685
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442686
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442687
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442688
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442689
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442690
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442691
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442692
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442693
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442694
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442695
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442696
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442697
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442698
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442699
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442700
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442701
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442702
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442703
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442704
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442705
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442706
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442707
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442708
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442709
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442710
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442711
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442712
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442713
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442714
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442715
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442716
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442717
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442718
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2933006912442719
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495023906816
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684032
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684033
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684034
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684035
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684036
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684037
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684038
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684039
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684040
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684041
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684042
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684043
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684044
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684045
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684046
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684047
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684048
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684049
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684050
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684051
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684052
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684053
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684054
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684055
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684056
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684057
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684058
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684059
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684060
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684061
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684062
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684063
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684064
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684065
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684066
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684067
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684068
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684069
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684070
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684071
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684072
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684073
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684074
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684075
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684076
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684077
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684078
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684079
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684080
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684081
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684082
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684083
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684084
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684085
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684086
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684087
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684088
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684089
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684090
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684091
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684092
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684093
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684094
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684095
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684096
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684097
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684098
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684099
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684100
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684101
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684102
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684103
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684104
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684105
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684106
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684107
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684108
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684109
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684110
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684111
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684112
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684113
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684114
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684115
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684116
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684117
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684118
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684119
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684120
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684121
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684122
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684123
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684124
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684125
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684126
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684127
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684128
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684129
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684130
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684131
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684132
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684133
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684134
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684135
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684136
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684137
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684138
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684139
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684140
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684141
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684142
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684143
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684144
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684145
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684146
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684147
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684148
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684149
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684150
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684151
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684152
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684153
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684154
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684155
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684156
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684157
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684158
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684159
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684160
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684161
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684162
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684163
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684164
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684165
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684166
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684167
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684168
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684169
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684170
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684171
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684172
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684173
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684174
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684175
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684176
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684177
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684178
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684179
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684180
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684181
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684182
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684183
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684184
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684185
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684186
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684187
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684188
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684189
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684190
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684191
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684192
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684193
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684194
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684195
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684196
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684197
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684198
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684199
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684200
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684201
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684202
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684203
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684204
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684205
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684206
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684207
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684208
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684209
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684210
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684211
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684212
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684213
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684214
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684215
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684216
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684217
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684218
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684219
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684220
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684221
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684222
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684223
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684224
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684225
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684226
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684227
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684228
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684229
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684230
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684231
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684232
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684233
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684234
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684235
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684236
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684237
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684238
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684239
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684240
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684241
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684242
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684243
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684244
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684245
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684246
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684247
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684248
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684249
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684250
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684251
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684252
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684253
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684254
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684255
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684256
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684257
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684258
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684259
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684260
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684261
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684262
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684263
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684264
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684265
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684266
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684267
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495040684268
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878336
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878337
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878338
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878339
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878340
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878341
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878342
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878343
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878344
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878345
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878346
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878347
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878348
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878349
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878350
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878351
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878352
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878353
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878354
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878355
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878356
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878357
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878358
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878359
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878360
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878361
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878362
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878363
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878364
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878365
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878366
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878367
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878368
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878369
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878370
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878371
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878372
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878373
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878374
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878375
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878376
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878377
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878378
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878379
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878380
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878381
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878382
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878383
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878384
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878385
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878386
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878387
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878388
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878389
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878390
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878391
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878392
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878393
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878394
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878395
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878396
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878397
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878398
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878399
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878400
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878401
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878402
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878403
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878404
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878405
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878406
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878407
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878408
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878409
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878410
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878411
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878412
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878413
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878414
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878415
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878416
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878417
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878418
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878419
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878420
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878421
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878422
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878423
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878424
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878425
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878426
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878427
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878428
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878429
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878430
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878431
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878432
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878433
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878434
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878435
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878436
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878437
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878438
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878439
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878440
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878441
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878442
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878443
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878444
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878445
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878446
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878447
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878448
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878449
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878450
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878451
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878452
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878453
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878454
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878455
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878456
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878457
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878458
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878459
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878460
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878461
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878462
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878463
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878464
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878465
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878466
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878467
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878468
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878469
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878470
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878471
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878472
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878473
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878474
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878475
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878476
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878477
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878478
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878479
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878480
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878481
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878482
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878483
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878484
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878485
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878486
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878487
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878488
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878489
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878490
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878491
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878492
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878493
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878494
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878495
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878496
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878497
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878498
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878499
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878500
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878501
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878502
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878503
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878504
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878505
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878506
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878507
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878508
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878509
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878510
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878511
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878512
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878513
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878514
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878515
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878516
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878517
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878518
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878519
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878520
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878521
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878522
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878523
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878524
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878525
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878526
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878527
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878528
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878529
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878530
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878531
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878532
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878533
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878534
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878535
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878536
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878537
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878538
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878539
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878540
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878541
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878542
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878543
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878544
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878545
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878546
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878547
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878548
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878549
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878550
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878551
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878552
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878553
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878554
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878555
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878556
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878557
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878558
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878559
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878560
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878561
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878562
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878563
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878564
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878565
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878566
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878567
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878568
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878569
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878570
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878571
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878572
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878573
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878574
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878575
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878576
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878577
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878578
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878579
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878580
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878581
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878582
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878583
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878584
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878585
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878586
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878587
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878588
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878589
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878590
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878591
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878592
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878593
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878594
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878595
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878596
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878597
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878598
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878599
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878600
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878601
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878602
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878603
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878604
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878605
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878606
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878607
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878608
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878609
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878610
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878611
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878612
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878613
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878614
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878615
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878616
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878617
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878618
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878619
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878620
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878621
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878622
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878623
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878624
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878625
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878626
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878627
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878628
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878629
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878630
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878631
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878632
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878633
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878634
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878635
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878636
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878637
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878638
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878639
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878640
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878641
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878642
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878643
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878644
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878645
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878646
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878647
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878648
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878649
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878650
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878651
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878652
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878653
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878654
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878655
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878656
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878657
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878658
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878659
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878660
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878661
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878662
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878663
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878664
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878665
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878666
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878667
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878668
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878669
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878670
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878671
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878672
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878673
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878674
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878675
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878676
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878677
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878678
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878679
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878680
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878681
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878682
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878683
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878684
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878685
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878686
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878687
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878688
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878689
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878690
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878691
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878692
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878693
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878694
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878695
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878696
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878697
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878698
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878699
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878700
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878701
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878702
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878703
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878704
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878705
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878706
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878707
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878708
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878709
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878710
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878711
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878712
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878713
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878714
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878715
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878716
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878717
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878718
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878719
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878720
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878721
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878722
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878723
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878724
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878725
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878726
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878727
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878728
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878729
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878730
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878731
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878732
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878733
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878734
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878735
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878736
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878737
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878738
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878739
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878740
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878741
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878742
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878743
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878744
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878745
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878746
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878747
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878748
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878749
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878750
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878751
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878752
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878753
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878754
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878755
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878756
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878757
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878758
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878759
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878760
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878761
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878762
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878763
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878764
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878765
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878766
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878767
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878768
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878769
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878770
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878771
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878772
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878773
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878774
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878775
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878776
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878777
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878778
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878779
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878780
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878781
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878782
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878783
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878784
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878785
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878786
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878787
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878788
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878789
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878790
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878791
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878792
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878793
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878794
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878795
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878796
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878797
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878798
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878799
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878800
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878801
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878802
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878803
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878804
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878805
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878806
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878807
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878808
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878809
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878810
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878811
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878812
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878813
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878814
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878815
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878816
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878817
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878818
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878819
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878820
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878821
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878822
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878823
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878824
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878825
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878826
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878827
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878828
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878829
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878830
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878831
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878832
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878833
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878834
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878835
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878836
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878837
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878838
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878839
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878840
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878841
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878842
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878843
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878844
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878845
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878846
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878847
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878848
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878849
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878850
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878851
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878852
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878853
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878854
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878855
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878856
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878857
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878858
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878859
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878860
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878861
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878862
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878863
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878864
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878865
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878866
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878867
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878868
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878869
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878870
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878871
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878872
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878873
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878874
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878875
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878876
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878877
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878878
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878879
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878880
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878881
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878882
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878883
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878884
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878885
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878886
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878887
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878888
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878889
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878890
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878891
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878892
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878893
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878894
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878895
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878896
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878897
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878898
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878899
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878900
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878901
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878902
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878903
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878904
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878905
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878906
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878907
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878908
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878909
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878910
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878911
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878912
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878913
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878914
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878915
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878916
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878917
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878918
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878919
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878920
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878921
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878922
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878923
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878924
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878925
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878926
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878927
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878928
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878929
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878930
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878931
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878932
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878933
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878934
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878935
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878936
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878937
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878938
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878939
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878940
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878941
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878942
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878943
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878944
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878945
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878946
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878947
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878948
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878949
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878950
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878951
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878952
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878953
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878954
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878955
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878956
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878957
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878958
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878959
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878960
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878961
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878962
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878963
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878964
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878965
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878966
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878967
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878968
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878969
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878970
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878971
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878972
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878973
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878974
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878975
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878976
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878977
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878978
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878979
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878980
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878981
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878982
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878983
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878984
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878985
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878986
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878987
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878988
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878989
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878990
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878991
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878992
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878993
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878994
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878995
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878996
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878997
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878998
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044878999
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879000
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879001
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879002
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879003
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879004
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879005
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879006
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879007
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879008
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879009
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879010
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879011
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879012
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879013
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879014
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879015
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879016
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879017
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879018
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879019
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879020
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879021
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879022
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879023
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879024
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879025
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879026
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879027
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879028
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879029
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879030
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879031
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879032
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879033
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879034
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879035
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879036
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879037
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879038
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879039
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879040
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879041
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879042
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879043
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879044
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879045
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879046
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2935495044879047
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942343999488
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388096
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388097
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388098
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388099
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388100
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388101
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388102
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388103
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388104
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388105
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388106
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388107
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388108
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388109
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388110
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388111
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388112
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388113
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388114
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388115
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388116
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388117
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388118
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388119
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388120
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388121
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388122
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388123
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388124
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388125
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388126
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388127
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388128
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388129
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388130
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388131
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388132
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388133
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388134
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388135
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388136
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388137
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388138
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388139
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388140
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388141
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388142
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388143
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388144
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388145
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388146
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388147
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388148
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388149
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388150
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388151
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388152
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388153
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388154
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388155
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388156
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388157
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388158
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388159
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388160
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388161
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388162
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388163
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388164
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388165
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388166
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388167
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388168
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388169
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388170
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388171
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388172
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388173
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388174
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388175
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388176
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388177
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388178
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388179
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388180
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388181
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388182
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388183
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388184
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388185
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388186
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388187
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388188
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388189
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388190
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388191
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388192
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388193
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388194
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388195
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388196
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388197
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388198
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388199
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388200
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388201
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388202
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388203
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388204
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388205
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388206
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388207
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388208
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388209
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388210
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388211
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388212
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388213
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388214
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388215
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388216
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388217
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388218
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388219
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388220
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388221
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388222
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388223
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388224
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388225
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388226
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388227
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388228
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388229
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388230
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388231
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388232
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388233
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388234
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388235
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388236
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388237
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388238
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388239
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388240
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388241
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388242
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388243
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388244
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388245
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388246
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388247
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388248
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388249
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388250
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388251
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388252
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388253
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388254
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388255
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388256
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388257
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388258
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388259
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388260
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388261
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388262
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388263
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388264
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388265
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388266
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388267
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388268
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388269
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388270
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388271
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388272
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388273
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388274
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388275
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388276
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388277
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388278
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388279
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388280
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388281
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388282
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388283
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388284
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388285
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388286
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388287
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388288
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388289
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388290
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388291
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388292
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388293
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388294
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388295
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388296
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388297
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388298
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388299
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388300
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388301
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388302
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388303
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388304
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388305
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388306
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388307
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388308
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388309
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388310
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388311
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388312
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388313
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388314
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388315
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388316
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388317
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388318
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388319
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388320
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388321
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388322
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388323
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388324
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388325
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388326
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388327
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388328
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388329
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388330
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388331
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388332
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388333
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388334
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388335
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388336
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388337
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388338
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388339
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388340
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388341
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388342
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388343
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388344
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388345
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388346
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388347
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388348
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388349
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388350
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388351
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388352
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388353
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388354
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388355
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388356
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388357
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388358
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388359
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388360
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388361
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388362
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388363
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388364
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388365
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388366
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388367
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388368
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388369
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388370
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388371
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388372
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388373
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388374
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388375
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388376
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388377
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388378
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388379
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388380
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388381
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388382
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388383
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388384
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388385
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388386
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388387
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388388
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388389
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388390
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388391
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388392
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388393
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388394
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388395
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388396
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388397
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388398
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388399
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388400
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388401
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388402
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388403
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388404
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388405
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388406
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388407
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388408
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388409
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388410
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388411
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388412
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388413
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388414
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388415
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388416
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388417
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388418
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388419
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388420
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388421
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388422
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388423
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388424
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388425
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388426
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388427
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388428
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388429
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388430
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388431
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388432
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388433
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388434
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388435
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388436
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388437
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388438
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388439
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388440
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388441
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388442
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388443
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388444
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388445
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388446
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388447
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388448
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388449
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388450
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388451
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388452
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388453
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388454
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388455
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388456
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388457
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388458
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388459
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388460
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388461
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388462
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388463
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388464
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388465
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388466
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388467
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388468
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388469
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388470
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388471
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388472
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388473
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388474
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388475
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388476
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388477
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388478
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388479
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388480
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388481
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388482
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388483
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388484
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388485
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388486
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388487
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388488
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388489
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388490
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388491
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388492
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388493
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388494
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388495
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388496
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388497
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388498
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388499
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388500
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388501
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388502
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388503
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388504
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388505
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388506
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388507
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388508
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388509
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388510
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388511
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388512
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388513
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388514
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388515
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388516
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388517
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388518
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388519
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388520
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388521
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388522
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388523
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388524
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388525
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388526
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388527
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388528
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388529
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388530
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388531
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388532
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388533
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388534
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388535
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388536
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388537
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388538
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388539
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388540
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388541
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388542
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388543
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388544
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388545
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388546
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388547
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388548
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388549
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388550
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388551
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388552
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388553
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388554
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388555
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388556
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388557
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388558
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388559
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388560
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388561
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388562
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388563
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388564
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388565
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388566
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388567
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388568
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388569
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388570
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388571
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388572
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388573
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388574
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388575
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388576
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388577
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388578
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388579
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388580
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388581
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388582
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388583
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388584
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388585
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388586
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388587
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388588
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388589
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388590
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388591
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388592
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388593
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388594
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388595
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388596
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388597
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388598
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388599
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388600
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388601
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388602
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388603
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388604
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388605
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388606
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388607
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388608
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388609
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388610
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388611
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388612
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388613
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388614
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388615
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388616
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388617
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388618
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388619
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388620
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388621
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388622
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388623
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388624
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388625
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388626
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388627
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388628
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388629
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388630
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388631
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388632
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388633
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388634
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388635
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388636
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388637
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388638
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388639
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388640
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388641
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388642
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388643
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388644
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388645
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388646
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388647
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388648
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388649
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388650
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388651
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388652
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388653
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388654
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388655
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388656
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388657
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388658
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388659
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388660
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388661
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388662
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388663
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388664
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388665
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388666
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388667
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388668
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388669
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388670
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388671
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388672
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388673
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388674
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388675
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388676
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388677
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388678
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388679
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388680
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388681
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388682
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388683
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388684
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388685
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388686
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388687
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388688
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388689
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388690
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388691
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388692
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388693
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388694
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388695
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388696
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388697
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388698
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388699
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388700
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388701
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388702
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388703
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388704
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388705
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388706
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388707
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388708
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388709
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388710
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388711
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388712
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388713
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388714
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388715
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388716
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388717
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388718
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388719
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388720
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388721
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388722
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388723
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388724
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388725
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388726
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388727
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388728
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388729
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388730
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388731
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388732
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388733
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388734
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388735
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388736
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388737
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388738
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388739
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388740
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388741
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388742
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388743
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388744
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388745
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388746
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388747
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388748
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388749
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388750
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388751
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388752
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388753
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388754
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388755
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388756
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388757
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388758
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388759
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388760
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388761
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388762
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388763
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388764
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388765
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388766
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388767
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388768
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388769
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388770
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388771
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388772
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388773
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388774
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388775
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388776
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388777
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388778
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388779
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388780
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388781
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388782
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388783
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388784
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388785
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388786
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388787
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388788
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388789
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388790
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388791
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388792
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388793
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388794
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388795
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388796
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388797
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388798
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388799
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388800
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388801
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388802
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388803
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388804
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388805
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388806
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388807
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388808
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388809
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388810
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388811
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388812
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388813
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388814
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388815
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388816
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388817
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388818
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388819
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388820
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388821
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388822
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388823
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388824
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388825
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388826
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388827
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388828
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388829
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388830
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388831
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388832
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388833
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388834
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388835
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388836
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388837
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388838
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388839
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388840
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388841
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388842
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388843
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388844
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388845
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388846
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388847
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388848
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388849
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388850
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388851
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388852
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388853
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388854
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388855
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388856
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388857
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388858
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388859
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388860
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388861
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388862
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388863
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388864
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388865
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388866
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388867
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388868
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388869
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388870
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388871
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388872
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388873
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388874
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388875
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388876
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388877
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388878
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388879
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388880
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388881
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388882
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388883
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388884
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388885
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388886
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388887
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388888
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388889
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388890
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388891
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388892
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388893
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388894
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388895
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388896
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388897
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388898
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388899
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388900
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388901
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388902
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388903
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388904
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388905
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388906
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388907
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388908
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388909
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388910
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388911
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388912
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388913
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388914
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388915
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388916
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388917
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388918
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388919
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388920
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388921
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388922
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388923
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388924
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388925
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388926
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388927
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388928
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388929
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388930
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388931
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388932
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388933
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388934
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388935
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388936
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388937
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388938
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388939
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388940
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388941
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388942
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388943
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388944
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388945
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388946
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388947
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388948
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388949
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388950
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388951
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388952
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388953
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388954
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388955
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388956
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388957
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388958
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388959
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388960
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388961
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388962
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388963
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388964
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388965
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388966
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388967
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388968
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388969
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388970
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388971
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388972
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388973
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388974
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388975
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388976
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388977
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388978
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388979
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388980
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388981
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388982
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388983
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388984
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388985
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388986
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388987
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388988
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388989
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388990
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388991
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388992
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388993
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388994
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388995
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388996
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388997
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388998
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352388999
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389000
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389001
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389002
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389003
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389004
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389005
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389006
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389007
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389008
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389009
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389010
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389011
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389012
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389013
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389014
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389015
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389016
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389017
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389018
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389019
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389020
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389021
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389022
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389023
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389024
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389025
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389026
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389027
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389028
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389029
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389030
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389031
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389032
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389033
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389034
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389035
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389036
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389037
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389038
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389039
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389040
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389041
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389042
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389043
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389044
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389045
    m_Localized: "\"\uC5B4\uC11C \uC624\uC138\uC694, \uAD00\uCE21\uC790\uB2D8. \uC601\uC9C0
      \uB0B4 \uC0DD\uBA85 \uC720\uC9C0 \uC7A5\uCE58 \uBC0F \uC5D0\uD14C\uB974 \uC5D0\uB108\uC9C0
      \uD750\uB984, \uBAA8\uB450 \uC815\uC0C1\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC744
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389046
    m_Localized: "\"\uC5D8\uD53C\uC2A4\uB85C\uBD80\uD130 \uBBF8\uD655\uC778 \uB370\uC774\uD130\uAC00
      \uC218\uC2E0\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBD84\uC11D\uC744 \uC2DC\uC791\uD560\uAE4C\uC694?
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD310\uB2E8\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389047
    m_Localized: "\"\uC774 \uAD11\uD65C\uD55C \uC6B0\uC8FC\uC5D0\uC11C \uC88C\uD45C\uB97C
      \uC783\uC9C0 \uC54A\uB294 \uC720\uC77C\uD55C \uBC29\uBC95\uC740... \uBC14\uB85C
      \uB2F9\uC2E0\uC774 \uC81C \uACC1\uC5D0 \uC788\uB294 \uAC83\uC774\uACA0\uC8E0.
      \uD6C4\uD6C4, \uB18D\uB2F4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389048
    m_Localized: "\"\uCEE4\uD53C\uB77C\uB3C4 \uD55C \uC794 \uB0B4\uB824\uB4DC\uB9B4\uAE4C\uC694? 
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD734\uC2DD\uB3C4 \uC911\uC694\uD55C \uC784\uBB34\uC758
      \uC77C\uBD80\uB2C8\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389049
    m_Localized: "\"\uC800\uC758 \uCD5C\uC6B0\uC120 \uC120\uD0DD\uC0AC\uD56D\uC740
      \uC5B8\uC81C\uB098 \uAD00\uCE21\uC790\uB2D8\uC758 \uC548\uC804\uACFC \uC2B9\uB9AC\uC785\uB2C8\uB2E4.
      \uADF8\uB7EC\uB2C8 \uC548\uC2EC\uD558\uACE0 \uC9C0\uD718\uD574 \uC8FC\uC138\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389050
    m_Localized: "\"\uC624\uC168\uB098\uC694, \uAD00\uCE21\uC790\uB2D8? \uC624\uB298
      \uD6C8\uB828 \uC2A4\uCF00\uC904\uC740 \uD3C9\uC18C\uBCF4\uB2E4 1.5\uBC30 \uB354
      \uBE61\uBE61\uD558\uAC8C \uC7A1\uC544 \uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389051
    m_Localized: "\"\uB370\uC774\uD130\uB9CC \uBBFF\uB294\uB2E4\uBA74 \uC2E4\uC804\uC5D0\uC11C
      \uBB34\uB108\uC9C8 \uBFD0\uC774\uC5D0\uC694. \uB2F9\uC2E0\uC744 \uC704\uD574\uC11C
      \uB354\uB354\uC6B1 \uD558\uB4DC\uD55C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uC900\uBE44\uD574\uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389052
    m_Localized: "\"\uC6C0\uC9C1\uC784\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uB454\uD558\uB124\uC694.
      \uC544\uAE4C\uBD80\uD130 \uC800\uB97C \uD790\uB057 \uAC70\uB9AC\uC2DC\uB358\uB370
      \uD639\uC2DC......?\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389053
    m_Localized: "\"\uC2DC\uBBAC\uB808\uC774\uC158 \uC885\uB8CC. ...\uD765, \uC774\uBC88\uC5D4
      \uC81C\uBC95\uC774\uAD70\uC694. \uC544\uC8FC \uC870\uAE08\uC740, \uAD00\uCE21\uC790\uB2D8\uC744
      \uB2E4\uC2DC \uBD24\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2936942352389054
    m_Localized: "\"\uC804\uC7A5\uC740 \uC790\uBE44\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC5EC\uAE30\uC11C \uD758\uB9B0 \uB540\uBC29\uC6B8\uB9CC\uD07C\uC740
      \uB2F9\uC2E0\uC744 \uBC30\uC2E0\uD558\uC9C0 \uC54A\uC744\uAC70\uC5D0\uC694.
      \uC790, \uB2E4\uC74C \uC2DC\uBBAC\uB808\uC774\uC158\uC744 \uBC14\uB85C \uC9C4\uD589\uD574\uBCF4\uC8E0\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144973819904
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014208
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014209
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014210
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014211
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014212
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014213
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014214
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014215
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014216
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014217
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014218
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014219
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014220
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014221
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014222
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014223
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014224
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014225
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014226
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014227
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014228
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014229
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014230
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014231
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014232
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014233
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014234
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014235
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014236
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014237
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014238
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014239
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014240
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014241
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014242
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014243
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014244
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014245
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014246
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014247
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014248
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014249
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014250
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014251
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014252
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014253
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014254
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014255
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014256
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014257
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014258
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014259
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014260
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014261
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014262
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014263
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014264
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014265
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014266
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014267
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014268
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014269
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014270
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014271
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014272
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014273
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014274
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014275
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014276
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014277
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014278
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144978014279
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208512
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208513
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208514
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208515
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208516
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208517
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208518
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208519
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208520
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208521
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208522
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208523
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208524
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208525
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208526
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208527
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208528
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208529
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208530
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208531
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208532
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208533
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208534
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208535
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208536
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208537
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208538
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208539
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208540
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208541
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208542
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208543
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208544
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208545
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208546
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208547
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208548
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208549
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208550
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208551
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208552
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208553
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208554
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208555
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208556
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208557
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208558
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208559
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208560
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208561
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208562
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208563
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208564
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208565
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208566
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208567
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208568
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208569
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208570
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208571
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208572
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208573
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208574
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208575
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208576
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208577
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208578
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208579
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208580
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208581
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208582
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208583
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208584
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208585
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208586
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208587
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208588
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208589
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208590
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208591
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208592
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208593
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208594
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208595
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208596
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208597
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208598
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208599
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208600
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208601
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208602
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208603
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208604
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208605
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208606
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208607
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208608
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208609
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208610
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208611
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208612
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208613
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208614
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208615
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208616
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208617
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208618
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208619
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208620
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208621
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208622
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208623
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208624
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208625
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208626
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208627
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208628
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208629
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208630
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208631
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208632
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208633
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208634
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208635
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208636
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208637
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208638
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208639
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208640
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208641
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208642
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208643
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208644
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208645
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208646
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208647
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208648
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208649
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208650
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208651
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208652
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208653
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208654
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208655
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208656
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208657
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208658
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208659
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208660
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208661
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208662
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208663
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208664
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208665
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208666
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208667
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208668
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208669
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208670
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208671
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208672
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208673
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208674
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208675
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208676
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208677
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208678
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208679
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208680
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208681
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208682
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208683
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208684
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208685
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208686
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208687
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208688
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208689
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208690
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208691
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208692
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208693
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208694
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208695
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144982208696
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402816
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402817
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402818
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402819
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402820
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402821
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402822
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402823
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402824
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402825
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402826
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402827
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402828
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402829
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402830
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402831
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402832
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402833
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402834
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402835
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402836
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402837
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402838
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402839
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402840
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402841
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402842
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402843
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402844
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402845
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402846
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402847
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402848
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402849
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402850
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402851
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402852
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402853
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402854
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402855
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402856
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402857
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402858
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402859
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402860
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402861
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402862
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402863
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402864
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402865
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402866
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402867
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402868
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402869
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402870
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402871
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402872
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402873
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402874
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402875
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402876
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402877
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402878
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402879
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402880
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402881
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402882
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402883
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402884
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402885
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402886
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402887
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402888
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402889
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402890
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402891
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402892
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402893
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402894
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402895
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402896
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402897
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402898
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402899
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402900
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402901
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402902
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402903
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402904
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402905
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402906
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402907
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402908
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402909
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402910
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402911
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402912
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402913
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402914
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402915
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402916
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402917
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402918
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402919
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402920
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402921
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402922
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402923
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402924
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402925
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402926
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402927
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402928
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402929
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402930
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402931
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402932
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402933
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402934
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402935
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402936
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402937
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402938
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402939
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402940
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402941
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402942
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402943
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402944
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402945
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402946
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402947
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402948
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402949
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402950
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402951
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402952
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402953
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402954
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402955
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402956
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402957
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402958
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402959
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402960
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402961
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402962
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402963
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402964
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402965
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402966
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402967
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402968
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402969
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402970
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402971
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402972
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402973
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402974
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402975
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402976
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402977
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402978
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402979
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402980
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402981
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402982
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402983
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402984
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402985
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402986
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402987
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402988
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402989
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402990
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402991
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402992
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402993
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402994
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402995
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402996
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402997
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402998
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986402999
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403000
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403001
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403002
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403003
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403004
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403005
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403006
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403007
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403008
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403009
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403010
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403011
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403012
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403013
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403014
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403015
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403016
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403017
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403018
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403019
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403020
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403021
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403022
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403023
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403024
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403025
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403026
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403027
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403028
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403029
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403030
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403031
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403032
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403033
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403034
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403035
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403036
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403037
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403038
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403039
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403040
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403041
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403042
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403043
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403044
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403045
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403046
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403047
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403048
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403049
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403050
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403051
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403052
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403053
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403054
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403055
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403056
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403057
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403058
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403059
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403060
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403061
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403062
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403063
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403064
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403065
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403066
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403067
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403068
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403069
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403070
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403071
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403072
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403073
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403074
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403075
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403076
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403077
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403078
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403079
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403080
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403081
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403082
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403083
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403084
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403085
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403086
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403087
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403088
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403089
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403090
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403091
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403092
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403093
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403094
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403095
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403096
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403097
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403098
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403099
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403100
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403101
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403102
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403103
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403104
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403105
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403106
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403107
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403108
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403109
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403110
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403111
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403112
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403113
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403114
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403115
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403116
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403117
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403118
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403119
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403120
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403121
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403122
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403123
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403124
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403125
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403126
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403127
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403128
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403129
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403130
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403131
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403132
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403133
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403134
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403135
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403136
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403137
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403138
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403139
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403140
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403141
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403142
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403143
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403144
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403145
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403146
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403147
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403148
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403149
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403150
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403151
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403152
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403153
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403154
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403155
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403156
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403157
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403158
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403159
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403160
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403161
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403162
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403163
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403164
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403165
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403166
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403167
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403168
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403169
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403170
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403171
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403172
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403173
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403174
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403175
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403176
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403177
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403178
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403179
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403180
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403181
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403182
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403183
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403184
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403185
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403186
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403187
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403188
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403189
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403190
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403191
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403192
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403193
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403194
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403195
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403196
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403197
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403198
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403199
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403200
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403201
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403202
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403203
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403204
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403205
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403206
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403207
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403208
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403209
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403210
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403211
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403212
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403213
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403214
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403215
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403216
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403217
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403218
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403219
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403220
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403221
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403222
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403223
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403224
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403225
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403226
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403227
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403228
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403229
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403230
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403231
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403232
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403233
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403234
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403235
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403236
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403237
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403238
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403239
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403240
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403241
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403242
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403243
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403244
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403245
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403246
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403247
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403248
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403249
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403250
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403251
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403252
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403253
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403254
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403255
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403256
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403257
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403258
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403259
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403260
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403261
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403262
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403263
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403264
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403265
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403266
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403267
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403268
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403269
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403270
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403271
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403272
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403273
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403274
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403275
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403276
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403277
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403278
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403279
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403280
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403281
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403282
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403283
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403284
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403285
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403286
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403287
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403288
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403289
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403290
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403291
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403292
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403293
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403294
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403295
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403296
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403297
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403298
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403299
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403300
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403301
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403302
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403303
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403304
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403305
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403306
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403307
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403308
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403309
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403310
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403311
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403312
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403313
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403314
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403315
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403316
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403317
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403318
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403319
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403320
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403321
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403322
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403323
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403324
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403325
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403326
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403327
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403328
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403329
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403330
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403331
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403332
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403333
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403334
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403335
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403336
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403337
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403338
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403339
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403340
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403341
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403342
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403343
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403344
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403345
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403346
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403347
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403348
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403349
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403350
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403351
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403352
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403353
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403354
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403355
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403356
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403357
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403358
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403359
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403360
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403361
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403362
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403363
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403364
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403365
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403366
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403367
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403368
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403369
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403370
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403371
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403372
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403373
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403374
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403375
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403376
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403377
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403378
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403379
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403380
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403381
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403382
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403383
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403384
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403385
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403386
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403387
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403388
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403389
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403390
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403391
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403392
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403393
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403394
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403395
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403396
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403397
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403398
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403399
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403400
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403401
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403402
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403403
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403404
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403405
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403406
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403407
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403408
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403409
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403410
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403411
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403412
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403413
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403414
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403415
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403416
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403417
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403418
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403419
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403420
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403421
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403422
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403423
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403424
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403425
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403426
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403427
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403428
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403429
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403430
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403431
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403432
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403433
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403434
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403435
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403436
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403437
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403438
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403439
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403440
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403441
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403442
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403443
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403444
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403445
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403446
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403447
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403448
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403449
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403450
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403451
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403452
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403453
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403454
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403455
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403456
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403457
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403458
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403459
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403460
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403461
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403462
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403463
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403464
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403465
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403466
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403467
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403468
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403469
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403470
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403471
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403472
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403473
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403474
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403475
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403476
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403477
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403478
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403479
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403480
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403481
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403482
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403483
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403484
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403485
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403486
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403487
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403488
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403489
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403490
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403491
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403492
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403493
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403494
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403495
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403496
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403497
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403498
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403499
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403500
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403501
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403502
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403503
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403504
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403505
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403506
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403507
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403508
    m_Localized: "\"\uC5B4\uC11C \uC624\uC138\uC694, \uAD00\uCE21\uC790\uB2D8. \uC601\uC9C0
      \uB0B4 \uC0DD\uBA85 \uC720\uC9C0 \uC7A5\uCE58 \uBC0F \uC5D0\uD14C\uB974 \uC5D0\uB108\uC9C0
      \uD750\uB984, \uBAA8\uB450 \uC815\uC0C1\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC744
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403509
    m_Localized: "\"\uC5D8\uD53C\uC2A4\uB85C\uBD80\uD130 \uBBF8\uD655\uC778 \uB370\uC774\uD130\uAC00
      \uC218\uC2E0\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBD84\uC11D\uC744 \uC2DC\uC791\uD560\uAE4C\uC694?
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD310\uB2E8\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403510
    m_Localized: "\"\uC774 \uAD11\uD65C\uD55C \uC6B0\uC8FC\uC5D0\uC11C \uC88C\uD45C\uB97C
      \uC783\uC9C0 \uC54A\uB294 \uC720\uC77C\uD55C \uBC29\uBC95\uC740... \uBC14\uB85C
      \uB2F9\uC2E0\uC774 \uC81C \uACC1\uC5D0 \uC788\uB294 \uAC83\uC774\uACA0\uC8E0.
      \uD6C4\uD6C4, \uB18D\uB2F4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403511
    m_Localized: "\"\uCEE4\uD53C\uB77C\uB3C4 \uD55C \uC794 \uB0B4\uB824\uB4DC\uB9B4\uAE4C\uC694? 
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD734\uC2DD\uB3C4 \uC911\uC694\uD55C \uC784\uBB34\uC758
      \uC77C\uBD80\uB2C8\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403512
    m_Localized: "\"\uC800\uC758 \uCD5C\uC6B0\uC120 \uC120\uD0DD\uC0AC\uD56D\uC740
      \uC5B8\uC81C\uB098 \uAD00\uCE21\uC790\uB2D8\uC758 \uC548\uC804\uACFC \uC2B9\uB9AC\uC785\uB2C8\uB2E4.
      \uADF8\uB7EC\uB2C8 \uC548\uC2EC\uD558\uACE0 \uC9C0\uD718\uD574 \uC8FC\uC138\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403513
    m_Localized: "\"\uC624\uC168\uB098\uC694, \uAD00\uCE21\uC790\uB2D8? \uC624\uB298
      \uD6C8\uB828 \uC2A4\uCF00\uC904\uC740 \uD3C9\uC18C\uBCF4\uB2E4 1.5\uBC30 \uB354
      \uBE61\uBE61\uD558\uAC8C \uC7A1\uC544 \uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403514
    m_Localized: "\"\uB370\uC774\uD130\uB9CC \uBBFF\uB294\uB2E4\uBA74 \uC2E4\uC804\uC5D0\uC11C
      \uBB34\uB108\uC9C8 \uBFD0\uC774\uC5D0\uC694. \uB2F9\uC2E0\uC744 \uC704\uD574\uC11C
      \uB354\uB354\uC6B1 \uD558\uB4DC\uD55C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uC900\uBE44\uD574\uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403515
    m_Localized: "\"\uC6C0\uC9C1\uC784\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uB454\uD558\uB124\uC694.
      \uC544\uAE4C\uBD80\uD130 \uC800\uB97C \uD790\uB057 \uAC70\uB9AC\uC2DC\uB358\uB370
      \uD639\uC2DC......?\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403516
    m_Localized: "\"\uC2DC\uBBAC\uB808\uC774\uC158 \uC885\uB8CC. ...\uD765, \uC774\uBC88\uC5D4
      \uC81C\uBC95\uC774\uAD70\uC694. \uC544\uC8FC \uC870\uAE08\uC740, \uAD00\uCE21\uC790\uB2D8\uC744
      \uB2E4\uC2DC \uBD24\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2943144986403517
    m_Localized: "\"\uC804\uC7A5\uC740 \uC790\uBE44\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC5EC\uAE30\uC11C \uD758\uB9B0 \uB540\uBC29\uC6B8\uB9CC\uD07C\uC740
      \uB2F9\uC2E0\uC744 \uBC30\uC2E0\uD558\uC9C0 \uC54A\uC744\uAC70\uC5D0\uC694.
      \uC790, \uB2E4\uC74C \uC2DC\uBBAC\uB808\uC774\uC158\uC744 \uBC14\uB85C \uC9C4\uD589\uD574\uBCF4\uC8E0\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080441495552
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884160
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884161
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884162
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884163
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884164
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884165
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884166
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884167
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884168
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884169
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884170
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884171
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884172
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884173
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884174
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884175
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884176
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884177
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884178
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884179
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884180
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884181
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884182
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884183
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884184
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884185
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884186
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884187
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884188
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884189
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884190
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884191
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884192
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884193
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884194
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884195
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884196
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884197
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884198
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884199
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884200
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884201
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884202
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884203
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884204
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884205
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884206
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884207
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884208
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884209
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884210
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884211
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884212
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884213
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884214
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884215
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884216
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884217
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884218
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884219
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884220
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884221
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884222
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884223
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884224
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884225
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884226
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884227
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884228
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884229
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884230
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884231
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884232
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884233
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884234
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884235
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884236
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884237
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884238
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884239
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884240
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884241
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884242
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884243
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884244
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884245
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884246
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884247
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884248
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884249
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884250
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884251
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884252
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884253
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884254
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884255
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884256
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884257
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884258
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884259
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884260
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884261
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884262
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884263
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884264
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884265
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884266
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884267
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884268
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884269
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884270
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884271
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884272
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884273
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884274
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884275
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884276
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884277
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884278
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884279
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884280
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884281
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884282
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884283
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884284
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884285
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884286
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884287
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884288
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884289
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884290
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884291
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884292
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884293
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884294
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884295
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884296
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884297
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884298
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884299
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884300
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884301
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884302
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884303
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884304
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884305
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884306
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884307
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884308
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884309
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884310
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884311
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884312
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884313
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884314
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884315
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884316
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884317
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884318
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884319
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884320
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884321
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884322
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884323
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884324
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884325
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884326
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884327
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884328
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884329
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884330
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884331
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884332
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884333
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884334
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884335
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884336
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884337
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884338
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884339
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884340
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884341
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884342
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884343
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884344
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884345
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884346
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884347
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884348
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884349
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884350
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884351
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884352
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884353
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884354
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884355
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884356
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884357
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884358
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884359
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884360
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884361
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884362
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884363
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884364
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884365
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884366
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884367
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884368
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884369
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884370
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884371
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884372
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884373
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884374
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884375
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884376
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884377
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884378
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884379
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884380
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884381
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884382
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884383
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884384
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884385
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884386
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884387
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884388
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884389
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884390
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884391
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884392
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884393
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884394
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884395
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884396
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884397
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884398
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884399
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884400
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884401
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884402
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884403
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884404
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884405
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884406
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884407
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884408
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884409
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884410
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884411
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884412
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884413
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884414
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884415
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884416
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884417
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884418
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884419
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884420
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884421
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884422
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884423
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884424
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884425
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884426
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884427
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884428
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884429
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884430
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884431
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884432
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884433
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884434
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884435
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884436
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884437
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884438
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884439
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884440
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884441
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884442
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884443
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884444
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884445
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884446
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884447
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884448
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884449
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884450
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884451
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884452
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884453
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884454
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884455
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884456
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884457
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884458
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884459
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884460
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884461
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884462
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884463
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884464
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884465
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884466
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884467
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884468
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884469
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884470
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884471
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884472
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884473
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884474
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884475
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884476
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884477
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884478
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884479
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884480
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884481
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884482
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884483
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884484
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884485
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884486
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884487
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884488
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884489
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884490
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884491
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884492
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884493
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884494
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884495
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884496
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884497
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884498
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884499
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884500
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884501
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884502
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884503
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884504
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884505
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884506
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884507
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884508
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884509
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884510
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884511
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884512
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884513
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884514
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884515
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884516
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884517
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884518
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884519
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884520
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884521
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884522
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884523
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884524
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884525
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884526
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884527
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884528
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884529
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884530
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884531
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884532
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884533
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884534
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884535
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884536
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884537
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884538
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884539
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884540
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884541
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884542
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884543
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884544
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884545
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884546
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884547
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884548
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884549
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884550
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884551
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884552
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884553
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884554
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884555
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884556
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884557
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884558
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884559
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884560
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884561
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884562
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884563
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884564
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884565
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884566
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884567
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884568
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884569
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884570
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884571
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884572
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884573
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884574
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884575
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884576
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884577
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884578
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884579
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884580
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884581
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884582
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884583
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884584
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884585
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884586
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080449884587
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272768
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272769
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272770
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272771
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272772
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272773
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272774
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272775
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272776
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272777
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272778
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272779
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272780
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272781
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272782
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272783
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272784
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272785
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272786
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272787
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272788
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272789
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272790
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272791
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272792
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272793
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272794
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272795
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272796
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272797
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272798
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272799
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272800
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272801
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272802
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272803
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272804
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272805
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272806
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272807
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272808
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272809
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272810
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272811
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272812
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272813
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272814
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272815
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272816
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272817
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272818
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272819
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272820
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272821
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272822
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272823
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272824
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272825
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272826
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272827
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272828
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272829
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272830
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272831
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272832
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272833
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272834
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272835
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272836
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272837
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272838
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272839
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272840
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272841
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272842
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272843
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272844
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272845
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272846
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272847
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272848
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272849
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272850
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272851
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272852
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272853
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272854
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272855
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272856
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272857
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272858
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272859
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272860
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272861
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272862
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272863
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272864
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272865
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272866
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272867
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272868
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272869
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272870
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272871
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272872
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272873
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272874
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272875
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272876
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272877
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272878
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272879
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272880
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272881
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272882
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272883
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272884
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272885
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272886
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272887
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272888
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272889
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272890
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272891
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272892
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272893
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272894
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272895
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272896
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272897
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272898
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272899
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272900
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272901
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272902
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272903
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272904
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272905
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272906
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272907
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272908
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272909
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272910
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272911
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272912
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272913
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272914
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272915
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272916
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272917
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272918
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272919
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272920
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272921
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272922
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272923
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272924
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272925
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272926
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272927
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272928
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272929
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272930
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272931
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272932
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272933
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272934
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272935
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272936
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272937
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272938
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272939
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272940
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272941
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272942
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272943
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272944
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272945
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272946
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272947
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272948
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272949
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272950
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272951
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272952
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272953
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272954
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272955
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272956
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272957
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272958
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272959
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272960
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272961
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272962
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272963
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272964
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272965
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272966
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272967
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272968
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272969
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272970
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272971
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272972
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272973
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272974
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272975
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272976
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272977
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272978
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272979
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272980
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272981
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272982
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272983
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272984
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272985
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272986
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272987
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272988
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272989
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272990
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272991
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272992
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272993
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272994
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272995
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272996
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272997
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272998
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458272999
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273000
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273001
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273002
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273003
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273004
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273005
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273006
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273007
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273008
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273009
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273010
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273011
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273012
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273013
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273014
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273015
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273016
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273017
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273018
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273019
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273020
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273021
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273022
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273023
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273024
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273025
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273026
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273027
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273028
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273029
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273030
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273031
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273032
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273033
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273034
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273035
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273036
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273037
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273038
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273039
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273040
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273041
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273042
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273043
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273044
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273045
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273046
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273047
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273048
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273049
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273050
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273051
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273052
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273053
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273054
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273055
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273056
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273057
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273058
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273059
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273060
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273061
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273062
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273063
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273064
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273065
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273066
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273067
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273068
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273069
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273070
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273071
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273072
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273073
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273074
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273075
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273076
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273077
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273078
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273079
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273080
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273081
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273082
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273083
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273084
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273085
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273086
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273087
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273088
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273089
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273090
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273091
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273092
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273093
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273094
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273095
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273096
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273097
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273098
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273099
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273100
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273101
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273102
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273103
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273104
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273105
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273106
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273107
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273108
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273109
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273110
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273111
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273112
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273113
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273114
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273115
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273116
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273117
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273118
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273119
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273120
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273121
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273122
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273123
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273124
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273125
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273126
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273127
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273128
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273129
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273130
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273131
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273132
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273133
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273134
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273135
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273136
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273137
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273138
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273139
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273140
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273141
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273142
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273143
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273144
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273145
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273146
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273147
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273148
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273149
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273150
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273151
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273152
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273153
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273154
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273155
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273156
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273157
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273158
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273159
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273160
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273161
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273162
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273163
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273164
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273165
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273166
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273167
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273168
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273169
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273170
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273171
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273172
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273173
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273174
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273175
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273176
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273177
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273178
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273179
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273180
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273181
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273182
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273183
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273184
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273185
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273186
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273187
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273188
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273189
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273190
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273191
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273192
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273193
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273194
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273195
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273196
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273197
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273198
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273199
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273200
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273201
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273202
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273203
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273204
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273205
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273206
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273207
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273208
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273209
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273210
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273211
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273212
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273213
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273214
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273215
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273216
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273217
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273218
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273219
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273220
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273221
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273222
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273223
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273224
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273225
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273226
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273227
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273228
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273229
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273230
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273231
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273232
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273233
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273234
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273235
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273236
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273237
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273238
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273239
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273240
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273241
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273242
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273243
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273244
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273245
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273246
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273247
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273248
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273249
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273250
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273251
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273252
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273253
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273254
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273255
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273256
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273257
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273258
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273259
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273260
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273261
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273262
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273263
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273264
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273265
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273266
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273267
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273268
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273269
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273270
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273271
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273272
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273273
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273274
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273275
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273276
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273277
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273278
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273279
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273280
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273281
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273282
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273283
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273284
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273285
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273286
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273287
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273288
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273289
    m_Localized: "\"\uC5B4\uC11C \uC624\uC138\uC694, \uAD00\uCE21\uC790\uB2D8. \uC601\uC9C0
      \uB0B4 \uC0DD\uBA85 \uC720\uC9C0 \uC7A5\uCE58 \uBC0F \uC5D0\uD14C\uB974 \uC5D0\uB108\uC9C0
      \uD750\uB984, \uBAA8\uB450 \uC815\uC0C1\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC744
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273290
    m_Localized: "\"\uC5D8\uD53C\uC2A4\uB85C\uBD80\uD130 \uBBF8\uD655\uC778 \uB370\uC774\uD130\uAC00
      \uC218\uC2E0\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBD84\uC11D\uC744 \uC2DC\uC791\uD560\uAE4C\uC694?
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD310\uB2E8\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273291
    m_Localized: "\"\uC774 \uAD11\uD65C\uD55C \uC6B0\uC8FC\uC5D0\uC11C \uC88C\uD45C\uB97C
      \uC783\uC9C0 \uC54A\uB294 \uC720\uC77C\uD55C \uBC29\uBC95\uC740... \uBC14\uB85C
      \uB2F9\uC2E0\uC774 \uC81C \uACC1\uC5D0 \uC788\uB294 \uAC83\uC774\uACA0\uC8E0.
      \uD6C4\uD6C4, \uB18D\uB2F4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273292
    m_Localized: "\"\uCEE4\uD53C\uB77C\uB3C4 \uD55C \uC794 \uB0B4\uB824\uB4DC\uB9B4\uAE4C\uC694? 
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD734\uC2DD\uB3C4 \uC911\uC694\uD55C \uC784\uBB34\uC758
      \uC77C\uBD80\uB2C8\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273293
    m_Localized: "\"\uC800\uC758 \uCD5C\uC6B0\uC120 \uC120\uD0DD\uC0AC\uD56D\uC740
      \uC5B8\uC81C\uB098 \uAD00\uCE21\uC790\uB2D8\uC758 \uC548\uC804\uACFC \uC2B9\uB9AC\uC785\uB2C8\uB2E4.
      \uADF8\uB7EC\uB2C8 \uC548\uC2EC\uD558\uACE0 \uC9C0\uD718\uD574 \uC8FC\uC138\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273294
    m_Localized: "\"\uC624\uC168\uB098\uC694, \uAD00\uCE21\uC790\uB2D8? \uC624\uB298
      \uD6C8\uB828 \uC2A4\uCF00\uC904\uC740 \uD3C9\uC18C\uBCF4\uB2E4 1.5\uBC30 \uB354
      \uBE61\uBE61\uD558\uAC8C \uC7A1\uC544 \uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273295
    m_Localized: "\"\uB370\uC774\uD130\uB9CC \uBBFF\uB294\uB2E4\uBA74 \uC2E4\uC804\uC5D0\uC11C
      \uBB34\uB108\uC9C8 \uBFD0\uC774\uC5D0\uC694. \uB2F9\uC2E0\uC744 \uC704\uD574\uC11C
      \uB354\uB354\uC6B1 \uD558\uB4DC\uD55C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uC900\uBE44\uD574\uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273296
    m_Localized: "\"\uC6C0\uC9C1\uC784\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uB454\uD558\uB124\uC694.
      \uC544\uAE4C\uBD80\uD130 \uC800\uB97C \uD790\uB057 \uAC70\uB9AC\uC2DC\uB358\uB370
      \uD639\uC2DC......?\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273297
    m_Localized: "\"\uC2DC\uBBAC\uB808\uC774\uC158 \uC885\uB8CC. ...\uD765, \uC774\uBC88\uC5D4
      \uC81C\uBC95\uC774\uAD70\uC694. \uC544\uC8FC \uC870\uAE08\uC740, \uAD00\uCE21\uC790\uB2D8\uC744
      \uB2E4\uC2DC \uBD24\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2953080458273298
    m_Localized: "\"\uC804\uC7A5\uC740 \uC790\uBE44\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC5EC\uAE30\uC11C \uD758\uB9B0 \uB540\uBC29\uC6B8\uB9CC\uD07C\uC740
      \uB2F9\uC2E0\uC744 \uBC30\uC2E0\uD558\uC9C0 \uC54A\uC744\uAC70\uC5D0\uC694.
      \uC790, \uB2E4\uC74C \uC2DC\uBBAC\uB808\uC774\uC158\uC744 \uBC14\uB85C \uC9C4\uD589\uD574\uBCF4\uC8E0\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786195546112
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323328
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323329
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323330
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323331
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323332
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323333
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323334
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323335
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323336
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323337
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323338
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323339
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323340
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323341
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323342
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323343
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323344
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323345
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323346
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323347
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323348
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323349
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323350
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323351
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323352
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323353
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323354
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323355
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323356
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323357
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323358
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323359
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323360
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323361
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323362
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323363
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323364
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323365
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323366
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323367
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323368
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323369
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323370
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323371
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323372
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323373
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323374
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323375
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323376
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323377
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323378
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323379
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323380
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323381
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323382
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323383
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323384
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323385
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323386
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323387
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323388
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323389
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323390
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323391
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323392
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323393
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323394
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323395
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323396
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323397
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323398
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323399
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323400
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323401
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323402
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323403
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323404
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323405
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323406
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323407
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323408
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323409
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323410
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323411
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323412
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323413
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323414
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323415
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323416
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323417
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323418
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323419
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323420
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323421
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323422
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323423
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323424
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323425
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323426
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323427
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323428
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323429
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323430
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323431
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323432
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323433
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323434
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323435
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323436
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323437
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323438
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323439
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323440
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323441
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323442
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323443
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323444
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323445
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323446
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323447
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323448
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323449
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323450
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323451
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323452
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323453
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323454
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323455
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323456
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323457
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323458
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323459
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323460
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323461
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323462
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323463
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323464
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323465
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323466
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323467
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323468
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323469
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323470
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323471
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323472
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323473
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323474
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323475
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323476
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323477
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323478
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323479
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323480
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323481
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323482
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323483
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323484
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323485
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323486
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323487
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323488
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323489
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323490
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323491
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323492
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323493
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323494
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323495
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323496
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323497
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323498
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323499
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323500
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323501
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323502
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323503
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323504
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323505
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323506
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323507
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323508
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323509
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323510
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323511
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323512
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323513
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323514
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323515
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323516
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323517
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323518
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323519
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323520
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323521
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323522
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323523
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323524
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323525
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323526
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323527
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323528
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323529
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323530
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323531
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323532
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323533
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323534
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323535
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323536
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323537
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323538
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323539
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323540
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323541
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323542
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323543
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323544
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323545
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323546
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323547
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323548
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323549
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323550
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323551
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323552
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323553
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323554
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323555
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323556
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323557
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323558
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323559
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323560
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323561
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323562
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323563
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323564
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323565
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323566
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323567
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323568
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323569
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323570
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323571
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323572
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323573
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323574
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323575
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323576
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323577
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323578
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323579
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323580
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323581
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323582
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323583
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323584
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323585
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323586
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323587
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323588
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323589
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323590
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323591
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323592
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323593
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323594
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323595
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323596
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323597
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323598
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323599
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323600
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323601
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323602
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323603
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323604
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323605
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323606
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323607
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323608
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323609
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323610
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323611
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323612
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323613
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323614
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323615
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323616
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323617
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323618
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323619
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323620
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323621
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323622
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323623
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323624
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323625
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323626
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323627
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323628
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323629
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323630
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323631
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323632
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323633
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323634
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323635
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323636
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323637
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323638
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323639
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323640
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323641
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323642
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323643
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323644
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323645
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323646
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323647
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323648
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323649
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323650
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323651
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323652
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323653
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323654
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323655
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323656
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323657
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323658
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323659
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323660
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323661
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323662
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323663
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323664
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323665
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323666
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323667
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323668
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323669
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323670
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323671
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323672
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323673
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323674
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323675
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323676
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323677
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323678
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323679
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323680
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323681
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323682
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323683
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323684
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323685
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323686
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323687
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323688
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323689
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323690
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323691
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323692
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323693
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323694
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323695
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323696
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323697
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323698
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323699
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323700
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323701
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323702
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323703
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323704
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323705
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323706
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323707
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323708
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323709
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323710
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323711
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323712
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323713
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323714
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323715
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323716
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323717
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323718
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323719
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323720
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323721
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323722
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323723
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323724
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323725
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323726
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323727
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323728
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323729
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323730
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323731
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323732
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323733
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323734
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323735
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323736
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323737
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323738
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323739
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323740
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323741
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323742
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323743
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323744
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323745
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323746
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323747
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323748
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323749
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323750
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323751
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323752
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323753
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323754
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323755
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323756
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323757
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323758
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323759
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323760
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323761
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323762
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323763
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323764
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323765
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323766
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323767
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323768
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323769
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323770
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323771
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323772
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323773
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323774
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323775
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323776
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323777
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323778
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323779
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323780
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323781
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323782
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323783
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323784
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323785
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323786
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323787
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323788
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323789
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323790
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323791
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323792
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323793
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323794
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323795
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323796
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323797
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323798
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323799
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323800
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323801
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323802
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323803
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323804
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323805
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323806
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323807
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323808
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323809
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323810
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323811
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323812
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323813
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323814
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323815
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323816
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323817
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323818
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323819
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323820
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323821
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323822
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323823
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323824
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323825
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323826
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323827
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323828
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323829
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323830
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323831
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323832
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323833
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323834
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323835
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323836
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323837
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323838
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323839
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323840
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323841
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323842
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323843
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323844
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323845
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323846
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323847
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323848
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323849
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323850
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323851
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323852
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323853
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323854
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323855
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323856
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323857
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323858
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323859
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323860
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323861
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323862
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323863
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323864
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323865
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323866
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323867
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323868
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323869
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323870
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323871
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323872
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323873
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323874
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323875
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323876
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323877
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323878
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323879
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323880
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323881
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323882
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323883
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323884
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323885
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323886
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323887
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323888
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323889
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323890
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323891
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323892
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323893
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323894
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323895
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323896
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323897
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323898
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323899
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323900
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323901
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323902
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323903
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323904
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323905
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323906
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323907
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323908
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323909
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323910
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323911
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323912
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323913
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323914
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323915
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323916
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323917
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323918
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323919
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323920
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323921
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323922
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323923
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323924
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323925
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323926
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323927
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323928
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323929
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323930
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323931
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323932
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323933
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323934
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323935
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323936
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323937
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323938
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323939
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323940
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323941
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323942
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323943
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323944
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323945
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323946
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323947
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323948
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323949
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323950
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323951
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786212323952
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711936
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711937
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711938
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711939
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711940
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711941
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711942
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711943
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711944
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711945
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711946
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711947
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711948
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711949
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711950
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711951
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711952
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711953
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711954
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711955
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711956
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711957
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711958
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711959
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711960
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711961
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711962
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711963
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711964
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711965
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711966
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711967
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711968
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711969
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711970
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711971
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711972
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711973
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711974
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711975
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711976
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711977
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711978
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711979
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711980
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711981
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711982
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711983
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711984
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711985
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711986
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711987
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711988
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711989
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711990
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711991
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711992
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711993
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711994
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711995
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711996
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711997
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711998
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220711999
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712000
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712001
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712002
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712003
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712004
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712005
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712006
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712007
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712008
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712009
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712010
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712011
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712012
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712013
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712014
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712015
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712016
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712017
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712018
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712019
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712020
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712021
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712022
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712023
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712024
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712025
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712026
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712027
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712028
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712029
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712030
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712031
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712032
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712033
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712034
    m_Localized: "\uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uC73C\uB2C8 \uC81C\uAC00
      \uBC29\uBC95\uC744 \uC124\uBA85\uD574\uB4DC\uB9B4\uAED8\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712035
    m_Localized: "\uC800\uD76C \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uC5D0\uAC8C
      \uC788\uB294 \uC2A4\uD14C\uB9AC\uC544\uC758 \uD798\uC744 \uC77C\uAED8\uC6B0\uAE30
      \uC704\uD574\uC11C\uB294 \uC9C0\uD718\uAD00\uC758 \uC9C0\uD718\uAC00 \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712036
    m_Localized: "\uC6B0\uC120 \uC800\uB97C \uC120\uD0DD\uD574\uC11C \n\uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712037
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC758 \uC2A4\uD14C\uB9AC\uC544\uB294
      \uB113\uC740 \uBC94\uC704\uB97C \uC9C0\uB2C8\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712038
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712039
    m_Localized: "\uC2F8\uC6B8 \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694!
      \n\uC804\uD22C \uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712040
    m_Localized: "\uC73D\u2026! \uB05D\uB3C4\uC5C6\uC774 \uBAB0\uB824\uC624\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712041
    m_Localized: "\uC544\uBB34\uB798\uB3C4 [\uC2A4\uD14C\uB9AC\uC544]\uC758 \uD798\uC744
      \uC774\uB04C\uC5B4\uB0B4\uC57C \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712042
    m_Localized: "\uC2A4\uD154\uB77C \uB098\uC774\uCE20\uB4E4\uC740 \uC800\uB9C8\uB2E4
      \uACE0\uC720\uD55C [\uC2A4\uD14C\uB9AC\uC544]\uB97C \uBCF4\uC720\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712043
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uC9C0\uC2DC\uB97C \uB0B4\uB824\uC8FC\uC2E0\uB2E4\uBA74
      \uADF8 \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712044
    m_Localized: "\uC774\uC81C \uD798\uC744 \uC774\uB04C\uC5B4\uB0BC \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694! \uC9C0\uCF1C\uBD10\uC8FC\uC138\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712045
    m_Localized: "\uD734, \uBB34\uC0AC\uD788 \uB124\uD53C\uB9BC\uB4E4\uC744 \uBB3C\uB9AC\uCE60
      \uC218 \uC788\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712046
    m_Localized: "\uAE84\uC544\u2026..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712047
    m_Localized: "\uC800\uCABD \uBC29\uD5A5\uC5D0\uC11C \uB204\uAD70\uAC00\uC758
      \uBE44\uBA85\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712048
    m_Localized: "\uB2E4\uB978 \uB3D9\uB8CC\uB4E4\uB3C4 \uC704\uD5D8\uD560\uC9C0
      \uBAB0\uB77C\uC694. \uAD00\uCE21\uC790\uB2D8, \uC9C0\uAE08 \uC0C1\uD669\uC774
      \uD798\uB4E4\uACE0 \uB2F9\uD669\uC2A4\uB7EC\uC6B0\uC2DC\uACA0\uC9C0\uB9CC \uC870\uAE08\uB9CC
      \uB354 \uD798\uB0B4\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712049
    m_Localized: "\uC5D0\uC787\u2026.! \uADF8\uB9CC \uC880 \uB2E4\uAC00\uC640 \uC774
      \uB354\uB7EC\uC6B4 \uB124\uD53C\uB9BC \uB188\uB4E4\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712050
    m_Localized: "\uC720\uB2C8! \uBB34\uC0AC\uD588\uAD6C\uB098!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712051
    m_Localized: "\uC557?! \uC544\uD2F0\uB791 \uAD00\uCE21\uC790\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712052
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC800\uD76C\uB3C4 \uC804\uD22C\uC5D0
      \uD569\uB958\uD574\uC57C \uD560 \uAC83 \uAC19\uC544\uC694! \uB2E4\uC2DC \uD55C
      \uBC88 \uC9C0\uD718\uB97C..!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712053
    m_Localized: "\uAD00\uCE21\uC790! \uB0B4 [\uC2A4\uD14C\uB9AC\uC544]\uB294 \uAE30\uC5B5\uD558\uACE0
      \uC788\uC9C0?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712054
    m_Localized: "\uB098\uB294 \uC544\uD2F0 \uCC98\uB7FC \uADFC\uC721\uC9C8\uC774
      \uC544\uB2C8\uB2C8\uAE4C, \uC704\uCE58 \uC120\uC815\uC5D0 \uC870\uC2EC\uD574\uC57C\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712055
    m_Localized: "\uAC00\uC774\uB4DC: \uC2A4\uD154\uB77C \uB9C8\uD0C0\uAC00 \uACF5\uBA85\uD558\uACE0
      \uC788\uC5B4\uC694! \n\uAC19\uC740 \uC131\uAD70\uC5D0 \uC18C\uC18D\uB41C \uACBD\uC6B0
      \uACF5\uBA85\uC744 \uD1B5\uD574 \uCD94\uAC00\uC801\uC778 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712056
    m_Localized: "\uC0DD\uC131\uB41C \uCD08\uC2E0\uC131\uC744 \uC544\uD2B8\uB808\uC2DC\uC544\uC5D0\uAC8C
      \uC804\uB2EC\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712057
    m_Localized: "\uD5E4\uD5F7..! \uB4E0\uB4E0\uD55C\uAC78!?\n\uC774\uC81C \uB9C8\uC74C\uAECF
      \uC2F8\uC6B8 \uC218 \uC788\uACA0\uC5B4. \n\uADF8\uB7FC \uAC04\uB2E4! \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712058
    m_Localized: "\uB124\uD53C\uB9BC \uB140\uC11D\uB4E4 \uAE4C\uBD88\uC5C8\uACA0\uB2E4\u2026!
      \uB0B4 \uC228\uACA8\uC9C4 \uD798\uC744 \uBCF4\uC5EC\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712059
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC918! \uC544\uD2F0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712060
    m_Localized: "\uC9C0\uD718\uAD00, \uB2E4\uC2DC\uD55C \uBC88 \uC800\uC5D0\uAC8C
      \uC2A4\uD14C\uB9AC\uC544\uC758 \uBC1C\uD604\uC744\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712061
    m_Localized: "\uC800\uAE30\uC5D0 \uD0C4\uD53C\uAC00 \uB5A8\uC5B4\uC838 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712062
    m_Localized: "\uC774\uAC74\u2026. \uD544\uB9AC\uC544\uAC00 \uB0A8\uAE34 \uD0C4\uD53C?\n\uADFC\uCC98\uC5D0
      \uD544\uB9AC\uC544\uAC00 \uC788\uB294 \uAC83 \uAC19\uC544\uC694. \uC11C\uB458\uB7EC
      \uCC3E\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712063
    m_Localized: "\u2026..\uD0C4\uD53C\uAC00 \uAC70\uC758 \uB2E4 \uB5A8\uC5B4\uC838\uAC00\uACE0
      \uC788\uC5B4. \uC774\uB300\uB85C \uC788\uB2E4\uAC04 \uC704\uD5D8\uD574\uC9C0\uACE0
      \uB9D0\uAC70\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712064
    m_Localized: "\uC774 \uBAB8 \uB4F1\uC7A5!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712065
    m_Localized: "\uC720\uB2C8?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712066
    m_Localized: "\uD544\uB9AC\uC544! \uAD1C\uCC2E\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712067
    m_Localized: "\uC774 \uBAB8\uC744 \uAE30\uB2E4\uB9B0 \uAC83\uC778\uAC00? \uD544\uB9AC\uC5EC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712068
    m_Localized: "\uD5DB\uC18C\uB9AC \uD558\uB294 \uAC83 \uBCF4\uB2C8 \uBA40\uCA61\uD55C\uAC00
      \uBCF4\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712069
    m_Localized: "\uC544\uB2C8\uB77C\uACE0 \uD558\uACE0 \uC2F6\uC9C0\uB9CC, \uC704\uD5D8\uD55C
      \uC0C1\uD669\uC774\uC5C8\uC5B4 \uACE0\uB9C8\uC6CC\uC694 \uBAA8\uB450\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712070
    m_Localized: "\uB514\uD39C\uB354\uC5D0\uC694! \uAC15\uB825\uD55C \uBC29\uC5B4\uB825\uC744
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uB124\uD53C\uB9BC \uAC1C\uCCB4\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712071
    m_Localized: "\uAD00\uCE21\uC790! \uD569\uB958\uD574\uC11C \uC5BC\uB978 \uC4F8\uC5B4\uBC84\uB9AC\uC790\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712072
    m_Localized: "\uB9C8\uC2A4\uD130. \uC81C [\uC2A4\uD14C\uB9AC\uC544]\uC774\uB77C\uBA74
      \n\uCDA9\uBD84\uD788 \uC0C1\uB300\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712073
    m_Localized: "\uAC00\uC774\uB4DC: \uD544\uB9AC\uC544\uB294 \uB192\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uAE30\uC0AC\uB85C\uC11C, \n\uC801\uC758 \uBC29\uC5B4
      \uC800\uD56D\uB825\uC744 \uBB34\uC2DC\uD558\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712074
    m_Localized: "\uB9C8\uC2A4\uD130. \uC800\uB294 \uBA40\uB9AC\uC788\uB294 \uC801\uC744
      \uC0C1\uB300\uD560 \uB54C \uAC00\uC7A5 \uAC15\uD55C \uC704\uB825\uC744 \uBC1C\uD718\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712075
    m_Localized: "\uC704\uCE58\uB97C \uC870\uC815\uD574 \uB514\uD39C\uB354\uC640
      \uC9C1\uC120 \uC704\uCE58\uB85C \uC774\uB3D9\uC2DC\uCF1C\uC8FC\uC2DC\uAE38
      \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712076
    m_Localized: "\uAC00\uC774\uB4DC: \uC18D\uC131\uB825\uC774 \uCC28\uC624\uB974\uACE0
      \uC788\uB124\uC694. \uAC19\uC740 \uC18D\uC131\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uBC30\uCE58\uD558\uB294 \uACBD\uC6B0 \n\uC18D\uC131\uB825\uC774 \uACF5\uBA85\uD574
      \uBC30\uCE58\uB41C \uAE30\uC0AC\uB4E4\uC758 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712077
    m_Localized: "\uB9C8\uC2A4\uD130. \uC660\uC9C0 \uB354 \uCE58\uBA85\uC801\uC778
      \uACF5\uACA9\uC744 \uD560 \uC218 \uC788\uC744 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712078
    m_Localized: "\uADF8\uB7FC \uB3CC\uC785\uD569\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712079
    m_Localized: "\uC790\uACE0\uB85C \uBA85\uC0AC\uC218\uB77C\uBA74 \uC544\uBB34\uB9AC
      \uD798\uB4E0 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uD45C\uC801\uC744 \uB193\uCE58\uC9C0
      \uC54A\uB294\uBC95\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712080
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC800\uACF3\uC5D0\uC11C \uC2DD\uC2A4\uD63C\uC758
      \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB824\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712081
    m_Localized: "\uC5B4?! \uC800\uACF3\uC5D0 \uD54F\uC790\uAD6D\uC774 \uB0A8\uC544\uC788\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712082
    m_Localized: "\uC800\uD76C\uB97C \uC81C\uC678\uD558\uBA74 \uD604\uC7AC \uD568\uC120\uC5D0
      \uC788\uB294 \uC0DD\uBA85\uCCB4\uB294 \uD074\uB808\uC774 \uBFD0\uC774\uC5D0\uC694\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712083
    m_Localized: "\uC544\uBB34\uB798\uB3C4 \uD54F\uC790\uAD6D\uC744 \uB530\uB77C\uAC00\uAE30
      \uC704\uD574\uC11C\uB294 \uC2DD\uC2A4\uD63C\uC744 \uBB3C\uB9AC\uCCD0\uC57C
      \uD560 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712084
    m_Localized: "\uC2DD\uC2A4\uD63C\uC740 \uAC15\uB825\uD55C \uB124\uD53C\uB9BC\uC785\uB2C8\uB2E4.
      \uC9C0\uAE08\uAE4C\uC9C0 \uBC30\uC6B4 \uB0B4\uC6A9\uC73C\uB85C \uBB3C\uB9AC\uCCD0\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712085
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uB2E4\uC2DC \uD55C\uBC88 \uC9C0\uD718\uB97C...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712086
    m_Localized: "\uC9C0\uAE08\uBD80\uD130 \uBC30\uC18D \uAE30\uB2A5\uC744 \uC774\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712087
    m_Localized: "\uBC30\uC18D \uAE30\uB2A5\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712088
    m_Localized: "\uC548\uB155\uD558\uC138\uC694 \uAD00\uCE21\uC790\uB2D8. \uBB34\uC0AC\uD788
      \uB3CC\uC544\uC624\uC154\uC11C \uB2E4\uD589\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712089
    m_Localized: "\uD1B5\uC2E0\uC7A5\uCE58\uC758 \uD30C\uAD34\uB85C \uC5F0\uB77D\uC744
      \uB4DC\uB9B4 \uC218 \uC5C6\uC5B4 \uAC71\uC815\uD588\uAC70\uB4E0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712090
    m_Localized: "\uC544\uC557\u2026\uB9DE\uB2E4! \uAE30\uC5B5\uC744 \uC783\uC73C\uC168\uB2E4\uACE0
      \uD588\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712091
    m_Localized: "\uC800\uB294 \uD50C\uB808\uC774\uC544\uB370\uC2A4 \uC804\uC18D
      \uC624\uD37C\uB808\uC774\uD130 \uC544\uC2A4\uB098\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712092
    m_Localized: "(\uBC29\uAE0B \uC6C3\uC73C\uBA70) \uB2E4\uC2DC \uD55C \uBC88 \uC798
      \uBD80\uD0C1\uB4DC\uB9B4\uAC8C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712093
    m_Localized: "\uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8\uC774 \uC81C\uAC8C
      \uAD00\uCE21\uC790\uB2D8 \uAED8\uC11C \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC744
      \uC218 \uC788\uB3C4\uB85D \uB3C4\uC6B0\uB77C\uB294 \uBA85\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712094
    m_Localized: "\uAD00\uCE21\uC790\uB2D8 \uC774\uAC74 \uAE30\uC5B5\uB098\uC2DC\uB098\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712095
    m_Localized: "\uAD00\uCE21\uC790\uB780, \uAD00\uCE21 \uAE30\uAD6C H.O.P.E\uB97C
      \uD1B5\uD574 \uC2A4\uD154\uB77C \uB098\uC774\uD2B8\uAC00 \uB420 \uC18C\uB140\uB4E4\uC744
      \uAD00\uCE21\uD558\uACE0,\n\uADF8\uB4E4\uC744 \uCC3E\uC544\uB0B4 \uBCC4\uC758
      \uD798\uC744 \uAC01\uC131\uC2DC\uD0A4\uB294 \uC790\uB4E4\uC744 \uB73B\uD55C\uB2E4\uB294
      \uAC83\uC744\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712096
    m_Localized: "\uD558\uC9C0\uB9CC \uC9C0\uAE08\uC740 \uAE09\uD55C \uB9CC\uD07C!
      \uC7AC\uD074\uB9B0 \uBD80\uD568\uC7A5\uB2D8 \uAED8\uC11C \uBBF8\uB9AC \uD638\uCD9C\uD574\uB454
      \uAE30\uC0AC\uB4E4 \uC911 \uC791\uC804\uC5D0 \uD544\uC694\uD55C \uC778\uC6D0\uC744
      \uCD94\uB824\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712097
    m_Localized: "\uADF8\uB7FC \uD568\uAED8 \uC791\uC804\uC744 \uC218\uD589\uD560
      \uAE30\uC0AC\uB4E4\uC744 \uD655\uC778\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712098
    m_Localized: "\uC791\uC804\uC774 \uC704\uD5D8\uD560 \uC218 \uC788\uC73C\uB2C8
      \uC77C\uB2E8 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744 \uBAA8\uC9D1\uD574\uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712099
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694! \uC5ED\uC2DC \uAD00\uCE21\uC790\uB2D8\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712100
    m_Localized: "\uC774\uBC88\uC5D4 \uBAA8\uC9D1\uD55C \uAE30\uC0AC\uB4E4\uC774
      \uC274 \uC7A5\uC18C\uB97C \uAC74\uC124\uD574 \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712101
    m_Localized: "\uC6B0\uC120 \uC81C\uD074\uB9B0\uB2D8\uC774 \uC8FC\uC2E0 \uAE30\uC0AC\uB4E4\uC744
      \uBAA8\uC9D1\uD560 \uC218 \uC788\uB294 \uD2F0\uCF13\uC744 \uC218\uB839\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712102
    m_Localized: "\uC640! \uC774\uB9CC\uD07C\uC774\uB098 \uC8FC\uC2DC\uB2E4\uB2C8,
      \uC774\uBC88 \uC784\uBB34\uAC00 \uB9E4\uC6B0 \uC911\uC694\uD55C\uAC00\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712103
    m_Localized: "\uC6B0\uC120 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC774 \uC785\uB2E8\uD55C
      \uB9CC\uD07C, \uC0C8\uB85C\uC6B4 \uC219\uC18C\uAC00 \uD544\uC694\uD560 \uAC83
      \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712104
    m_Localized: "\uC804\uB2EC\uBC1B\uC740 \uAC74\uC124 \uC7AC\uB8CC\uB97C \uD65C\uC6A9\uD574
      \uC804\uCD08\uAE30\uC9C0\uC778 '\uD5C8\uBE14'\uC5D0 \uC219\uC18C\uB97C \uC81C\uC791\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712105
    m_Localized: "\uC774\uACF3\uC744 \uC120\uD0DD\uD558\uBA74 \uC218\uB9AC \uB4DC\uB860\uB4E4\uC774
      \uC219\uC18C\uB97C \uBCF5\uAD6C\uD574\uC904\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712106
    m_Localized: "\uBCF5\uAD6C\uC5D0\uB294 \uAC74\uC124 \uC7AC\uB8CC\uB4E4\uC774
      \uB4E4\uC5B4\uAC00\uC9C0\uB9CC, \n\uC774\uBC88\uC5D4 \uBD80\uD568\uC7A5\uB2D8
      \uAED8\uC11C \uC81C\uACF5\uD574\uC8FC\uC168\uC5B4\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712107
    m_Localized: "\uD5C8\uBE14\uC5D0 \uC219\uC18C\uAC00 \uB298\uC5B4\uB0A0\uC218\uB85D
      \uC804\uD22C\uC5D0 \uCC38\uC5EC \uAC00\uB2A5\uD55C \uC778\uC6D0\uC774 \uB298\uC5B4\uB098\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712108
    m_Localized: "\uD558\uC9C0\uB9CC, \uD604\uC7AC \uD5C8\uBE14\uC758 \uB3D9\uB825\uC774
      \uBD80\uC871\uD574\uC11C \uCD94\uAC00\uC801\uC778 \uBCF5\uAD6C\uB294 \uD798\uB4E4
      \uAC83 \uAC19\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712109
    m_Localized: "\uC774\uBC88\uC5D4 \uC0C8\uB85C\uC6B4 \uAE30\uC0AC\uB4E4\uC744
      \uC131\uC7A5\uC2DC\uD0A4\uB294 \uBC29\uBC95\uC744 \uC54C\uC544\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712110
    m_Localized: "\uC784\uBB34\uC744 \uC704\uD574 \uB5A0\uB098\uAE30 \uC804 \uD604\uC7AC\uAE4C\uC9C0
      \uC131\uB2E8\uC5D0 \uCC38\uC5EC\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712111
    m_Localized: "\uC774 \uACF3 '\uAE30\uC0AC \uAD00\uB9AC' \uBC84\uD2BC\uC744 \uD1B5\uD574
      \uD604\uC7AC \uBCF4\uC720\uD55C \uAE30\uC0AC\uB4E4\uC758 \uC0C1\uD0DC\uB97C
      \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712112
    m_Localized: "\uC640 \uC0C8\uB85C\uC6B4 \uC131\uB2E8\uC6D0 \uBD84\uB4E4\uC774
      \uB9CE\uC774 \uBAA8\uC5EC\uACC4\uC2DC\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712113
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544 \uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712114
    m_Localized: "\uAE30\uC0AC\uC758 \uC131\uC7A5\uC5D0\uB294 '\uC804\uD22C \uB370\uC774\uD130'\uAC00
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712115
    m_Localized: "\uC804\uD22C \uB370\uC774\uD130'\uB294 \uC2A4\uD14C\uC774\uC9C0\uB098
      \uB2E4\uB978 \uD0D0\uD5D8\uC744 \uD1B5\uD574 \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712116
    m_Localized: "\uADF8\uB7FC \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C
      \uC131\uC7A5\uC2DC\uCF1C \uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712117
    m_Localized: "\uC640\uC544! \uAE30\uC0AC\uAC00 \uC131\uC7A5\uD588\uC5B4\uC694.
      \uC5BC\uB9C8\uB098 \uAC15\uD574\uC84C\uB294\uC9C0\uB294 \uC774\uACF3\uC744
      \uD1B5\uD574 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712118
    m_Localized: "\uADF8\uB7FC \uC900\uBE44\uB3C4 \uB9C8\uCCE4\uC73C\uB2C8. \uD074\uB808\uC774\uC528\uC758
      \uBAA9\uC801\uC9C0\uC778 \n'\uC544\uB974\uCF00'\uB85C \uC88C\uD45C\uB97C \uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712119
    m_Localized: "\uC544\uC2A4\uB098\uC528 \uBD80\uD0C1\uB4DC\uB824\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712120
    m_Localized: "\uB878\uC800. \uC2DC\uC2A4\uD15C \uC62C \uADF8\uB9B0. \uB77C\uC774\uD2B8
      \uBE0C\uB9C1\uC5B4. \uC544\uB974\uCF00\uB85C \uCD9C\uD56D\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712121
    m_Localized: "\uC2B9\uBB34\uC6D0 \uC5EC\uB7EC\uBD84 \uAED8\uC11C\uB294 \uAF49
      \uC7A1\uC73C\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712122
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694! \uADF8 \uC9C0\uC5ED\uC5D0 \uC9C0\uB8B0\uAC00
      \uB9E4\uC124\uB418\uC5B4 \uC788\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712123
    m_Localized: "\uC9C0\uB8B0\uB77C\uB2C8\u2026? \uC544\uC9C1 \uB124\uD53C\uB9BC\uC73C\uB85C
      \uBD80\uD130 \uC800\uD56D\uD558\uB294 \uC778\uB958\uAC00 \uC544\uC9C1 \uC0AC\uB294
      \uAC83\uC77C\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712124
    m_Localized: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uC800\uAC83\uC744
      \uC798 \uD65C\uC6A9\uD558\uBA74 \n\uB124\uD53C\uB9BC\uB4E4\uC744 \uC77C\uAC70\uC5D0
      \uC4F8\uC5B4\uBC84\uB9B4 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712125
    m_Localized: "\uADF8 \uC791\uC804\uC744 \uC4F0\uC790\uB294 \uAC70\uC9C0? \uC77C\uBA85
      \uB204\uC6CC\uC11C \uB124\uD53C\uB9BC \uAD34\uB86D\uD788\uAE30 \uC600\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712126
    m_Localized: "...\uB204\uC6CC\uC11C \uB5A1\uBA39\uAE30\uC785\uB2C8\uB2E4. \uC720\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712127
    m_Localized: "\uADF8\uAC8C \uADF8\uAC70\uC9C0! \uC5B4\uCA0B\uB4E0 \uC800 \uC9C0\uB8B0\uC5D0
      \uB124\uD53C\uB9BC\uC744 \uC720\uC778\uD558\uBA74 \uB418\uB294\uAC70\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712128
    m_Localized: "\uADF8\uB7FC \uC720\uC778\uC740 \uC81C\uAC00 \uB9E1\uB3C4\uB85D
      \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712129
    m_Localized: "\uC800\uB97C \uC774 \uC601\uC5ED\uC5D0 \uBC30\uCE58\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712130
    m_Localized: "\uC5ED\uC2DC \uAD00\uCE21\uC790 \uB2D8! \uD6CC\uB96D\uD55C \uC9C0\uD718\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712131
    m_Localized: "\uB9C8\uCE68 \uC2E0\uADDC \uC131\uB2E8\uC6D0\uB4E4\uB3C4 \uBCF4\uCDA9\uB418\uC5C8\uC73C\uB2C8
      \uC804\uD22C\uC5D0 \uCC38\uC5EC\uC2DC\uCF1C\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712132
    m_Localized: "\uC774\uC81C \uC784\uBB34\uB97C \uC218\uD589\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712133
    m_Localized: "\uADF8\uB7FC \uAC11\uB2C8\uB2E4. \uC778\uCE74\uC6B4\uD130!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712134
    m_Localized: "\uC720\uB2C8, \uADF8 \uBC18\uC9DD\uC774\uB294 \uAC74 \uBB50\uC5D0\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712135
    m_Localized: "\uC544\u2026\uC544\uB0D0! \uC774\uAC74 \uADF8\uB7EC\uB2C8\uAE4C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712136
    m_Localized: "...\uD5E4\uD5E4. \uADF8\uB0E5 \uC774\uC058\uB2E4 \uBCF4\uB2C8 \uC8FC\uC6E0\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712137
    m_Localized: "\uC720\uB2C8\u2026 \uAE09\uBC15\uD55C \uC804\uD22C \uC911\uC5D0
      \uAC1C\uBCC4 \uD589\uB3D9\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712138
    m_Localized: "\uBBF8... \uBBF8\uC548\uD574! \uADF8\uB798\uB3C4 \uC774\uAC70,
      \uC544\uAE4C '\uC704\uC0C1\uC758 \uADF8\uB9BC\uC790'\uAC00 \uC0AC\uB77C\uC9C4
      \uC790\uB9AC\uC5D0...!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712139
    m_Localized: "\uC557... \uC7A0\uAE50\uB9CC\uC694, \uC720\uB2C8 \uC528! \uADF8\uAC70
      \uD639\uC2DC... '\uC18D\uC131\uC11D'\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712140
    m_Localized: "\u2018\uC18D\uC131\uC11D\u2019\uC774\uC694? \uAE30\uC0AC\uC758
      \uD55C\uACC4\uB97C \uB3CC\uD30C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC900\uB2E4\uB294
      \uADF8 \uAD11\uC11D\uC774 \uC774\uACF3\uC5D0 \uC788\uB2E4\uB2C8..."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712141
    m_Localized: "\uC798\uB418\uC5C8\uB124\uC694! \uC7AC\uC815\uBE44\uB97C \uD558\uB294
      \uB3D9\uC548, \uADF8 \uB3CC\uC744 \uC774\uC6A9\uD574 \uAE30\uC0AC\uB4E4\uC758
      \uC7A0\uC7AC\uB825\uC744 \uC774\uB04C\uC5B4\uB0B4 \uBCF4\uC8E0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712142
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC6B0\uC120 \uC815\uBE44\uB97C \uC704\uD574
      \uC5D8\uD53C\uC2A4\uB85C \uBCF5\uADC0\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712143
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB300\uAE30\uC911\uC778 \uAE30\uC0AC\uB4E4\uC744
      \uC0B4\uD3B4\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712144
    m_Localized: "\uC774\uBC88\uC5D4 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uB97C \uB354
      \uAC15\uD558\uAC8C \uB9CC\uB4E4 \uCC28\uB840\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712145
    m_Localized: "\uB9C8\uCE68 \uC774\uC804\uC5D0 \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8
      \uAED8\uC11C \uC8FC\uC2E0 \uC131\uC7A5 \uB370\uC774\uD130\uAC00 \uB0A8\uC558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712146
    m_Localized: "\uB808\uBCA8\uC5C5\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544\uB97C
      10\uAE4C\uC9C0 \uC131\uC7A5\uC2DC\uCF1C\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712147
    m_Localized: "\uC640 \uC544\uD2B8\uB808\uC2DC\uC544\uC528\uAC00 \uD55C\uACC4
      \uAE4C\uC9C0 \uC131\uC7A5\uD588\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712148
    m_Localized: "10\uB808\uBCA8 \uB9C8\uB2E4 \uAE30\uC0AC\uB4E4\uC740 \uC131\uC7A5\uC758
      \uD55C\uACC4\uC5D0 \uB2E4\uB2E4\uB985\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712149
    m_Localized: "\uC774 \uB54C \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uCD5C\uB300
      \uC131\uC7A5\uC2DC\uD0AC \uC218 \uC788\uB294 \uB808\uBCA8\uC744 \uC62C\uB824\uC904
      \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712150
    m_Localized: "\uC774\uBC88\uC5D4 \uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uD55C\uACC4 \uB3CC\uD30C\uB97C \uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712151
    m_Localized: "\uD55C\uACC4 \uB3CC\uD30C\uB97C \uD1B5\uD574 \uAE30\uC0AC\uC758
      \uCD5C\uB300 \uB808\uBCA8\uC774 \uC0C1\uC2B9\uD558\uACE0 \uB2A5\uB825\uCE58\uB3C4
      \uD06C\uAC8C \uC0C1\uC2B9\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712152
    m_Localized: "\uC774\uB807\uAC8C \uAC15\uD574\uC9C0\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00
      \uC778\uB958\uAC00 \uC544\uD06C\uB97C \uB418\uCC3E\uC744 \uC218 \uC788\uC744\uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712153
    m_Localized: "\uADF8\uB7FC \uC774\uC81C \uB2E4\uC2DC \uD074\uB808\uC774\uC528\uB97C
      \uCC3E\uC73C\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712154
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D4 \uC18D\uC131\uC758
      \uC0C1\uAD00 \uAD00\uACC4\uC5D0 \uB300\uD574 \uACF5\uBD80\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712155
    m_Localized: "\uB124\uD53C\uB9BC\uB4E4\uC740 \uCD1D 6\uAC00\uC9C0\uC758 \uC18D\uC131\uC73C\uB85C
      \uB098\uB258\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712156
    m_Localized: "\uAC01\uAC01\uC758 \uC18D\uC131\uC740 \uC0C1\uAD00\uAD00\uACC4\uAC00
      \uC874\uC7AC\uD558\uBA70, \n\uC57D\uC810\uC778 \uC18D\uC131\uC73C\uB85C \uACF5\uACA9\uD560
      \uACBD\uC6B0 \uB354\uC6B1 \uAC15\uD55C \uD53C\uD574\uB97C \uC785\uD790 \uC218
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712157
    m_Localized: "\uBAAC\uC2A4\uD130\uC758 \uC18D\uC131\uC740 \uC774\uACF3\uC5D0\uC11C
      \uD655\uC778 \uAC00\uB2A5\uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712158
    m_Localized: "\uB9C8\uCE68 \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC18D\uC131\uC774
      \uBB3C\uC18D\uC131\uC774\uB124\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712159
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544\uC528\uC640 \uD544\uB9AC\uC544\uC528\uB294
      \uC804\uAE30 \uC18D\uC131\uC774\uB2C8 \uB354 \uAC15\uD55C \uD53C\uD574\uB97C
      \uC785\uD790 \uC218 \uC788\uACA0\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712160
    m_Localized: "\uBC18\uB300\uB85C \uC720\uB2C8\uC528\uB294 \uBD88 \uC18D\uC131\uC774\uB77C
      \uD3C9\uC18C\uBCF4\uB2E4 \uD798\uC744 \uB0BC \uC218 \uC5C6\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712161
    m_Localized: "\uC720\uB2C8\uC528\uB97C \uC804\uD22C\uC5D0\uC11C \uC81C\uC678\uD558\uACE0
      \uC774\uBC88\uC5D0 \uC0C8\uB85C\uC624\uC2E0 \uBD84\uB4E4\uC744 \uD65C\uC6A9\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712162
    m_Localized: "\uC900\uBE44\uAC00 \uB2E4 \uB418\uC168\uB2E4\uBA74 \uC804\uD22C
      \uC2DC\uC791\uC744 \uB20C\uB7EC \uB124\uD53C\uB9BC\uB4E4\uC744 \uD63C\uB0B4\uC8FC\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712163
    m_Localized: "\uBE45\uB9C8\uC6B0\uC2A4\uB294 \uD070 \uC785\uC744 \uC774\uC6A9\uD574
      \uB3CC\uC9C4\uD574 \uC9C1\uC120 \uAC70\uB9AC\uC758 \uAE30\uC0AC\uB4E4\uC744
      \uACF5\uACA9\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712164
    m_Localized: "\uC9C1\uC120 \uAC70\uB9AC\uC5D0 \uAE30\uC0AC\uB4E4\uC774 \uBAA8\uC774\uC9C0
      \uC54A\uB3C4\uB85D \uBC30\uCE58\uC5D0 \uC8FC\uC758\uD558\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712165
    m_Localized: "\uC624\uC168\uAD70\uC694 \uAD00\uCE21\uC790\uB2D8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712166
    m_Localized: "\uC548\uADF8\uB798\uB3C4 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00\uB2D8\uC774
      \uBD80\uD0C1\uD558\uC2E0 \uBB3C\uD488\uC744 \uC804\uB2EC\uD558\uAE30 \uC704\uD574
      \uC5B8\uC81C\uCBE4 \uC624\uC2DC\uB098 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712167
    m_Localized: "\uCA14\uC794! \uC774 '\uAE30\uC5B5\uC758 \uC870\uAC01'\uC73C\uB85C
      \uB9D0\uD558\uC790\uBA74, \uC2A4\uD14C\uB9AC\uC544\uC758 \uC228\uACA8\uC9C4
      \uD798\uC744 \uC774\uB04C\uC5B4\uB0B4\uB294 \uC18C\uC911\uD55C \uBB3C\uD488\uC774\uC5D0\uC694!
      \n\uC7AC\uC815\uC5D0 \uC5C4\uACA9\uD558\uC2E0 \uC7AC\uD074\uB9B0 \uBD80\uC0AC\uB839\uAD00
      \uB2D8\uAED8\uC11C \uC774\uB7F0 \uADC0\uD55C \uAC83\uC744 \uC8FC\uC2DC\uB2E4\uB2C8\u2026.!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712168
    m_Localized: "\uC544 \uCC38, \uB0B4 \uC815\uC2E0 \uC880 \uBD10. \uBC14\uB85C
      \uAE30\uC0AC\uB4E4\uC744 \uAC15\uD654\uD574\uBCF4\uB3C4\uB85D \uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712169
    m_Localized: "\uB9C8\uCE68 \uC774\uC804 \uC804\uD22C\uC5D0\uC11C \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uC758 \uAE30\uC5B5\uC870\uAC01\uC744 \uD68D\uB4DD\uD588\uC73C\uB2C8
      \uC774\uB97C \uD65C\uC6A9\uD574\uBD10\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712170
    m_Localized: "\uCD08\uC6D4\uC740 \uAE30\uC0AC\uB4E4\uC758 \uAE30\uC5B5 \uC870\uAC01\uC744
      \uBAA8\uC544 \uAE30\uC0AC\uC758 \uC228\uACA8\uC9C4 \uC7A0\uC7AC\uB825\uC744
      \uB04C\uC5B4\uB0BC \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712171
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC544\uD2B8\uB808\uC2DC\uC544
      \uC528\uB97C \uCD08\uC6D4\uC2DC\uCF1C \uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712172
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD588\uC5B4\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712173
    m_Localized: "\uCD08\uC6D4\uC5D0 \uC131\uACF5\uD560 \uACBD\uC6B0 \uB2A5\uB825\uCE58\uAC00
      \uD06C\uAC8C \uC0C1\uC2B9\uD558\uACE0, Passive \uC2A4\uD0AC\uC774 \uAC15\uD654\uB418\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712174
    m_Localized: "\uC774\uC81C \uC131\uC7A5\uB3C4 \uC644\uB8CC\uD588\uC73C\uB2C8
      \uC81C\uD074\uB9B0 \uC911\uC7A5\uB2D8\uC774 \uC120\uBB3C\uD574\uC8FC\uC2E0
      \uB0A8\uC740 \uC7AC\uB8CC\uB4E4\uC744 \uC0B4\uD3B4\uBCF4\uB7EC \uAC00\uC694!."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712175
    m_Localized: "\uC774\uAC74\u2026.\uBD80\uC0AC\uB839\uAD00\uB2D8\uC758 \uB450\uBC88\uC9F8
      \uC120\uBB3C! \uAD00\uCE21\uC790\uB2D8, \uBB34\uB824 [\uCF54\uC5B4]\uB77C\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712176
    m_Localized: "\uCF54\uC5B4?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712177
    m_Localized: "\uCF54\uC5B4\uB294 \uB9E4\uC6B0\uADC0\uD55C \uAC00\uCE58\uB97C
      \uC9C0\uB2C8\uACE0 \uC788\uB294 \uD5C8\uBE14\uC758 \uD544\uC218 \uB3D9\uB825\uC6D0\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712178
    m_Localized: "\uCF54\uC5B4\uB97C \uC124\uCE58\uD558\uBA74 [\uD5C8\uBE14]\uC758
      \uC804\uB825\uC744 \uBCF5\uC6D0\uD558\uACE0 \uCD94\uAC00\uC801\uC778 \uAC74\uCD95\uBB3C\uB4E4\uC744
      \uC774\uC6A9\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712179
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uC784\uBB34\uC5D0 \uD22C\uC785\uB418\uAE30
      \uC804 \uCF54\uC5B4\uB97C \uD1B5\uD574 \uD5C8\uBE14\uC744 \uD655\uC7A5 \uD558\uBA74
      \uC5B4\uB5A8\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712180
    m_Localized: "\uC989\uC2DC \uCF54\uC5B4\uC758 \uCD94\uAC00 \uC124\uCE58\uB97C
      \uC704\uD574 \uD5C8\uBE14\uC758 \uCEE4\uBA58\uB4DC \uC13C\uD130\uB85C \uC774\uB3D9\uD574\uBCF4\uC790\uAD6C\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712181
    m_Localized: "\uC774\uACF3\uC5D0 \uC120\uBB3C\uBC1B\uC740 \uCF54\uC5B4\uB97C
      \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712182
    m_Localized: "\uC6B0\uC640! \uD5C8\uBE14\uC758 \uB3D9\uB825\uB4E4\uC774 \uBCF5\uAD6C\uB418\uACE0
      \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712183
    m_Localized: "\uB3D9\uB825 \uBD80\uC871\uC73C\uB85C \uC124\uCE58\uD558\uC9C0
      \uBABB\uD588\uB358 \uAC74\uBB3C\uB4E4\uC744 \uC774\uC81C \uC774\uC6A9\uD560
      \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712184
    m_Localized: "\uBC14\uB85C \uC124\uCE58\uD558\uB7EC \uAC00\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712185
    m_Localized: "\uC774\uC81C, \uB530\uB4EF\uD55C \uBB3C\uC774 \uB098\uC624\uB294
      \uC695\uC870\uC640 \uC624\uD1A0 \uB0C9\uB09C\uBC29\uC774 \uC9C0\uC6D0\uB418\uB294
      \uC219\uC18C\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712186
    m_Localized: "\u2026\uC720\uB2C8, \uADF8\uAC83\uBCF4\uB2E4\uB294 \uC800\uD76C\uC5D0\uAC90
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD560 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712187
    m_Localized: "\uBAB0\uB77C, \uBAB0\uB77C! \uC720\uB2C8\uB294 \uB530\uB4EF\uD55C
      \uBB3C\uB85C \uBAA9\uC695\uD558\uACE0 \uC2F6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712188
    m_Localized: "\uD544\uB9AC\uC544 \uC774\uBC88\uC5D0\uB294 \uC720\uB2C8\uC5D0\uAC8C
      \uC591\uBCF4\uD558\uBA74 \uC5B4\uB5A8\uAE4C\uC694? \uD604\uC7AC \uC778\uC6D0\uB9CC\uC73C\uB85C\uB294
      \uB2E4\uC74C \uC784\uBB34\uC5D0 \uC9C0\uC7A5\uC774 \uC788\uC744\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712189
    m_Localized: "\uC5ED\uC2DC \uC544\uD2F0\uB294 \uC13C\uC2A4\uAC00 \uC88B\uB2E4\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712190
    m_Localized: "\uD6C4\u2026 \uC5B4\uCA54 \uC218 \uC5C6\uC8E0. \uD558\uC9C0\uB9CC
      \uC5B8\uC820\uAC00\uB294 \uBC18\uB4DC\uC2DC\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712191
    m_Localized: "\uADF8\uB7FC \uC815\uB9AC\uAC00 \uC644\uB8CC\uB41C \uAC83\uC73C\uB85C
      \uC54C\uACE0 \uC219\uC18C\uB97C \uCD94\uAC00\uB85C \uC124\uCE58\uD574\uBD10\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712192
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uC0C8\uB85C\uC6B4 \uC219\uC18C\uB97C
      \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712193
    m_Localized: "\uB4DC\uB514\uC5B4 5\uBA85\uC758 \uD569\uC219 \uC0DD\uD65C\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uB294\uAC70\uC57C?! \uC800\uAE30 \uCE68\uB300\uB294 \uC720\uB2C8\uAC00
      \uCC28\uC9C0\uD560\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712194
    m_Localized: "\u2026..\uC720\uB2C8. \uD558\uC9C0\uB9CC \uC5ED\uC2DC \uB113\uC5B4\uC9C0\uB2C8
      \uB9C8\uC74C\uC774 \uD48D\uC694\uB85C\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712195
    m_Localized: "\uADF8\uB7FC \uC800 \uBE48 \uACF5\uAC04\uC5D0\uB294 \uD6C8\uB828
      \uAE30\uAD6C\uB97C\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712196
    m_Localized: "\uAD00\uCE21\uC790! \uD544\uB9AC\uC544\uAC00 \uB610 \uC774\uC0C1\uD55C
      \uAC83\uC744 \uC219\uC18C\uC5D0 \uB123\uC73C\uB824\uACE0 \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712197
    m_Localized: "\uD544\uB9AC\uC544. \uB2E4\uC74C\uC5D0 \uAF2D \uD6C8\uB828 \uACF5\uAC04\uC744
      \uBCC4\uB3C4\uB85C \uB9CC\uB4E4\uC5B4\uC904\uD14C\uB2C8\uAE4C. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB4E4 \uB9CC\uB07D\uD558\uAC8C \uD574\uC8FC\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712198
    m_Localized: "\uB9C8\uC2A4\uD130\uC758 \uC758\uACAC\uC774 \uADF8\uB807\uB2E4\uBA74\u2026.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712199
    m_Localized: "\uADF8\uB7FC \uB0A8\uC740 \uB3D9\uB825\uC73C\uB85C \uC774\uC5B4\uC11C
      \uC0C8\uB85C\uC6B4 \uAC74\uBB3C\uB4E4\uC744 \uC124\uCE58\uD558\uB7EC \uAC00\uBCF4\uC790\uAD6C\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712200
    m_Localized: "\uADFC\uB370, \uC774 \uC544\uB984\uB2E4\uC6B4 \uD050\uBE0C\uB294
      \uBB50\uC8E0?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712201
    m_Localized: "\uD788\uD79B! \uC800\uBC88\uC5D0\uB4E4\uB9B0 \uD589\uC131\uC5D0\uC11C
      \uC774\uC058\uAE38\uB808 \uC2AC\uCA4D \uAC00\uC838\uC654\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712202
    m_Localized: "\uC720\uB2C8, \uC5D8\uD53C\uC2A4 \uC678\uBD80\uBB3C\uCCB4 \uBC18\uC785
      \uAE08\uC9C0 \uBC95\uB839 4\uC870\uC5D0 \uB530\uB77C\u2026.."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712203
    m_Localized: "\uC73C\uC557! \uADF8\uB9CC\uD574 \uB0B4\uAC00 \uC798\uBABB\uD588\uC5B4.
      \uAC00\uC838\uB2E4 \uBC84\uB9AC\uBA74 \uB418\uC796\uC544."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712204
    m_Localized: "\uADF8\uAC74 \uB514\uBA58\uC158 \uD050\uBE0C?! \uC5B4\uC9F8\uC11C
      \uADF8\uACF3\uC5D0\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712205
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C? \uC774 \uD2B9\uC218\uD558\uAC8C
      \uC0DD\uAE34 \uB3CC\uC758 \uC774\uB984\uC778\uAC00?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712206
    m_Localized: "\uB124, \uB9DE\uC544\uC694. \uBC1C\uACAC\uB41C\uC9C0 \uC5BC\uB9C8\uB418\uC9C0
      \uC54A\uB294 \uBCF4\uC11D\uC73C\uB85C\uC11C \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC774\uC57C\uAE30 \uD558\uAE38 \uC5C4\uCCAD\uB09C \uC5F0\uAD6C \uAC00\uCE58\uAC00
      \uC788\uB294 \uBCF4\uC11D\uC774\uB77C\uACE0 \uD558\uB354\uB77C\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712207
    m_Localized: "\uAD00\uCE21\uC790\uB2D8! \uC774\uBC88\uC5D0 \uC5D8\uD53C\uC2A4\uC5D0\uC11C
      \uC5F0\uAD6C\uD558\uACE0 \uC788\uB294 \uB514\uBA58\uC158 \uD050\uBE0C\uC758
      \uC2E0\uADDC \uC124\uBE44 \uC124\uCE58 \uD5C8\uAC00\uB97C \uB0B4\uC92C\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712208
    m_Localized: "\uC9C0\uC18D\uC801\uC73C\uB85C \uC5F0\uAD6C\uD558\uBA74 \uC800\uD76C\uC5D0\uAC8C
      \uD070 \uB3C4\uC6C0\uC774 \uB420\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712209
    m_Localized: "\uC5BC\uB978 \uD5C8\uBE14\uC5D0 \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712210
    m_Localized: "\uC774\uACF3\uC744 \uB20C\uB7EC \uB514\uBA58\uC158 \uD050\uBE0C
      \uC5F0\uAD6C\uC18C\uB97C \uC124\uCE58\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712211
    m_Localized: "\uC798\uD558\uC168\uC5B4\uC694. \uC5ED\uC2DC \uAD00\uCE21\uC790
      \uB2D8\uC774\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712212
    m_Localized: "\uC774\uC81C \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712213
    m_Localized: "\uB514\uBA58\uC158 \uD050\uBE0C\uB97C \uC5F0\uAD6C\uD560 \uC900\uBE44\uAC00
      \uC644\uB8CC\uB418\uC5C8\uC5B4\uC694. \n'\uAE30\uC0AC-\uACF5\uACA9\uB825 \uC99D\uD3ED'
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD574\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712214
    m_Localized: "\uC5F0\uAD6C\uB294 \uB514\uBA58\uC158 \uD050\uBE0C \uC5F0\uAD6C\uC18C\uC5D0\uC11C
      \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712215
    m_Localized: "\uC774\uACF3\uC5D0\uC120 \uAC01\uAC01\uC758 \uB514\uBA58\uC158
      \uD050\uBE0C\uB97C \uD65C\uC6A9\uD558\uC5EC \n\uAE30\uC0AC, \uC131\uAD70, \uC18D\uC131
      \uC5F0\uAD6C\uAC00 \uAC00\uB2A5\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712216
    m_Localized: "\uC5F0\uAD6C\uC5D0\uB294 \uAC01\uAC01 \uD544\uC694\uD55C \uB514\uBA58\uC158
      \uD050\uBE0C \uBC0F \n\uC62C\uB77C\uAC00\uB294 \uB2A5\uB825\uCE58\uAC00 \uB2E4\uB974\uB2E4\uB294
      \uC810 \uC720\uC758\uD574\uC8FC\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712217
    m_Localized: "\uC774\uBC88\uC5D4 \uAE30\uC0AC\uB4E4\uC758 \uACF5\uACA9\uB825\uC744
      \uC62C\uB824\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712218
    m_Localized: "\uC640! \uC131\uB2E8\uC6D0\uB4E4\uC774 \uD568\uAED8 \uAC15\uD574\uC9C4\uAC8C
      \uB290\uAEF4\uC838\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712219
    m_Localized: "\uADF8\uB7FC \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uAE30\uC0AC\uB4E4\uC758
      \uD6C8\uB828\uC744 \uC704\uD574 \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158
      \uC13C\uD130\uB97C \uB9CC\uB4E4\uC5B4\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712220
    m_Localized: "\uD734! \uC544\uC2AC\uC544\uC2AC\uD558\uAC8C \uB0A8\uC740\uC7AC\uD654\uB85C
      \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uB97C \uAC74\uC124\uD560
      \uC218 \uC788\uACA0\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712221
    m_Localized: "\uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130 \uBD80\uC9C0\uB294
      \uC5EC\uAE30\uAC00 \uC88B\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712222
    m_Localized: "\uBC14\uB85C \uAC74\uC124\uC744 \uC9C4\uD589\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712223
    m_Localized: "\uB4DC\uB514\uC5B4....\uC6B0\uB9AC \uC131\uB2E8\uC5D0\uB3C4 \uD6C8\uB828\uD560
      \uC218 \uC788\uB294 \uACF5\uAC04\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712224
    m_Localized: "\uC544\uC557...! \uAD00\uCE21\uC790. \uD544\uB9AC\uC544\uAC00 \uD765\uBD84\uD574\uC11C
      \uB2EC\uB824\uB4E4\uAE30 \uC2DC\uC791\uD588\uC5B4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712225
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC740 \uD544\uB9AC\uC544\uAC00 \uB9C8\uC74C\uAECF
      \uB9CC\uB07E\uD558\uAC8C \uB194\uB450\uC8E0. \uADF8\uB3D9\uC548 \uC5F4\uC57D\uD55C
      \uD658\uACBD\uC5D0 \uB178\uB825\uD574\uC654\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712226
    m_Localized: "\uD6C4\uD6D7. \uB9C8\uC74C\uC5D0 \uB4DC\uC168\uB2E4\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uC774\uC81C \uBAA8\uB4E0 \uC900\uBE44\uB3C4 \uB05D\uB0AC\uACA0\uB2E4.
      \uCD9C\uD56D \uC900\uBE44\uB97C \uD574\uBCF4\uC790\uAD6C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712227
    m_Localized: "\uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158 \uC13C\uD130\uAC00
      \uC9C0\uC5B4\uC9C4 \uB9CC\uD07C \uC774\uC81C \uC2DC\uBBAC\uB808\uC774\uC158
      \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712228
    m_Localized: "\uC6B0\uC640! \uC9C4\uC9DC \uC804\uD22C\uD558\uB294 \uAC83 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712229
    m_Localized: "\uB9C8\uC2A4\uD130! \uC774\uAC78\uB85C \uCD5C\uC57D\uC774\uB77C\uB294
      \uC800\uD76C\uC758 \uC624\uBA85\uC744 \uC53C\uC744 \uC218 \uC788\uC744 \uC218
      \uC788\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712230
    m_Localized: "\uD6C4\uD6D7. \uC804\uD22C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uD558\uAC8C \uB418\uBA74 \uC2DC\uAC04\uC774 \uC9C0\uB0A8\uC5D0 \uB530\uB77C
      \uC5D0\uB108\uC9C0\uB97C \uC800\uC7A5\uD560 \uC218 \uC788\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712231
    m_Localized: "\uC800\uC7A5\uB41C \uC5D0\uB108\uC9C0\uB97C \uD1B5\uD574 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712232
    m_Localized: "\uB9C8\uCE68 \uC5D0\uB108\uC9C0\uAC00 \uAC00\uB4DD \uCC3C\uC73C\uB2C8
      \uBC14\uB85C \uC2DC\uBBAC\uB808\uC774\uC158 \uBCF4\uC0C1\uC744 \uBC1B\uC544\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712233
    m_Localized: "\uC6B0\uC640! \uB3FC\uC9C0 \uC800\uAE08\uD1B5 \uAC19\uC796\uC544?!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712234
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD55C \uC608\uD589 \uC5F0\uC2B5\uC744
      \uD55C \uAC83 \uAC19\uC544\uC694. \uC5BC\uB978 \uD074\uB808\uC774\uB97C \uCC3E\uC544\uBCF4\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712235
    m_Localized: "\uAC1C\uBBF8\uC9C0\uC625\uC740 \uB2FF\uC740 \uC0C1\uB300\uB97C
      \uBB34\uC791\uC704 \uC704\uCE58\uB85C \uB0B4\uBCF4\uB0B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712236
    m_Localized: "\uC774\uB97C \uC798 \uD65C\uC6A9\uD574\uC11C \uC544\uAD70\uC744
      \uBCF4\uD638\uD558\uACE0 \uC801\uAD70\uC744 \uC2B5\uACA9\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712237
    m_Localized: "\uC624\uC789? \uC800\uAE30 \uBA40\uB9AC\uC5D0 \uC800\uAC74 \uBB50\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712238
    m_Localized: "\u2026.\uD0D1?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712239
    m_Localized: "\uC774\uB7F0 \uC0AC\uB9C9\uC5D0 \uD0D1\uC774\uB77C\uB2C8 \uC774\uC0C1\uD558\uAD70\uC694.
      \uC2E0\uAE30\uB8E8\uC778 \uAC78\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712240
    m_Localized: "\uC800\uAC74 \uC544\uB9C8\u2026.\uBC14\uBCA8\uC77C\uAC70\uC5D0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712241
    m_Localized: "\uBC14\uBCA8? \uADF8\uAC8C \uBB54\uB370?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712242
    m_Localized: "\uC5EC\uB7EC \uD589\uC131\uC5D0 \uAC78\uCCD0 \uB098\uD0C0\uB098\uB294
      \uD2B9\uC218\uD55C \uAC74\uCD95\uBB3C\uB85C\uC11C, \uC800\uAE30\uC5D0 \uB4E4\uC5B4\uAC04
      \uC0AC\uB78C\uB4E4\uC740 '\uC2DC\uB828'\uC744 \uBC1B\uAC8C\uB418\uACE0 \uADF8\uAC83\uC744
      \uC774\uACA8\uB0BC \uACBD\uC6B0 \uC5C4\uCCAD\uB09C \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uB2E4\uACE0 \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712243
    m_Localized: "\uC624\u2026! \uC27D\uAC8C \uB9D0\uD574 \uC5B4\uB514\uB4E0 \uC788\uB294
      \uBCF4\uBB3C\uCC3D\uACE0\uC796\uC544!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712244
    m_Localized: "\u2026.\uC5ED\uC2DC \uC800\uC18D\uD558\uB124\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712245
    m_Localized: "\uD765! \uBB50\uB77C\uD558\uB4E0 \uC800 \uC548\uC5D0 \uC788\uB294
      \uBCF4\uBB3C\uB4E4\uC740 \uBAA8\uB450 \uB0B4\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712246
    m_Localized: "\uC7A0\uAE50\uB9CC\uC694. \uC720\uB2C8! \uADF8\uB807\uAC8C \uB530\uB85C
      \uD589\uB3D9\uD558\uBA74 \uC704\uD5D8\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712247
    m_Localized: "\uC548\uB530\uB77C\uC624\uBA74 \uC9C4\uC9DC\uB85C \uBCF4\uBB3C\uC744
      \uD63C\uC790 \uB3C5\uCC28\uC9C0\uD55C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712248
    m_Localized: "\uAD00\uCE21\uC790. \uAE30\uC5B5\uC0C1\uC2E4 \uC774\uC57C\uAE34
      \uB4E4\uC5C8\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712249
    m_Localized: "\uAD00\uCE21\uC790\uB2D8. \uB9C8\uB9AC\uC5D0\uB294 \uB300\uC778\uC554\uC0B4\uC5D0
      \uD2B9\uD654\uB418\uC5B4 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712250
    m_Localized: "\uB9C8\uCE68 \uC801\uC744 \uD68C\uBCF5\uD558\uB294 \uBAA8\uB178\uC544\uC774\uAC00
      \uC788\uB124\uC694. \uB9C8\uB9AC\uC5D0\uC5D0\uAC8C \uC81C\uAC70\uB97C \uBD80\uD0C1\uD558\uC8E0."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712251
    m_Localized: "\uC774\uACF3\uC5D0 \uBC30\uCE58\uBC14\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712252
    m_Localized: "\uB9C8\uB9AC\uC5D0\uAC00 \uC788\uB294 \uD50C\uB808\uC774\uC544
      \uB370\uC2A4\uC758 \uD798\uC744 \uB290\uAEF4\uBCF4\uB77C\uAD6C!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712253
    m_Localized: "\uC778\uCE74\uC6B4\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712254
    m_Localized: "\uAD00\uCE21\uC790\uB294 \uAE30\uC6D0\uC744 \uC54C \uC218 \uC5C6\uB294
      \uC2E0\uBE44\uD55C \uD798\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712255
    m_Localized: "\uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD558\uAE30
      \uC704\uD574\uC11C\uB294 \uC2AC\uB86F\uC5D0 \uB4F1\uB85D\uD574\uC57C \uD574\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712256
    m_Localized: "\uC774\uACF3\uC5D0 \uC0C8\uB86D\uAC8C \uAD00\uCE21\uD55C \uC2A4\uD0AC\uC744
      \uB4F1\uB85D\uD574\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712257
    m_Localized: "\uC774\uC81C \uC2E4\uC81C \uC804\uD22C\uC5D0\uC11C \uAD00\uCE21\uC790
      \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBCFC\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712258
    m_Localized: "\uC544\uC774\uAE30\uC2A4 \uBC29\uD328\uB294 \n\uBAAC\uC2A4\uD130\uB97C
      \uB109\uBC31\uC2DC\uCF1C \uC544\uAD70\uC744 \uBCF4\uD638\uD558\uACE0, \n\uC801\uC5D0\uAC8C
      \uCDA9\uB3CC\uC744 \uC720\uB3C4\uD560 \uC218 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712259
    m_Localized: "\uC774\uACF3\uC5D0 \uAD00\uCE21\uC790 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574\uBD10\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712260
    m_Localized: "\"\uC5B4\uC11C \uC624\uC138\uC694, \uAD00\uCE21\uC790\uB2D8. \uC601\uC9C0
      \uB0B4 \uC0DD\uBA85 \uC720\uC9C0 \uC7A5\uCE58 \uBC0F \uC5D0\uD14C\uB974 \uC5D0\uB108\uC9C0
      \uD750\uB984, \uBAA8\uB450 \uC815\uC0C1\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC744
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712261
    m_Localized: "\"\uC5D8\uD53C\uC2A4\uB85C\uBD80\uD130 \uBBF8\uD655\uC778 \uB370\uC774\uD130\uAC00
      \uC218\uC2E0\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBD84\uC11D\uC744 \uC2DC\uC791\uD560\uAE4C\uC694?
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD310\uB2E8\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712262
    m_Localized: "\"\uC774 \uAD11\uD65C\uD55C \uC6B0\uC8FC\uC5D0\uC11C \uC88C\uD45C\uB97C
      \uC783\uC9C0 \uC54A\uB294 \uC720\uC77C\uD55C \uBC29\uBC95\uC740... \uBC14\uB85C
      \uB2F9\uC2E0\uC774 \uC81C \uACC1\uC5D0 \uC788\uB294 \uAC83\uC774\uACA0\uC8E0.
      \uD6C4\uD6C4, \uB18D\uB2F4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712263
    m_Localized: "\"\uCEE4\uD53C\uB77C\uB3C4 \uD55C \uC794 \uB0B4\uB824\uB4DC\uB9B4\uAE4C\uC694? 
      \uAD00\uCE21\uC790\uB2D8\uC758 \uD734\uC2DD\uB3C4 \uC911\uC694\uD55C \uC784\uBB34\uC758
      \uC77C\uBD80\uB2C8\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712264
    m_Localized: "\"\uC800\uC758 \uCD5C\uC6B0\uC120 \uC120\uD0DD\uC0AC\uD56D\uC740
      \uC5B8\uC81C\uB098 \uAD00\uCE21\uC790\uB2D8\uC758 \uC548\uC804\uACFC \uC2B9\uB9AC\uC785\uB2C8\uB2E4.
      \uADF8\uB7EC\uB2C8 \uC548\uC2EC\uD558\uACE0 \uC9C0\uD718\uD574 \uC8FC\uC138\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712265
    m_Localized: "\"\uC624\uC168\uB098\uC694, \uAD00\uCE21\uC790\uB2D8? \uC624\uB298
      \uD6C8\uB828 \uC2A4\uCF00\uC904\uC740 \uD3C9\uC18C\uBCF4\uB2E4 1.5\uBC30 \uB354
      \uBE61\uBE61\uD558\uAC8C \uC7A1\uC544 \uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712266
    m_Localized: "\"\uB370\uC774\uD130\uB9CC \uBBFF\uB294\uB2E4\uBA74 \uC2E4\uC804\uC5D0\uC11C
      \uBB34\uB108\uC9C8 \uBFD0\uC774\uC5D0\uC694. \uB2F9\uC2E0\uC744 \uC704\uD574\uC11C
      \uB354\uB354\uC6B1 \uD558\uB4DC\uD55C \uC2DC\uBBAC\uB808\uC774\uC158\uC744
      \uC900\uBE44\uD574\uB1A8\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712267
    m_Localized: "\"\uC6C0\uC9C1\uC784\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uB454\uD558\uB124\uC694.
      \uC544\uAE4C\uBD80\uD130 \uC800\uB97C \uD790\uB057 \uAC70\uB9AC\uC2DC\uB358\uB370
      \uD639\uC2DC......?\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712268
    m_Localized: "\"\uC2DC\uBBAC\uB808\uC774\uC158 \uC885\uB8CC. ...\uD765, \uC774\uBC88\uC5D4
      \uC81C\uBC95\uC774\uAD70\uC694. \uC544\uC8FC \uC870\uAE08\uC740, \uAD00\uCE21\uC790\uB2D8\uC744
      \uB2E4\uC2DC \uBD24\uC744\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 2989786220712269
    m_Localized: "\"\uC804\uC7A5\uC740 \uC790\uBE44\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC5EC\uAE30\uC11C \uD758\uB9B0 \uB540\uBC29\uC6B8\uB9CC\uD07C\uC740
      \uB2F9\uC2E0\uC744 \uBC30\uC2E0\uD558\uC9C0 \uC54A\uC744\uAC70\uC5D0\uC694.
      \uC790, \uB2E4\uC74C \uC2DC\uBBAC\uB808\uC774\uC158\uC744 \uBC14\uB85C \uC9C4\uD589\uD574\uBCF4\uC8E0\""
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
