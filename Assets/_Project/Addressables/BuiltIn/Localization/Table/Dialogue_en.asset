%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 8c07de4e6b118478b9e53f481dac2451, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24195883008
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 751442059264
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 5490640674816
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 6272467329024
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 7011403030528
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788929
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788930
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788931
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788932
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788933
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788934
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788935
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788936
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788937
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788938
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788939
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788940
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788941
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788942
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788943
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788944
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788945
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788946
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788947
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788948
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788949
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788950
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788951
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788952
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788953
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788954
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788955
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788956
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788957
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788958
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788959
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788960
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788961
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788962
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788963
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788964
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788965
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788966
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788967
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788968
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788969
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788970
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788971
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788972
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788973
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788974
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788975
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788976
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788977
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788978
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788979
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788980
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788981
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788982
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788983
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788984
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788985
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788986
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788987
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788988
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788989
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788990
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788991
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788992
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788993
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788994
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788995
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788996
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788997
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788998
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788999
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789000
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789001
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789002
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789003
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789004
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789005
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789006
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789007
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789008
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789009
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789010
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789011
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789012
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789013
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789014
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789015
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789016
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789017
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789018
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789019
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789020
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789021
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789022
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789023
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789024
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789025
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789026
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789027
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789028
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789029
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789030
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789031
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789032
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789033
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789034
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789035
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789036
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789037
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789038
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789039
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789040
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789041
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789042
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789043
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789044
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789045
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789046
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789047
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789048
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789049
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789050
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789051
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789052
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789053
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789054
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789055
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789056
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789057
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789058
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789059
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789060
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789061
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789062
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789063
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789064
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789065
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789066
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789067
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789068
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789069
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789070
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789071
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789072
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789073
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789074
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789075
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789076
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789077
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789078
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789079
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789080
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789081
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789082
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789083
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789084
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789085
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789086
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789087
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789088
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789089
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789090
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789091
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789092
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789093
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789094
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789095
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789096
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789097
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789098
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789099
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789100
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789101
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789102
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789103
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789104
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789105
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789106
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789107
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789108
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789109
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789110
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789111
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789112
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789113
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789114
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789115
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789116
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789117
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789118
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789119
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789120
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789121
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789122
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789123
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789124
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789125
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789126
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789127
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789128
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789129
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789130
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789131
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789132
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789133
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789134
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789135
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789136
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789137
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789138
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789139
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789140
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789141
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789142
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789143
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789144
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789145
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789146
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789147
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789148
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789149
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789150
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789151
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789152
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789153
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789154
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789155
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789156
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789157
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789158
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789159
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789160
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789161
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789162
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789163
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789164
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789165
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789166
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789167
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789168
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789169
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789170
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789171
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789172
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789173
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789174
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789175
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789176
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789177
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789178
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789179
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789180
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789181
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789182
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789183
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789184
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789185
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789186
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789187
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789188
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789189
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789190
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789191
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789192
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789193
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789194
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789195
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789196
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789197
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789198
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789199
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789200
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789201
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789202
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789203
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789204
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789205
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789206
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789207
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789208
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789209
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789210
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789211
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789212
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789213
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789214
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789215
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789216
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789217
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789218
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789219
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789220
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789221
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789222
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789223
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789224
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789225
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789226
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789227
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789228
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789229
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789230
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789231
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789232
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789233
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789234
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789235
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789236
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789237
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789238
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789239
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789240
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789241
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789242
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789243
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789244
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789245
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789246
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789247
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789248
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789249
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789250
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789251
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789252
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789253
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789254
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789255
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789256
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789257
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789258
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789259
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789260
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789261
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789262
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789263
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789264
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789265
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789266
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789267
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789268
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789269
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789270
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789271
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789272
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789273
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789274
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789275
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789276
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789277
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789278
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789279
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789280
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789281
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789282
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789283
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789284
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789285
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789286
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789287
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789288
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789289
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789290
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789291
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789292
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789293
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789294
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789295
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789296
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789297
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789298
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789299
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789300
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789301
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789302
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789303
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789304
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789305
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789306
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789307
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789308
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789309
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789310
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789311
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789312
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789313
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789314
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789315
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789316
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789317
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789318
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789319
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789320
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789321
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789322
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789323
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789324
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789325
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789326
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789327
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789328
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789329
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789330
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789331
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789332
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789333
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789334
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789335
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789336
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789337
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789338
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789339
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789340
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789341
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789342
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789343
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789344
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789345
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789346
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789347
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789348
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789349
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789350
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789351
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789352
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789353
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789354
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789355
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789356
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789357
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789358
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789359
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789360
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789361
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789362
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789363
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789364
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789365
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789366
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789367
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789368
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789369
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789370
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789371
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789372
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789373
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789374
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789375
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789376
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789377
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789378
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789379
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789380
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789381
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789382
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789383
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789384
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789385
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789386
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789387
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789388
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789389
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789390
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789391
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789392
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789393
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789394
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789395
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789396
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789397
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789398
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789399
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789400
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789401
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789402
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789403
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789404
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789405
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789406
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789407
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789408
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789409
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789410
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789411
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789412
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789413
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789414
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789415
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789416
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789417
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789418
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789419
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789420
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789421
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789422
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789423
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789424
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789425
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789426
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789427
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789428
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789429
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789430
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789431
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789432
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789433
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789434
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789435
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789436
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789437
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789438
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789439
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789440
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789441
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789442
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789443
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789444
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789445
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789446
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789447
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789448
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789449
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789450
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789451
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789452
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789453
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789454
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789455
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789456
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789457
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789458
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789459
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789460
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789461
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789462
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789463
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789464
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789465
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789466
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789467
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789468
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789469
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789470
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789471
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789472
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789473
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789474
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789475
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789476
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789477
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789478
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789479
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789480
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789481
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789482
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789483
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789484
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789485
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789486
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789487
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789488
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789489
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789490
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789491
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789492
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789493
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789494
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789495
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789496
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789497
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789498
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789499
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789500
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789501
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789502
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789503
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789504
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789505
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789506
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789507
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789508
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789509
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789510
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789511
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789512
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789513
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789514
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789515
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789516
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789517
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789518
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789519
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789520
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789521
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789522
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789523
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789524
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789525
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789526
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789527
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789528
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789529
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789530
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789531
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789532
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789533
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789534
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789535
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789536
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789537
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789538
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789539
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789540
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789541
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789542
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789543
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789544
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789545
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789546
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789547
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789548
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789549
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789550
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789551
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789552
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789553
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789554
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789555
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789556
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789557
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789558
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789559
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789560
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789561
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789562
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789563
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789564
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789565
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789566
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789567
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789568
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789569
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789570
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789571
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789572
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789573
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789574
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789575
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789576
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789577
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789578
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789579
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789580
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789581
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789582
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789583
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789584
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789585
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789586
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789587
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789588
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789589
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789590
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789591
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789592
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789593
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789594
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789595
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789596
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789597
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789598
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789599
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789600
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789601
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789602
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789603
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789604
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789605
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789606
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789607
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789608
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789609
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789610
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789611
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789612
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789613
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789614
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789615
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789616
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789617
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789618
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789619
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789620
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789621
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789622
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789623
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789624
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789625
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789626
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789627
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789628
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789629
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789630
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789631
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789632
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789633
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789634
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789635
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789636
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789637
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789638
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789639
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789640
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789641
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789642
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789643
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789644
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789645
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789646
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789647
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789648
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789649
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789650
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789651
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359804588032
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170944
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170945
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170946
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170947
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170948
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170949
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170950
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170951
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170952
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170953
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170954
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170955
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170956
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170957
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170958
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170959
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170960
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170961
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170962
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170963
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170964
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170965
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170966
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170967
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170968
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170969
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170970
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170971
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170972
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170973
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170974
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170975
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170976
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170977
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170978
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170979
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170980
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170981
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170982
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170983
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170984
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170985
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170986
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170987
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170988
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170989
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170990
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170991
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170992
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170993
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170994
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170995
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170996
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170997
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170998
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817170999
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171000
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171001
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171002
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171003
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171004
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171005
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171006
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171007
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171008
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171009
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171010
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171011
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171012
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171013
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171014
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171015
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171016
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171017
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171018
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171019
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171020
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171021
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171022
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171023
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171024
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171025
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171026
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171027
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171028
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171029
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171030
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171031
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171032
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171033
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171034
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171035
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171036
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171037
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171038
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171039
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171040
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171041
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171042
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171043
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171044
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171045
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171046
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171047
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171048
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171049
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171050
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171051
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171052
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171053
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171054
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171055
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171056
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171057
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171058
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171059
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171060
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171061
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171062
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171063
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171064
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171065
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171066
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171067
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171068
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171069
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171070
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171071
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171072
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171073
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171074
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171075
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171076
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171077
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171078
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171079
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171080
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171081
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171082
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171083
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171084
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171085
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171086
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171087
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171088
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171089
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171090
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171091
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171092
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171093
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171094
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171095
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171096
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171097
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171098
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171099
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171100
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171101
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171102
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171103
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171104
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171105
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171106
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171107
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171108
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171109
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171110
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171111
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171112
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171113
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171114
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171115
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171116
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171117
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171118
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171119
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171120
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171121
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171122
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171123
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171124
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171125
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171126
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171127
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171128
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171129
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171130
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171131
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171132
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171133
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171134
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171135
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171136
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171137
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171138
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171139
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171140
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171141
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171142
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171143
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171144
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171145
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171146
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171147
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171148
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171149
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171150
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171151
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171152
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171153
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171154
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171155
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171156
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171157
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171158
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171159
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171160
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171161
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171162
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171163
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171164
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171165
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171166
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171167
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171168
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171169
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171170
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171171
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171172
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171173
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171174
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171175
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171176
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171177
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171178
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171179
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171180
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171181
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171182
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171183
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171184
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171185
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171186
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171187
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171188
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171189
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171190
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171191
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171192
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171193
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171194
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171195
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171196
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171197
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171198
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171199
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171200
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171201
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171202
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171203
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171204
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171205
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171206
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171207
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171208
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171209
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171210
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171211
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171212
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171213
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171214
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171215
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171216
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171217
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171218
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171219
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171220
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171221
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171222
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171223
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171224
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171225
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171226
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171227
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171228
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171229
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171230
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171231
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171232
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171233
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171234
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171235
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171236
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171237
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171238
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171239
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171240
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171241
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171242
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171243
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171244
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171245
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171246
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171247
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171248
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171249
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171250
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171251
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171252
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171253
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171254
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171255
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171256
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171257
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171258
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171259
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171260
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171261
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171262
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171263
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171264
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171265
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171266
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171267
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171268
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171269
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171270
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171271
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171272
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171273
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171274
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171275
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171276
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171277
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171278
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171279
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171280
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171281
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171282
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171283
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171284
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171285
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171286
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171287
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171288
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171289
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171290
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171291
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171292
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171293
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171294
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171295
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171296
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171297
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171298
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171299
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171300
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171301
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171302
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171303
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171304
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171305
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171306
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171307
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171308
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171309
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171310
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171311
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171312
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171313
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171314
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171315
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171316
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171317
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171318
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171319
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171320
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171321
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171322
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171323
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171324
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171325
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171326
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171327
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171328
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171329
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171330
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171331
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171332
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171333
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171334
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171335
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171336
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171337
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171338
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171339
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171340
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171341
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171342
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171343
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171344
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171345
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171346
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171347
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171348
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171349
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171350
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171351
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171352
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171353
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171354
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171355
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171356
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171357
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171358
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171359
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171360
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171361
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171362
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171363
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171364
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171365
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171366
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171367
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171368
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171369
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171370
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171371
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171372
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171373
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171374
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171375
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171376
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171377
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171378
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171379
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171380
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171381
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171382
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171383
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171384
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171385
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171386
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171387
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171388
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171389
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171390
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171391
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171392
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171393
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171394
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171395
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171396
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171397
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171398
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171399
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171400
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171401
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171402
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171403
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171404
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171405
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171406
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171407
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171408
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171409
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171410
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171411
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171412
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171413
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171414
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171415
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171416
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171417
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171418
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171419
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171420
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171421
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171422
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171423
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171424
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171425
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171426
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171427
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171428
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171429
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171430
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171431
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171432
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171433
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171434
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171435
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171436
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171437
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171438
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171439
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171440
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171441
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171442
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171443
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171444
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171445
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171446
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171447
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171448
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171449
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171450
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171451
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171452
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171453
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171454
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171455
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171456
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171457
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171458
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171459
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171460
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171461
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171462
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171463
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171464
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171465
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171466
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171467
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171468
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171469
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171470
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171471
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171472
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171473
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171474
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171475
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171476
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171477
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171478
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171479
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171480
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171481
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171482
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171483
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171484
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171485
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171486
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171487
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171488
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171489
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171490
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171491
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171492
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171493
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171494
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171495
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171496
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171497
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171498
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171499
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171500
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171501
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171502
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171503
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171504
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171505
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171506
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171507
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171508
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171509
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171510
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171511
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171512
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171513
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171514
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171515
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171516
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171517
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171518
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171519
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171520
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171521
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171522
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171523
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171524
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171525
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171526
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171527
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171528
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171529
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171530
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171531
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171532
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171533
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171534
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171535
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171536
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171537
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171538
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171539
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171540
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171541
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171542
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171543
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171544
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171545
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171546
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171547
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171548
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171549
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171550
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171551
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171552
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171553
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171554
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171555
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171556
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171557
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171558
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171559
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171560
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171561
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171562
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171563
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171564
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171565
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171566
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171567
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171568
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171569
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171570
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171571
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171572
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171573
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 457359817171574
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365248
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365249
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365250
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365251
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365252
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365253
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365254
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365255
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365256
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365257
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365258
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365259
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365260
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365261
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365262
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365263
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365264
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365265
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365266
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365267
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365268
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365269
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365270
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365271
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365272
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365273
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365274
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365275
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365276
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365277
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365278
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365279
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365280
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365281
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365282
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365283
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365284
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365285
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365286
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365287
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365288
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365289
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365290
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365291
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365292
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365293
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365294
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365295
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365296
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365297
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365298
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365299
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365300
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365301
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365302
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365303
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365304
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365305
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365306
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365307
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365308
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365309
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365310
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365311
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365312
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365313
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365314
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365315
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365316
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365317
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365318
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365319
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365320
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365321
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365322
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365323
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365324
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365325
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365326
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365327
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365328
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365329
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365330
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365331
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365332
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365333
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365334
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365335
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365336
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365337
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365338
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 457359821365339
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608100098048
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680960
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680961
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680962
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680963
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680964
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680965
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680966
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680967
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680968
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680969
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680970
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680971
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680972
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680973
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680974
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680975
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680976
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680977
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680978
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680979
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680980
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680981
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680982
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680983
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680984
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680985
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680986
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680987
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680988
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680989
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680990
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680991
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680992
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680993
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680994
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680995
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680996
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680997
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680998
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112680999
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681000
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681001
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681002
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681003
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681004
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681005
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681006
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681007
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681008
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681009
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681010
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681011
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681012
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681013
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681014
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681015
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681016
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681017
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681018
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681019
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681020
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681021
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681022
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681023
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681024
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681025
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681026
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681027
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681028
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681029
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681030
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681031
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681032
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681033
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681034
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681035
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681036
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681037
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681038
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681039
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681040
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681041
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681042
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681043
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681044
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681045
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681046
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681047
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681048
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681049
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681050
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681051
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681052
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681053
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681054
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681055
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681056
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681057
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681058
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681059
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681060
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681061
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681062
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681063
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681064
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681065
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681066
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681067
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681068
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681069
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681070
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681071
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681072
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681073
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681074
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681075
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681076
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681077
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681078
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681079
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681080
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681081
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681082
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681083
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681084
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681085
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681086
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681087
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681088
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681089
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681090
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681091
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681092
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681093
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681094
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681095
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681096
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681097
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681098
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681099
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681100
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681101
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681102
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681103
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681104
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681105
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681106
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681107
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681108
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681109
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681110
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681111
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681112
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681113
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681114
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681115
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681116
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681117
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681118
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681119
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681120
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681121
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681122
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681123
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681124
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681125
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681126
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681127
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681128
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681129
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681130
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681131
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681132
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681133
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681134
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681135
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681136
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681137
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681138
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681139
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681140
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681141
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681142
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681143
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681144
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681145
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681146
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681147
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681148
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681149
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681150
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681151
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681152
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681153
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681154
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681155
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681156
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681157
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681158
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681159
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681160
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681161
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681162
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681163
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681164
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681165
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681166
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681167
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681168
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681169
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681170
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681171
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681172
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681173
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681174
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681175
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681176
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681177
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681178
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681179
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681180
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681181
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681182
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681183
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681184
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681185
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681186
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681187
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681188
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681189
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681190
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681191
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681192
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681193
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681194
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681195
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681196
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681197
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681198
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681199
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681200
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681201
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681202
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681203
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681204
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681205
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681206
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681207
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681208
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681209
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681210
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681211
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681212
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681213
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681214
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681215
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681216
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681217
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681218
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681219
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681220
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681221
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681222
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681223
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681224
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681225
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681226
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681227
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681228
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681229
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681230
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681231
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681232
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681233
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681234
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681235
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681236
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681237
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681238
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681239
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681240
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681241
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681242
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681243
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681244
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681245
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681246
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681247
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681248
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681249
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681250
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681251
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681252
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681253
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681254
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681255
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681256
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681257
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681258
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681259
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681260
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681261
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681262
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681263
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681264
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681265
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681266
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681267
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681268
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681269
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681270
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681271
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681272
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681273
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681274
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681275
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681276
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681277
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681278
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681279
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681280
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681281
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681282
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681283
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681284
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681285
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681286
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681287
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681288
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681289
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681290
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681291
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681292
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681293
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681294
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681295
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681296
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681297
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681298
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681299
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681300
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681301
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681302
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681303
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681304
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681305
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681306
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681307
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681308
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681309
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681310
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681311
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681312
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681313
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681314
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681315
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681316
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681317
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681318
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681319
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681320
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681321
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681322
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681323
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681324
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681325
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681326
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681327
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681328
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681329
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681330
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681331
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681332
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681333
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681334
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681335
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681336
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681337
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681338
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681339
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681340
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681341
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681342
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681343
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681344
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681345
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681346
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681347
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681348
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681349
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681350
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681351
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681352
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681353
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681354
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681355
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681356
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681357
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681358
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681359
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681360
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681361
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681362
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681363
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681364
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681365
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681366
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681367
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681368
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681369
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681370
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681371
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681372
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681373
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681374
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681375
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681376
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681377
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681378
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681379
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681380
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681381
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681382
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681383
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681384
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681385
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681386
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681387
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681388
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681389
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681390
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681391
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681392
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681393
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681394
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681395
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681396
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681397
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681398
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681399
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681400
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681401
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681402
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681403
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681404
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681405
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681406
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681407
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681408
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681409
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681410
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681411
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681412
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681413
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681414
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681415
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681416
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681417
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681418
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681419
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681420
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681421
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681422
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681423
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681424
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681425
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681426
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681427
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681428
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681429
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681430
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681431
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681432
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681433
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681434
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681435
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681436
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681437
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681438
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681439
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681440
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681441
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681442
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681443
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681444
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681445
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681446
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681447
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681448
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681449
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681450
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681451
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681452
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681453
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681454
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681455
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681456
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681457
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681458
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681459
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681460
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681461
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681462
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681463
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681464
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681465
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681466
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681467
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681468
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681469
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681470
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681471
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681472
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681473
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681474
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681475
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681476
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681477
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681478
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681479
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681480
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681481
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681482
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681483
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681484
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681485
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681486
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681487
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681488
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681489
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681490
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681491
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681492
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681493
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681494
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681495
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681496
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681497
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681498
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681499
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681500
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681501
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681502
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681503
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681504
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681505
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681506
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681507
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681508
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681509
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681510
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681511
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681512
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681513
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681514
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681515
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681516
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681517
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681518
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681519
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681520
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681521
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681522
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681523
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681524
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681525
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681526
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681527
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681528
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681529
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681530
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681531
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681532
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681533
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681534
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681535
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681536
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681537
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681538
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681539
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681540
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681541
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681542
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681543
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681544
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681545
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681546
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681547
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681548
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681549
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681550
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681551
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681552
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681553
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681554
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681555
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681556
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681557
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681558
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681559
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681560
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681561
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681562
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681563
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681564
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681565
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681566
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681567
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681568
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681569
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681570
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681571
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681572
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681573
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681574
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681575
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681576
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681577
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681578
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681579
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681580
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681581
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681582
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681583
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681584
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681585
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681586
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681587
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681588
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681589
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681590
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681591
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681592
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681593
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681594
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681595
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681596
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681597
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681598
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681599
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681600
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681601
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681602
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681603
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681604
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681605
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681606
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681607
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681608
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681609
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681610
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681611
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681612
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681613
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681614
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681615
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681616
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681617
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681618
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681619
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681620
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681621
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681622
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681623
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681624
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681625
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681626
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681627
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681628
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681629
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681630
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681631
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681632
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681633
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681634
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681635
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681636
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681637
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681638
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681639
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681640
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681641
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681642
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681643
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681644
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681645
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681646
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681647
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681648
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681649
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681650
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681651
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681652
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681653
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681654
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681655
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681656
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681657
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681658
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681659
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681660
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681661
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681662
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681663
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681664
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681665
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681666
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681667
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681668
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681669
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681670
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681671
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681672
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681673
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681674
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681675
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681676
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681677
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681678
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681679
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681680
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681681
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 460608112681682
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700897746944
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329856
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329857
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329858
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329859
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329860
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329861
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329862
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329863
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329864
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329865
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329866
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329867
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329868
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329869
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329870
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329871
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329872
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329873
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329874
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329875
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329876
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329877
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329878
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329879
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329880
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329881
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329882
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329883
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329884
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329885
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329886
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329887
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329888
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329889
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329890
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329891
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329892
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329893
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329894
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329895
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329896
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329897
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329898
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329899
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329900
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329901
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329902
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329903
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329904
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329905
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329906
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329907
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329908
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329909
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329910
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329911
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329912
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329913
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329914
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329915
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329916
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329917
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329918
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329919
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329920
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329921
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329922
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329923
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329924
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329925
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329926
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329927
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329928
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329929
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329930
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329931
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329932
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329933
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329934
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329935
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329936
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329937
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329938
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329939
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329940
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329941
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329942
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329943
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329944
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329945
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329946
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329947
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329948
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329949
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329950
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329951
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329952
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329953
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329954
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329955
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329956
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329957
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329958
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329959
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329960
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329961
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329962
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329963
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329964
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329965
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329966
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329967
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329968
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329969
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329970
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329971
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329972
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329973
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329974
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329975
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329976
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329977
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329978
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329979
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329980
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329981
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329982
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329983
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329984
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329985
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329986
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329987
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329988
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329989
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329990
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329991
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329992
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329993
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329994
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329995
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329996
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329997
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329998
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910329999
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330000
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330001
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330002
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330003
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330004
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330005
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330006
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330007
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330008
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330009
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330010
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330011
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330012
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330013
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330014
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330015
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330016
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330017
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330018
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330019
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330020
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330021
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330022
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330023
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330024
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330025
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330026
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330027
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330028
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330029
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330030
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330031
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330032
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330033
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330034
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330035
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330036
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330037
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330038
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330039
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330040
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330041
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330042
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330043
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330044
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330045
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330046
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330047
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330048
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330049
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330050
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330051
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330052
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330053
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330054
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330055
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330056
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330057
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330058
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330059
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330060
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330061
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330062
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330063
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330064
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330065
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330066
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330067
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330068
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330069
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330070
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330071
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330072
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330073
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330074
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330075
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330076
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330077
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330078
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330079
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330080
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330081
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330082
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330083
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330084
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330085
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330086
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330087
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330088
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330089
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330090
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330091
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330092
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330093
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330094
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330095
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330096
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330097
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330098
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330099
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330100
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330101
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330102
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330103
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330104
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330105
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330106
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330107
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330108
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330109
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330110
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330111
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330112
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330113
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330114
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330115
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330116
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330117
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330118
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330119
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330120
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330121
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330122
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330123
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330124
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330125
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330126
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330127
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330128
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330129
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330130
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330131
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330132
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330133
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330134
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330135
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330136
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330137
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330138
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330139
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330140
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330141
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330142
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330143
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330144
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330145
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330146
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330147
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330148
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330149
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330150
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330151
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330152
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330153
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330154
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330155
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330156
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330157
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330158
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330159
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330160
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330161
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330162
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330163
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330164
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330165
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330166
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330167
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330168
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330169
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330170
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330171
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330172
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330173
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330174
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330175
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330176
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330177
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330178
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330179
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330180
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330181
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330182
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330183
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330184
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330185
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330186
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330187
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330188
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330189
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330190
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330191
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330192
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330193
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330194
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330195
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330196
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330197
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330198
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330199
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330200
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330201
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330202
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330203
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330204
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330205
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330206
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330207
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330208
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330209
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330210
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330211
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330212
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330213
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330214
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330215
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330216
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330217
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330218
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330219
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330220
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330221
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330222
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330223
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330224
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330225
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330226
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330227
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330228
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330229
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330230
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330231
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330232
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330233
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330234
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330235
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330236
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330237
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330238
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330239
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330240
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330241
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330242
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330243
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330244
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330245
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330246
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330247
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330248
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330249
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330250
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330251
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330252
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330253
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330254
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330255
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330256
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330257
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330258
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330259
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330260
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330261
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330262
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330263
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330264
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330265
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330266
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330267
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330268
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330269
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330270
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330271
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330272
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464700910330273
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524160
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524161
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524162
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524163
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524164
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524165
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524166
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524167
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524168
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524169
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524170
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524171
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524172
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524173
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524174
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524175
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524176
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524177
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524178
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524179
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524180
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524181
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524182
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524183
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524184
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524185
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524186
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524187
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524188
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524189
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524190
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524191
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524192
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524193
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524194
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524195
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524196
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524197
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524198
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524199
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524200
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524201
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524202
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524203
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524204
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524205
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524206
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524207
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524208
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524209
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524210
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524211
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524212
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524213
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524214
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524215
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524216
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524217
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524218
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524219
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524220
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524221
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524222
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524223
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524224
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524225
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524226
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524227
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524228
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524229
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524230
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524231
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524232
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524233
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524234
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524235
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524236
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524237
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524238
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524239
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524240
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524241
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524242
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524243
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524244
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524245
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524246
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524247
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524248
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524249
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524250
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524251
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524252
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524253
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524254
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524255
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524256
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524257
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524258
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524259
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524260
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524261
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524262
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524263
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524264
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524265
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524266
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524267
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524268
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524269
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524270
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524271
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524272
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524273
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524274
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524275
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524276
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524277
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524278
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524279
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524280
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524281
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524282
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524283
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524284
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524285
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524286
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524287
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524288
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524289
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524290
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524291
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524292
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524293
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524294
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524295
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524296
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524297
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524298
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524299
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524300
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524301
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524302
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524303
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524304
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524305
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524306
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524307
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524308
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524309
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524310
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524311
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524312
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524313
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524314
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524315
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524316
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524317
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524318
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524319
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524320
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524321
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524322
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524323
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524324
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524325
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524326
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524327
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524328
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524329
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524330
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524331
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524332
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524333
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524334
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524335
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524336
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524337
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524338
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524339
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524340
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524341
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524342
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524343
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524344
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524345
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524346
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524347
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524348
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524349
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524350
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524351
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524352
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524353
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524354
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524355
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524356
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524357
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524358
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524359
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524360
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524361
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524362
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524363
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524364
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524365
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524366
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524367
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524368
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524369
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524370
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524371
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524372
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524373
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524374
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524375
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524376
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524377
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524378
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524379
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524380
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524381
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524382
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524383
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524384
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524385
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524386
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524387
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524388
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524389
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524390
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524391
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524392
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524393
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524394
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524395
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524396
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524397
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524398
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524399
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524400
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524401
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524402
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524403
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524404
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524405
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524406
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524407
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524408
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524409
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524410
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524411
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524412
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524413
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524414
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524415
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524416
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524417
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524418
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524419
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524420
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524421
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524422
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524423
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524424
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524425
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524426
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524427
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524428
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524429
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524430
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524431
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524432
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524433
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524434
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524435
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524436
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524437
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524438
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524439
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524440
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524441
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524442
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524443
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524444
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524445
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524446
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524447
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524448
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524449
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524450
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524451
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524452
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524453
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524454
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524455
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524456
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524457
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524458
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524459
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524460
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524461
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524462
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524463
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 464700914524464
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
