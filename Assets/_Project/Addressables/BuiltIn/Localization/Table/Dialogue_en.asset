%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 8c07de4e6b118478b9e53f481dac2451, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24195883008
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 751442059264
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 5490640674816
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 6272467329024
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 7011403030528
    m_Localized: "\uB561\uD050 \uC564 \uC720?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788928
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788929
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788930
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788931
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788932
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788933
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788934
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788935
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788936
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788937
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788938
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788939
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788940
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788941
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788942
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788943
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788944
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788945
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788946
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788947
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788948
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788949
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788950
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788951
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788952
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788953
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788954
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788955
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788956
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788957
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788958
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788959
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788960
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788961
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788962
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788963
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788964
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788965
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788966
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788967
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788968
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788969
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788970
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788971
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788972
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788973
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788974
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788975
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788976
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788977
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788978
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788979
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788980
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788981
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788982
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788983
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788984
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788985
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788986
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788987
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788988
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788989
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788990
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788991
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788992
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788993
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788994
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788995
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788996
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788997
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788998
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089788999
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789000
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789001
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789002
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789003
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789004
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789005
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789006
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789007
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789008
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789009
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789010
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789011
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789012
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789013
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789014
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789015
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789016
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789017
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789018
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789019
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789020
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789021
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789022
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789023
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789024
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789025
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789026
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789027
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789028
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789029
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789030
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789031
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789032
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789033
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789034
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789035
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789036
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789037
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789038
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789039
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789040
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789041
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789042
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789043
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789044
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789045
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789046
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789047
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789048
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789049
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789050
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789051
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789052
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789053
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789054
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789055
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789056
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789057
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789058
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789059
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789060
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789061
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789062
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789063
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789064
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789065
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789066
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789067
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789068
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789069
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789070
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789071
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789072
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789073
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789074
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789075
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789076
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789077
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789078
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789079
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789080
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789081
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789082
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789083
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789084
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789085
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789086
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789087
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789088
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789089
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789090
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789091
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789092
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789093
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789094
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789095
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789096
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789097
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789098
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789099
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789100
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789101
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789102
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789103
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789104
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789105
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789106
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789107
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789108
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789109
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789110
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789111
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789112
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789113
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789114
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789115
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789116
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789117
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789118
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789119
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789120
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789121
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789122
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789123
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789124
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789125
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789126
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789127
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789128
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789129
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789130
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789131
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789132
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789133
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789134
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789135
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789136
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789137
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789138
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789139
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789140
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789141
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789142
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789143
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789144
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789145
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789146
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789147
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789148
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789149
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789150
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789151
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789152
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789153
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789154
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789155
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789156
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789157
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789158
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789159
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789160
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789161
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789162
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789163
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789164
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789165
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789166
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789167
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789168
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789169
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789170
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789171
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789172
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789173
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789174
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789175
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789176
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789177
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789178
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789179
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789180
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789181
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789182
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789183
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789184
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789185
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789186
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789187
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789188
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789189
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789190
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789191
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789192
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789193
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789194
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789195
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789196
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789197
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789198
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789199
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789200
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789201
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789202
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789203
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789204
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789205
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789206
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789207
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789208
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789209
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789210
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789211
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789212
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789213
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789214
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789215
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789216
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789217
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789218
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789219
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789220
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789221
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789222
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789223
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789224
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789225
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789226
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789227
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789228
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789229
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789230
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789231
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789232
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789233
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789234
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789235
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789236
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789237
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789238
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789239
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789240
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789241
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789242
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789243
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789244
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789245
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789246
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789247
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789248
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789249
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789250
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789251
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789252
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789253
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789254
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789255
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789256
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789257
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789258
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789259
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789260
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789261
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789262
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789263
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789264
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789265
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789266
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789267
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789268
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789269
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789270
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789271
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789272
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789273
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789274
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789275
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789276
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789277
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789278
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789279
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789280
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789281
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789282
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789283
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789284
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789285
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789286
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789287
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789288
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789289
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789290
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789291
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789292
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789293
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789294
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789295
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789296
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789297
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789298
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789299
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789300
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789301
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789302
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789303
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789304
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789305
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789306
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789307
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789308
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789309
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789310
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789311
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789312
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789313
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789314
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789315
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789316
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789317
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789318
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789319
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789320
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789321
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789322
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789323
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789324
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789325
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789326
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789327
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789328
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789329
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789330
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789331
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789332
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789333
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789334
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789335
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789336
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789337
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789338
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789339
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789340
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789341
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789342
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789343
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789344
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789345
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789346
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789347
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789348
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789349
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789350
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789351
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789352
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789353
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789354
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789355
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789356
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789357
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789358
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789359
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789360
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789361
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789362
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789363
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789364
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789365
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789366
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789367
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789368
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789369
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789370
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789371
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789372
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789373
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789374
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789375
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789376
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789377
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789378
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789379
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789380
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789381
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789382
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789383
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789384
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789385
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789386
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789387
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789388
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789389
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789390
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789391
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789392
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789393
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789394
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789395
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789396
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789397
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789398
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789399
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789400
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789401
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789402
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789403
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789404
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789405
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789406
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789407
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789408
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789409
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789410
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789411
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789412
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789413
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789414
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789415
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789416
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789417
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789418
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789419
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789420
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789421
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789422
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789423
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789424
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789425
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789426
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789427
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789428
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789429
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789430
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789431
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789432
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789433
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789434
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789435
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789436
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789437
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789438
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789439
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789440
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789441
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789442
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789443
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789444
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789445
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789446
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789447
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789448
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789449
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789450
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789451
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789452
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789453
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789454
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789455
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789456
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789457
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789458
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789459
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789460
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789461
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789462
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789463
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789464
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789465
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789466
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789467
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789468
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789469
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789470
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789471
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789472
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789473
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789474
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789475
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789476
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789477
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789478
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789479
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789480
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789481
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789482
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789483
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789484
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789485
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789486
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789487
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789488
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789489
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789490
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789491
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789492
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789493
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789494
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789495
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789496
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789497
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789498
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789499
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789500
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789501
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789502
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789503
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789504
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789505
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789506
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789507
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789508
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789509
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789510
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789511
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789512
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789513
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789514
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789515
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789516
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789517
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789518
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789519
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789520
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789521
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789522
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789523
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789524
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789525
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789526
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789527
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789528
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789529
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789530
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789531
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789532
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789533
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789534
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789535
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789536
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789537
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789538
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789539
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789540
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789541
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789542
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789543
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789544
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789545
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789546
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789547
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789548
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789549
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789550
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789551
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789552
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789553
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789554
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789555
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789556
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789557
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789558
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789559
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789560
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789561
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789562
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789563
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789564
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789565
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789566
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789567
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789568
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789569
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789570
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789571
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789572
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789573
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789574
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789575
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789576
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789577
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789578
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789579
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789580
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789581
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789582
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789583
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789584
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789585
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789586
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789587
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789588
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789589
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789590
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789591
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789592
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789593
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789594
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789595
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789596
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789597
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789598
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789599
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789600
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789601
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789602
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789603
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789604
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789605
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789606
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789607
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789608
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789609
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789610
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789611
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789612
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789613
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789614
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789615
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789616
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789617
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789618
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789619
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789620
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789621
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789622
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789623
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789624
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789625
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789626
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789627
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789628
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789629
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789630
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789631
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789632
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789633
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789634
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789635
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789636
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789637
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789638
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789639
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789640
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789641
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789642
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789643
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789644
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789645
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789646
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789647
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789648
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789649
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789650
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 338011089789651
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043786440704
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635008
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635009
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635010
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635011
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635012
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635013
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635014
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635015
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635016
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635017
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635018
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635019
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635020
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635021
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635022
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635023
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635024
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635025
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635026
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635027
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635028
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635029
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635030
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635031
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635032
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 453043790635033
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829312
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829313
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829314
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829315
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829316
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829317
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829318
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829319
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829320
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829321
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829322
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829323
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829324
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829325
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829326
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829327
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829328
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829329
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829330
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829331
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829332
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829333
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829334
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829335
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829336
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829337
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829338
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829339
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829340
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829341
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829342
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829343
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829344
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829345
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829346
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829347
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829348
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829349
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829350
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829351
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829352
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829353
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829354
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829355
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829356
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829357
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829358
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829359
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829360
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829361
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829362
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829363
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829364
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829365
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829366
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829367
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829368
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829369
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829370
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829371
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829372
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829373
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829374
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829375
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829376
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829377
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829378
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829379
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829380
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829381
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829382
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829383
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829384
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829385
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829386
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829387
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829388
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829389
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829390
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829391
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829392
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829393
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829394
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829395
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829396
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829397
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829398
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829399
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829400
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829401
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829402
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829403
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829404
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829405
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829406
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829407
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829408
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829409
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829410
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829411
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829412
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829413
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829414
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829415
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829416
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829417
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829418
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829419
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829420
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829421
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829422
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829423
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829424
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829425
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829426
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829427
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829428
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829429
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829430
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829431
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829432
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829433
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829434
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829435
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829436
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829437
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829438
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829439
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829440
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829441
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829442
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829443
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829444
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829445
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829446
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829447
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829448
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829449
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829450
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829451
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829452
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829453
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829454
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829455
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829456
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829457
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829458
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829459
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829460
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829461
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829462
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829463
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829464
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829465
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829466
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829467
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829468
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829469
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829470
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829471
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829472
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829473
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829474
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829475
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829476
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829477
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829478
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829479
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829480
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829481
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829482
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829483
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829484
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829485
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829486
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829487
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829488
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829489
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829490
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829491
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829492
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829493
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829494
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829495
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829496
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829497
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829498
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829499
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829500
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829501
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829502
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829503
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829504
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829505
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829506
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829507
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829508
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829509
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829510
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829511
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829512
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829513
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829514
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829515
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829516
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829517
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829518
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829519
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829520
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829521
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829522
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829523
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829524
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829525
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829526
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829527
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829528
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829529
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829530
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829531
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829532
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829533
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829534
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829535
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829536
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829537
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829538
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829539
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829540
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829541
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829542
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829543
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829544
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829545
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829546
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829547
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829548
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829549
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829550
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829551
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829552
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829553
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829554
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829555
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829556
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829557
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829558
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829559
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829560
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829561
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829562
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829563
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829564
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829565
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829566
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829567
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829568
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829569
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829570
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829571
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829572
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829573
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829574
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829575
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829576
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829577
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829578
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829579
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829580
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829581
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829582
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829583
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829584
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829585
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829586
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829587
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829588
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829589
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829590
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829591
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829592
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829593
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829594
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829595
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829596
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829597
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829598
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829599
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829600
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829601
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829602
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829603
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829604
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829605
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829606
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829607
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829608
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829609
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829610
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829611
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829612
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829613
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829614
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829615
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829616
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829617
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829618
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829619
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829620
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829621
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829622
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829623
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829624
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829625
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829626
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829627
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829628
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829629
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829630
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829631
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829632
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829633
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829634
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829635
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829636
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829637
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829638
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829639
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829640
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829641
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829642
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829643
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829644
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829645
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829646
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829647
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829648
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829649
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829650
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829651
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829652
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829653
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829654
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829655
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829656
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829657
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829658
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829659
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829660
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829661
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829662
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829663
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829664
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829665
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829666
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829667
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829668
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829669
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829670
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829671
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829672
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829673
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829674
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829675
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829676
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829677
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829678
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829679
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829680
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829681
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829682
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829683
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829684
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829685
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829686
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829687
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829688
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829689
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829690
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829691
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829692
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829693
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829694
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829695
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829696
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829697
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829698
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829699
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829700
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829701
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829702
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829703
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829704
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829705
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829706
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829707
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829708
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829709
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829710
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829711
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829712
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829713
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829714
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829715
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829716
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829717
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829718
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829719
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829720
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829721
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829722
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829723
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829724
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829725
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829726
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829727
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829728
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829729
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829730
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829731
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829732
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829733
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829734
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829735
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829736
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829737
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829738
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829739
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829740
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829741
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829742
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829743
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829744
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829745
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829746
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829747
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829748
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829749
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829750
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829751
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829752
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829753
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829754
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829755
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829756
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829757
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829758
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829759
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829760
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829761
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829762
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829763
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829764
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829765
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829766
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829767
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829768
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829769
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829770
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829771
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829772
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829773
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829774
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829775
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829776
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829777
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829778
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829779
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829780
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829781
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829782
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829783
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829784
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829785
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829786
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829787
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829788
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829789
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829790
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829791
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829792
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829793
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829794
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829795
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829796
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829797
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829798
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829799
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829800
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829801
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829802
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829803
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829804
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829805
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829806
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829807
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829808
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829809
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829810
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829811
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829812
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829813
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829814
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829815
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829816
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829817
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829818
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829819
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829820
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829821
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829822
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829823
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829824
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829825
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829826
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829827
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829828
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829829
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829830
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829831
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829832
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829833
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829834
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829835
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829836
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829837
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829838
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829839
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829840
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829841
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829842
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829843
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829844
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829845
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829846
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829847
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829848
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829849
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829850
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829851
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829852
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829853
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829854
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829855
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829856
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829857
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829858
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829859
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829860
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829861
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829862
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829863
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829864
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829865
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829866
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829867
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829868
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829869
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829870
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829871
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829872
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829873
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829874
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829875
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829876
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829877
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829878
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829879
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829880
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829881
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829882
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829883
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829884
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829885
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829886
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829887
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829888
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829889
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829890
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829891
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829892
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829893
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829894
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829895
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829896
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829897
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829898
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829899
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829900
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829901
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829902
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829903
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829904
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829905
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829906
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829907
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829908
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829909
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829910
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829911
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829912
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829913
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829914
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829915
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829916
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829917
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829918
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829919
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829920
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829921
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829922
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829923
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829924
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829925
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829926
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829927
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829928
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829929
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829930
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829931
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829932
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829933
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829934
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829935
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829936
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829937
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829938
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829939
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829940
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829941
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829942
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829943
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829944
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829945
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829946
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829947
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829948
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829949
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829950
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829951
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829952
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829953
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829954
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829955
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829956
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829957
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829958
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829959
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829960
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829961
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829962
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829963
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829964
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829965
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829966
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829967
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829968
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829969
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829970
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829971
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829972
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829973
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829974
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829975
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829976
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829977
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829978
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829979
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829980
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829981
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829982
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829983
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829984
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829985
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829986
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829987
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829988
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829989
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829990
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829991
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829992
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829993
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829994
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829995
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829996
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829997
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829998
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794829999
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830000
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830001
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830002
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830003
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830004
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830005
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830006
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830007
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
      \uC6B0\uB9AC\uB294 \uC6B0\uB9AC\uB9CC\uC758 \uB2F5\uC744 \uCC3E\uC544\uB0BC
      \uAC70\uC5D0\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 453043794830008
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uC5B4\uC11C \uC774\uCABD\uC73C\uB85C\u2026!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660073844736
    m_Localized: Commander! Please wake up!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233344
    m_Localized: .....
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233345
    m_Localized: Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233346
    m_Localized: At the moment, all of our troops have been...<color=#F75D32>wiped
      out.</color> It's just you and me, <color=#F75D32>Commander.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233347
    m_Localized: 'Now, there''s only one option left: you must return to the <color=#F75D32>past</color>
      and change the <color=#F75D32>future</color> again.'
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233348
    m_Localized: I believe in you, Commander. I know you can do it.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233349
    m_Localized: "You are\u2026 our only <color=#F75D32>savior.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233350
    m_Localized: Commander....?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233351
    m_Localized: "Finally\u2026 you\u2019re awake."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233352
    m_Localized: 'This may be sudden, but I am <color=#F75D32>Atresia,</color>

      a
      Stella Knight from the <color=#F75D32>Pleiades.</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233353
    m_Localized: "You\u2019ve just been summoned from the future to this place, <color=#F75D32>Geofront.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233354
    m_Localized: Something must have happened.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233355
    m_Localized: "Don\u2019t worry, I will help you, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233356
    m_Localized: Select the Stella Knights from the <color=#F75D32>bottom of the
      screen</color> and deploy them to the battlefield!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233357
    m_Localized: "I heard you\u2019re the newly appointed Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233358
    m_Localized: "You\u2019ve been assigned without any proper training..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233359
    m_Localized: That goes against the <color=#F75D32>rules.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233360
    m_Localized: Let me see if you truly have what it takes.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233361
    m_Localized: Each Stella Knight has a designated </color>position (role).</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233362
    m_Localized: Philia is in the <color=#F75D32>Ranger</color> position and can
      attack enemies from a  <color=#F75D32>long distance.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233363
    m_Localized: "As for me, I\u2019m in the <color=#F75D32>Guardian</color> position,
      taking the <color=#F75D32>role of protecting</color> allies at the frontlines."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233364
    m_Localized: Use me to <color=#F75D32>block the enemies</color> at the front,
      and have Philia <color=#F75D32>attacking the enemies!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233365
    m_Localized: I heard a new Commander has arrived!!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233366
    m_Localized: "Why didn\u2019t you tell me right away!?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233367
    m_Localized: Yuni! Calm down. The Commander is in a confused state right now.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233368
    m_Localized: Oh, really!? Then let me cheer you up!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233369
    m_Localized: My position is <color=#F75D32>Supporter.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233370
    m_Localized: I take on the role of <color=#F75D32> supporting the battle </color>of
      allies with <color=#F75D32>healing and buffs!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233371
    m_Localized: My skill, <color=#F75D32>Power Up</color>, increases the <color=#F75D32>ATK!</color>
      of the allies!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233372
    m_Localized: "Now, all that\u2019s left is the <color=#F75D32>final training</color>,
      Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233373
    m_Localized: "After this training, you\u2019ll be deployed straight into real
      combat."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233374
    m_Localized: Please eliminate the <color=#F75D32>final enemy</color> with Philia
      (Ranger) and Yuni (Supporter)!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233375
    m_Localized: Thank you for coming all the way to the <color=#F75D32>Flame Wastes</color>,
      Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233376
    m_Localized: I am <color=#F75D32>Mensha</color>, a member of the Elpis Special
      Forces.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233377
    m_Localized: We are currently conducting a search for a <color=#F75D32>missing</color>
      Stella Knight in the Flame Wastes.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233378
    m_Localized: Can you tell me the name of the missing knight?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233379
    m_Localized: Her name is <color=#F75D32>Alice.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233380
    m_Localized: "Additionally, we\u2019ve been informed that another Stella Knight
      is also missing,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233381
    m_Localized: "but it\u2019s difficult to confirm anything at the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233382
    m_Localized: "Alice... she's a companion I\u2019ve worked with on previous missions."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233383
    m_Localized: "Let\u2019s go rescue her right away, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233384
    m_Localized: Thank you, Commander. I will <color=#F75D32>show you the way!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233385
    m_Localized: Oh, by the way, Commander, what is <color=#F75D32>your name?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233386
    m_Localized: My position is <color=#F75D32>Tank</color>, and I protect allies
      from the enemy's <color=#F75D32>physical attacks.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233387
    m_Localized: Especially with my skill, <color=#F75D32>Guard Up</color>, I grant
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233388
    m_Localized: a <color=#F75D32>shield</color> to allies in the same row.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233389
    m_Localized: Use me to <color=#F75D32>protect</color> the allies!!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233390
    m_Localized: Phew, thanks to Mensha, we escaped the danger!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233391
    m_Localized: "Let\u2019s continue the adventure, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233392
    m_Localized: Ouch! What is this, there's lava on the ground?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233393
    m_Localized: Be careful, it's a <color=#F75D32>Lava Zone!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233394
    m_Localized: The boss of this region used his magic to create the <color=#F75D32>Lava
      Zone.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233395
    m_Localized: "If the Stella Knights step onto the lava, they\u2019ll take"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233396
    m_Localized: <color=#F75D32>damage,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233397
    m_Localized: so please be cautious when deploying us!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233398
    m_Localized: We almost got just roasted in it!!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233399
    m_Localized: It seems like the <color=#F75D32>Lava Zones</color> will keep appearing
      in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233400
    m_Localized: "Please make sure to check that there are no <color=#F75D32>Lava
      Zones</color> nearby when you\u2019re deploying us!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233401
    m_Localized: Huh!? Now there's a <color=#F75D32>huge wall</color> up ahead!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233402
    m_Localized: That one is an <color=#F75D32>obstacle</color>, and if there is
      an obstacle in front of us, it will <color=#F75D32>block our movement.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233403
    m_Localized: Also, Stella Knights <color=#F75D32>cannot be deployed</color> where
      obstacles are present.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233404
    m_Localized: "With obstacles, you can also <color=#F75D32>direct</color> the
      enemy\u2019s movement, so make good use of them!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233405
    m_Localized: Hmm... I feel like my attacks <color=#F75D32>are not working well.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233406
    m_Localized: It seems the monsters have high <color=#F75D32>Phys DEF.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233407
    m_Localized: "In situations like this, we need <color=#F75D32>Mage\u2019s</color>
      <color=#F75D32>magic attacks</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233408
    m_Localized: "Let\u2019s keep moving forward! I\u2019m sure we\u2019ll find a
      way!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233409
    m_Localized: We received a word from HQ that <color=#F75D32>Alice</color> is
      nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233410
    m_Localized: Just a little more to go, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233411
    m_Localized: Alice! She is over there!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233412
    m_Localized: Wait... something seems a bit off with her eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233413
    m_Localized: Alice!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233414
    m_Localized: Are you okay? Can you hear me?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233415
    m_Localized: Eliminate... the <color=#F75D32>intruder</color>...eliminate...the
      intruder...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233416
    m_Localized: What...? Alice, snap out of it! What happened to you?! Commander,
      please help her break free!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233417
    m_Localized: "Be careful, Commander! There\u2019s a <color=#F75D32>Lava Zone</color>
      right ahead of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233418
    m_Localized: Where...am I...?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233419
    m_Localized: Alice! It seems you were hypnotized by the enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233420
    m_Localized: "You\u2019ve come to help me, Atresia!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233421
    m_Localized: Thank you, Atresia. I owe you so much.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233422
    m_Localized: I am in the <color=#F75D32>Mage</color> position and can use <color=#F75D32>magic
      attacks,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233423
    m_Localized: which means I can deal heavy <color=#F75D32>magic damage</color>
      to Tanks!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233424
    m_Localized: First, <color=#F75D32>level me up</color> to level 3!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233425
    m_Localized: "Great, Commander, now I\u2019m ready to fight!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233426
    m_Localized: Head to the next stage and deploy me!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233427
    m_Localized: "Commander! I\u2019m a Mage with the <color=#F75D32>Water Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233428
    m_Localized: If you deploy me along with <color=#F75D32>Philia, the Water Ranger,</color>
      who has the same synergy as me,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233429
    m_Localized: the <color=#F75D32>Water Synergy</color> effect will give all the
      Stella Knights a <color=#F75D32>shield!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233430
    m_Localized: Deploy me and check out the <color=#F75D32>Water Synergy effect</color>
      for yourself!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233431
    m_Localized: How about that!? <color=#F75D32>Water Synergy</color> effect is
      pretty cool in action, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233432
    m_Localized: Aside from the Water Synergy, there are other synergies of <color=#F75D32>Fire/Earth/Wind/Light/Darkness.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233433
    m_Localized: "As you continue to fight, you\u2019ll get to experience various
      synergies!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233434
    m_Localized: "Let\u2019s head to the next stage!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233435
    m_Localized: Oh, hold on, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233436
    m_Localized: The HQ has just opened the <color=#F75D32>Combat Trial</color> dungeon
      to help the Stella Knights in training!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233437
    m_Localized: They say <color=#F75D32>clones of Stella Knights</color> will be
      appearing as enemies!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233438
    m_Localized: Additionally, when you clear a <color=#F75D32>certain stage</color>
      of Combat Trial,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233439
    m_Localized: you can <color=#F75D32>increase by 1</color> the number of units
      for deployment.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233440
    m_Localized: "Let\u2019s challenge the dungeon up to that very stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233441
    m_Localized: Wow, I just fought myself! That was so strange!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233442
    m_Localized: If I were to fight against an enemy that looks like me... hmm, that
      would be tough.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233443
    m_Localized: Oh, Commander, as I mentioned earlier, clearing a <color=#F75D32>certain
      stage</color> will increase the <color=#F75D32>number of deployment units</color>
      for the battle.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233444
    m_Localized: "At this point, if you clear <color=#F75D32>Stage 4</color>, you\u2019ll
      be able to increase the number of deployment units."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233445
    m_Localized: Battle of Validation stages open upon collecting <color=#F75D32>Stage
      Clear Stars.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233446
    m_Localized: Should we continue challenging the <color=#F75D32>stages?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233447
    m_Localized: Commander, seems like the enemies are <color=#F75D32>gathering on
      the right.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233448
    m_Localized: In times like this, if you <color=#F75D32>use me, Atresia</color>,
      I can strike multiple enemies at once.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233449
    m_Localized: Please <color=#F75D32>deploy me</color> in the right position.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233450
    m_Localized: "What\u2019s that <color=#F75D32>giant monster?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233451
    m_Localized: That giant monster is the <color=#F75D32>Magma Golem</color> guarding
      this area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233452
    m_Localized: It drops magma in a <color=#F75D32>cross-shaped area</color> and
      stuns enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233453
    m_Localized: Try <color=#F75D32>deploying</color> the Stella Knights in positions
      that avoid the <color=#F75D32>skill range</color> of Magma Golem!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233454
    m_Localized: "Commander, we\u2019ve just received a message from HQ on <color=#F75D32>reinforcements!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233455
    m_Localized: "Let\u2019s gather more companions to face stronger enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233456
    m_Localized: Wow, the battlefield is packed with Stella Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233457
    m_Localized: These new troops will be a great addition. Before heading into serious
      battle,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233458
    m_Localized: "let\u2019s get the team ready by <color=#F75D32>leveling them up!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233459
    m_Localized: "Oh! There\u2019s a light coming from the <color=#F75D32>Combat
      Trial!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233460
    m_Localized: "Commander, it\u2019s time to face the <color=#F75D32>giant boss</color>
      of the Combat Trial."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233461
    m_Localized: Defeat the <color=#F75D32>giant boss</color> and increase the number
      of <color=#F75D32>units you can deploy</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233462
    m_Localized: Phew... that was a tough battle, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233463
    m_Localized: We finally defeated the General Jacqueline, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233464
    m_Localized: Now, we can deploy one more companion.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233465
    m_Localized: Shall we head to the battlefield and check it out?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233466
    m_Localized: Wow! Now we can deploy <color=#F75D32>1 more</color> companion!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233467
    m_Localized: The more companions you deploy, the <color=#F75D32>more synergies</color>
      you can activate.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233468
    m_Localized: Additionally, the <color=#F75D32>more Stella Knights with the same
      synergy you deploy</color>, the stronger the synergy effects will be.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233469
    m_Localized: So be sure to actively use Stella Knights with the same synergy!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233470
    m_Localized: Ahh! I want to activate the Fire Synergy too!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233471
    m_Localized: Alice, HQ mentioned that another Stella Knight beside you is also
      missing.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233472
    m_Localized: Do you happen to know who she might be?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233473
    m_Localized: "It\u2019s probably <color=#F75D32>Blin</color>..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233474
    m_Localized: The reason this place is in flames is actually because of <color=#F75D32>her
      fire magic.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233475
    m_Localized: '!?'
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233476
    m_Localized: "I don\u2019t believe it either, but I clearly saw <color=#F75D32>Blin</color>
      using fire magic..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233477
    m_Localized: "We\u2019ll just have to confirm whether it\u2019s true or not."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233478
    m_Localized: Burn everything to ashes!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233479
    m_Localized: "That\u2019s <color=#F75D32>Blin\u2019s </color> voice!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233480
    m_Localized: "It sounds like she\u2019s not far from here."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233481
    m_Localized: "Let\u2019s hurry, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233482
    m_Localized: "Blin! It\u2019s me, Alice!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233483
    m_Localized: Who are you?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233484
    m_Localized: "Blin... you don\u2019t recognize me?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233485
    m_Localized: Hah! Ridiculous. Humanity is all deceived...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233486
    m_Localized: <color=#F75D32>The Witch of Laplace</color> will lead us to the
      truth!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233487
    m_Localized: Commander! Blin seems to have been severely <color=#F75D32>brainwashed.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233488
    m_Localized: Help bring her back!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233489
    m_Localized: Why... why am I here...?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233490
    m_Localized: You came to save me, Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233491
    m_Localized: Blin...! What happened to you?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233492
    m_Localized: Well... while I was fighting relentlessly at the gate, a purple
      light suddenly flashed before my eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233493
    m_Localized: "After that... I don\u2019t remember much..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233494
    m_Localized: "It\u2019s similar to Alice\u2019s experience."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233495
    m_Localized: Something is definitely going on, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233496
    m_Localized: It has been reported that another Stella Knight is missing in the
      <color=#F75D32>[Frozen City].</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233497
    m_Localized: Rescue the Stella Knight who went missing, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233498
    m_Localized: Since you helped me, Observer, I'd like to give you some <color=#F75D32>special
      gifts.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233499
    m_Localized: First, click on the <color=#F75D32>Attendance</color> button on
      the main screen!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233500
    m_Localized: By logging in daily, you can receive <color=#F75D32>various rewards</color>
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233501
    m_Localized: I still need a little more time to regain my strength.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233502
    m_Localized: "By <color=#F75D32>tomorrow</color>, my magical energy will be fully
      restored, and I\u2019ll be able to join you as <color=#F75D32>your companion!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233503
    m_Localized: "Don\u2019t forget to check the <color=#F75D32>Attendance</color>
      again <color=#F75D32>tomorrow!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233504
    m_Localized: Now, for the second gift.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233505
    m_Localized: Let's head to the first stage of Chapter 3!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233506
    m_Localized: Click the <color=#F75D32>+ button</color> above the battle start
      button on the right.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233507
    m_Localized: "You\u2019ll see the <color=#F75D32>[Explosion]</color> commander
      skill I gave you as a gift."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233508
    m_Localized: "You\u2019ll need to <color=#F75D32>equip the commander skill</color>
      to be able to use it during battle."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233509
    m_Localized: To use it, simply <color=#F75D32>click</color> the commander skill
      and then
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233510
    m_Localized: <color=#F75D32>drag it</color> to your desired location to activate
      the skill there.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233511
    m_Localized: "Let\u2019s try using the commander skill to take out some enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233512
    m_Localized: What do you think!? Pretty amazing gift, right!?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233513
    m_Localized: "Don\u2019t forget to use it"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233514
    m_Localized: whenever the Stella Knights are in danger!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233515
    m_Localized: "Thank you, Blin! Let\u2019s move on to the next stage, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233516
    m_Localized: Oh, so cold!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233517
    m_Localized: Why am I always the one finding these weird things?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233518
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233519
    m_Localized: "Ugh... it\u2019s so cold, I can\u2019t even move a step!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233520
    m_Localized: Commander, there are <color=#F75D32>ice zones</color> scattered
      throughout this area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233521
    m_Localized: If Stella Knights stand on an ice zone,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233522
    m_Localized: they will become <color=#F75D32>frozen</color> for a short period,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233523
    m_Localized: making them <color=#F75D32>unable</color> to move or attack.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233524
    m_Localized: What!? That's so unfair!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233525
    m_Localized: Let's be careful while <color=#F75D32>deploying</color> Stella Knights,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233526
    m_Localized: Now that I think about it, all I can see here is snow?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233527
    m_Localized: This place used to be a regular city facility...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233528
    m_Localized: Until the <color=#F75D32>Ice Queen</color> appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233529
    m_Localized: The Ice Queen...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233530
    m_Localized: Could she be the <color=#F75D32>Apostle</color> that HQ has been
      searching for?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233531
    m_Localized: "<color=#F75D32>Apostle?!</color> What\u2019s an Apostle??"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233532
    m_Localized: It seems that in the Frozen City, a new type of enemy
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233533
    m_Localized: with a <color=#F75D32>different position</color> will appear, unlike
      before.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233534
    m_Localized: When we move to the next stage, I'll explain further!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233535
    m_Localized: In the Frozen City, monsters of the <color=#F75D32>Assassin</color>
      type will appear.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233536
    m_Localized: Enemy Assassins will <color=#F75D32>move</color> to our side at
      the start of the battle,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233537
    m_Localized: so place <color=#F75D32>Tanks</color> with high physical defense
      in the back to prepare for the Assassins' attacks!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233538
    m_Localized: It seems that person is brainwashed as well!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233539
    m_Localized: It's clear from the way she's pointing her sword at us.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233540
    m_Localized: ...The <color=#F75D32>intruder</color> who has invaded our territory...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233541
    m_Localized: All of you... will... perish...here...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233542
    m_Localized: Scary...! She is clearly not in her right mind!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233543
    m_Localized: Looks like an <color=#F75D32>Assassin</color>, so be careful of
      <color=#F75D32>attacks from back!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233544
    m_Localized: Are you alright?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233545
    m_Localized: It seems I caused some trouble.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233546
    m_Localized: ...Thanks for snapping me out of it.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233547
    m_Localized: Commander, could you help me <color=#F75D32>level up?</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233548
    m_Localized: I want to repay my debt.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233549
    m_Localized: "Thank you, from now on, I\u2019ll fight by your side."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233550
    m_Localized: Oh, Commander! A message from HQ just came in, inviting us to the
      <color=#F75D32>Arena!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233551
    m_Localized: The Arena is a place where you can <color=#F75D32>fight other Stella
      Knights</color> and pick up new strategies!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233552
    m_Localized: "Let\u2019s click the [Arena] button on the main screen!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233553
    m_Localized: Also, in the Arena Defense deck, you can deploy <color=#F75D32>obstacles</color>
      as well as Stella Knights,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233554
    m_Localized: so be sure to actively use the <color=#F75D32>obstacles</color>
      to your advantage!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233555
    m_Localized: Phew~ That was so much fun, right, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233556
    m_Localized: "It seems like you enjoy battles, don\u2019t you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233557
    m_Localized: In the <color=#F75D32>Arena</color>, the more battles you fight,
      the higher your <color=#F75D32>tier</color> will become, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233558
    m_Localized: "The higher your tier, the <color=#F75D32>better rewards</color>
      you\u2019ll get, so make sure to enjoy the Arena to its fullest!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233559
    m_Localized: "Commander, you haven\u2019t forgotten about me, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233560
    m_Localized: "Let\u2019s get back to monster hunting."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233561
    m_Localized: "Since I\u2019m in the <color=#F75D32>Assassin position</color>,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233562
    m_Localized: "I can <color=#F75D32>instantly move</color> to the enemy\u2019s
      side."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233563
    m_Localized: Use me to target the enemy <color=#F75D32>Rangers and Mages</color>
      positioned in the rear.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233564
    m_Localized: "When you deploy me, I\u2019ll move to the <color=#F75D32>farthest
      enemy</color> from my position,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233565
    m_Localized: so place me strategically to <color=#F75D32>target</color> the enemies
      you want.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233566
    m_Localized: "Wow! She flies straight into the enemy lines, doesn\u2019t she,
      Sheena!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233567
    m_Localized: Assassins ignore any enemies in front of them and <color=#F75D32>move
      to the backline,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233568
    m_Localized: so use Assassins to target <color=#F75D32>enemies hiding in the
      back.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233569
    m_Localized: "Let\u2019s keep fighting."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233570
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233571
    m_Localized: "What\u2019s wrong, Sheena?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233572
    m_Localized: "I\u2019m sensing something... a <color=#F75D32>dark presence.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233573
    m_Localized: Is it something you recognize?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233574
    m_Localized: ...I feel an <color=#F75D32>unfamiliar yet familiar aura</color>,
      it seems to be nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233575
    m_Localized: "First, let's deal with the enemies in front of us. As we go, we\u2019ll
      uncover <color=#F75D32>its identity.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233576
    m_Localized: ...That person..!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233577
    m_Localized: ...<color=#F75D32>Hati!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233578
    m_Localized: Why are you with the monsters?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233579
    m_Localized: ...Sheena. After you lost your eyesight in battle,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233580
    m_Localized: many things have changed.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233581
    m_Localized: "The world\u2019s justice, and even me."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233582
    m_Localized: To me, these monsters look like... <color=#F75D32>humans.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233583
    m_Localized: "Oh, no, she\u2019s not in her right mind."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233584
    m_Localized: Commander, be careful! The enemies are approaching!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233585
    m_Localized: This place...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233586
    m_Localized: Hati! It seems you were <color=#F75D32>hypnotized</color> by the
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233587
    m_Localized: Me..?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233588
    m_Localized: "...I\u2019m glad you are okay, Hati."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233589
    m_Localized: "It seems I\u2019ve caused some trouble. I\u2019m sorry, everyone."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233590
    m_Localized: And thank you, Sheena.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233591
    m_Localized: Commander! HQ just sent word that reinforcements are on the way!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233592
    m_Localized: Shall we move to the <color=#F75D32>summon</color> to welcome new
      companions?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233593
    m_Localized: Before diving into a full-scale battle, let's take a moment for
      <color=#F75D32>reorganization!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233594
    m_Localized: Commander! It seems a new stage has opened in the <color=#F75D32>Combat
      Trial.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233595
    m_Localized: "It's an opportunity to increase the number of <color=#F75D32>additional
      units</color> to deploy. Let\u2019s head to the <color=#F75D32>Combat Trial</color>
      right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233596
    m_Localized: Congratulations on your victory, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233597
    m_Localized: Now, you can deploy up to <color=#F75D32>6 Stella Knights!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233598
    m_Localized: Let's enter the <color=#F75D32>stage</color> right away and check
      it out, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233599
    m_Localized: The snowstorm seems to be getting stronger.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233600
    m_Localized: Could it be because of the Apostle's aura?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233601
    m_Localized: But what exactly is an Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233602
    m_Localized: An Apostle is a being that <color=#F75D32>controls all the monsters</color>,
      a commander of some sort.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233603
    m_Localized: The <color=#F75D32>Apostle is likely the one behind</color> the
      Stella Knights' hypnosis and their strange behavior.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233604
    m_Localized: Is the Apostle the reason this happened to me too?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233605
    m_Localized: It's possible.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233606
    m_Localized: <color=#F75D32>Defeating the Apostle</color> might weaken the monsters.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233607
    m_Localized: Let's keep moving forward, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233608
    m_Localized: Ah! A <color=#F75D32>giant monster</color> has appeared!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233609
    m_Localized: Is that the Apostle?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233610
    m_Localized: According to HQ, that monster is called <color=#F75D32>Ice Balrog.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233611
    m_Localized: It uses <color=#F75D32>ice attacks</color> on enemies <color=#F75D32>nearby,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233612
    m_Localized: so we need to use <color=#F75D32>ranged allies</color> to take it
      down!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233613
    m_Localized: Try using a <color=#F75D32>Ranger</color> or <color=#F75D32>Mage</color>
      with long-range attacks, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233614
    m_Localized: Now that I think about it, I heard there was a Stella Knight who
      was
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233615
    m_Localized: <color=#F75D32>deployed here before</color> Hati and me.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233616
    m_Localized: Could this Frozen City be like this because of that Stella Knight?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233617
    m_Localized: "It\u2019s possible."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233618
    m_Localized: A Stella Knight who uses <color=#F75D32>ice</color>, just like Alice...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233619
    m_Localized: But who could it be?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233620
    m_Localized: "Whoa! Look over there, on the right! There\u2019s an interesting-looking
      platform!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233621
    m_Localized: "Ah, that\u2019s an <color=#F75D32>ATK Buff Zone.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233622
    m_Localized: If you <color=#F75D32>place</color> a Stella Knight on that spot,
      their ATK will increase.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233623
    m_Localized: Please note that ATK increases only when standing on the <color=#F75D32>platform.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233624
    m_Localized: Deploy Stella Knights with <color=#F75D32>high ATK</color> to deal
      strong damage to the enemy!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233625
    m_Localized: I remember now, it was the <color=#F75D32>White Reaper.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233626
    m_Localized: Who?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233627
    m_Localized: The Stella Knight who was deployed here before.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233628
    m_Localized: "I\u2019ve heard her being as beautiful as a swan but incredibly
      ruthless."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233629
    m_Localized: "If she can freeze this entire city, she\u2019s definitely not weak."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233630
    m_Localized: Hmm... the monsters are gathering on the <color=#F75D32>right!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233631
    m_Localized: There is some ice to the right, so be cautious when deploying us,
      Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233632
    m_Localized: It suddenly got quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233633
    m_Localized: "Once we defeat the monsters ahead, we\u2019ll face the <color=#F75D32>ruler
      of this area.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233634
    m_Localized: "Freezing an entire region like this won\u2019t make them easy to
      beat."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233635
    m_Localized: "But if we all work together, I\u2019m sure we can win."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233636
    m_Localized: Commander, lend us a hand!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233637
    m_Localized: Commander... I think that's the <color=#F75D32>Stella Knight.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233638
    m_Localized: Finally... you've made it here.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233639
    m_Localized: You had me worried there with such poor skills.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233640
    m_Localized: Ugh, what a sharp tongue she got!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233641
    m_Localized: "You\u2019ll at least provide me some entertainment, won\u2019t
      you?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233642
    m_Localized: "Now, let\u2019s begin the dance of battle!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233643
    m_Localized: The snow... has stopped.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233644
    m_Localized: Is it all over...?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233645
    m_Localized: (Mysterious voice) This is... not the end.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233646
    m_Localized: (Mysterious voice) I will destroy this
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233647
    m_Localized: "(Mysterious voice) <color=#F75D32>cowardly world</color> you\u2019ve
      created,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233648
    m_Localized: (Mysterious voice) and rebuild it anew!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233649
    m_Localized: Odette!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233650
    m_Localized: Seems like she passed out. We should send her back to HQ for treatment.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233651
    m_Localized: That strange voice just now...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233652
    m_Localized: It must have been the leader of all Apostles, the <color=#F75D32>Witch
      of Laplace.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233653
    m_Localized: "There\u2019s still a trace of the Witch of Laplace\u2019s aura
      lingering in the aftermath of the battle."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233654
    m_Localized: "I\u2019ll send a request to HQ for analysis."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233655
    m_Localized: (1 hour later.)
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233656
    m_Localized: HQ has sent back the analysis results.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233657
    m_Localized: "The Witch\u2019s aura is pointing towards the <color=#F75D32>[Forgotten
      Desert].</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233658
    m_Localized: HQ has just sent a mission to join up with <color=#F75D32>Mino</color>,
      who was deployed earlier, and carry out the operation together.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233659
    m_Localized: "It\u2019s a desert this time!?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233660
    m_Localized: "I\u2019ve heard that Mino is a <color=#F75D32>Genius Engineer</color>
      who developed various weapons for HQ at a young age."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233661
    m_Localized: "This mission won\u2019t be easy either."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233662
    m_Localized: Let's head to the <color=#F75D32>[Forgotten Desert]</color> right
      away!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233663
    m_Localized: 'After the battle with Odette, Commander, you''ve acquired a new
      commander skill: <color=#F75D32>[Freezing]!</color>'
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233664
    m_Localized: It temporarily <color=#F75D32>freezes</color> enemies in a certain
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233665
    m_Localized: Shall we give it a try?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233666
    m_Localized: "Ugh... I\u2019m so thirsty! It feels like my throat is burning
      up!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233667
    m_Localized: Just hold on a bit longer, Yuni. Once we meet the Stella Knight
      <color=#F75D32>Mino</color>, who was deployed ahead,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233668
    m_Localized: "we\u2019ll receive food supplies."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233669
    m_Localized: Oh right, I know Mino quite well.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233670
    m_Localized: "We\u2019ve worked together on missions before, and we\u2019re also
      connected on a personal level."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233671
    m_Localized: "She\u2019s kind of a weirdo, but I\u2019ll give talking to her
      a shot when we meet."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233672
    m_Localized: "Let\u2019s clear out the enemies in front of us first."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233673
    m_Localized: Commander, HQ has sent detailed information on the enemies in this
      area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233674
    m_Localized: The enemies are using <color=#F75D32>Earth Synergy</color>, and
      their <color=#F75D32>Phys DEF</color> is much higher than regular monsters!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233675
    m_Localized: Using a Ranger like me, who has high <color=#F75D32>Phys Pen</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233676
    m_Localized: or a Mage with <color=#F75D32>magic attacks</color> will help you
      defeat them easily!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233677
    m_Localized: Use Rangers and Mages to INTer the <color=#F75D32>Earth Synergy</color>
      monsters, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233678
    m_Localized: "Oh? What\u2019s this sand pit?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233679
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233680
    m_Localized: That sandy area is a trap set by the sandworms of this desert.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233681
    m_Localized: "If you step into that area, you\u2019ll be lifted into the air
      and unable to participate in the battle for a <color=#F75D32>certain amount
      of time.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233682
    m_Localized: "You\u2019ll be an easy target for enemies, so watch out!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233683
    m_Localized: By the way, Mino hasn't responded at all... Could something be wrong?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233684
    m_Localized: No need to worry.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233685
    m_Localized: "She\u2019s the type to get absorbed in her world, probably she
      got somewhere making new weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233686
    m_Localized: "Hopefully, the new one doesn\u2019t explode this time..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233687
    m_Localized: "Oh!? Now there\u2019s a different <color=#F75D32>buff platform</color>
      here!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233688
    m_Localized: That buff zone is a <color=#F75D32>DEF Buff</color> zone.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233689
    m_Localized: Positioning Stella Knights there will increase their <color=#F75D32>DEF,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233690
    m_Localized: so strategically place them to increase their chances of survival!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233691
    m_Localized: Mino! What are you up to this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233692
    m_Localized: Hati!? What are you doing here?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233693
    m_Localized: "We received a mission from HQ to join forces with you, Mino, and
      search for the Witch of Laplace\u2019s traces."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233694
    m_Localized: Hmm... HQ suddenly sent reinforcements? They ignored me when I asked
      for help before.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233695
    m_Localized: "With all these rumors about brainwashing and getting controlled,
      I can\u2019t trust anyone!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233696
    m_Localized: Prove yourselves with your skills!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233697
    m_Localized: Ha... Looks like she just wants to show off her new weapon.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233698
    m_Localized: "Commander, I\u2019ll snap her out of it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233699
    m_Localized: Mino uses <color=#F75D32>Earth Synergy</color>, which gives her
      high Phys DEF.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233700
    m_Localized: However, I have a high <color=#F75D32>Phys Pen</color>, so I can
      deal effective damage to her.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233701
    m_Localized: Use me to defeat Mino.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233702
    m_Localized: "Phew\u2014 that was fun!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233703
    m_Localized: That was fun!? I almost died because of you!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233704
    m_Localized: "See? I told you, she\u2019s a bit of a weirdo."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233705
    m_Localized: Now that it's clear none of us are being brainwashed, let's get
      down to business.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233706
    m_Localized: "You\u2019re not familiar with this desert, so I\u2019ll guide you!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233707
    m_Localized: First, <color=#F75D32>level me up</color> to level 5.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233708
    m_Localized: By the way, Mino, what brings you here?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233709
    m_Localized: <color=#F75D32>Ancient Relic</color> is the answer.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233710
    m_Localized: The Ancient Relic?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233711
    m_Localized: HQ believes the Ancient Relic is directly linked to the recent brainwashing
      incidents.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233712
    m_Localized: "That\u2019s why I was sent to analyze it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233713
    m_Localized: "It\u2019s also something I personally find quite interesting."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233714
    m_Localized: Then, we might even find a clue about the Apostle.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233715
    m_Localized: But have you found it?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233716
    m_Localized: No!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233717
    m_Localized: Why are you so confident about that!?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233718
    m_Localized: "It\u2019s not supposed to be so easy to find! The Ancient Relic
      is divided into three pieces."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233719
    m_Localized: "Each part is guarded by the desert\u2019s monsters, the sandworms
      and desert scorpions."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233720
    m_Localized: HQ sent you guys because it's not easy for me to handle all the
      monsters alone,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233721
    m_Localized: so they ordered to form a team and recover the relic.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233722
    m_Localized: "Ugh, <color=#F75D32>sandworms!</color> I really don\u2019t want
      to deal with them!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233723
    m_Localized: "... It seems there\u2019s a sandworm nearby."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233724
    m_Localized: How do you know?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233725
    m_Localized: The number of creatures around us has suddenly dropped.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233726
    m_Localized: "I\u2019ve heard sandworms drain the life force of nearby creatures."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233727
    m_Localized: "You\u2019ll be caught off guard if you\u2019ve never faced one
      before."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233728
    m_Localized: "I\u2019ll lead the battle, follow me!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233729
    m_Localized: W-what is that giant worm?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233730
    m_Localized: "It\u2019s my first time seeing one in person too."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233731
    m_Localized: Sandworms mainly attack by biting enemies nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233732
    m_Localized: "When they use their skill, they burrow underground, and during
      that time, they can\u2019t be <color=#F75D32>targeted.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233733
    m_Localized: Then they emerge from beneath and strike the enemy with the highest
      ATK with <color=#F75D32>spikes.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233734
    m_Localized: The Stella Knight with the <color=#F75D32>highest ATK</color> among
      us needs to be extra careful.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233735
    m_Localized: "Alright, let\u2019s begin the sandworm hunt!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233736
    m_Localized: Finally... we defeated it...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233737
    m_Localized: Is that the piece of a relic?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233738
    m_Localized: "Yes, this is the first piece of the ancient relic that I\u2019ve
      been searching for."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233739
    m_Localized: Now, we just need to find two more!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233740
    m_Localized: Ugh, relics or whatever, I just want to go back to HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233741
    m_Localized: "Oh, what\u2019s that chest over there?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233742
    m_Localized: That chest is a <color=#F75D32>destructible obstacle</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233743
    m_Localized: that you can <color=#F75D32>destroy</color> by dealing damage to
      it.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233744
    m_Localized: Destroying obstacles can open new paths, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233745
    m_Localized: Mino! But why are you so obsessed with finding the ancient relic?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233746
    m_Localized: Obviously, to create an incredible weapon!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233747
    m_Localized: If I can make a weapon that no one else can,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233748
    m_Localized: no one will ever look down on me again!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233749
    m_Localized: Here we go again...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233750
    m_Localized: "Let\u2019s hope this \u2018ultimate weapon\u2019 of yours actually
      works this time."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233751
    m_Localized: Of course, it will, who do you think made it?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233752
    m_Localized: "Remember that time in the middle of a battlefield when the gun
      you made didn\u2019t fire and I almost died?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233753
    m_Localized: That was a minor detail, totally insignificant. Small things like
      that are trivial to a genius like me!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233754
    m_Localized: "...I\u2019m starting to question whether looking for the ancient
      relic is really the right thing, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233755
    m_Localized: "Ahh! What\u2019s that scorpion?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233756
    m_Localized: It looks like the second guardian monster has appeared.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233757
    m_Localized: That scorpion shoots a <color=#F75D32>deadly venomous sting</color>
      that suppresses healing abilities!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233758
    m_Localized: The sting also tracks nearby enemies and deals additional damage,
      so be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233759
    m_Localized: "Alright, that\u2019s the second piece secured."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233760
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233761
    m_Localized: Wait a moment, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233762
    m_Localized: We just got word from HQ that a new stage in the <color=#F75D32>Battle
      of Validation</color> has opened.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233763
    m_Localized: This is a chance to expand our unit deployment up to <color=#F75D32>7
      units.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233764
    m_Localized: "Let\u2019s challenge the dungeon right away!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233765
    m_Localized: Congratulations, Commander! Now you can deploy up to 7 of our Stella
      Knights!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233766
    m_Localized: Also, HQ has just sent a request for reinforcements.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233767
    m_Localized: Head to the main screen and proceed with a <color=#F75D32>10x summon!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233768
    m_Localized: Shall we organize the squad one more time before the big battle?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233769
    m_Localized: "Once we find the last relic piece, I can finally create the ultimate
      weapon I\u2019ve been dreaming of!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233770
    m_Localized: "Mino, I\u2019ve always wondered, why is becoming the best so important
      to you."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233771
    m_Localized: Of course, it is! Shouldn't the whole world know that I'm a genius?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233772
    m_Localized: "They\u2019re already using plenty of your weapons in the HQ Geofront."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233773
    m_Localized: Most people agree that the quality is pretty good, too.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233774
    m_Localized: "What\u2019s this? A compliment from you?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233775
    m_Localized: Just saying... I think you're already doing great just the way you
      are.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233776
    m_Localized: What's with the cheesy talk? What's gotten into you? Ahem!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233777
    m_Localized: "Anyway, let\u2019s go hunt some monsters!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233778
    m_Localized: Embarrassed, are we?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233779
    m_Localized: "There\u2019s no end to them."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233780
    m_Localized: "If the battle\u2019s wearing you out, make sure to make full use
      of our Rangers, Commander."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233781
    m_Localized: The knights in <color=#F75D32>Ranger position</color>, including
      myself, can easily take out monsters in this area with high penetration.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233782
    m_Localized: Additionally, certain Stella Knights also have high <color=#F75D32>penetration</color>,
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233783
    m_Localized: so make sure to check the <color=#F75D32>stats</color> of the units
      for the best results.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233784
    m_Localized: Only one more to go.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233785
    m_Localized: "Let\u2019s go take down that sandworm!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233786
    m_Localized: "With this, we\u2019ve gathered all the ancient relic pieces!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233787
    m_Localized: Now, we just need to return to HQ and assemble them.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233788
    m_Localized: The real challenge is figuring out how to get out of here.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233789
    m_Localized: But everyone, be cautious from now on.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233790
    m_Localized: "There\u2019s actually one more Stella Knight staying here besides
      me."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233791
    m_Localized: Unfortunately, it seems that person has been brainwashed.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233792
    m_Localized: Who is it?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233793
    m_Localized: The Destroyer of Earth, <color=#F75D32>Tetora.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233794
    m_Localized: Huh? Teto...what?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233795
    m_Localized: Tetora... I've never heard of this name before.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233796
    m_Localized: "You don\u2019t know Tetora, who was recently ranked <color=#F75D32>Number
      1 in the Arena</color> among the Stella Knights?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233797
    m_Localized: Apparently, Tetora came to the desert with the intent of claiming
      the Ancient Relic.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233798
    m_Localized: Sadly, it looks like she was brainwashed during that process.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233799
    m_Localized: We need to rescue her, too!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233800
    m_Localized: "Unfortunately, it won\u2019t be that easy. She didn\u2019t become
      Arena\u2019s top rank for nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233801
    m_Localized: Is there any way to save her?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233802
    m_Localized: Well, I guess now is the time to think it over.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233803
    m_Localized: Well done, weaklings!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233804
    m_Localized: "You\u2019ve gone through all this trouble gathering the Ancient
      Relic for me."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233805
    m_Localized: "You\u2019ve worked so hard, now hand it over!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233806
    m_Localized: How can she be so shameless?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233807
    m_Localized: She is a Guardian with an Earth Synergy.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233808
    m_Localized: Being a Guardian, her Phys DEF is low, but her <color=#F75D32>Magic
      DEF</color> is high.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233809
    m_Localized: It would be best if <color=#F75D32>Rangers</color> like <color=#F75D32>Philia,
      Hati, and I</color> take on Tetora.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233810
    m_Localized: That's all for the explanation. Now let's face her head-on!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233811
    m_Localized: ...We barely won...
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233812
    m_Localized: "...I told you, she\u2019s Arena's number one for a reason."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233813
    m_Localized: What am I doing in the desert?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233814
    m_Localized: Who are you people?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233815
    m_Localized: "You were brainwashed by the enemy during your search for that Ancient
      Relic, but don\u2019t worry, you\u2019re all right now."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233816
    m_Localized: Haha! Looks like I owe you one, huh?
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233817
    m_Localized: Next time, come visit the Arena! I'll personally take you on!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233818
    m_Localized: "So you're saying you want to fight again? I should\u2019ve just
      left you brainwashed!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233819
    m_Localized: Commander! We've received a message from HQ!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233820
    m_Localized: There's a request to move to the Forest of Beasts, but... things
      seem complicated internally.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233821
    m_Localized: "Let\u2019s move to the <<color=#F75D32>[Forest of Beasts]</color>
      first, I'll explain the details further."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233822
    m_Localized: Let's head to the <<color=#F75D32>[Forest of Beasts]</color>, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233823
    m_Localized: 'Commander, by clearing the desert region, you''ve acquired a new
      commander skill: <color=#F75D32>[Airborne]</color>!'
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233824
    m_Localized: The Airborne skill allows you to lift a designated enemy into the
      air for a certain period.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233825
    m_Localized: It's a great skill for controlling powerful enemies, so make sure
      to use it!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233826
    m_Localized: Ugh, seriously!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233827
    m_Localized: Why do the monsters in this area seem to have such a fast <color=#F75D32>ATK
      SPD?!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233828
    m_Localized: "That\u2019s because the monsters here have <color=#F75D32>Wind
      Synergy.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233829
    m_Localized: The more monsters with Wind Synergy are placed together, the faster
      their <color=#F75D32>ATK SPD</color> becomes.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233830
    m_Localized: Use Stella Knights to decrease their ATK SPD
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233831
    m_Localized: or increase the <color=#F75D32>DEF</color> to prepare for the enemies'
      attacks, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233832
    m_Localized: Philia! But why did we come to the jungle this time?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233833
    m_Localized: Ah, I forgot to explain.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233834
    m_Localized: It appears that the HQ of the <color=#F75D32>Rebel Forces</color>,
      who are in conflict with our HQ, is located in this region.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233835
    m_Localized: Rebel forces?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233836
    m_Localized: In the end, the HQ is made up of people with diverse beliefs, so
      conflicts like this are inevitable.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233837
    m_Localized: The HQ is hoping to take this opportunity to identify key figures
      of the <color=#F75D32>Rebel Forces.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233838
    m_Localized: "May, from the HQ\u2019s audit team, was sent ahead and should be
      somewhere around here."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233839
    m_Localized: "Let\u2019s meet with her and check the current situation."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233840
    m_Localized: Be careful, Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233841
    m_Localized: Eek! What is this now?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233842
    m_Localized: "It\u2019s a hunting trap for beasts."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233843
    m_Localized: I've heard that there are many traps like this scattered throughout
      the area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233844
    m_Localized: "If you step on one, you\u2019ll take damage and be unable to move
      for a while, so watch your step."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233845
    m_Localized: Oh! There's another new platform over there!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233846
    m_Localized: Here comes Philia the Explainer!
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233847
    m_Localized: Am I really that much of an explainer? Hmm.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233848
    m_Localized: That platform is a magic power platform, which significantly increases
      the damage of Stella Knights in the <color=#F75D32>Mage position.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233849
    m_Localized: Just like with the other platforms, the effect only applies while
      you're standing on it, so keep that in mind.
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233850
    m_Localized: "We\u2019re almost at the rendezvous point where we should meet
      up with May."
    m_Metadata:
      m_Items: []
  - m_Id: 461660082233851
    m_Localized: "By the way, wasn\u2019t May part of HQ\u2019s internal lifestyle
      management organization, <color=#F75D32>MAID?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427648
    m_Localized: "That\u2019s right! Even though she\u2019s a terrible cook, she
      sure tries her best!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427649
    m_Localized: Yes, but while the MAID team officially handles lifestyle management,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427650
    m_Localized: its main role is auditing internal corruption within the organization.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427651
    m_Localized: Who's there!?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427652
    m_Localized: "We\u2019re the Pleiades unit, dispatched by HQ to assist you, May."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427653
    m_Localized: Pleiades... that's the unit where Philia is a part of.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427654
    m_Localized: "Hm. But this mission is supposed to be a covert one, so HQ wouldn\u2019t
      send a unit so easily..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427655
    m_Localized: I can't trust you just yet!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427656
    m_Localized: "Ah, everyone\u2019s so on edge lately with all these brainwashing
      incidents!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427657
    m_Localized: We have no choice for now. Let's proceed with the battle, Commander!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427658
    m_Localized: Philia! So it really was you.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427659
    m_Localized: "It\u2019s been a while, May. Almost half a year, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427660
    m_Localized: Yes, it's been about that long since I was dispatched.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427661
    m_Localized: "May, what\u2019s the current situation?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427662
    m_Localized: "I have pinpointed the location of the secret organization\u2019s
      base, but I\u2019ve been short on combat personnel to raid it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427663
    m_Localized: "Now that you\u2019re all here, including Atresia,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427664
    m_Localized: we can finally begin the operation.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427665
    m_Localized: "We\u2019ll discuss the details as we move!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427666
    m_Localized: Have you identified any key figures within the secret organization?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427667
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427668
    m_Localized: "... Yes, but now I... I\u2019m not so sure."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427669
    m_Localized: "Everything points in one direction, but I just can\u2019t bring
      myself to believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427670
    m_Localized: "Oh, right... maybe you\u2019re just seeing what you want to see!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427671
    m_Localized: Yuni!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427672
    m_Localized: It must be someone you really trusted.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427673
    m_Localized: ... Th-that's...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427674
    m_Localized: Oh! I think I hear something stomping around!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427675
    m_Localized: It sounds like one of the giant monsters in this area.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427676
    m_Localized: Everyone, prepare for battle!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427677
    m_Localized: May, what kind of monster is it?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427678
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427679
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427680
    m_Localized: Oh! Sorry, I got lost in thought for a moment...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427681
    m_Localized: "I know it\u2019s tough, but for now, let\u2019s focus on taking
      down the enemy in front of us!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427682
    m_Localized: The enemy ahead is a <color=#F75D32>Tank-type</color> giant monster.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427683
    m_Localized: When it uses its skill, it leaps into the air and then lands, dealing
      <color=#F75D32>damage and stunning</color> anyone nearby!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427684
    m_Localized: It targets the enemy with the lowest current HP,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427685
    m_Localized: so we need to make sure to protect any allies with low HP right
      now!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427686
    m_Localized: Whew! That monster was like an enraged gorilla!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427687
    m_Localized: "We\u2019ve received a message from HQ on reinforcements!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427688
    m_Localized: "Let\u2019s head to the main screen and summon them, Commander!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427689
    m_Localized: This area seems to be more dangerous than we thought, Commander.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427690
    m_Localized: How about leveling up before the real battle begins?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427691
    m_Localized: What have you been thinking about all this time, May?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427692
    m_Localized: "That\u2019s..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427693
    m_Localized: "If you're uncomfortable, you don\u2019t have to talk about it,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427694
    m_Localized: but the day will come when you'll have to face that person.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427695
    m_Localized: "...That\u2019s right. In the end, I have to face her.."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427696
    m_Localized: "Alright, since you\u2019re all on this mission with me, I\u2019ll
      tell you."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427697
    m_Localized: The person currently suspected of being part of the rebel forces
      is...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427698
    m_Localized: Who is it...?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427699
    m_Localized: "It\u2019s the current leader of MAID, <color=#F75D32>April.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427700
    m_Localized: "April? Isn\u2019t she one of the founding members of the MAID organization?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427701
    m_Localized: The top executives have been closely monitoring the founding members
      of each organization for a long time,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427702
    m_Localized: believing that those who stand the firmest are the most likely to
      break.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427703
    m_Localized: But to me, that just seems like the top trying to maintain their
      power.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427704
    m_Localized: A recent incident turned their suspicions into certainty.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427705
    m_Localized: A high-ranking official was recently <color=#F75D32>assassinated</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427706
    m_Localized: At first, it was thought to be an accident, but after investigating
      the circumstances and evidence,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427707
    m_Localized: it became clear that it was a planned incident.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427708
    m_Localized: "But that alone isn\u2019t enough to accuse April, is it?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427709
    m_Localized: That's right, but the story changes when you consider that the person
      who was assassinated had been pushing for a hardline policy against the Stella
      Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427710
    m_Localized: You mean the policy to mass-produce us as disposable weapons of
      war.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427711
    m_Localized: And because of that policy, many Stella Knights and their affiliates
      lost their lives.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427712
    m_Localized: "Crucially, among the victims were April\u2019s own family."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427713
    m_Localized: ...It seems we have an intruder.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427714
    m_Localized: Wait, is it another brainwashed Stella Knight? Snap out of it, you
      fool!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427715
    m_Localized: "...No, it doesn\u2019t feel like that."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427716
    m_Localized: I have no grudge against you.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427717
    m_Localized: "I\u2019m just hired for the job."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427718
    m_Localized: Commander, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427719
    m_Localized: Whew... we finally took her down!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427720
    m_Localized: Ahem, so if we summarize what May has told us so far,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427721
    m_Localized: 1. A key executive who treated the Stella Knights like disposable
      weapons was killed.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427722
    m_Localized: "2. That executive was responsible for the death of April\u2019s
      family in the past."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427723
    m_Localized: 3. And out of a grudge, April likely formed the rebel forces! Is
      that right?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427724
    m_Localized: Yuni! You're particularly sharp today!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427725
    m_Localized: "That\u2019s correct. There\u2019s also a lot of circumstantial
      evidence to support this."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427726
    m_Localized: "At this point, it\u2019s almost certain."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427727
    m_Localized: May. What do you want to do now?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427728
    m_Localized: I... I...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427729
    m_Localized: "Philia, don\u2019t push May too hard like that."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427730
    m_Localized: Hmm... Then let me tell you about my past.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427731
    m_Localized: Before joining Atresia and Yuni, I was deployed to another battlefield.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427732
    m_Localized: "Back then, the leader I trusted was secretly selling off our team\u2019s
      weapons."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427733
    m_Localized: "If we had those weapons, many of my companions wouldn\u2019t have
      been hurt."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427734
    m_Localized: "I wanted to ask the leader why, but I just couldn\u2019t do it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427735
    m_Localized: It must have been really hard for you...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427736
    m_Localized: It felt like all the memories we shared would become lies.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427737
    m_Localized: But now I regret it. I wish I had faced the truth.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427738
    m_Localized: If I had, I would have found the strength to move forward.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427739
    m_Localized: No! April must have had her reasons!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427740
    m_Localized: May!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427741
    m_Localized: April was the kind of person who never backed down from doing the
      tough jobs for all of us!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427742
    m_Localized: Someone like her could never... could never have done something
      like this!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427743
    m_Localized: Where are you going, May?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427744
    m_Localized: "I\u2019ll go after her!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427745
    m_Localized: (Grabbing May) May!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427746
    m_Localized: (Panting)
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427747
    m_Localized: ... You can all return to HQ now.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427748
    m_Localized: "This isn\u2019t why I brought you here."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427749
    m_Localized: "From here on, I\u2019ll handle everything on my own."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427750
    m_Localized: "No need to worry... I\u2019ll handle it."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427751
    m_Localized: May, snap out of it!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427752
    m_Localized: "We\u2019re right in the middle of enemy territory, and I can sense
      a giant monster nearby!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427753
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427754
    m_Localized: "...  I know you're confused, but let\u2019s take down the giant
      monster first, then we can think this through."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427755
    m_Localized: "We\u2019re still companions, after all. You can\u2019t do this
      alone."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427756
    m_Localized: "(Seeing May return with Atresia) Oh! May\u2019s back!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427757
    m_Localized: ... Have you calmed down a bit?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427758
    m_Localized: ...What should I do now...?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427759
    m_Localized: "You\u2019re exhausted. Let\u2019s clear out the nearby monsters
      first and take a moment to think together."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427760
    m_Localized: "Ugh, I can\u2019t stand this gloomy mood!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427761
    m_Localized: How long are you all going to sit there in silence? Come on, you
      fools!!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427762
    m_Localized: We've received a message from HQ, but... this is...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427763
    m_Localized: "What\u2019s the message?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427764
    m_Localized: It looks like a video of April... making an announcement herself.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427765
    m_Localized: ?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427766
    m_Localized: "It seems she\u2019s officially acknowledging what she\u2019s been
      doing and the existence of the organization."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427767
    m_Localized: Now, of all times?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427768
    m_Localized: "It feels like she\u2019s taking all the blame upon herself..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427769
    m_Localized: Drawing all the arrows toward her?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427770
    m_Localized: I need to confirm this myself.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427771
    m_Localized: Have you made up your mind?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427772
    m_Localized: "When I first joined MAID, I couldn\u2019t even brew a proper cup
      of tea,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427773
    m_Localized: but April told me that what matters is to keep trying, to never
      give up.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427774
    m_Localized: She said that this spirit of trying would slowly make the world
      a better place.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427775
    m_Localized: What are you talking about all of a sudden!?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427776
    m_Localized: I may not be able to change the situation right now, but at the
      very least, I want to ask her directly.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427777
    m_Localized: Why she planned all of this, what her true goal was.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427778
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427779
    m_Localized: April! What on earth are you doing?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427780
    m_Localized: So, you've finally made it here, May.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427781
    m_Localized: We could have fixed everything! Why...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427782
    m_Localized: My time stopped when my family and friends were taken from me.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427783
    m_Localized: "It\u2019s already too late."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427784
    m_Localized: April....
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427785
    m_Localized: "Come, May. Show them that what I taught you wasn\u2019t in vain!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427786
    m_Localized: (As May embraces wounded April) April...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427787
    m_Localized: May... Remember my words.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427788
    m_Localized: ... Beware of... the enemy within...
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427789
    m_Localized: "These monsters... might be part of <color=#F75D32>someone\u2019s</color>
      plan..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427790
    m_Localized: April!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427791
    m_Localized: "Alright, everyone, great work. (Muttering quietly to herself) It
      would have been better if they hadn\u2019t made me come to such a filthy place..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427792
    m_Localized: Why are those lower-ranked Stella Knights going through all this
      trouble when they should just follow <color=#F75D32>Lady Hecate's</color> orders
      quietly?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427793
    m_Localized: Why should we care? <color=#F75D32>Central HQ</color> will handle
      everything from here.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427794
    m_Localized: You're being way too harsh!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427795
    m_Localized: "Look! Those people are taking away April\u2019s body...! The writing
      on their clothes says..."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427796
    m_Localized: <color=#F75D32>Destruction??</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427797
    m_Localized: "That\u2019s the same organization my former leader sold weapons
      to...!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427798
    m_Localized: "Something is seriously wrong... We can\u2019t just sit here and
      do nothing."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427799
    m_Localized: "I can\u2019t let them take April\u2019s body. I\u2019m heading
      to HQ."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427800
    m_Localized: "There\u2019s definitely a meaning behind April\u2019s words about
      the enemy within."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427801
    m_Localized: "May, we\u2019ll go with you."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427802
    m_Localized: Will you join us too, Commander?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427803
    m_Localized: Thank you, Commander. From now on,
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427804
    m_Localized: "we\u2019ll be heading to <color=#F75D32>HQ.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427805
    m_Localized: Commander, we can't stop here!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427806
    m_Localized: Level us up, and
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427807
    m_Localized: "we\u2019ll be able to easily defeat the enemies!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427808
    m_Localized: "I\u2019ll take you to the <color=#F75D32>Stella Knights Management.</color>
      Please level up the <color=#F75D32>Stella Knights!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427809
    m_Localized: "Commander! Don\u2019t get too discouraged."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427810
    m_Localized: Level us up using rewards from the <color=#F75D32>Quests</color>
      or <color=#F75D32>Idle Bonus,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427811
    m_Localized: "and we\u2019ll become super strong!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427812
    m_Localized: Commander! Did you know that by replaying previous <color=#F75D32>stages,</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427813
    m_Localized: "not only can you earn rewards for clearing, but you can also get
      <color=#F75D32>summon tickets</color> based on the <color=#F75D32>total number
      of stars</color> you\u2019ve collected?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427814
    m_Localized: You can check the <color=#F75D32>total number of stars</color> by
      clicking the <color=#F75D32>globe icon</color> in the bottom left of the main
      screen!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427815
    m_Localized: "Now, let\u2019s go replay those previous <color=#F75D32>stages!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427816
    m_Localized: Whoa! What a <color=#F75D32>gigantic robot!!</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427817
    m_Localized: Where on earth did it come from?!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427818
    m_Localized: Welcome, everyone. This is the Combat Trial designed to draw out
      the <color=#F75D32>latent power</color> of the Stella Knights.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427819
    m_Localized: "If you defeat me in battle, you\u2019ll be able to deploy <color=#F75D32>1
      additional unit</color> in future fights."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427820
    m_Localized: "Be careful, Commander. General Jacqueline\u2019s <color=#F75D32>Neo
      Titan</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427821
    m_Localized: fires a laser cannon that deals damage to <color=#F75D32>specific
      locations</color> at set intervals.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427822
    m_Localized: "There\u2019s a <color=#F75D32>pattern</color> to where the cannon
      fires,"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427823
    m_Localized: so if you observe carefully, you can find a <color=#F75D32>safe
      spot.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427824
    m_Localized: Shall we begin?
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427825
    m_Localized: Commander, this is where you can set up your <color=#F75D32>Arena
      Defense Deck.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427826
    m_Localized: In addition to deploying Stella Knights, you can also <color=#F75D32>place
      obstacles</color> to craft your strategy.
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427827
    m_Localized: "Obstacles are particularly useful for <color=#F75D32>directing
      the enemy\u2019s movement,</color> so be sure to take advantage of them."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427828
    m_Localized: "Also, your defense deck will be active even when you\u2019re <color=#F75D32>offline,</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427829
    m_Localized: and through battle records, you can even seek <color=#F75D32>revenge</color>
      on those who defeated your defense deck!
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427830
    m_Localized: "\uADF8\uB300\uB4E4\uC744 \uC704\uD55C \uC790\uBE44\uB85C \uC601\uC6D0\uD55C
      \uC548\uC2DD\uACFC \uACE0\uC694\uC5D0 \uC0BC\uCF1C\uC838 \uC0AC\uB77C\uC838\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427831
    m_Localized: "\u2026. \uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140\uAC00 \uAC15\uB825\uD55C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD558\uACE0 \uC788\uC5B4. \uACF5\uACA9\uC5D0
      \uB300\uBE44\uD574\uC57C \uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427832
    m_Localized: "\u2026\uC120\uBB3C\uC740 \uC815\uC911\uD788 \uAC70\uC808\uD558\uB3C4\uB85D
      \uD560\uAC8C\uC694.\n\uC774\uBBF8 \uC9C4\uC808\uBA38\uB9AC \uB0A0 \uB9CC\uD07C
      \uB9CE\uC740 \uC120\uBB3C\uC744 \uBC1B\uC558\uC73C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427833
    m_Localized: "\uBAA8\uB450 \uB0B4 \uB4A4\uB85C \uBD99\uC5B4\uC694!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427834
    m_Localized: "\uADF8\uB0A0\uC758 \uB9F9\uC138\uD55C \uB300\uB85C \uC774\uC820
      \uB204\uAD6C\uB3C4 \uB2E4\uCE58\uAC8C \uD558\uC9C0 \uC54A\uACA0\uC5B4\u2026!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427835
    m_Localized: "\uC5EC\uC804\uD788 \uB108\uD76C\uB294 \uC5B4\uB9AC\uC11D\uAD6C\uB098,
      \uBC1C\uBC84\uB465 \uCE60\uC218\uB85D \uACE0\uD1B5\uB9CC \uAE38\uC5B4\uC9C8
      \uBFD0\uC778 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427836
    m_Localized: "\uD06C\uC754\u2026! \uC7A0\uC2DC\uB9CC \uC274\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427837
    m_Localized: "\uB098\uB3C4, \uB098\uB3C4.. \uB354 \uC774\uC0C1 \uB0B4 \uB3D9\uB8CC\uB4E4\uC744
      \uC544\uD504\uAC8C \uD560 \uC21C \uC5C6\uC5B4. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uB3D9\uB8CC\uB4E4\uC744 \uC9C0\uCF1C\uB0BC\uAC70\uC57C!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427838
    m_Localized: "\uC720\uB2C8. \uC9C0\uAE08\uC774\uC5D0\uC694! \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB9C8\uB140\uAC00 \uACF5\uACA9\uC744 \uBA48\uCD98 \uC0AC\uC774 \uC800\uD76C\uAC00
      \uACF5\uACA9\uD574\uC57C \uD574\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427839
    m_Localized: "\uD5E4\u2026.\uD5E4\uCE58\uC6E0\uB098?!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427840
    m_Localized: "\uC720...! \uADF8 \uB9D0\uC740....!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427841
    m_Localized: "\uACB0\uACFC\uAC00 \uBCF4\uC774\uB294\uB370\uB3C4 \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uAC00\uC0C1\uD558\uB098, \uB367 \uC5C6\uC744 \uBFD0\uC774\uAD6C\uB098\u2026."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427842
    m_Localized: "\uC774\uC870\uCC28 \uBAA8\uB450 \uB098\uC758 \uAD8C\uB2A5 \uC544\uB798
      \uC788\uB294 \uAC83\uC744."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427843
    m_Localized: "\uC544\u2026.\uC548\uB3FC!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427844
    m_Localized: "\uC720\uB2C8, \uD544\uB9AC\uC544, \uD074\uB808\uC774!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427845
    m_Localized: "\uC774\uC790\uC2DD! \uC6A9\uC11C \uBABB\uD574..!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427846
    m_Localized: "\uC544\uD2B8\uB808\uC2DC\uC544, \uC9C0\uAE08\uC774\uC57C! \uB0B4\uAC00
      \uB9C8\uB140\uB97C \uC57D\uD654\uC2DC\uD0A8 \uC0AC\uC774\uC5D0 \uACF5\uACA9\uD574!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427847
    m_Localized: "\uADF8\uB798, \uC544\uC9C1 \uBB34\uB108\uC9C8\uC21C \uC5C6\uC5B4.
      \n\uC6B0\uB9AC\uAC00 \uC778\uB958\uC758 \uB9C8\uC9C0\uB9C9 \uD76C\uB9DD\uC774\uB2C8\uAE4C!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427848
    m_Localized: "\uAC00\uC18C\uB86D\uAD6C\uB098...!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427849
    m_Localized: "\uB9C8\uB9AC\uC5D0!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427850
    m_Localized: "\u2026.\uC774\uB807\uAC8C \uB41C \uC774\uC0C1 \uC81C \uBAA9\uC228\uC744
      \uAC78\uC5B4\uC11C\uB77C\uB3C4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427851
    m_Localized: "\uAD00\uCE21\uC790\uB2D8, \uD718\uB9D0\uB9AC\uC9C0 \uC54A\uAC8C
      \uC870\uC2EC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427852
    m_Localized: "\uD574\uB0B8\uAC78\uAE4C\uC694..?"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427853
    m_Localized: "\u2026..\uC5EC\uAE30\uAE4C\uC9C0 \uD574\uB0B8 \uAC83\uC744 \uCE6D\uCC2C\uD574\uC8FC\uB9C8,
      \uD558\uC9C0\uB9CC \uAC00\uB828\uD55C \uC544\uC774\uC5EC."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427854
    m_Localized: "\uC5B8\uC820\uAC00 \uD6C4\uD68C\uD558\uACE0 \uBD80\uC11C\uC9C8
      \uAC83\uC774\uB77C\uBA74, \uCC28\uB77C\uB9AC \uB0B4 \uC190\uC73C\uB85C \uB108\uD76C\uC758
      \uBBF8\uB798\uB97C \uBD80\uC154\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427855
    m_Localized: "\uC774\uC820 \uC7A5\uB09C\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427856
    m_Localized: "\uB2F9\uC2E0\uC740 \uB9C8\uC9C0\uB9C9 \uB0A8\uC740 \uD798\uC744
      \uC9DC\uB0B4 \uBC1C\uBC84\uB465\uCE58\uB824 \uD55C\uB2E4. \uD558\uC9C0\uB9CC
      '\uB77C\uD50C\uB77C\uC2A4\uC758 \uB9C8\uB140'\uB294 \uADF8\uC800 \uBE44\uC6C3\uB4EF,
      \uC190 \uC9D3\uC73C\uB85C \uADF8 \uBC1C\uC545\uC744 \uBB34\uC704\uB85C \uB3CC\uB824\uBCF4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427857
    m_Localized: "\uBCF4\uC544\uB77C. \uC774\uAC83\uC774 \uB108\uD76C\uC758... '\uBB34\uB825\uD568'\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427858
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4 \uB9C8\uB140\uAC00 \uB2F9\uC2E0\uC744
      \uD5A5\uD55C \uB9C8\uC9C0\uB9C9 \uC77C\uACA9\uC744 \uB0A0\uB9AC\uB294 \uC21C\uAC04"
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427859
    m_Localized: "\uB2F9\uC2E0\uC758 \uC55E\uC5D0\uB294 \uC774\uB97C \uB300\uC2E0
      \uB9C9\uC544\uC11C\uB294, \n\uBCF8\uC2E0\uC758 \uD798\uC744 \uB118\uC5B4\uC120
      \uBD80\uC791\uC6A9\uC73C\uB85C \uC810\uC810 \uBB34\uB108\uC838 \uAC00\uB294
      \uC5E3\uB41C \uC18C\uB140\uAC00 \uC11C \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427860
    m_Localized: "\u2026\uC544\uB1E8, \uC800\uD76C\uB294 \uD3EC\uAE30\uD558\uC9C0
      \uC54A\uC744\uAC70\uC5D0\uC694. \uC800\uB3C4, \uC81C \uB3D9\uB8CC\uB4E4\uB3C4,
      \uAD00\uCE21\uC790\uB2D8\uB3C4,\n\uC544\uB2C8 \uC778\uB958\uB294 \uBAA8\uB450
      \uC800\uD56D\uC744 \uB05D\uAE4C\uC9C0 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC744
      \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 461660086427861
    m_Localized: "\uB2F9\uC2E0\uC774 \uC5B4\uB5A4 \uBBF8\uB798\uB97C \uAD00\uCE21\uD588\uB358,
